@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="mb-8">
    <h1 class="text-[32px] font-bold text-dark mb-2">Tổng quan Doanh thu (Dashboard)</h1>
    <p class="text-muted">Báo cáo hiệu suất kinh doanh và dòng tiền từ hệ thống JobHuntly.</p>
</div>

<!-- Filters -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Chọn Tháng</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Toàn thời gian</option>
                <option value="1">Tháng 1</option>
                <option value="2">Tháng 2</option>
                <option value="3">Tháng 3</option>
                <option value="4">Tháng 4</option>
                <option value="5" selected>Tháng 5</option>
                <!-- Add other months -->
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Chọn Năm</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="2026" selected>Năm 2026</option>
                <option value="2025">Năm 2025</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Loại Báo cáo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="monthly" selected>Theo Tháng</option>
                <option value="quarterly">Theo Quý</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Cập nhật báo cáo
            </button>
        </div>
    </form>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Total Revenue Card -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-50 rounded-full opacity-50"></div>
        <div class="flex items-start justify-between relative z-10">
            <div>
                <p class="text-muted font-medium text-sm mb-1">Tổng thu nhập (Tháng 5/2026)</p>
                <h3 class="text-3xl font-bold text-dark mb-2">145,250,000đ</h3>
                <div class="flex items-center gap-1 text-sm font-medium text-green-600 bg-green-50 w-max px-2 py-1 rounded">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    <span>+12.5% so với Tháng 4</span>
                </div>
            </div>
            <div class="w-12 h-12 rounded-full bg-primary bg-opacity-10 text-primary flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
        </div>
    </div>

    <!-- Active Packages Card -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-purple-50 rounded-full opacity-50"></div>
        <div class="flex items-start justify-between relative z-10">
            <div>
                <p class="text-muted font-medium text-sm mb-1">Số lượt mua gói dịch vụ</p>
                <h3 class="text-3xl font-bold text-dark mb-2">324</h3>
                <div class="flex items-center gap-1 text-sm font-medium text-green-600 bg-green-50 w-max px-2 py-1 rounded">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    <span>+5.2% so với Tháng 4</span>
                </div>
            </div>
            <div class="w-12 h-12 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            </div>
        </div>
    </div>

    <!-- Total Revenue by Quarter -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-orange-50 rounded-full opacity-50"></div>
        <div class="flex items-start justify-between relative z-10">
            <div>
                <p class="text-muted font-medium text-sm mb-1">Tổng thu nhập Quý 2/2026</p>
                <h3 class="text-3xl font-bold text-dark mb-2">290,500,000đ</h3>
                <div class="flex items-center gap-1 text-sm font-medium text-gray-500 bg-gray-100 w-max px-2 py-1 rounded">
                    Đang diễn ra
                </div>
            </div>
            <div class="w-12 h-12 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
        </div>
    </div>
</div>

<!-- Charts / Detailed Data Section Placeholder -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Line Chart Placeholder -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
        <h3 class="font-bold text-dark text-lg mb-6">Biểu đồ Doanh thu Nửa đầu năm 2026</h3>
        <div class="h-64 flex items-end justify-between gap-2 border-b border-l border-gray-200 p-4 pb-0 pl-0 relative">
            <!-- Mock Bar Chart -->
            <div class="w-full h-full flex items-end justify-around pb-1">
                <div class="w-1/6 bg-primary opacity-40 rounded-t-sm h-[30%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">55M</span></div>
                <div class="w-1/6 bg-primary opacity-40 rounded-t-sm h-[40%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">72M</span></div>
                <div class="w-1/6 bg-primary opacity-60 rounded-t-sm h-[60%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">110M</span></div>
                <div class="w-1/6 bg-primary opacity-80 rounded-t-sm h-[75%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">129M</span></div>
                <div class="w-1/6 bg-primary rounded-t-sm h-[90%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">145M</span></div>
                <div class="w-1/6 bg-primary opacity-20 rounded-t-sm h-[10%] hover:opacity-100 transition-opacity relative group"><span class="absolute -top-8 left-1/2 -translate-x-1/2 text-xs font-bold hidden group-hover:block">Dự kiến</span></div>
            </div>
        </div>
        <div class="flex justify-around text-xs text-muted mt-2 font-medium">
            <span>Tháng 1</span>
            <span>Tháng 2</span>
            <span>Tháng 3</span>
            <span>Tháng 4</span>
            <span class="text-primary font-bold">Tháng 5</span>
            <span>Tháng 6</span>
        </div>
    </div>

    <!-- Recent Transactions Table -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden flex flex-col">
        <div class="p-6 border-b border-[#D6DDEB] flex justify-between items-center">
            <h3 class="font-bold text-dark text-lg">Giao dịch Gói Dịch vụ gần nhất</h3>
            <a href="#" class="text-sm font-bold text-primary hover:underline">Xem tất cả</a>
        </div>
        <div class="flex-1 overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                        <th class="py-3 px-6 text-dark font-bold text-xs uppercase">Công ty</th>
                        <th class="py-3 px-6 text-dark font-bold text-xs uppercase">Gói đã mua</th>
                        <th class="py-3 px-6 text-dark font-bold text-xs uppercase text-right">Số tiền</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <tr class="border-b border-gray-100">
                        <td class="py-4 px-6 font-medium text-dark">VNG Corporation</td>
                        <td class="py-4 px-6 text-muted">Premium Package (1 Tháng)</td>
                        <td class="py-4 px-6 font-bold text-green-600 text-right">+2,500,000đ</td>
                    </tr>
                    <tr class="border-b border-gray-100">
                        <td class="py-4 px-6 font-medium text-dark">FPT Software</td>
                        <td class="py-4 px-6 text-muted">Basic Package (3 Tháng)</td>
                        <td class="py-4 px-6 font-bold text-green-600 text-right">+1,200,000đ</td>
                    </tr>
                    <tr class="border-b border-gray-100">
                        <td class="py-4 px-6 font-medium text-dark">Shopee Vietnam</td>
                        <td class="py-4 px-6 text-muted">Vip Package (1 Tháng)</td>
                        <td class="py-4 px-6 font-bold text-green-600 text-right">+5,000,000đ</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
