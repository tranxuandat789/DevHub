@* 04/06/2026-DatTX *@
@model DevHub.ViewModels.Admin.CreateModeratorViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm mới Moderator";
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="mb-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg text-sm">
        Vui lòng kiểm tra lại thông tin nhập vào.
    </div>
}

<div class="mb-8">
    <a href="/AdminModerator" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">Tạo / Chỉnh sửa Moderator</h1>
    <p class="text-muted">Cấp quyền truy cập vào Moderator Panel cho nhân viên mới.</p>
</div>

<form method="post" action="/AdminModerator/Create" class="max-w-3xl">
    @Html.AntiForgeryToken()
    
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-8 border border-[#D6DDEB]">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                <label class="block text-dark font-bold mb-2">Họ và Tên <span class="text-red-500">*</span></label>
                <input type="text" name="FullName" value="@Model?.FullName" placeholder="Nguyễn Văn A" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
                @if (ViewData.ModelState["FullName"]?.Errors.Any() == true)
                {
                    <p class="text-red-500 text-xs mt-1">@ViewData.ModelState["FullName"]?.Errors.First().ErrorMessage</p>
                }
            </div>
            <div>
                <label class="block text-dark font-bold mb-2">Email nội bộ <span class="text-red-500">*</span></label>
                <input type="email" name="Email" value="@Model?.Email" placeholder="example.mod@jobhuntly.com" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
                @if (ViewData.ModelState["Email"]?.Errors.Any() == true)
                {
                    <p class="text-red-500 text-xs mt-1">@ViewData.ModelState["Email"]?.Errors.First().ErrorMessage</p>
                }
            </div>
            <div class="md:col-span-2">
                <label class="block text-dark font-bold mb-2">Username đăng nhập <span class="text-red-500">*</span></label>
                <input type="text" name="Username" value="@Model?.Username" placeholder="Ví dụ: example_mod" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
                @if (ViewData.ModelState["Username"]?.Errors.Any() == true)
                {
                    <p class="text-red-500 text-xs mt-1">@ViewData.ModelState["Username"]?.Errors.First().ErrorMessage</p>
                }
                <p class="text-xs text-muted mt-2">Username dùng để đăng nhập, chỉ bao gồm chữ, số và dấu gạch dưới.</p>
            </div>
        </div>

        <div class="mb-6 border-t border-gray-100 pt-6">
            <h4 class="font-bold text-dark mb-4 text-sm uppercase tracking-wide text-gray-500">Cài đặt Mật khẩu</h4>
            <div>
                <label class="block text-dark font-bold mb-2">Mật khẩu <span class="text-red-500">*</span></label>
                <input type="password" name="Password" placeholder="Nhập mật khẩu (tối thiểu 8 ký tự)" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark" required>
                @if (ViewData.ModelState["Password"]?.Errors.Any() == true)
                {
                    <p class="text-red-500 text-xs mt-1">@ViewData.ModelState["Password"]?.Errors.First().ErrorMessage</p>
                }
            </div>
        </div>

        <div class="mb-6 border-t border-gray-100 pt-6">
            <h4 class="font-bold text-dark mb-4 text-sm uppercase tracking-wide text-gray-500">Phân Loại Công Việc</h4>
            <div>
                <label class="block text-dark font-bold mb-2">Loại công việc <span class="text-red-500">*</span></label>
                <p class="text-xs text-muted mb-3">Mỗi Moderator chỉ được gán đúng 1 loại task. Họ chỉ thấy và xử lý được các task thuộc loại này.</p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    @foreach (var (val, label, desc, icon, color) in new[] {
                        ("COMPANY_APPROVAL", "Duyệt Công Ty",    "Xét duyệt hồ sơ chứng nhận công ty",    "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1", "blue"),
                        ("JOB_POST",         "Duyệt Bài Đăng", "Xét duyệt tin tuyển dụng mới đăng",       "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z", "violet"),
                        ("REVIEW",           "Duyệt Đánh Giá", "Xét duyệt đánh giá công ty từ ứng viên", "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z", "amber")
                    })
                    {
                        <label class="cursor-pointer group">
                            <input type="radio" name="TaskType" value="@val"
                                   class="peer sr-only"
                                   @(Model?.TaskType == val ? "checked" : "")>
                            <div class="border-2 border-[#D6DDEB] peer-checked:border-@(color)-500 peer-checked:bg-@(color)-50 rounded-xl p-4 hover:border-@(color)-300 transition-all">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-@(color)-100 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-@(color)-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@icon"/>
                                        </svg>
                                    </div>
                                    <span class="font-bold text-dark text-sm">@label</span>
                                </div>
                                <p class="text-xs text-muted">@desc</p>
                            </div>
                        </label>
                    }
                </div>
                @if (ViewData.ModelState["TaskType"]?.Errors.Any() == true)
                {
                    <p class="text-red-500 text-xs mt-2">@ViewData.ModelState["TaskType"]?.Errors.First().ErrorMessage</p>
                }
            </div>
        </div>


        <div class="flex gap-4 pt-4 border-t border-[#D6DDEB]">
            <button type="submit" class="bg-primary text-white font-bold px-8 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Lưu Tài khoản
            </button>
            <a href="/AdminModerator" class="bg-white text-dark font-bold px-8 py-3 rounded-lg border border-[#D6DDEB] hover:bg-gray-50 transition-all">
                Hủy Bỏ
            </a>
        </div>

    </div>

</form>

