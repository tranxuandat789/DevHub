@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm/Sửa Moderator";
}

<div class="mb-8">
    <a href="/AdminModerator" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">Tạo / Chỉnh sửa Moderator</h1>
    <p class="text-muted">Cấp quyền truy cập vào Moderator Panel cho nhân viên mới.</p>
</div>

<form onsubmit="event.preventDefault(); submitModerator();" class="max-w-3xl">
    
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-8 border border-[#D6DDEB]">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                <label class="block text-dark font-bold mb-2">Họ và Tên <span class="text-red-500">*</span></label>
                <input type="text" placeholder="Nguyễn Văn A" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>
            <div>
                <label class="block text-dark font-bold mb-2">Email nội bộ <span class="text-red-500">*</span></label>
                <input type="email" placeholder="example.mod@jobhuntly.com" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>
        </div>

        <div class="mb-6 border-t border-gray-100 pt-6">
            <h4 class="font-bold text-dark mb-4 text-sm uppercase tracking-wide text-gray-500">Cài đặt Mật khẩu</h4>
            <div>
                <label class="block text-dark font-bold mb-2">Mật khẩu tạm thời (Tùy chọn)</label>
                <input type="password" placeholder="Để trống nếu muốn hệ thống tự tạo mật khẩu ngẫu nhiên" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark">
                <p class="text-xs text-muted mt-2">Hệ thống sẽ tự động gửi email thông báo kèm mật khẩu (nếu có) đến cho người dùng mới.</p>
            </div>
        </div>

        <div class="mb-8 border-t border-gray-100 pt-6">
            <label class="flex items-center gap-3 cursor-pointer p-4 border border-gray-100 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors">
                <input type="checkbox" checked class="w-5 h-5 text-primary rounded focus:ring-primary">
                <div>
                    <span class="font-bold text-dark block">Kích hoạt tài khoản ngay (Is Active)</span>
                    <span class="text-xs text-muted">Nếu không, tài khoản sẽ ở trạng thái Vô hiệu hóa (Chờ kích hoạt).</span>
                </div>
            </label>
        </div>

        <div class="flex gap-4 pt-4 border-t border-[#D6DDEB]">
            <button type="submit" class="bg-primary text-white font-bold px-8 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Lưu Tài khoản
            </button>
            <a href="/AdminModerator" class="bg-white text-dark font-bold px-8 py-3 rounded-lg border border-[#D6DDEB] hover:bg-gray-50 transition-all">
                Hủy Bỏ
            </a>
        </div>

    </div>

</form>

@section Scripts {
    <script>
        function submitModerator() {
            alert('Lưu Moderator thành công! Hệ thống đã gửi email thông báo.');
            window.location.href = '/AdminModerator';
        }
    </script>
}
