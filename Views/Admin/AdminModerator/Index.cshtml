@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Moderator";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Danh sách Moderator</h1>
        <p class="text-muted">Kiểm soát phân quyền, vô hiệu hóa hoặc tạo mới tài khoản cho các Điều phối viên (Moderators).</p>
    </div>
    <a href="/AdminModerator/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Moderator mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" placeholder="Tên hoặc Email Moderator..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo Tên</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="name_asc">A đến Z</option>
                <option value="name_desc">Z đến A</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo Ngày tạo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest">Mới nhất (Newest)</option>
                <option value="oldest">Cũ nhất (Oldest)</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Lọc & Sắp xếp
            </button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Thông tin Moderator</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Ngày tham gia</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Mod 1: Active -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#M102</td>
                    <td class="py-4 px-6 flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-lg border border-blue-200">H</div>
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Hoàng Tuấn Anh</div>
                            <div class="text-xs text-muted mt-0.5">anhht.mod@jobhuntly.com</div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                            Đang hoạt động
                        </span>
                    </td>
                    <td class="py-4 px-6 text-muted font-medium">
                        15/01/2026
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/AdminModerator/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleModStatus('M102', 1)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Vô hiệu hóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                        </button>
                    </td>
                </tr>
                
                <!-- Mod 2: Disabled -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#M101</td>
                    <td class="py-4 px-6 flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center font-bold text-lg border border-gray-300">L</div>
                        <div>
                            <div class="font-bold text-gray-500 line-through decoration-1 line-clamp-1">Lê Thị Mai</div>
                            <div class="text-xs text-muted mt-0.5">mailt.mod@jobhuntly.com</div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200">
                            Vô hiệu hóa
                        </span>
                    </td>
                    <td class="py-4 px-6 text-muted font-medium">
                        20/12/2025
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/AdminModerator/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleModStatus('M101', 0)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Kích hoạt lại">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </button>
                    </td>
                </tr>

                <!-- Mod 3: Active -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#M105</td>
                    <td class="py-4 px-6 flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-lg border border-indigo-200">T</div>
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Trần Quốc Việt</div>
                            <div class="text-xs text-muted mt-0.5">viet.tq@jobhuntly.com</div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                            Đang hoạt động
                        </span>
                    </td>
                    <td class="py-4 px-6 text-muted font-medium">
                        02/03/2026
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/AdminModerator/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleModStatus('M105', 1)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Vô hiệu hóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModStatus(id, currentState) {
            const actionName = currentState === 1 ? 'VÔ HIỆU HÓA' : 'TÁI KÍCH HOẠT';
            if (confirm(`ADMIN: Bạn có chắc chắn muốn ${actionName} tài khoản Moderator #${id}?`)) {
                alert(`Đã cập nhật trạng thái Moderator #${id} thành công! Hệ thống đã ghi log.`);
            }
        }
    </script>
}
