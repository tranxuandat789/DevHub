@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kiểm tra Gói đăng ký";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Các Gói Đăng ký (Subscriptions)</h1>
        <p class="text-muted">Kiểm tra tình trạng sử dụng gói dịch vụ hiện tại của các nhà tuyển dụng.</p>
    </div>
</div>

<!-- Filters -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm Nhà tuyển dụng</label>
            <input type="text" placeholder="Tên công ty hoặc Email..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tên Gói Dịch vụ</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả các gói</option>
                <option value="basic">Gói Tiêu chuẩn</option>
                <option value="premium">Gói Premium</option>
                <option value="vip">Gói VIP Đặc biệt</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái gói</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả</option>
                <option value="active">Đang hiệu lực (Active)</option>
                <option value="expired">Đã hết hạn (Expired)</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Lọc dữ liệu
            </button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[1000px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Công ty / Nhà tuyển dụng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Gói Dịch vụ</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Đã dùng (Bài đăng)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Hiệu lực (Start - End)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Sub 1: Active -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#S8092</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark text-base mb-0.5">VNG Corporation</div>
                        <div class="text-xs text-muted">quan.hr@vng.com.vn</div>
                    </td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-primary">Premium Package</div>
                        <div class="text-xs text-muted">12 Tháng</div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <div class="w-full bg-gray-200 rounded-full h-2.5 mb-1">
                            <div class="bg-blue-600 h-2.5 rounded-full" style="width: 45%"></div>
                        </div>
                        <span class="text-xs font-bold text-dark">45 / 100</span>
                    </td>
                    <td class="py-4 px-6 text-muted">
                        <span class="block">Bắt đầu: 24/05/2026</span>
                        <span class="block text-xs mt-1 text-red-500 font-medium">Hết hạn: 24/05/2027</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                            Đang hiệu lực
                        </span>
                    </td>
                </tr>
                
                <!-- Sub 2: Expired -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#S7540</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark text-base mb-0.5">Tiki Corp</div>
                        <div class="text-xs text-muted">tuyendung@tiki.vn</div>
                    </td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-gray-600">Basic Package</div>
                        <div class="text-xs text-muted">1 Tháng</div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <div class="w-full bg-gray-200 rounded-full h-2.5 mb-1">
                            <div class="bg-red-500 h-2.5 rounded-full" style="width: 100%"></div>
                        </div>
                        <span class="text-xs font-bold text-red-500">10 / 10</span>
                    </td>
                    <td class="py-4 px-6 text-muted opacity-60">
                        <span class="block">Bắt đầu: 20/04/2026</span>
                        <span class="block text-xs mt-1 font-medium">Hết hạn: 20/05/2026</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200">
                            Đã hết hạn
                        </span>
                    </td>
                </tr>

                <!-- Sub 3: Active but almost out of limit -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 font-mono text-muted">#S8050</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark text-base mb-0.5">Shopee Vietnam</div>
                        <div class="text-xs text-muted">hr@shopee.vn</div>
                    </td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-yellow-600">VIP Package</div>
                        <div class="text-xs text-muted">6 Tháng</div>
                    </td>
                    <td class="py-4 px-6 text-center">
                        <div class="w-full bg-gray-200 rounded-full h-2.5 mb-1">
                            <div class="bg-yellow-400 h-2.5 rounded-full" style="width: 95%"></div>
                        </div>
                        <span class="text-xs font-bold text-dark">48 / 50</span>
                    </td>
                    <td class="py-4 px-6 text-muted">
                        <span class="block">Bắt đầu: 10/05/2026</span>
                        <span class="block text-xs mt-1 text-red-500 font-medium">Hết hạn: 10/11/2026</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                            Đang hiệu lực
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 3 của 1,245 gói đăng ký
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">2</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>
