@model DevHub.ViewModels.Admin.AssignModeratorViewModel

@{
    ViewData["Title"] = "Phân Công Ngành Cho Moderator";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-8" x-data="{ activeTab: 'company' }">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-[32px] font-bold text-dark mb-2">Quản Lý Phân Công Ngành</h1>
            <p class="text-muted">Chỉ định Moderator phụ trách theo từng nhóm ngành nghề.</p>
        </div>
        <div>
            <a href="/AssignModerator/History" class="inline-flex items-center justify-center bg-white border border-[#D6DDEB] text-dark font-medium px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Lịch Sử Phân Công
            </a>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 relative" role="alert">
            <span class="block sm:inline">@TempData["SuccessMsg"]</span>
        </div>
    }

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <div>
                <p class="text-muted text-sm font-medium">Công ty chờ duyệt</p>
                <h3 class="text-2xl font-bold text-dark">@Model.PendingCompanies</h3>
            </div>
        </div>
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
                <p class="text-muted text-sm font-medium">Bài đăng chờ duyệt</p>
                <h3 class="text-2xl font-bold text-dark">@Model.PendingJobPosts</h3>
            </div>
        </div>
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB] flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            </div>
            <div>
                <p class="text-muted text-sm font-medium">Đánh giá chờ duyệt</p>
                <h3 class="text-2xl font-bold text-dark">@Model.PendingReviews</h3>
            </div>
        </div>
    </div>

    <!-- Main Content: Tabs -->
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
        
        <!-- Tab Headers -->
        <div class="flex border-b border-[#D6DDEB]">
            <button @@click="activeTab = 'company'" 
                    :class="{ 'border-primary text-primary font-bold': activeTab === 'company', 'border-transparent text-muted hover:text-dark hover:border-gray-300': activeTab !== 'company' }"
                    class="flex-1 py-4 px-6 text-center border-b-2 font-medium transition-colors outline-none">
                <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    Duyệt Công Ty
                </div>
            </button>
            <button @@click="activeTab = 'job'" 
                    :class="{ 'border-primary text-primary font-bold': activeTab === 'job', 'border-transparent text-muted hover:text-dark hover:border-gray-300': activeTab !== 'job' }"
                    class="flex-1 py-4 px-6 text-center border-b-2 font-medium transition-colors outline-none">
                <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Duyệt Bài Đăng
                </div>
            </button>
            <button @@click="activeTab = 'review'" 
                    :class="{ 'border-primary text-primary font-bold': activeTab === 'review', 'border-transparent text-muted hover:text-dark hover:border-gray-300': activeTab !== 'review' }"
                    class="flex-1 py-4 px-6 text-center border-b-2 font-medium transition-colors outline-none">
                <div class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                    Duyệt Đánh Giá
                </div>
            </button>
        </div>

        <div>
            <!-- COMPANY_APPROVAL TAB -->
            <div x-show="activeTab === 'company'" style="display: none;">
                <form action="/AssignModerator/AssignIndustryBatch" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskType" value="COMPANY_APPROVAL" />
                    <div class="p-6 pb-2 border-b border-[#D6DDEB]">
                        <p class="text-muted">Quản lý phân công Ngành nghề cho các Moderator phụ trách Duyệt Công Ty.</p>
                    </div>
                    @await Html.PartialAsync("_IndustryTablePartial", new ViewDataDictionary(ViewData) 
                    { 
                        { "TaskType", "COMPANY_APPROVAL" }, 
                        { "Assignments", Model.CompanyIndustryAssignments },
                        { "Moderators", Model.CompanyModerators }
                    })
                    <div class="p-4 bg-gray-50 flex justify-end gap-3 border-t border-[#D6DDEB]">
                        <button type="button" onclick="autoDistribute('COMPANY_APPROVAL')" class="bg-white border border-primary text-primary font-bold px-6 py-2.5 rounded-lg hover:bg-primary hover:bg-opacity-10 transition-all shadow-sm flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            Tự động phân chia
                        </button>
                        <button type="submit" class="bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                            Lưu Cấu Hình
                        </button>
                    </div>
                </form>
            </div>

            <!-- JOB_POST TAB -->
            <div x-show="activeTab === 'job'" style="display: none;">
                <form action="/AssignModerator/AssignIndustryBatch" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskType" value="JOB_POST" />
                    <div class="p-6 pb-2 border-b border-[#D6DDEB]">
                        <p class="text-muted">Quản lý phân công Ngành nghề cho các Moderator phụ trách Duyệt Bài Đăng.</p>
                    </div>
                    @await Html.PartialAsync("_IndustryTablePartial", new ViewDataDictionary(ViewData) 
                    { 
                        { "TaskType", "JOB_POST" }, 
                        { "Assignments", Model.JobPostIndustryAssignments },
                        { "Moderators", Model.JobPostModerators }
                    })
                    <div class="p-4 bg-gray-50 flex justify-end gap-3 border-t border-[#D6DDEB]">
                        <button type="button" onclick="autoDistribute('JOB_POST')" class="bg-white border border-primary text-primary font-bold px-6 py-2.5 rounded-lg hover:bg-primary hover:bg-opacity-10 transition-all shadow-sm flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            Tự động phân chia
                        </button>
                        <button type="submit" class="bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                            Lưu Cấu Hình
                        </button>
                    </div>
                </form>
            </div>

            <!-- REVIEW TAB -->
            <div x-show="activeTab === 'review'" style="display: none;">
                <form action="/AssignModerator/AssignIndustryBatch" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskType" value="REVIEW" />
                    <div class="p-6 pb-2 border-b border-[#D6DDEB]">
                        <p class="text-muted">Quản lý phân công Ngành nghề cho các Moderator phụ trách Duyệt Đánh Giá.</p>
                    </div>
                    @await Html.PartialAsync("_IndustryTablePartial", new ViewDataDictionary(ViewData) 
                    { 
                        { "TaskType", "REVIEW" }, 
                        { "Assignments", Model.ReviewIndustryAssignments },
                        { "Moderators", Model.ReviewModerators }
                    })
                    <div class="p-4 bg-gray-50 flex justify-end gap-3 border-t border-[#D6DDEB]">
                        <button type="button" onclick="autoDistribute('REVIEW')" class="bg-white border border-primary text-primary font-bold px-6 py-2.5 rounded-lg hover:bg-primary hover:bg-opacity-10 transition-all shadow-sm flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            Tự động phân chia
                        </button>
                        <button type="submit" class="bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                            Lưu Cấu Hình
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    <script>
        async function autoDistribute(taskType) {
            try {
                // Fetch the suggested distribution from the API
                const response = await fetch(`/AssignModerator/SuggestDistribution?taskType=${taskType}`);
                if (!response.ok) throw new Error("API failed");
                const data = await response.json();

                // data is a dictionary of { "IndustryName": moderatorId }
                let updatedCount = 0;

                // Find the form corresponding to the taskType
                const form = document.querySelector(`form input[value="${taskType}"]`).closest('form');

                for (const [industry, modId] of Object.entries(data)) {
                    // Find the select element for this industry
                    // Because industry names can contain special characters or spaces, we use attribute selector carefully
                    const selects = form.querySelectorAll(`select[name="assignments[${CSS.escape(industry)}]"]`);
                    if (selects.length > 0) {
                        selects[0].value = modId || "";
                        updatedCount++;
                    }
                }

                alert(`Đã tự động phân chia ${updatedCount} ngành nghề. Vui lòng xem lại và bấm "Lưu Cấu Hình" để áp dụng.`);
            } catch (err) {
                console.error(err);
                alert("Có lỗi xảy ra khi tự động phân chia.");
            }
        }
    </script>
}
