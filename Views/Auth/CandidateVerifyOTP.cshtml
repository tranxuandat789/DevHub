@{
    ViewData["Title"] = "Xác thực tài khoản Ứng viên";
}

<div class="relative min-h-screen py-12 overflow-hidden flex items-center justify-center bg-[#F7F5FC]">
    <div class="max-w-md w-full px-4 relative z-10">
        <div class="bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)] relative z-20">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-5 text-primary">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <h1 class="text-2xl md:text-[28px] font-bold text-dark mb-3">Xác thực OTP</h1>
                <p class="text-muted text-[15px] leading-relaxed">
                    Chúng tôi đã gửi một mã xác nhận gồm 6 chữ số đến email <strong class="text-dark font-semibold">@ViewData["Email"]</strong>. Vui lòng nhập mã để hoàn tất đăng ký (Mã có hiệu lực trong 15 phút).
                </p>
            </div>

            @if (TempData["ErrorMessage"] is string errMsg)
            {
                <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-[14px] flex items-center gap-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>@errMsg</span>
                </div>
            }

            <form action="/Auth/CandidateVerifyOTP" method="POST" id="otpForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="otp" id="otpValue" />
                <div class="flex justify-between gap-2 mb-8">
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                    <input type="text" maxlength="1" class="w-10 sm:w-12 h-14 text-center text-xl font-bold border border-bordercolor rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required />
                </div>
 
                <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md mb-6">
                    Xác nhận
                </button>
            </form>
 
            <div class="text-center text-[15px]">
                <span class="text-muted">Chưa nhận được mã?</span> 
                <button type="button" id="resendBtn" class="text-primary font-medium hover:underline ml-1 disabled:text-gray-400 disabled:no-underline" disabled>Gửi lại (60s)</button>
            </div>
            
            <div class="mt-8 text-center">
                <a href="/Auth/Register" class="text-muted font-medium hover:text-primary transition-colors inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Quay lại đăng ký
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('input[type="text"][maxlength="1"]');
            const otpForm = document.getElementById('otpForm');
            const otpValue = document.getElementById('otpValue');
            const resendBtn = document.getElementById('resendBtn');

            if (inputs.length > 0) inputs[0].focus();

            inputs.forEach((input, index) => {
                input.addEventListener('input', function() {
                    this.value = this.value.replace(/[^0-9]/g, '');
                    if (this.value.length === 1) {
                        if (index < inputs.length - 1) {
                            inputs[index + 1].focus();
                        }
                    }
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && !this.value) {
                        if (index > 0) {
                            inputs[index - 1].focus();
                        }
                    }
                });
            });

            otpForm.addEventListener('submit', function(e) {
                let otp = '';
                inputs.forEach(input => {
                    otp += input.value;
                });
                otpValue.value = otp;
            });

            let countdown = 60;
            let timer;
            function startTimer() {
                countdown = 60;
                resendBtn.disabled = true;
                resendBtn.textContent = `Gửi lại (${countdown}s)`;
                timer = setInterval(() => {
                    countdown--;
                    if (countdown <= 0) {
                        clearInterval(timer);
                        resendBtn.disabled = false;
                        resendBtn.textContent = 'Gửi lại';
                    } else {
                        resendBtn.textContent = `Gửi lại (${countdown}s)`;
                    }
                }, 1000);
            }

            startTimer();

            resendBtn.addEventListener('click', function() {
                resendBtn.disabled = true;
                resendBtn.textContent = 'Đang gửi...';

                fetch('/Auth/CandidateResendOTP', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('Mã OTP mới đã được gửi qua email của bạn.');
                        startTimer();
                    } else {
                        alert(data.message || 'Gửi lại OTP thất bại.');
                        resendBtn.disabled = false;
                        resendBtn.textContent = 'Gửi lại';
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Đã xảy ra lỗi kết nối.');
                    resendBtn.disabled = false;
                    resendBtn.textContent = 'Gửi lại';
                });
            });
        });
    </script>
}
