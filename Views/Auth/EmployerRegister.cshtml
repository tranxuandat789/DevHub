@model DevHub.ViewModels.Auth.RegisterRecruiterViewModel
@{
    ViewData["Title"] = "Đăng ký Nhà tuyển dụng";
}

<div class="relative min-h-screen py-12 md:py-20 overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 25% 65%, rgba(139, 92, 246, 0.15), transparent 45%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex justify-center">
            
            <!-- Center Column: Form -->
            <div class="w-full max-w-lg bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)] relative z-20">
                <h1 class="text-2xl md:text-[32px] font-bold text-dark mb-3 text-center">Đăng ký Nhà tuyển dụng</h1>
                <p class="text-muted text-[15px] mb-8 leading-relaxed text-center">
                    Tạo tài khoản nhà tuyển dụng để bắt đầu tìm kiếm những ứng viên tài năng nhất.
                </p>

                <!-- Error Banner -->
                <div id="errorBanner" class="@(ViewBag.ErrorMessage == null ? "hidden" : "") mb-5 p-4 rounded-xl bg-red-50 border border-red-200 text-red-600 text-[14px] flex items-start gap-2">
                    <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span id="errorMessageText">@ViewBag.ErrorMessage</span>
                </div>

                <form asp-action="EmployerRegister" asp-controller="Auth" method="post" id="employerRegisterForm" onsubmit="return validateForm(event)">
                    <div class="mb-4">
                        <input type="text" placeholder="Họ và tên" name="FullName" id="fnID" value="@Model?.FullName"
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4">
                        <input type="email" placeholder="Email (ví dụ: example@gmail.com hoặc example@fpt.edu.vn)" name="Email" id="eID" value="@Model?.Email"
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4">
                        <input type="tel" placeholder="Số điện thoại (ví dụ: 091 1234 567)" name="Phone" id="pID" value="@Model?.Phone"
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4 relative">
                        <input type="password" placeholder="Mật khẩu" name="Password" id="passwordID"
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                        <button type="button" onclick="togglePassword('passwordID', this)" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mb-5 relative">
                        <input type="password" placeholder="Nhập lại mật khẩu" name="VerifyPassword" id="verifyPasswordID"
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                        <button type="button" onclick="togglePassword('verifyPasswordID', this)" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mb-6 flex items-start gap-3">
                        <div class="flex items-center h-5 mt-0.5">
                            <input id="terms" type="checkbox" class="w-4 h-4 text-primary bg-white border-bordercolor rounded focus:ring-primary focus:ring-2" required>
                        </div>
                        <label for="terms" class="text-[14px] text-muted leading-snug">
                            Tôi đồng ý với <a href="#" class="text-primary hover:underline">quy chế hoạt động</a> và <a href="#" class="text-primary hover:underline">chính sách bảo mật thông tin</a> của DevHub dành cho nhà tuyển dụng
                        </label>
                    </div>

                    <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md">
                        Đăng ký
                    </button>
                    @Html.AntiForgeryToken()
                </form>

                <div class="flex items-center my-6">
                    <div class="flex-grow h-px bg-bordercolor"></div>
                    <span class="px-4 text-muted text-[13px]">Hoặc bằng</span>
                    <div class="flex-grow h-px bg-bordercolor"></div>
                </div>

                <button class="w-full bg-white border border-bordercolor text-dark font-medium py-3.5 rounded-lg hover:bg-gray-50 transition-colors flex items-center justify-center gap-3 text-[15px]">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    Google
                </button>

                <p class="text-center text-muted mt-8 text-[15px]">
                    Bạn đã có tài khoản tuyển dụng? <a href="/Auth/EmployerLogin" class="text-primary font-medium hover:underline">Đăng nhập ngay</a>
                </p>
            </div>
            
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, button) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            button.innerHTML = `
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                </svg>
            `;
        } else {
            input.type = "password";
            button.innerHTML = `
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            `;
        }
    }

    function validateForm(event) {
        const errorBanner = document.getElementById("errorBanner");
        const errorMessageText = document.getElementById("errorMessageText");
        
        // Hide banner first
        errorBanner.classList.add("hidden");
        errorMessageText.innerText = "";
        
        const fullName = document.getElementById("fnID").value.trim();
        const email = document.getElementById("eID").value.trim();
        const phone = document.getElementById("pID").value.trim();
        const password = document.getElementById("passwordID").value;
        const verifyPassword = document.getElementById("verifyPasswordID").value;
        
        let errors = [];
        
        // FullName validation (at least 2 words)
        const words = fullName.split(/\s+/).filter(w => w.length > 0);
        if (words.length < 2) {
            errors.push("Họ và tên phải có ít nhất 2 từ!");
        }
        
        // Phone validation (0xx xxxx xxx)
        const phoneRegex = /^0\d{2} \d{4} \d{3}$/;
        if (!phoneRegex.test(phone)) {
            errors.push("Số điện thoại phải đúng định dạng '0xx xxxx xxx' (ví dụ: 091 1234 567)!");
        }
        
        // Email validation (@@gmail.com or @@fpt.edu.vn)
        const gmailRegex = /^[a-zA-Z0-9._%+-]+@@gmail\.com$/;
        const fptRegex = /^[a-zA-Z0-9._%+-]+@@fpt\.edu\.vn$/;
        if (!gmailRegex.test(email) && !fptRegex.test(email)) {
            errors.push("Email phải có đuôi @@gmail.com hoặc @@fpt.edu.vn!");
        }
        
        // Password match validation
        if (password !== verifyPassword) {
            errors.push("Mật khẩu và mật khẩu nhập lại không khớp!");
        }
        
        // Password strength validation
        // At least 8 chars, 1 uppercase, 1 special, 1 digit
        const passStrengthRegex = /^(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{8,}$/;
        if (!passStrengthRegex.test(password)) {
            errors.push("Mật khẩu phải dài ít nhất 8 ký tự, chứa ít nhất 1 chữ in hoa, 1 chữ số và 1 ký tự đặc biệt!");
        }
        
        if (errors.length > 0) {
            event.preventDefault();
            errorMessageText.innerHTML = errors.join("<br/>");
            errorBanner.classList.remove("hidden");
            window.scrollTo({ top: 0, behavior: 'smooth' });
            return false;
        }
        return true;
    }
</script>
