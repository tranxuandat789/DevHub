@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="relative min-h-screen py-12 overflow-hidden flex items-center justify-center" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.15), transparent 45%);">
    <div class="max-w-md w-full px-4 relative z-10">
        <div class="bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)] relative z-20">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-5 text-primary">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                </div>
                <h1 class="text-2xl md:text-[32px] font-bold text-dark mb-3">Quên mật khẩu?</h1>
                <p class="text-muted text-[15px] leading-relaxed">
                    Đừng lo lắng! Nhập email gắn với tài khoản của bạn và chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.
                </p>
            </div>

            <form action="/Auth/VerifyOTP" method="GET">
                <div class="mb-6 text-left">
                    <label class="block text-dark font-medium mb-2 text-[15px]">Email của bạn</label>
                    <input type="email" placeholder="Nhập địa chỉ email" 
                           class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                </div>

                <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md">
                    Gửi mã OTP
                </button>
            </form>

            <div class="mt-8 text-center">
                <a href="javascript:history.back()" class="text-muted font-medium hover:text-primary transition-colors inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Quay lại đăng nhập
                </a>
            </div>
        </div>
    </div>
</div>

