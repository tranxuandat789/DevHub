@model DevHub.ViewModels.Auth.GoogleRecruiterInfoViewModel
@{
    ViewData["Title"] = "Hoàn tất đăng ký - DevHub";
    ViewData["HideHeaderFooter"] = false;
}

<div class="min-h-screen bg-lightbg flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-2xl shadow-lg p-10 w-full max-w-md">

        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
                <div class="w-5 h-5 border-2 border-white rounded-full relative">
                    <div class="absolute top-0 right-0 w-1.5 h-1.5 bg-white rounded-full"></div>
                </div>
            </div>
            <span class="text-[22px] font-bold text-dark">DevHub</span>
        </div>

        <h1 class="text-[24px] font-bold text-dark mb-1">Hoàn tất đăng ký</h1>
        <p class="text-[14px] text-muted mb-6">
            Chào mừng <span class="font-semibold text-primary">@Model.FullName</span>! Vui lòng bổ sung thông tin để tiếp tục.
        </p>

        @if (TempData["GeneralError"] is string genErr)
        {
            <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-[14px] flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                @genErr
            </div>
        }

        <form asp-action="GoogleRecruiterInfo" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-5">
                <label class="block text-[13px] font-semibold text-dark mb-1.5">Email</label>
                <input type="text" value="@Model.Email" disabled
                       class="w-full px-4 py-3.5 border border-bordercolor rounded-lg bg-gray-50 text-muted text-[15px] cursor-not-allowed" />
                <input type="hidden" name="Email" value="@Model.Email" />
            </div>

            <div class="mb-5">
                <label class="block text-[13px] font-semibold text-dark mb-1.5">Họ và tên</label>
                <input type="text" value="@Model.FullName" disabled
                       class="w-full px-4 py-3.5 border border-bordercolor rounded-lg bg-gray-50 text-muted text-[15px] cursor-not-allowed" />
                <input type="hidden" name="FullName" value="@Model.FullName" />
            </div>

            <div class="mb-7">
                <label class="block text-[13px] font-semibold text-dark mb-1.5">Số điện thoại <span class="text-red-500">*</span></label>
                <input asp-for="Phone" type="tel" placeholder="0901234567"
                       class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" />
                <span asp-validation-for="Phone" class="text-red-500 text-[13px] mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md mb-3">
                Hoàn tất đăng ký
            </button>
            <a href="/Auth/RecruiterLogin"
               class="block text-center text-[14px] text-muted hover:text-primary transition-colors">
                ← Quay lại đăng nhập
            </a>
        </form>
    </div>
</div>

