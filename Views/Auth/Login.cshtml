@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="bg-[#F7F5FC] min-h-screen py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-start gap-12 lg:gap-24">
            
            <!-- Left Column: Form -->
            <div class="w-full lg:w-5/12 bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)]">
                <h1 class="text-2xl md:text-[32px] font-bold text-dark mb-3">Đăng nhập trở lại</h1>
                <p class="text-muted text-[15px] mb-8 leading-relaxed">
                    Cùng xây dựng một hồ sơ nổi bật và nhận được các cơ hội sự nghiệp lý tưởng
                </p>

                <form onsubmit="event.preventDefault(); document.cookie = 'IsLoggedIn=true; path=/'; document.cookie = 'UserRole=Candidate; path=/'; window.location.href = '/';">
                    <div class="mb-5">
                        <input type="text" placeholder="Email hoặc số điện thoại" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-3 relative">
                        <input type="password" placeholder="Mật khẩu" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="flex justify-end mb-6">
                        <a href="/Auth/ForgotPassword" class="text-primary text-[14px] font-medium hover:underline">Quên mật khẩu</a>
                    </div>

                    <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md">
                        Đăng nhập
                    </button>
                </form>

                <div class="flex items-center my-6">
                    <div class="flex-grow h-px bg-bordercolor"></div>
                    <span class="px-4 text-muted text-[13px]">Hoặc bằng</span>
                    <div class="flex-grow h-px bg-bordercolor"></div>
                </div>

                <button class="w-full bg-white border border-bordercolor text-dark font-medium py-3.5 rounded-lg hover:bg-gray-50 transition-colors flex items-center justify-center gap-3 text-[15px]">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Google
                </button>

                <p class="text-center text-muted mt-8 text-[15px]">
                    Bạn sử dụng lần đầu? <a href="/Auth/Register" class="text-primary font-medium hover:underline">Đăng ký ngay</a>
                </p>
            </div>

            <!-- Right Column: Info -->
            <div class="w-full lg:w-7/12 pt-8 lg:pt-16">
                <h2 class="text-[28px] md:text-[36px] font-bold text-dark leading-[1.3] mb-10 max-w-[600px]">
                    Đăng nhập để truy cập ngay vào hàng ngàn đánh giá và dữ liệu lương thị trường IT
                </h2>

                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Xem trước mức lương để có thể lợi thế khi thoả thuận lương</p>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Tìm hiểu về phúc lợi, con người, văn hóa công ty qua các đánh giá chân thật</p>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Dễ dàng ứng tuyển chỉ với một thao tác</p>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Quản lý hồ sơ và quyền riêng tư của bạn</p>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

