@model DevHub.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập Nhà tuyển dụng";
}

<div class="relative min-h-screen py-12 md:py-20 overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.15), transparent 45%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">

            <div class="w-full lg:w-5/12 bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)] relative z-20">
                <h1 class="text-2xl md:text-[32px] font-bold text-dark mb-3">Đăng nhập Nhà tuyển dụng</h1>
                <p class="text-muted text-[15px] mb-8 leading-relaxed">
                    Đăng nhập để tìm kiếm và kết nối với hàng ngàn ứng viên tiềm năng cho doanh nghiệp của bạn.
                </p>

                @if (TempData["GeneralError"] is string genErr)
                {
                    <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-[14px] flex items-center gap-2">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        @genErr
                    </div>
                }

                <form asp-action="RecruiterLogin" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-5">
                        <input type="text" name="Email" value="@(TempData["PrefillEmail"]?.ToString() ?? "")" placeholder="Email"
                               class="w-full px-4 py-3.5 border @(TempData["EmailError"] != null ? "border-red-400" : "border-bordercolor") rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" />
                        @if (TempData["EmailError"] is string emailErr)
                        {
                            <p class="text-red-500 text-[13px] mt-1 flex items-center gap-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                @emailErr
                            </p>
                        }
                    </div>

                    <div class="mb-3 relative">
                        <input type="password" id="passwordInput" name="Password" placeholder="Mật khẩu"
                               class="w-full px-4 py-3.5 pr-12 border @(TempData["PasswordError"] != null ? "border-red-400" : "border-bordercolor") rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" />
                        <button type="button" onclick="togglePasswordVisibility('passwordInput', 'eyeIcon')" class="absolute right-4 top-[15px] text-muted hover:text-primary focus:outline-none">
                            <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.895 7.895L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                            </svg>
                        </button>
                        @if (TempData["PasswordError"] is string pwErr)
                        {
                            <p class="text-red-500 text-[13px] mt-1 flex items-center gap-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                @pwErr
                            </p>
                        }
                    </div>

                    <div class="flex items-center justify-between mb-6 mt-3">
                        <label class="flex items-center gap-2 text-[14px] text-muted cursor-pointer">
                            <input type="checkbox" name="RememberMe" value="true" class="rounded" />
                            Ghi nhớ đăng nhập
                        </label>
                        <a href="/Auth/ForgotPassword" class="text-[14px] text-primary hover:underline font-medium">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md">
                        Đăng nhập
                    </button>
                </form>

                <div class="flex items-center my-6">
                    <div class="flex-grow h-px bg-bordercolor"></div>
                    <span class="px-4 text-muted text-[13px]">Hoặc bằng</span>
                    <div class="flex-grow h-px bg-bordercolor"></div>
                </div>

                <a href="/Auth/GoogleLogin?from=recruiter"
                   class="w-full bg-white border border-bordercolor text-dark font-medium py-3.5 rounded-lg hover:bg-gray-50 transition-colors flex items-center justify-center gap-3 text-[15px]">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Google
                </a>

                <p class="text-center text-muted mt-8 text-[15px]">
                    Lần đầu tuyển dụng? <a href="/Auth/RecruiterRegister" class="text-primary font-medium hover:underline">Đăng ký ngay</a>
                </p>
            </div>

            <div class="w-full lg:w-7/12 pt-0 lg:-mt-20 text-center lg:text-left">
                <h2 class="text-[36px] md:text-[48px] font-bold text-dark leading-[1.2] mb-10 max-w-[600px] mx-auto lg:mx-0">
                    Tìm kiếm nhân tài <br class="hidden md:block"/>
                    nhanh chóng & <span class="text-[#26A4FF]">hiệu quả</span>
                </h2>
                <div class="space-y-6 max-w-[500px] mx-auto lg:mx-0">
                    <div class="flex items-start gap-4 text-left">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Tiếp cận nguồn ứng viên chất lượng cao, đa dạng lĩnh vực.</p>
                    </div>
                    <div class="flex items-start gap-4 text-left">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Đăng tin tuyển dụng dễ dàng, quản lý hồ sơ ứng viên thông minh.</p>
                    </div>
                    <div class="flex items-start gap-4 text-left">
                        <div class="mt-1 flex-shrink-0 text-green-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-[16px] md:text-[18px] text-dark font-medium">Công cụ AI hỗ trợ gợi ý và ghép nối ứng viên phù hợp nhất.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function togglePasswordVisibility(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            // Eye open icon
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />';
        } else {
            input.type = "password";
            // Eye slash icon
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.895 7.895L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />';
        }
    }
</script>

