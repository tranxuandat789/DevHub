@{
    ViewData["Title"] = "Đăng ký";
}

<div class="bg-[#F7F5FC] min-h-screen py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            
            <!-- Center Column: Form -->
            <div class="w-full max-w-lg bg-white rounded-[20px] p-8 md:p-10 shadow-[0_15px_40px_rgba(70,64,222,0.14)]">
                <h1 class="text-2xl md:text-[32px] font-bold text-dark mb-3">Tạo tài khoản mới</h1>
                <p class="text-muted text-[15px] mb-8 leading-relaxed">
                    Cùng xây dựng một hồ sơ nổi bật và nhận được các cơ hội sự nghiệp lý tưởng
                </p>

                <form onsubmit="event.preventDefault(); document.cookie = 'IsLoggedIn=true; path=/'; document.cookie = 'UserRole=Candidate; path=/'; window.location.href = '/';">
                    <div class="mb-4">
                        <input type="text" placeholder="Họ và tên" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4">
                        <input type="email" placeholder="Email" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4">
                        <input type="tel" placeholder="Số điện thoại" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                    </div>

                    <div class="mb-4 relative">
                        <input type="password" placeholder="Mật khẩu" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mb-5 relative">
                        <input type="password" placeholder="Nhập lại mật khẩu" 
                               class="w-full px-4 py-3.5 border border-bordercolor rounded-lg focus:outline-none focus:border-primary transition-colors text-[15px]" required />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>

                    <div class="mb-6 flex items-start gap-3">
                        <div class="flex items-center h-5 mt-0.5">
                            <input id="terms" type="checkbox" class="w-4 h-4 text-primary bg-white border-bordercolor rounded focus:ring-primary focus:ring-2" required>
                        </div>
                        <label for="terms" class="text-[14px] text-muted leading-snug">
                            Tôi đồng ý với <a href="#" class="text-primary hover:underline">quy chế hoạt động</a> và <a href="#" class="text-primary hover:underline">chính sách bảo mật thông tin</a> của JobHuntly
                        </label>
                    </div>

                    <button type="submit" class="w-full bg-primary text-white font-bold py-3.5 rounded-lg hover:bg-opacity-90 transition-all text-[16px] shadow-md">
                        Đăng ký
                    </button>
                </form>

                <div class="flex items-center my-6">
                    <div class="flex-grow h-px bg-bordercolor"></div>
                    <span class="px-4 text-muted text-[13px]">Hoặc bằng</span>
                    <div class="flex-grow h-px bg-bordercolor"></div>
                </div>

                <button class="w-full bg-white border border-bordercolor text-dark font-medium py-3.5 rounded-lg hover:bg-gray-50 transition-colors flex items-center justify-center gap-3 text-[15px]">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Google
                </button>

                <p class="text-center text-muted mt-8 text-[15px]">
                    Bạn đã có tài khoản? <a href="/Account/Login" class="text-primary font-medium hover:underline">Đăng nhập ngay</a>
                </p>
            </div>
            
        </div>
    </div>
</div>
