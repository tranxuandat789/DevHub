@model DevHub.Models.BlogPost
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-white min-h-screen pt-8 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="flex mb-8 text-sm text-muted">
            <a href="/" class="hover:text-primary transition">Trang chủ</a>
            <span class="mx-2">/</span>
            <a href="/Blog" class="hover:text-primary transition">Blog</a>
            <span class="mx-2">/</span>
            <span class="text-dark font-medium line-clamp-1">@Model.Title</span>
        </nav>

        <!-- Article Header -->
        <header class="mb-10">
            <div class="flex items-center gap-3 text-sm mb-6">
                <span class="bg-blue-50 text-[#26A4FF] px-3 py-1 rounded-full font-medium uppercase tracking-wide text-xs">Công nghệ</span>
                <span class="text-muted">•</span>
                <span class="text-muted">@Model.PublishedAt?.ToString("dd Thg MM, yyyy")</span>
            </div>
            <h1 class="font-epilogue font-bold text-4xl md:text-5xl leading-tight text-dark mb-8">
                @Model.Title
            </h1>
            
            <div class="flex items-center justify-between border-y border-bordercolor py-6">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-xl">
                        @(Model.Publisher?.FullName?.Substring(0, 1) ?? "A")
                    </div>
                    <div>
                        <p class="font-bold text-dark text-lg">@(Model.Publisher?.FullName ?? "Admin Vũ")</p>
                        <p class="text-sm text-muted">Tác giả</p>
                    </div>
                </div>
                <!-- Social Share -->
                <div class="flex items-center gap-3">
                    <span class="text-sm text-muted mr-2">Chia sẻ:</span>
                    <button class="w-10 h-10 rounded-full border border-bordercolor flex items-center justify-center text-muted hover:text-[#26A4FF] hover:border-[#26A4FF] transition">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                    </button>
                    <button class="w-10 h-10 rounded-full border border-bordercolor flex items-center justify-center text-muted hover:text-blue-700 hover:border-blue-700 transition">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </button>
                    <button class="w-10 h-10 rounded-full border border-bordercolor flex items-center justify-center text-muted hover:text-blue-600 hover:border-blue-600 transition">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
                    </button>
                </div>
            </div>
        </header>

        <!-- Hero Image -->
        @if(!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <figure class="mb-12">
                <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="w-full h-auto rounded-2xl object-cover" />
            </figure>
        }

        <!-- Article Content -->
        <article class="prose prose-lg max-w-none text-muted mb-16">
            @Html.Raw(Model.Content)
        </article>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-16 pb-8 border-b border-bordercolor">
            <span class="text-sm font-medium text-dark mr-2 py-1">Tags:</span>
            @if (!string.IsNullOrEmpty(Model.Tag))
            {
                var tags = Model.Tag.Split(',', StringSplitOptions.RemoveEmptyEntries);
                foreach (var t in tags)
                {
                    <a href="#" class="px-3 py-1 bg-gray-100 text-gray-600 rounded-md text-sm hover:bg-gray-200 transition">@t.Trim()</a>
                }
            }

        </div>

        <!-- Related Articles -->
        @if (ViewBag.RelatedBlogs != null && ((IEnumerable<DevHub.Models.BlogPost>)ViewBag.RelatedBlogs).Any())
        {
            var relatedBlogs = (IEnumerable<DevHub.Models.BlogPost>)ViewBag.RelatedBlogs;
            <div>
                <h3 class="text-2xl font-bold text-dark mb-8">Bài viết liên quan</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    @foreach (var related in relatedBlogs)
                    {
                        var firstTag = !string.IsNullOrEmpty(related.Tag) ? related.Tag.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)[0].Trim() : "Bài viết";
                        <a href="/CareerHandbook/@related.Slug" class="group flex gap-4 bg-white rounded-xl hover:bg-gray-50 transition p-2 -ml-2">
                            <img src="@(string.IsNullOrEmpty(related.ThumbnailUrl) ? "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=200&auto=format&fit=crop" : related.ThumbnailUrl)" alt="@related.Title" class="w-24 h-24 rounded-lg object-cover" />
                            <div>
                                <div class="text-xs text-[#26A4FF] font-semibold mb-1 uppercase">@firstTag</div>
                                <h4 class="text-base font-bold text-dark mb-1 group-hover:text-[#26A4FF] transition line-clamp-2">@related.Title</h4>
                                <p class="text-xs text-muted">@(related.PublishedAt?.ToString("dd Thg MM, yyyy") ?? related.CreatedAt?.ToString("dd Thg MM, yyyy"))</p>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <style>
        .prose .image-style-side {
            float: right;
            margin-left: 2rem;
            max-width: 50%;
        }
        .prose .image-style-align-left {
            float: left;
            margin-right: 2rem;
            max-width: 50%;
        }
        .prose .image-style-align-right {
            float: right;
            margin-left: 2rem;
            max-width: 50%;
        }
        .prose .image-style-align-center {
            margin-left: auto;
            margin-right: auto;
        }
        .prose figure.image {
            display: table;
            clear: both;
            text-align: center;
        }
        .prose figure.image img {
            margin: 0 auto;
        }
        .prose figure.image figcaption {
            display: table-caption;
            caption-side: bottom;
            word-break: break-word;
            color: var(--tw-prose-captions);
            font-size: 0.875em;
            line-height: 1.4285714;
            margin-top: 0.8571429em;
        }
    </style>
}
