@model DevHub.Models.BlogPost
@{
    ViewData["Title"] = Model.Title;
    var relatedBlogs = ViewBag.RelatedBlogs as List<DevHub.Models.BlogPost> ?? new List<DevHub.Models.BlogPost>();
}

<div class="bg-lightbg min-h-screen py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="flex text-sm text-muted mb-8" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center hover:text-primary transition-colors">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
                        Trang chủ
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                        <a href="/CareerHandbook" class="ml-1 md:ml-2 hover:text-primary transition-colors">Cẩm nang nghề nghiệp</a>
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Article Header -->
        <div class="mb-8">
            @if (!string.IsNullOrEmpty(Model.Tag))
            {
                <div class="flex flex-wrap gap-2 mb-4">
                    @foreach (var tag in Model.Tag.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()))
                    {
                        <a href="/CareerHandbook?tag=@tag" class="bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full hover:bg-primary hover:text-white transition-colors">@tag</a>
                    }
                </div>
            }
            <h1 class="text-3xl md:text-4xl font-bold text-dark mb-6 leading-tight">@Model.Title</h1>
            
            <div class="flex items-center justify-between border-b border-gray-200 pb-6">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
                        @(!string.IsNullOrWhiteSpace(Model.Publisher?.FullName) ? Model.Publisher.FullName.Substring(0, 1).ToUpper() : "A")
                    </div>
                    <div>
                        <p class="text-sm font-bold text-dark">@(string.IsNullOrWhiteSpace(Model.Publisher?.FullName) ? "Admin" : Model.Publisher.FullName)</p>
                        <p class="text-xs text-muted">@(Model.PublishedAt?.ToString("dd/MM/yyyy HH:mm") ?? Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</p>
                    </div>
                </div>
                
                <!-- Share options -->
                <div class="flex items-center gap-2">
                    <button class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-muted hover:text-primary hover:border-primary transition-colors" title="Chia sẻ qua Facebook">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </button>
                    <button class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-muted hover:text-primary hover:border-primary transition-colors" title="Sao chép liên kết" onclick="navigator.clipboard.writeText(window.location.href); alert('Đã sao chép liên kết!');">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Thumbnail -->
        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <div class="mb-10 rounded-2xl overflow-hidden shadow-sm">
                <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="w-full h-auto object-cover max-h-[500px]">
            </div>
        }

        <!-- Content -->
        <article class="prose prose-lg max-w-none prose-img:rounded-xl prose-img:shadow-sm prose-headings:text-dark prose-p:text-muted prose-a:text-primary hover:prose-a:text-primary/80 mb-16">
            @Html.Raw(Model.Content)
        </article>
    </div>

    <!-- Related Articles -->
    @if (relatedBlogs.Any())
    {
        <div class="bg-white border-t border-gray-200 py-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h3 class="text-2xl font-bold text-dark mb-8 text-center">Bài viết liên quan</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    @foreach (var blog in relatedBlogs)
                    {
                        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow group flex flex-col sm:flex-row h-full">
                            <a href="/CareerHandbook/@blog.Slug" class="block sm:w-2/5 aspect-video sm:aspect-auto relative overflow-hidden flex-shrink-0">
                                @if (!string.IsNullOrEmpty(blog.ThumbnailUrl))
                                {
                                    <img src="@blog.ThumbnailUrl" alt="@blog.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                                }
                                else
                                {
                                    <div class="w-full h-full bg-gray-100 flex items-center justify-center group-hover:scale-105 transition-transform duration-300">
                                        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    </div>
                                }
                            </a>
                            <div class="p-5 flex flex-col flex-1">
                                <a href="/CareerHandbook/@blog.Slug" class="text-base font-bold text-dark hover:text-primary transition-colors line-clamp-2 mb-2">
                                    @blog.Title
                                </a>
                                <p class="text-xs text-muted mb-auto">@(blog.PublishedAt?.ToString("dd/MM/yyyy") ?? blog.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</p>
                                
                                <div class="mt-4 pt-4 border-t border-gray-50 flex items-center gap-2">
                                    <div class="w-5 h-5 rounded-full bg-primary/10 flex items-center justify-center text-primary text-[10px] font-bold">
                                        @(!string.IsNullOrWhiteSpace(blog.Publisher?.FullName) ? blog.Publisher.FullName.Substring(0, 1).ToUpper() : "A")
                                    </div>
                                    <span class="text-[13px] font-medium text-dark truncate">@(string.IsNullOrWhiteSpace(blog.Publisher?.FullName) ? "Admin" : blog.Publisher.FullName)</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
