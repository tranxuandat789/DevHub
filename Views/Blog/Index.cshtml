@model IEnumerable<DevHub.Models.BlogPost>

@{
    ViewData["Title"] = "Cẩm nang nghề nghiệp";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="relative overflow-hidden py-16 mb-8" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 70% 50%, rgba(38,164,255,0.18), transparent 45%), radial-gradient(circle at 25% 60%, rgba(139,92,246,0.12), transparent 40%);">
    <!-- Blob decorators -->
    <div class="absolute top-0 right-0 w-72 h-72 rounded-full opacity-20 blur-3xl" style="background: radial-gradient(circle, rgba(38,164,255,0.5), transparent 70%); transform: translate(30%, -30%);"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full opacity-15 blur-3xl" style="background: radial-gradient(circle, rgba(139,92,246,0.5), transparent 70%); transform: translate(-30%, 30%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Header -->
        <div class="text-center">
            <h1 class="font-epilogue font-bold text-[48px] leading-tight text-dark mb-4">
                Bài viết <span style="color: #26A4FF;">nổi bật</span>
            </h1>
            <p class="text-muted text-lg max-w-2xl mx-auto">
                Khám phá những góc nhìn mới, mẹo hay và xu hướng nghề nghiệp từ các chuyên gia để phát triển sự nghiệp của bạn.
            </p>
        </div>
    </div>
</div>

<div class="bg-white pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
        <!-- Categories & Search -->
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6">
            <div class="flex flex-wrap gap-3">
                @{
                    var currentSearchParam = string.IsNullOrEmpty(ViewBag.SearchKeyword) ? "" : $"&search={Uri.EscapeDataString(ViewBag.SearchKeyword)}";
                }
                <a href="/CareerHandbook?@(currentSearchParam.TrimStart('&'))" class="px-5 py-2.5 rounded-full @(string.IsNullOrEmpty(ViewBag.CurrentTag) ? "bg-[#26A4FF] text-white hover:bg-opacity-90" : "bg-gray-100 text-gray-600 hover:bg-gray-200") font-medium text-sm transition">Tất cả</a>
                @if (ViewBag.Tags != null)
                {
                    foreach (var t in (List<string>)ViewBag.Tags)
                    {
                        var isActive = ViewBag.CurrentTag == t;
                        <a href="/CareerHandbook?tag=@Uri.EscapeDataString(t)@currentSearchParam" class="px-5 py-2.5 rounded-full @(isActive ? "bg-[#26A4FF] text-white hover:bg-opacity-90" : "bg-gray-100 text-gray-600 hover:bg-gray-200") font-medium text-sm transition">@t</a>
                    }
                }
            </div>
            
            <form action="/CareerHandbook" method="get" class="relative w-full md:w-80">
                @if (!string.IsNullOrEmpty(ViewBag.CurrentTag))
                {
                    <input type="hidden" name="tag" value="@ViewBag.CurrentTag" />
                }
                <input type="text" name="search" value="@ViewBag.SearchKeyword" placeholder="Tìm kiếm bài viết..." class="w-full pl-10 pr-4 py-3 rounded-lg border border-bordercolor focus:outline-none focus:border-[#26A4FF] focus:ring-1 focus:ring-[#26A4FF] transition" />
                <button type="submit" class="absolute left-3 top-3.5 text-gray-400 hover:text-[#26A4FF]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </form>
        </div>

        @if (Model != null && Model.Any())
        {
            var featured = Model.First();
            var others = Model.Skip(1);

            <!-- Featured Article -->
            <div class="mb-16">
                <a href="/Blog/@featured.Slug" class="group grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-gray-50 rounded-2xl overflow-hidden hover:shadow-lg transition duration-300">
                    <div class="h-64 md:h-full w-full relative overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(featured.ThumbnailUrl) ? "https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=1000&auto=format&fit=crop" : featured.ThumbnailUrl)" alt="Featured Article" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                        @if (currentPage == 1) {
                            <div class="absolute top-4 left-4">
                                <span class="bg-[#26A4FF] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Mới nhất</span>
                            </div>
                        }
                    </div>
                    <div class="p-8 md:pr-12 md:py-12">
                        <div class="flex items-center gap-3 text-sm text-muted mb-4">
                            <span class="font-medium text-[#26A4FF]">Tổng hợp</span>
                            <span>•</span>
                            <span>@(featured.PublishedAt?.ToString("dd Thg MM, yyyy") ?? featured.CreatedAt?.ToString("dd Thg MM, yyyy"))</span>
                        </div>
                        <h2 class="text-3xl font-bold text-dark mb-3 group-hover:text-[#26A4FF] transition line-clamp-2">@featured.Title</h2>
                        @{
                            var featuredExcerpt = string.IsNullOrEmpty(featured.Content)
                                ? ""
                                : System.Text.RegularExpressions.Regex.Replace(featured.Content, "<.*?>", string.Empty);
                            if (featuredExcerpt.Length > 150) featuredExcerpt = featuredExcerpt.Substring(0, 150).TrimEnd() + "...";
                        }
                        @if (!string.IsNullOrEmpty(featuredExcerpt))
                        {
                            <p class="text-muted text-sm leading-relaxed line-clamp-3">@featuredExcerpt</p>
                        }
                        <div class="flex items-center justify-between mt-6">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold">
                                    @((featured.Publisher?.FullName ?? "Admin")[0])
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-dark">@(featured.Publisher?.FullName ?? "Admin")</p>
                                </div>
                            </div>
                            <span class="text-[#26A4FF] font-medium flex items-center gap-1">
                                Đọc tiếp <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Article Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var article in others)
                {
                    <a href="/Blog/@article.Slug" class="group bg-white rounded-xl border border-bordercolor overflow-hidden hover:shadow-md transition flex flex-col">
                        <div class="h-48 overflow-hidden relative">
                            <img src="@(string.IsNullOrEmpty(article.ThumbnailUrl) ? "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop" : article.ThumbnailUrl)" alt="Article" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                        </div>
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="text-xs text-[#26A4FF] font-semibold mb-2 uppercase tracking-wide">Tin tức</div>
                            <h3 class="text-xl font-bold text-dark mb-2 group-hover:text-[#26A4FF] transition line-clamp-2">@article.Title</h3>
                            @{
                                var artExcerpt = string.IsNullOrEmpty(article.Content)
                                    ? ""
                                    : System.Text.RegularExpressions.Regex.Replace(article.Content, "<.*?>", string.Empty);
                                if (artExcerpt.Length > 80) artExcerpt = artExcerpt.Substring(0, 80).TrimEnd() + "...";
                            }
                            @if (!string.IsNullOrEmpty(artExcerpt))
                            {
                                <p class="text-muted text-xs leading-relaxed mb-2 line-clamp-2">@artExcerpt</p>
                            }
                            <div class="flex items-center justify-between mt-auto pt-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 text-xs font-bold">
                                        @((article.Publisher?.FullName ?? "Admin")[0])
                                    </div>
                                    <span class="text-sm font-medium text-dark line-clamp-1">@(article.Publisher?.FullName ?? "Admin")</span>
                                </div>
                                <span class="text-xs text-muted">@(article.PublishedAt?.ToString("dd/MM/yyyy") ?? article.CreatedAt?.ToString("dd/MM/yyyy"))</span>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="mt-12 flex justify-center">
                    <nav class="flex items-center gap-2">
                        @{
                            var searchParam = string.IsNullOrEmpty(ViewBag.SearchKeyword) ? "" : $"&search={Uri.EscapeDataString(ViewBag.SearchKeyword)}";
                            var tagParam = string.IsNullOrEmpty(ViewBag.CurrentTag) ? "" : $"&tag={Uri.EscapeDataString(ViewBag.CurrentTag)}";
                            var queryParams = searchParam + tagParam;
                        }
                        <a href="?page=@(currentPage - 1)@queryParams" class="w-10 h-10 flex items-center justify-center rounded-lg border border-bordercolor text-muted hover:bg-gray-50 transition @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </a>
                        
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == currentPage)
                            {
                                <span class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#26A4FF] text-white font-medium">@i</span>
                            }
                            else
                            {
                                <a href="?page=@i@queryParams" class="w-10 h-10 flex items-center justify-center rounded-lg border border-bordercolor text-dark font-medium hover:bg-gray-50 transition">@i</a>
                            }
                        }

                        <a href="?page=@(currentPage + 1)@queryParams" class="w-10 h-10 flex items-center justify-center rounded-lg border border-bordercolor text-muted hover:bg-gray-50 transition @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-20 text-gray-500">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14"></path></svg>
                <h3 class="text-xl font-medium">Chưa có bài viết nào</h3>
                <p class="mt-2 text-sm">Hãy quay lại sau để đọc những bài viết mới nhất nhé.</p>
            </div>
        }
    </div>
</div>
