<meta charset="utf-8" />
@{
    ViewData["Title"] = "Lịch phỏng vấn";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Interviews";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex justify-between items-center mb-6 border-b border-[#D6DDEB] pb-4">
                        <h2 class="text-[20px] font-bold text-dark">Lịch phỏng vấn</h2>
                        <div class="flex gap-2">
                            <span class="bg-primary/10 text-primary text-sm font-semibold px-3 py-1 rounded-full">2 Lịch sắp tới</span>
                        </div>
                    </div>

                    <!-- Filter Options -->
                    <div class="flex flex-wrap gap-3 mb-6">
                        <button class="px-4 py-2 text-sm font-medium rounded-full bg-primary text-white transition-colors">Sắp tới</button>
                        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 hover:text-dark border border-[#D6DDEB] transition-colors">Đã qua</button>
                        <button class="px-4 py-2 text-sm font-medium rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 hover:text-dark border border-[#D6DDEB] transition-colors">Đã hủy</button>
                    </div>

                    <!-- Interview List -->
                    <div class="space-y-4">
                        @for (int i = 0; i < 2; i++)
                        {
                            <div class="block border border-[#D6DDEB] hover:border-primary/50 hover:shadow-sm transition-all rounded-xl p-5 group relative overflow-hidden">
                                <div class="absolute top-0 left-0 w-1 h-full bg-primary"></div>
                                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pl-2">
                                    
                                    <div class="flex items-start gap-4">
                                        <!-- Date Box -->
                                        <div class="w-16 h-16 rounded-xl flex flex-col items-center justify-center border border-[#D6DDEB] bg-gray-50 shadow-sm flex-shrink-0">
                                            <span class="text-xs font-bold text-primary uppercase">Th�ng 10</span>
                                            <span class="text-xl font-bold text-dark">25</span>
                                        </div>
                                        
                                        <!-- Interview Details -->
                                        <div>
                                            <h3 class="text-[17px] font-bold text-dark">Phỏng vấn Vòng 1 - UI/UX Designer</h3>
                                            <div class="flex items-center gap-2 mt-1 text-sm text-gray-500">
                                                <span class="font-medium text-dark flex items-center">
                                                    <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/BMW.svg" alt="Company" class="w-4 h-4 object-contain mr-1.5">
                                                    BMW
                                                </span>
                                            </div>
                                            
                                            <!-- Info items -->
                                            <div class="flex flex-wrap gap-y-2 gap-x-4 mt-3">
                                                <span class="text-[13px] font-medium text-gray-500 flex items-center">
                                                    <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                    09:00 AM - 10:00 AM
                                                </span>
                                                <span class="text-[13px] font-medium text-gray-500 flex items-center">
                                                    <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                                    </svg>
                                                    Google Meet
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Actions -->
                                    <div class="flex flex-col items-end gap-3 w-full md:w-auto mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-[#D6DDEB]">
                                        <div class="flex items-center gap-2">
                                            <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-blue-50 text-blue-600 border border-blue-100">Chờ phỏng vấn</span>
                                        </div>
                                        <div class="flex items-center justify-between w-full md:w-auto gap-3">
                                            <a href="#" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-primary text-white hover:bg-opacity-90 w-full text-center transition-colors shadow-sm">Tham gia ngay</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                </div>
            </div>

        </div>
    </div>
</div>