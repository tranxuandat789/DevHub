@using DevHub.ViewModels.Candidate
@model CandidateInterviewViewModel
@{
    ViewData["Title"] = "Lịch phỏng vấn";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Interviews";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex flex-col md:flex-row md:items-center justify-between mb-6 border-b border-[#D6DDEB] pb-4 gap-4">
                        <div class="flex items-center gap-4">
                            <h2 class="text-[20px] font-bold text-dark">Lịch phỏng vấn</h2>
                            <span class="bg-primary/10 text-primary text-sm font-semibold px-3 py-1 rounded-full">@Model.ScheduledCount Lịch sắp tới</span>
                        </div>
                        
                        <!-- Job Filter -->
                        <form method="get" class="relative min-w-[250px]" onchange="this.submit()">
                            <input type="hidden" name="tab" value="@Model.ActiveTab" />
                            <select name="jobId" class="w-full appearance-none pl-4 pr-10 py-2 bg-gray-50 border border-[#D6DDEB] rounded-lg focus:outline-none focus:border-primary text-sm font-medium text-dark cursor-pointer">
                                <option value="">Tất cả công việc</option>
                                @foreach (var job in Model.JobPosts)
                                {
                                    if (Model.SelectedJobId == job.JobId)
                                    {
                                        <option value="@job.JobId" selected>@job.Title</option>
                                    }
                                    else
                                    {
                                        <option value="@job.JobId">@job.Title</option>
                                    }
                                }
                            </select>
                            <svg class="w-4 h-4 text-gray-500 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </form>
                    </div>

                    <!-- Filter Options -->
                    <div class="flex flex-wrap gap-3 mb-6">
                        @{
                            string BaseUrl = $"?jobId={Model.SelectedJobId}";
                            string GetTabClass(string tab) => Model.ActiveTab == tab 
                                ? "px-4 py-2 text-sm font-medium rounded-full bg-primary text-white transition-colors" 
                                : "px-4 py-2 text-sm font-medium rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 hover:text-dark border border-[#D6DDEB] transition-colors";
                            int allInterviewsTotal = Model.ScheduledCount + Model.PassedCount + Model.RejectedCount + Model.CancelledCount;
                        }
                        <a href="@(BaseUrl)&tab=all" class="@GetTabClass("all")">Tất cả (@allInterviewsTotal)</a>
                        <a href="@(BaseUrl)&tab=scheduled" class="@GetTabClass("scheduled")">Sắp tới (@Model.ScheduledCount)</a>
                        <a href="@(BaseUrl)&tab=passed" class="@GetTabClass("passed")">Trúng tuyển (@Model.PassedCount)</a>
                        <a href="@(BaseUrl)&tab=rejected" class="@GetTabClass("rejected")">Trượt (@Model.RejectedCount)</a>
                        <a href="@(BaseUrl)&tab=cancelled" class="@GetTabClass("cancelled")">Đã hủy (@Model.CancelledCount)</a>
                    </div>

                    <!-- Interview List -->
                    <div class="space-y-4">
                        @if (Model.Interviews.Any())
                        {
                            @foreach (var item in Model.Interviews)
                            {
                                <div class="block border border-[#D6DDEB] hover:border-primary/50 hover:shadow-sm transition-all rounded-xl p-5 group relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1 h-full @(item.Status == "cancelled" ? "bg-gray-400" : item.Status == "passed" ? "bg-green-500" : item.Status == "rejected" ? "bg-red-500" : "bg-primary")"></div>
                                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pl-2">
                                        
                                        <div class="flex items-start gap-4">
                                            <!-- Date Box -->
                                            <div class="w-16 h-16 rounded-xl flex flex-col items-center justify-center border border-[#D6DDEB] bg-gray-50 shadow-sm flex-shrink-0">
                                                <span class="text-xs font-bold text-primary uppercase">Thg @item.ScheduledTime.Month</span>
                                                <span class="text-xl font-bold text-dark">@item.ScheduledTime.Day</span>
                                            </div>
                                            
                                            <!-- Interview Details -->
                                            <div>
                                                <h3 class="text-[17px] font-bold text-dark line-clamp-2">Phỏng vấn - @item.Application?.Job?.Title</h3>
                                                <div class="flex items-center gap-2 mt-1 text-sm text-gray-500">
                                                    <span class="font-medium text-dark flex items-center">
                                                        <img src="@(item.Application?.Job?.Company?.CompanyLogoUrl ?? "https://upload.wikimedia.org/wikipedia/commons/4/44/BMW.svg")" alt="Company" class="w-4 h-4 object-contain mr-1.5">
                                                        <span class="truncate max-w-[150px] inline-block align-bottom">@item.Application?.Job?.Company?.CompanyName</span>
                                                    </span>
                                                </div>
                                                
                                                <!-- Info items -->
                                                <div class="flex flex-wrap gap-y-2 gap-x-4 mt-3">
                                                    <span class="text-[13px] font-medium text-gray-500 flex items-center">
                                                        <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                        </svg>
                                                        @item.ScheduledTime.ToString("HH:mm")
                                                    </span>
                                                    <span class="text-[13px] font-medium text-gray-500 flex items-center">
                                                        @if (item.InterviewType == "ONLINE")
                                                        {
                                                            <svg class="w-4 h-4 mr-1.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                                            </svg>
                                                            <span>Online Meeting</span>
                                                        }
                                                        else
                                                        {
                                                            <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                                            </svg>
                                                            <span>Trực tiếp</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                    <div class="flex flex-col items-end gap-3 w-full md:w-auto mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-[#D6DDEB]">
                                            <div class="flex items-center gap-2">
                                                @if (item.Status == "scheduled" || item.Status == "confirmed")
                                                {
                                                    <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-blue-50 text-blue-600 border border-blue-100">Chờ phỏng vấn</span>
                                                }
                                                else if (item.Status == "passed")
                                                {
                                                    <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-green-50 text-green-600 border border-green-100">Đã đậu</span>
                                                }
                                                else if (item.Status == "rejected")
                                                {
                                                    <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-red-50 text-red-600 border border-red-100">Trượt</span>
                                                }
                                                else if (item.Status == "cancelled")
                                                {
                                                    <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-gray-50 text-gray-600 border border-gray-200">Đã hủy</span>
                                                }
                                            </div>
                                            <div class="flex items-center gap-2">
                                                @if (item.Status == "scheduled")
                                                {
                                                    <button onclick="confirmAttendance(@item.InterviewId)" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-green-500 text-white hover:bg-green-600 transition-colors shadow-sm whitespace-nowrap">Xác nhận tham gia</button>
                                                    <button onclick="openCancelModal(@item.InterviewId)" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-red-50 text-red-600 hover:bg-red-100 transition-colors shadow-sm border border-red-200 whitespace-nowrap">Không thể tham gia</button>
                                                }
                                                else if (item.Status == "confirmed")
                                                {
                                                    <span class="px-4 py-1.5 rounded-lg text-sm font-medium bg-green-50 text-green-600 border border-green-200 shadow-sm whitespace-nowrap"><i class="fas fa-check mr-1"></i> Đã xác nhận tham gia</span>
                                                }
                                                <a href="/candidate/interviews/details/@item.InterviewId" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-white border border-[#D6DDEB] text-dark hover:border-primary hover:text-primary transition-colors shadow-sm whitespace-nowrap">Xem chi tiết</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="bg-white rounded-xl border border-dashed border-[#D6DDEB] p-10 text-center">
                                <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <h3 class="mt-2 text-sm font-semibold text-gray-900">Không có dữ liệu</h3>
                                <p class="mt-1 text-sm text-gray-500">Hiện chưa có lịch phỏng vấn nào phù hợp với bộ lọc.</p>
                            </div>
                        }
                    </div>
                    
                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <div class="mt-6 flex justify-center">
                            <div class="flex items-center gap-1">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    if (i == Model.CurrentPage)
                                    {
                                        <span class="w-8 h-8 rounded-lg bg-primary text-white font-medium text-sm flex items-center justify-center">@i</span>
                                    }
                                    else
                                    {
                                        <a href="@(BaseUrl)&tab=@Model.ActiveTab&page=@i" class="w-8 h-8 rounded-lg text-dark hover:bg-gray-100 font-medium text-sm flex items-center justify-center border border-gray-200 transition-colors">@i</a>
                                    }
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>

    </div>
</div>

<!-- Modal Không thể tham gia -->
<div id="cancelModal" class="fixed inset-0 z-[100] hidden bg-black/50 flex items-center justify-center backdrop-blur-sm transition-opacity opacity-0">
    <div class="bg-white rounded-2xl w-full max-w-md mx-4 md:mx-auto overflow-hidden shadow-2xl transform scale-95 transition-transform duration-300">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-lg font-bold text-gray-900">Không thể tham gia</h3>
            <button type="button" onclick="closeCancelModal()" class="text-gray-400 hover:text-gray-500 hover:bg-gray-100 p-1.5 rounded-lg transition-colors">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <form id="cancelForm" class="p-6">
            <input type="hidden" id="cancelInterviewId" name="id" />
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Vui lòng nhập lý do (Bắt buộc)</label>
                <textarea id="cancelReason" name="reason" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary text-sm" placeholder="Ví dụ: Tôi có việc bận đột xuất..." required></textarea>
            </div>
            <div class="flex justify-end gap-3 mt-6">
                <button type="button" onclick="closeCancelModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                    Đóng
                </button>
                <button type="submit" id="btnSubmitCancel" class="px-4 py-2 bg-red-600 border border-transparent rounded-lg text-sm font-medium text-white hover:bg-red-700 transition-colors shadow-sm flex items-center gap-2">
                    Xác nhận
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function confirmAttendance(id) {
            const result = await Swal.fire({
                title: 'Xác nhận tham gia?',
                text: 'Nhà tuyển dụng sẽ nhận được thông báo xác nhận của bạn.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#10B981',
                cancelButtonColor: '#6B7280',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Đóng'
            });

            if (!result.isConfirmed) return;

            Swal.fire({
                title: 'Đang xử lý...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const resp = await fetch('/candidate/interviews/confirm/' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const data = await resp.json();
                if (data.success) {
                    await Swal.fire('Thành công', data.message, 'success');
                    window.location.reload();
                } else {
                    Swal.fire('Lỗi', data.message || 'Có lỗi xảy ra', 'error');
                }
            } catch (e) {
                Swal.fire('Lỗi', 'Không thể kết nối máy chủ', 'error');
            }
        }

        const cancelModal = document.getElementById('cancelModal');
        const modalContent = cancelModal.querySelector('.bg-white');

        function openCancelModal(id) {
            document.getElementById('cancelInterviewId').value = id;
            document.getElementById('cancelReason').value = '';
            cancelModal.classList.remove('hidden');
            void cancelModal.offsetWidth;
            cancelModal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
        }

        function closeCancelModal() {
            cancelModal.classList.add('opacity-0');
            modalContent.classList.add('scale-95');
            setTimeout(() => { cancelModal.classList.add('hidden'); }, 300);
        }

        cancelModal.addEventListener('click', function (e) {
            if (e.target === cancelModal) closeCancelModal();
        });

        document.getElementById('cancelForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const id = document.getElementById('cancelInterviewId').value;
            const reason = document.getElementById('cancelReason').value.trim();

            if (!reason) {
                Swal.fire('Cảnh báo', 'Vui lòng nhập lý do', 'warning');
                return;
            }

            const btn = document.getElementById('btnSubmitCancel');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

            Swal.fire({
                title: 'Đang xử lý...',
                text: 'Hệ thống đang gửi thông báo đến nhà tuyển dụng',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const formData = new FormData();
                formData.append('reason', reason);

                const resp = await fetch('/candidate/interviews/cancel/' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                const data = await resp.json();
                if (data.success) {
                    closeCancelModal();
                    await Swal.fire('Thành công', data.message, 'success');
                    window.location.reload();
                } else {
                    Swal.fire('Lỗi', data.message || 'Có lỗi xảy ra', 'error');
                    btn.disabled = false;
                    btn.innerHTML = 'Xác nhận';
                }
            } catch (e) {
                Swal.fire('Lỗi', 'Không thể kết nối máy chủ', 'error');
                btn.disabled = false;
                btn.innerHTML = 'Xác nhận';
            }
        });
    </script>
}