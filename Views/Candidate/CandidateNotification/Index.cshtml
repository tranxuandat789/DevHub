@model IEnumerable<DevHub.Models.Notification>
<meta charset="utf-8" />
@{
    ViewData["Title"] = "Thông báo";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Notifications";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 border-b border-[#D6DDEB] pb-4 gap-4">
                        <div>
                            <h2 class="text-[20px] font-bold text-dark">Thông báo của bạn</h2>
                            <p class="text-gray-500 text-sm mt-1">Cập nhật những thông tin mới nhất về việc làm và tài khoản</p>
                        </div>
                        <div class="flex items-center gap-3">
                            <button id="mark-all-read-btn-page" class="text-[#4640DE] text-sm font-medium hover:underline bg-primary/5 px-3 py-1.5 rounded-lg">Đánh dấu tất cả đã đọc</button>
                        </div>
                    </div>

                    <!-- Notification List -->
                    <div class="space-y-4">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var notification in Model)
                            {
                                string bgColor = "bg-gray-50/20";
                                string borderColor = "border-[#D6DDEB]";
                                string iconBgColor = "bg-gray-100";
                                string iconTextColor = "text-gray-500";
                                
                                if (notification.SeverityLevel == "danger")
                                {
                                    bgColor = "bg-red-50/30";
                                    borderColor = "border-red-200 hover:border-red-300";
                                    iconBgColor = "bg-red-100";
                                    iconTextColor = "text-red-600";
                                }
                                else if (notification.SeverityLevel == "warning")
                                {
                                    bgColor = "bg-yellow-50/30";
                                    borderColor = "border-yellow-200 hover:border-yellow-300";
                                    iconBgColor = "bg-yellow-100";
                                    iconTextColor = "text-yellow-600";
                                }
                                else if (notification.SeverityLevel == "success")
                                {
                                    bgColor = "bg-green-50/30";
                                    borderColor = "border-green-200 hover:border-green-300";
                                    iconBgColor = "bg-green-100";
                                    iconTextColor = "text-green-600";
                                }
                                else if (notification.SeverityLevel == "info")
                                {
                                    bgColor = "bg-blue-50/20";
                                    borderColor = "border-blue-200 hover:border-blue-300";
                                    iconBgColor = "bg-blue-100";
                                    iconTextColor = "text-blue-600";
                                }

                                <div class="block border @borderColor hover:shadow-sm transition-all rounded-xl p-5 group @bgColor">
                                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                        <div class="flex items-start gap-4">
                                            <div class="w-12 h-12 rounded-full flex items-center justify-center @iconBgColor @iconTextColor flex-shrink-0">
                                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                                                </svg>
                                            </div>
                                            <div>
                                                <a href="/candidate/notifications/details/@notification.NotificationId" class="text-[16px] font-bold @(notification.IsRead == true ? "text-gray-700" : "text-dark") group-hover:text-primary transition-colors flex items-center gap-2">
                                                    @notification.Title
                                                    @if (notification.IsRead != true)
                                                    {
                                                        <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                                                    }
                                                </a>
                                                <p class="text-sm text-gray-600 mt-1 line-clamp-2">@notification.Message</p>
                                                <span class="text-[12px] text-gray-400 mt-2 block">@(notification.CreatedAt.HasValue ? notification.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "")</span>
                                            </div>
                                        </div>
                                        <div class="flex-shrink-0 w-full md:w-auto mt-2 md:mt-0">
                                            <a href="/candidate/notifications/details/@notification.NotificationId" class="px-4 py-2 rounded-lg text-sm font-medium border border-[#D6DDEB] hover:bg-gray-50 text-gray-700 w-full md:w-auto text-center transition-colors block">Chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-10 text-gray-500">
                                <p>Bạn không có thông báo nào.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#mark-all-read-btn-page').click(function() {
                $.post('/api/Notification/mark-all-read')
                    .done(function(res) {
                        if (res.success) {
                            toastr.success('Đã đánh dấu tất cả là đã đọc.');
                            setTimeout(() => window.location.reload(), 1000);
                        }
                    })
                    .fail(function() {
                        toastr.error('Có lỗi xảy ra.');
                    });
            });
        });
    </script>
}
