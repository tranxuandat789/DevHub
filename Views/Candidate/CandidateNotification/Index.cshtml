<meta charset="utf-8" />
@{
    ViewData["Title"] = "Thông báo";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Notifications";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 border-b border-[#D6DDEB] pb-4 gap-4">
                        <div>
                            <h2 class="text-[20px] font-bold text-dark">Thông báo của bạn</h2>
                            <p class="text-gray-500 text-sm mt-1">Cập nhật những thông tin mới nhất về việc làm và tài khoản</p>
                        </div>
                        <div class="flex items-center gap-3">
                            <button class="text-[#4640DE] text-sm font-medium hover:underline bg-primary/5 px-3 py-1.5 rounded-lg">Đã đọc</button>
                        </div>
                    </div>

                    <!-- Filters -->
                    <div class="flex flex-wrap gap-4 mb-6">
                        <select class="px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none text-sm text-gray-700 bg-white min-w-[150px]">
                            <option value="">Tất cả thời gian</option>
                            <option value="today">Hôm nay</option>
                            <option value="week">Tuần này</option>
                            <option value="month">Tháng này</option>
                        </select>

                        <select class="px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none text-sm text-gray-700 bg-white min-w-[150px]">
                            <option value="">Tất cả mức độ</option>
                            <option value="high">Quan trọng (Đỏ)</option>
                            <option value="medium">Bình thường (Xanh)</option>
                            <option value="low">Thông tin (Xám)</option>
                        </select>
                    </div>

                    <!-- Notification List -->
                    <div class="space-y-4">
                        <!-- Notification Item 1: High -->
                        <div class="block border border-red-200 hover:border-red-300 hover:shadow-sm transition-all rounded-xl p-5 group bg-red-50/30">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-red-100 text-red-600 flex-shrink-0">
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <a href="/candidate/notifications/details/1" class="text-[16px] font-bold text-dark group-hover:text-primary transition-colors flex items-center gap-2">
                                            Lịch phỏng vấn sắp tới
                                            <span class="w-2 h-2 rounded-full bg-red-500"></span>
                                        </a>
                                        <p class="text-sm text-gray-600 mt-1 line-clamp-2">Công ty Tech Solutions vừa gửi cho bạn một lời mời phỏng vấn vào lúc 09:00 AM ngày mai. Vui lòng xác nhận tham gia.</p>
                                        <span class="text-[12px] text-gray-400 mt-2 block">10 phút trước</span>
                                    </div>
                                </div>
                                <div class="flex-shrink-0 w-full md:w-auto mt-2 md:mt-0">
                                    <a href="/candidate/notifications/details/1" class="px-4 py-2 rounded-lg text-sm font-medium border border-[#D6DDEB] hover:bg-gray-50 text-gray-700 w-full md:w-auto text-center transition-colors block">Chi tiết</a>
                                </div>
                            </div>
                        </div>

                        <!-- Notification Item 2: Medium -->
                        <div class="block border border-blue-200 hover:border-blue-300 hover:shadow-sm transition-all rounded-xl p-5 group bg-blue-50/20">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-blue-100 text-blue-600 flex-shrink-0">
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <a href="/candidate/notifications/details/2" class="text-[16px] font-bold text-dark group-hover:text-primary transition-colors flex items-center gap-2">
                                            Hồ sơ đã được xem
                                            <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                                        </a>
                                        <p class="text-sm text-gray-600 mt-1 line-clamp-2">Nhà tuyển dụng từ công ty ABC Corp đã xem hồ sơ của bạn cho vị trí Frontend Developer.</p>
                                        <span class="text-[12px] text-gray-400 mt-2 block">2 giờ trước</span>
                                    </div>
                                </div>
                                <div class="flex-shrink-0 w-full md:w-auto mt-2 md:mt-0">
                                    <a href="/candidate/notifications/details/2" class="px-4 py-2 rounded-lg text-sm font-medium border border-[#D6DDEB] hover:bg-gray-50 text-gray-700 w-full md:w-auto text-center transition-colors block">Chi tiết</a>
                                </div>
                            </div>
                        </div>

                        <!-- Notification Item 3: Low/Read -->
                        <div class="block border border-[#D6DDEB] hover:border-primary/50 hover:shadow-sm transition-all rounded-xl p-5 group">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-gray-100 text-gray-500 flex-shrink-0">
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <a href="/candidate/notifications/details/3" class="text-[16px] font-bold text-gray-700 group-hover:text-primary transition-colors">
                                            Việc làm mới phù hợp với bạn
                                        </a>
                                        <p class="text-sm text-gray-500 mt-1 line-clamp-2">Chúng tôi tìm thấy 5 việc làm mới phù hợp với kỹ năng và định hướng của bạn trong tuần này.</p>
                                        <span class="text-[12px] text-gray-400 mt-2 block">1 ngày trước</span>
                                    </div>
                                </div>
                                <div class="flex-shrink-0 w-full md:w-auto mt-2 md:mt-0">
                                    <a href="/candidate/notifications/details/3" class="px-4 py-2 rounded-lg text-sm font-medium border border-[#D6DDEB] hover:bg-gray-50 text-gray-700 w-full md:w-auto text-center transition-colors block">Chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <div class="mt-8 flex justify-center">
                        <nav class="flex items-center space-x-1">
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-400 hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                            </button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-primary bg-primary text-white text-sm font-medium">1</button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-600 hover:bg-gray-50 transition-colors text-sm font-medium">2</button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-600 hover:bg-gray-50 transition-colors text-sm font-medium">3</button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-400 hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                            </button>
                        </nav>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
