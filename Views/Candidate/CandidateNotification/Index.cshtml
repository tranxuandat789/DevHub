@model IEnumerable<DevHub.Models.Notification>
<meta charset="utf-8" />
@{
    ViewData["Title"] = "Thông báo";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Notifications";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages  = ViewBag.TotalPages  ?? 1;
    int totalItems  = ViewBag.TotalItems  ?? 0;
    int pageSize    = 5;
    int fromItem    = totalItems == 0 ? 0 : (currentPage - 1) * pageSize + 1;
    int toItem      = Math.Min(currentPage * pageSize, totalItems);
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 border-b border-[#D6DDEB] pb-4 gap-4">
                        <div>
                            <h2 class="text-[20px] font-bold text-dark">Thông báo của bạn</h2>
                            <p class="text-gray-500 text-sm mt-1">Cập nhật những thông tin mới nhất về việc làm và tài khoản</p>
                        </div>
                        <div class="flex items-center gap-3">
                            <button id="mark-all-read-btn-page" class="text-[#4640DE] text-sm font-medium hover:underline bg-primary/5 px-3 py-1.5 rounded-lg">Đánh dấu tất cả đã đọc</button>
                        </div>
                    </div>

                    <!-- Filter Bar -->
                    <div class="bg-gray-50 p-4 rounded-lg border border-[#D6DDEB] mb-6 flex flex-wrap gap-4 items-end">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Trạng thái</label>
                            <select id="filterStatus" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none min-w-[150px]">
                                <option value="all" selected="@(ViewBag.CurrentStatus == "all" ? "selected" : null)">Tất cả</option>
                                <option value="unread" selected="@(ViewBag.CurrentStatus == "unread" ? "selected" : null)">Chưa đọc</option>
                                <option value="read" selected="@(ViewBag.CurrentStatus == "read" ? "selected" : null)">Đã đọc</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Sắp xếp</label>
                            <select id="filterSort" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none min-w-[150px]">
                                <option value="newest" selected="@(ViewBag.CurrentSort == "newest" ? "selected" : null)">Mới nhất</option>
                                <option value="oldest" selected="@(ViewBag.CurrentSort == "oldest" ? "selected" : null)">Cũ nhất</option>
                            </select>
                        </div>

                        <button onclick="applyFilters()" class="bg-[#4640DE] text-white px-5 py-2 rounded-lg font-medium text-sm hover:bg-indigo-700 transition-colors shadow-sm">
                            Lọc
                        </button>
                    </div>

                    <!-- Notification List -->
                    <div class="space-y-4">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var notification in Model)
                            {
                                string bgColor = notification.IsRead == true ? "bg-white opacity-80" : "bg-[#f8f9fc]";
                                string titleColor = notification.IsRead == true ? "text-gray-600 font-medium" : "text-gray-900 font-bold";
                                string dotColor = notification.IsRead == true ? "bg-transparent" : "bg-[#0f62fe]";
                                
                                string ctaText = "";
                                string ctaUrl = "";

                                if (notification.ReferenceId.HasValue)
                                {
                                    switch (notification.ReferenceType)
                                    {
                                        case "Application":
                                            ctaText = "Xem danh sách";
                                            ctaUrl = "/candidate/applications";
                                            break;
                                        case "JobPost":
                                            ctaText = "Xem tin tuyển dụng";
                                            ctaUrl = $"/candidate/jobs/details/{notification.ReferenceId}";
                                            break;
                                        case "Company":
                                            ctaText = "Xem hồ sơ công ty";
                                            ctaUrl = $"/company/details/{notification.ReferenceId}";
                                            break;
                                        case "Interview":
                                            ctaText = "Xem lịch";
                                            ctaUrl = $"/candidate/interviews/details/{notification.ReferenceId}";
                                            break;
                                    }
                                }

                                <div class="block border border-gray-200 hover:border-gray-300 hover:shadow-sm transition-all rounded-xl p-5 group @bgColor">
                                    <div class="flex flex-col md:flex-row justify-between items-start gap-4">
                                        <div class="flex items-start gap-3 w-full">
                                            <!-- Read/Unread Status Indicator -->
                                            <div class="w-2.5 h-2.5 rounded-full mt-1.5 flex-shrink-0 @dotColor"></div>
                                            
                                            <div class="flex-1">
                                                <a href="/candidate/notifications/details/@notification.NotificationId" class="text-[16px] @titleColor group-hover:text-primary transition-colors block mb-1">
                                                    @notification.Title
                                                </a>
                                                <p class="text-sm text-gray-600 mb-2 leading-relaxed">@notification.Message</p>
                                                


                                                <span class="text-[12px] text-gray-400 block mt-2">
                                                    @(notification.CreatedAt.HasValue ? notification.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "")
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="flex-shrink-0 w-full md:w-auto mt-3 md:mt-0 ml-0 md:ml-4 flex flex-col gap-2">
                                            @if (!string.IsNullOrEmpty(ctaText) && !string.IsNullOrEmpty(ctaUrl))
                                            {
                                                <a href="@ctaUrl" class="inline-flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium border border-gray-200 bg-white hover:bg-gray-50 text-gray-700 w-full md:w-auto transition-colors whitespace-nowrap">
                                                    @ctaText
                                                </a>
                                            }


                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-10 text-gray-500">
                                <p>Bạn không có thông báo nào.</p>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (totalItems > 0)
                    {
                        <div class="mt-6 pt-4 border-t border-[#D6DDEB] flex flex-col sm:flex-row justify-between items-center gap-3">
                            <span class="text-sm text-gray-500">
                                Hiển thị <span class="font-medium text-dark">@fromItem</span> – <span class="font-medium text-dark">@toItem</span>
                                trong tổng số <span class="font-medium text-dark">@totalItems</span> thông báo
                            </span>
                            @if (totalPages > 1)
                            {
                                <div class="flex gap-1.5">
                                    @if (currentPage > 1)
                                    {
                                        <a href="?page=@(currentPage - 1)" class="w-9 h-9 flex items-center justify-center rounded-lg border border-[#D6DDEB] bg-white text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="w-9 h-9 flex items-center justify-center rounded-lg border border-[#D6DDEB] bg-white text-gray-300 cursor-not-allowed">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                                        </span>
                                    }

                                    @for (int p = 1; p <= totalPages; p++)
                                    {
                                        if (p == currentPage)
                                        {
                                            <span class="w-9 h-9 flex items-center justify-center rounded-lg bg-[#4640DE] text-white font-bold text-sm shadow-sm">@p</span>
                                        }
                                        else
                                        {
                                            <a href="?page=@p" class="w-9 h-9 flex items-center justify-center rounded-lg border border-[#D6DDEB] bg-white text-gray-700 hover:bg-gray-50 font-medium text-sm transition-colors shadow-sm">@p</a>
                                        }
                                    }

                                    @if (currentPage < totalPages)
                                    {
                                        <a href="?page=@(currentPage + 1)" class="w-9 h-9 flex items-center justify-center rounded-lg border border-[#D6DDEB] bg-white text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="w-9 h-9 flex items-center justify-center rounded-lg border border-[#D6DDEB] bg-white text-gray-300 cursor-not-allowed">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('mark-all-read-btn-page')?.addEventListener('click', function() {
            fetch('/Notification/MarkAllAsRead', { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' } })
                .then(() => window.location.reload())
                .catch(() => alert('Có lỗi xảy ra.'));
        });

        function applyFilters() {
            const status = document.getElementById('filterStatus').value;
            const sort = document.getElementById('filterSort').value;
            window.location.href = `?status=${status}&sort=${sort}`;
        }
    </script>
}

