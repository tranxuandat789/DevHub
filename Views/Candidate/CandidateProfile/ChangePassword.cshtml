@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "ChangePassword";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="border-b border-[#D6DDEB] pb-4 mb-6">
                        <h2 class="text-[20px] font-bold text-dark">Đổi mật khẩu</h2>
                        <p class="text-sm text-gray-500 mt-1">Cập nhật mật khẩu để bảo vệ tài khoản của bạn</p>
                    </div>

                    <form class="max-w-2xl">
                        <div class="space-y-5">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu hiện tại</label>
                                <input type="password" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none" placeholder="Nhập mật khẩu hiện tại">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu mới</label>
                                <input type="password" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none" placeholder="Nhập mật khẩu mới">
                                <p class="text-xs text-gray-500 mt-1">Mật khẩu phải có ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường và số.</p>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Xác nhận mật khẩu mới</label>
                                <input type="password" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none" placeholder="Nhập lại mật khẩu mới">
                            </div>
                        </div>

                        <div class="mt-8 flex gap-3">
                            <button type="submit" class="px-6 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors">Cập nhật mật khẩu</button>
                            <button type="button" class="px-6 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors">Hủy</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
