@model DevHub.ViewModels.Candidate.CandidateProfileViewModel
@using System.Security.Claims
@{
    //03/06/2026 DatTX
    ViewData["Title"] = "Hồ sơ của tôi";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Profile";

    var candidate = Model.CandidateInfo;
    string displayName = candidate?.FullName ?? User.FindFirstValue(ClaimTypes.Email) ?? "Ứng viên";
    string displayEmail = candidate?.CandidateNavigation?.Email ?? User.FindFirstValue(ClaimTypes.Email) ?? "";
    string phone = !string.IsNullOrEmpty(candidate?.Phone) ? candidate.Phone : "Chưa cập nhật";
    string birthdate = candidate?.Birthdate.HasValue == true ? candidate.Birthdate.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật";
    string gender = !string.IsNullOrEmpty(candidate?.Gender) ? candidate.Gender : "Chưa cập nhật";
    string address = !string.IsNullOrEmpty(candidate?.Address) ? candidate.Address : "Chưa cập nhật";
    string socialMedia = !string.IsNullOrEmpty(candidate?.SocialMediaUrl) ? candidate.SocialMediaUrl : "Chưa cập nhật";
    string avatarUrl = candidate?.ImageUrl ?? "";

    var finalAvatar = !string.IsNullOrEmpty(avatarUrl)
        ? avatarUrl
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(displayName)}&background=4640DE&color=fff&size=128";

    DevHub.DTOs.Candidate.EduDto? edu = null;
    DevHub.DTOs.Candidate.ExpDto? exp = null;
    DevHub.DTOs.Candidate.LangDto? lang = null;
    List<DevHub.DTOs.Candidate.SkillDto> skillsList = new();

    if (Model.Cv != null)
    {
        try { if (!string.IsNullOrEmpty(Model.Cv.Education)) edu = System.Text.Json.JsonSerializer.Deserialize<List<DevHub.DTOs.Candidate.EduDto>>(Model.Cv.Education)?.FirstOrDefault(); } catch {}
        try { if (!string.IsNullOrEmpty(Model.Cv.Experience)) exp = System.Text.Json.JsonSerializer.Deserialize<List<DevHub.DTOs.Candidate.ExpDto>>(Model.Cv.Experience)?.FirstOrDefault(); } catch {}
        try { if (!string.IsNullOrEmpty(Model.Cv.Languages)) lang = System.Text.Json.JsonSerializer.Deserialize<List<DevHub.DTOs.Candidate.LangDto>>(Model.Cv.Languages)?.FirstOrDefault(); } catch {}
        try { if (!string.IsNullOrEmpty(Model.Cv.Skills)) skillsList = System.Text.Json.JsonSerializer.Deserialize<List<DevHub.DTOs.Candidate.SkillDto>>(Model.Cv.Skills) ?? new(); } catch {}
    }
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Hiển thị thông báo từ Controller (nếu có) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">@TempData["ErrorMessage"]</span>
            </div>
        }

        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1 space-y-5">
                
                <!-- Basic Info Card -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] relative">
                    <div class="flex items-center gap-5">
                        <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-upload').click()">
                            <img id="avatar-preview" src="@finalAvatar" alt="Avatar" class="w-[88px] h-[88px] rounded-full object-cover group-hover:opacity-80 transition-opacity"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(displayName)&background=4640DE&color=fff&size=128'">
                            <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                        </div>
                        <input type="file" id="avatar-upload" class="hidden" accept="image/*">
                        <div>
                            <h2 class="text-[24px] font-bold text-dark leading-tight">@displayName</h2>
                            <p class="text-gray-400 text-[15px] font-medium mt-1">Ứng viên</p>
                        </div>
                        <!-- Edit Button -->
                        <button onclick="openModal('basic-info', 'Cập nhật thông tin cá nhân')" class="absolute top-6 right-6 text-[#4640DE] hover:bg-indigo-50 p-1.5 rounded-md transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Grid Info -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-6 mt-8">
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            <span class="truncate">@displayEmail</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span>@phone</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span>@birthdate</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span>@gender</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span>@address</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            <span>@socialMedia</span>
                        </div>
                    </div>
                </div>

                <!-- CV Section -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <h3 class="text-[18px] font-bold text-dark mb-5">Hồ sơ đính kèm của bạn</h3>
                    @if (Model.Cv != null && !string.IsNullOrEmpty(Model.Cv.CvUrl))
                    {
                        <div class="flex items-center justify-between bg-[#F8F9FA] p-4 rounded-lg border border-[#D6DDEB] mb-4">
                            <div class="flex items-center gap-3">
                                <svg class="w-8 h-8 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2.5L17.5 9H13V4.5zM6 20V4h5v6h6v10H6z"/></svg>
                                <div>
                                    <p class="text-sm font-semibold text-dark">Hồ sơ hiện tại (PDF/DOCX)</p>
                                    <a href="@Model.Cv.CvUrl" target="_blank" class="text-xs text-[#4640DE] hover:underline">Xem hoặc tải xuống CV</a>
                                </div>
                            </div>
                        </div>
                    }
                    <form method="post" action="/Candidate/UploadCv" enctype="multipart/form-data" class="bg-[#F8F9FA] rounded-[8px] p-8 border border-[#D6DDEB] border-dashed flex flex-col items-center justify-center text-center relative hover:bg-gray-50 transition-colors">
                        <div class="w-12 h-12 mb-4 text-gray-300">
                            <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2.5L17.5 9H13V4.5zM6 20V4h5v6h6v10H6z"/>
                            </svg>
                        </div>
                        <p class="text-[14.5px] text-dark font-medium max-w-md mb-2 leading-relaxed">
                            Tải lên CV (Tối đa 5MB)
                        </p>
                        <p class="text-[13px] text-gray-400 mb-5">Định dạng hỗ trợ: .pdf, .docx</p>
                        
                        <!-- Input File ẩn, tự động nộp Form khi chọn file xong -->
                        <input type="file" name="cvFile" accept=".pdf,.docx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="this.form.submit()">
                        
                        <button type="button" class="bg-[#4640DE] text-white px-8 py-2.5 rounded-[5px] text-[15px] font-semibold hover:bg-opacity-90 transition-all pointer-events-none">
                            @(Model.Cv != null ? "Chọn tệp thay thế" : "Tải lên ngay")
                        </button>
                    </form>
                </div>

                <!-- Sections -->
                @{
                    var sections = new[] {
                        new { Id = "education", Title = "Học vấn", Desc = "Chia sẻ trình độ học vấn của bạn", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" },
                        new { Id = "experience", Title = "Kinh nghiệm làm việc", Desc = "Thể hiện những thông tin chi tiết về quá trình làm việc", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
                        new { Id = "skills", Title = "Kỹ năng", Desc = "Liệt kê các kỹ năng chuyên môn của bạn", IconColor = "bg-gray-50 text-gray-400", IconPath = "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
                        new { Id = "languages", Title = "Ngoại ngữ", Desc = "Liệt kê các ngôn ngữ mà bạn biết", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 15h4.498" }
                    };

                    foreach (var item in sections)
                    {
                        <div onclick="openModal('@item.Id', 'Cập nhật @item.Title')" class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] flex justify-between items-center group cursor-pointer hover:border-primary/30 transition-colors">
                            <div>
                                <h3 class="text-[17px] font-bold text-dark mb-1">@item.Title</h3>
                                <p class="text-gray-400 text-[14px]">@item.Desc</p>
                            </div>
                            <div class="flex items-center gap-5">
                                <!-- Graphic icon -->
                                <div class="w-[50px] h-[50px] @item.IconColor bg-opacity-60 rounded-full flex items-center justify-center relative overflow-hidden group-hover:scale-105 transition-transform">
                                    <svg class="w-7 h-7 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@item.IconPath" />
                                    </svg>
                                    <div class="absolute inset-0 bg-white bg-opacity-20 backdrop-blur-[1px]"></div>
                                </div>
                                <!-- Plus button -->
                                <button class="text-[#4640DE] hover:text-indigo-800 transition-colors">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Right Sidebar -->
            <div class="lg:w-[300px] flex-shrink-0 mt-8 lg:mt-0">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] sticky top-6">
                    <h3 class="text-[15.5px] font-bold text-dark text-center mb-2">Độ hoàn thiện hồ sơ</h3>
                    <div class="relative w-48 h-28 mx-auto">
                        <!-- Half Circle SVG -->
                        <svg viewBox="0 0 100 50" class="w-full h-full overflow-visible">
                            <!-- Background track -->
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#E5E7EB" stroke-width="12" stroke-linecap="round"/>
                            <!-- Progress track (Dynamic) -->
                            @{
                                double maxOffset = 125.66;
                                double currentOffset = maxOffset - (maxOffset * Model.ProfileCompletion / 100);
                            }
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#4640DE" stroke-width="12" stroke-linecap="round" stroke-dasharray="125.66" stroke-dashoffset="@currentOffset" class="transition-all duration-1000 ease-out"/>
                        </svg>
                        <!-- Center Text -->
                        <div class="absolute bottom-0 left-0 right-0 flex flex-col items-center justify-center transform translate-y-3">
                            <span class="text-[24px] font-bold text-dark leading-none">@Model.ProfileCompletion%</span>
                            <span class="text-[12px] text-gray-500 mt-1 font-medium">hoàn thành</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modals -->
<div id="genericModal" class="fixed inset-0 z-[100] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
    
    <!-- Modal Content -->
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh] transition-all">
        <div class="px-6 py-4 border-b border-[#D6DDEB] flex justify-between items-center bg-gray-50/50">
            <h3 id="modalTitle" class="text-lg font-bold text-gray-900">Tiêu đề</h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors p-1 hover:bg-gray-100 rounded-full">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6 overflow-y-auto w-full">
            <p class="text-gray-500 mb-4 text-sm">Cập nhật thông tin chi tiết cho phần này.</p>
            
            <!-- Basic Info Form (Dùng Action từ Controller + HTML5 Validation) -->
            <form id="form-basic-info" method="post" action="/Candidate/UpdateBasicInfo" class="modal-form hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                        <!-- HTML5 required chặn dữ liệu trống. onblur kích hoạt popup lỗi khi click ra ngoài -->
                        <input type="text" name="FullName" value="@Model.CandidateInfo?.FullName" required maxlength="100" title="Họ và tên là bắt buộc và không quá 100 ký tự" onblur="this.reportValidity()" placeholder="VD: Nguyễn Văn A" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <!-- Pattern: Bắt đầu bằng số 0 và theo sau là 9 con số -->
                        <input type="tel" name="Phone" value="@Model.CandidateInfo?.Phone" pattern="0[0-9]{9}" title="Số điện thoại phải bắt đầu bằng số 0 và gồm đúng 10 chữ số" onblur="this.reportValidity()" placeholder="VD: 0987654321" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày sinh</label>
                        <!-- Thêm thuộc tính max = cách đây 15 năm để chặn dưới tuổi lao động ngay trên giao diện -->
                        <input type="date" name="Birthdate" value="@(Model.CandidateInfo?.Birthdate?.ToString("yyyy-MM-dd"))" max="@DateTime.Now.AddYears(-15).ToString("yyyy-MM-dd")" title="Bạn phải đủ 15 tuổi (độ tuổi lao động) để cập nhật hồ sơ!" onblur="this.reportValidity()" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Giới tính</label>
                        <select name="Gender" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                            <option value="">-- Chọn giới tính --</option>
                            <option value="Nam" selected="@(Model.CandidateInfo?.Gender == "Nam")">Nam</option>
                            <option value="Nữ" selected="@(Model.CandidateInfo?.Gender == "Nữ")">Nữ</option>
                            <option value="Khác" selected="@(Model.CandidateInfo?.Gender == "Khác")">Khác</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ hiện tại</label>
                        <input type="text" name="Address" value="@Model.CandidateInfo?.Address" maxlength="255" placeholder="Nhập địa chỉ" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Link cá nhân (Portfolio, LinkedIn...)</label>
                        <!-- type="url" tự động kiểm tra định dạng web -->
                        <input type="url" name="SocialMediaUrl" value="@Model.CandidateInfo?.SocialMediaUrl" title="Vui lòng nhập đúng định dạng link web (phải có http:// hoặc https://)" onblur="this.reportValidity()" placeholder="https://" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Mức lương tối thiểu (VNĐ)</label>
                        <input type="number" name="ExpectedSalaryMin" value="@Model.CandidateInfo?.ExpectedSalaryMin" min="0" onblur="this.reportValidity()" title="Lương tối thiểu phải là số dương" placeholder="VD: 10000000" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Mức lương tối đa (VNĐ)</label>
                        <input type="number" name="ExpectedSalaryMax" value="@Model.CandidateInfo?.ExpectedSalaryMax" min="0" onblur="this.reportValidity()" title="Lương tối đa phải là số dương" placeholder="VD: 20000000" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số năm kinh nghiệm</label>
                        <input type="number" name="ExperienceYears" value="@Model.CandidateInfo?.ExperienceYears" min="0" max="50" onblur="this.reportValidity()" title="Số năm kinh nghiệm hợp lệ từ 0 đến 50" placeholder="VD: 2" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa điểm mong muốn</label>
                        <input type="text" name="PreferredLocation" value="@Model.CandidateInfo?.PreferredLocation" maxlength="100" placeholder="VD: Hồ Chí Minh" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2 flex items-center mt-2">
                        <input type="checkbox" id="cv-searchable" name="CvSearchable" value="true" @(Model.CandidateInfo?.CvSearchable == true ? "checked" : "") class="w-4 h-4 text-[#4640DE] border-gray-300 rounded focus:ring-[#4640DE]">
                        <!-- Hidden input required for checkbox false value in ASP.NET Core -->
                        <input type="hidden" name="CvSearchable" value="false">
                        <label for="cv-searchable" class="ml-2 block text-sm text-gray-700 cursor-pointer">Cho phép Nhà tuyển dụng tìm kiếm hồ sơ của tôi (Bật để có cơ hội nhận lời mời phỏng vấn)</label>
                    </div>
                </div>
            </form>

            <!-- Education Form -->
            <form id="form-education" action="/Candidate/UpdateEducation" method="post" class="modal-form hidden space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Trường học / Cơ sở đào tạo</label>
                    <input type="text" name="School" value="@edu?.School" required placeholder="VD: Đại học FPT" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngành học</label>
                        <input type="text" name="Major" value="@edu?.Major" required pattern="^[\p{L}0-9\s]+$" title="Không được chứa ký tự đặc biệt" placeholder="VD: Kỹ thuật phần mềm" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bằng cấp</label>
                        <input type="text" name="Degree" value="@edu?.Degree" required pattern="^[\p{L}0-9\s]+$" title="Không được chứa ký tự đặc biệt" placeholder="VD: Cử nhân" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày bắt đầu</label>
                        <input type="month" name="StartDate" value="@edu?.StartDate" required max="@DateTime.Now.ToString("yyyy-MM")" onblur="this.reportValidity()" title="Ngày bắt đầu không được vượt quá tháng hiện tại" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
            </form>
            
            <!-- Experience Form -->
            <form id="form-experience" action="/Candidate/UpdateExperience" method="post" class="modal-form hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Chức danh</label>
                        <input type="text" name="Title" value="@exp?.Title" required pattern="^[\p{L}0-9\s]+$" title="Không được chứa ký tự đặc biệt" placeholder="VD: Front-end Developer" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tên công ty</label>
                        <input type="text" name="Company" value="@exp?.Company" required pattern="^[\p{L}0-9\s]+$" title="Không được chứa ký tự đặc biệt" placeholder="VD: FPT Software" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Từ tháng</label>
                        <input type="month" name="StartDate" value="@exp?.StartDate" required id="exp-start" max="@DateTime.Now.ToString("yyyy-MM")" onchange="var end = document.getElementById('exp-end'); end.min = this.value; if(end.value && end.value <= this.value) end.setCustomValidity('Đến tháng phải sau Từ tháng'); else end.setCustomValidity('');" title="Từ tháng không được vượt quá tháng hiện tại" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Đến tháng</label>
                        <input type="month" name="EndDate" value="@exp?.EndDate" required id="exp-end" max="@DateTime.Now.ToString("yyyy-MM")" onchange="var start = document.getElementById('exp-start'); if(start.value && this.value <= start.value) this.setCustomValidity('Đến tháng phải sau Từ tháng'); else this.setCustomValidity('');" title="Đến tháng không được vượt quá tháng hiện tại và phải sau Từ tháng" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả công việc</label>
                    <textarea name="Description" required rows="4" placeholder="Mô tả chi tiết những việc bạn đã làm..." class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">@exp?.Description</textarea>
                </div>
            </form>

            <!-- Skills Form -->
            <form id="form-skills" action="/Candidate/UpdateSkills" method="post" class="modal-form hidden space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tên kỹ năng</label>
                    <select name="SkillName" required onblur="this.reportValidity()" title="Vui lòng chọn một công nghệ" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        <option value="">-- Chọn công nghệ --</option>
                        <option value="C#">C#</option>
                        <option value="Java">Java</option>
                        <option value="Python">Python</option>
                        <option value="JavaScript">JavaScript</option>
                        <option value="TypeScript">TypeScript</option>
                        <option value="ReactJS">ReactJS</option>
                        <option value="Angular">Angular</option>
                        <option value="VueJS">VueJS</option>
                        <option value="NodeJS">NodeJS</option>
                        <option value="ASP.NET Core">ASP.NET Core</option>
                        <option value="SQL Server">SQL Server</option>
                        <option value="MySQL">MySQL</option>
                        <option value="MongoDB">MongoDB</option>
                        <option value="AWS">AWS</option>
                        <option value="Docker">Docker</option>
                        <option value="Figma">Figma</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mức độ thành thạo</label>
                    <select name="Proficiency" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        <option value="Sơ cấp">Sơ cấp</option>
                        <option value="Trung cấp">Trung cấp</option>
                        <option value="Cao cấp">Cao cấp</option>
                        <option value="Chuyên gia">Chuyên gia</option>
                    </select>
                </div>
                
                @if (skillsList.Any())
                {
                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Các kỹ năng đã thêm:</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var s in skillsList)
                            {
                                <span class="px-3 py-1 bg-indigo-50 text-[#4640DE] text-sm font-medium rounded-full border border-indigo-100">
                                    @s.SkillName - @s.Proficiency
                                </span>
                            }
                        </div>
                    </div>
                }
            </form>

            <!-- Languages Form -->
            <form id="form-languages" action="/Candidate/UpdateLanguages" method="post" class="modal-form hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngoại ngữ</label>
                        <input type="text" name="Language" value="@lang?.Language" required pattern="^[\p{L}0-9\s]+$" title="Không được chứa ký tự đặc biệt" placeholder="VD: Tiếng Anh" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Trình độ</label>
                        <select name="Proficiency" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                            <option value="Sơ cấp" selected="@(lang?.Proficiency == "Sơ cấp")">Sơ cấp</option>
                            <option value="Trung cấp" selected="@(lang?.Proficiency == "Trung cấp")">Trung cấp</option>
                            <option value="Cao cấp" selected="@(lang?.Proficiency == "Cao cấp")">Cao cấp</option>
                            <option value="Bản ngữ" selected="@(lang?.Proficiency == "Bản ngữ")">Bản ngữ</option>
                        </select>
                    </div>
                </div>
            </form>

        </div>
        <div class="px-6 py-4 border-t border-[#D6DDEB] flex justify-end gap-3 bg-gray-50/50">
            <button onclick="closeModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg font-medium transition-colors text-sm">Hủy</button>
            <button onclick="submitActiveForm()" class="px-6 py-2 bg-[#4640DE] text-white rounded-lg font-medium hover:bg-opacity-90 transition-colors text-sm shadow-sm">Lưu thay đổi</button>
        </div>
    </div>
</div>

<script>
    function openModal(formId, title) {
        document.getElementById('modalTitle').innerText = title;
        
        // Hide all forms
        const forms = document.querySelectorAll('.modal-form');
        forms.forEach(form => form.classList.add('hidden'));
        
        // Show target form
        const targetForm = document.getElementById('form-' + formId);
        if (targetForm) {
            targetForm.classList.remove('hidden');
        }
        
        const modal = document.getElementById('genericModal');
        modal.classList.remove('hidden');
    }
    
    function closeModal() {
        const modal = document.getElementById('genericModal');
        modal.classList.add('hidden');
    }

    // Hàm JavaScript này sẽ tìm form đang mở và gửi nó đi 
    function submitActiveForm() {
        const activeForm = document.querySelector('.modal-form:not(.hidden)');
        if (activeForm && activeForm.tagName === 'FORM') {
            
            const startDateObj = activeForm.querySelector('input[name="StartDate"]');
            const endDateObj = activeForm.querySelector('input[name="EndDate"]');
            
            if (startDateObj && endDateObj) {
                if (startDateObj.value && endDateObj.value && endDateObj.value <= startDateObj.value) {
                    endDateObj.setCustomValidity('Thời gian kết thúc phải sau thời gian bắt đầu!');
                } else {
                    endDateObj.setCustomValidity('');
                }
            }

            // reportValidity() sẽ bắt trình duyệt soi các thẻ HTML5 (required, email, pattern...)
            // Nếu sai, nó báo đỏ. Nếu đúng, nó gửi form.
            if (activeForm.reportValidity()) {
                activeForm.submit();
            }
        } else {
            closeModal();
        }
    }

    // Avatar preview logic
    document.getElementById('avatar-upload').addEventListener('change', function(e) {
        if (e.target.files && e.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function(event) {
                document.getElementById('avatar-preview').src = event.target.result;
            };
            reader.readAsDataURL(e.target.files[0]);
            
            // Send file via AJAX to the server
            const formData = new FormData();
            formData.append('avatar', e.target.files[0]);

            fetch('/Candidate/UploadAvatar', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    console.log('Upload successful:', data.message);
                    // Sync with navbar avatar instantly!
                    const navbarAvatars = document.querySelectorAll('header img[alt="Avatar"]');
                    navbarAvatars.forEach(navImg => {
                        navImg.src = data.url;
                    });
                } else {
                    console.error('Upload failed:', data.message);
                }
            })
            .catch(error => {
                console.error('Error uploading avatar:', error);
            });
        }
    });
</script>

