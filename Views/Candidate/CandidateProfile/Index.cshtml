@model DevHub.ViewModels.Candidate.CandidateProfileViewModel
@using System.Security.Claims
@{
    //03/06/2026 DatTX
    ViewData["Title"] = "Hồ sơ của tôi";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Profile";

    var candidate = Model.CandidateInfo;
    string displayName = candidate?.FullName ?? User.FindFirstValue(ClaimTypes.Email) ?? "Ứng viên";
    string displayEmail = candidate?.CandidateNavigation?.Email ?? User.FindFirstValue(ClaimTypes.Email) ?? "";
    string phone = !string.IsNullOrEmpty(candidate?.Phone) ? candidate.Phone : "Chưa cập nhật";
    string birthdate = candidate?.Birthdate.HasValue == true ? candidate.Birthdate.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật";
    string gender = !string.IsNullOrEmpty(candidate?.Gender) ? candidate.Gender : "Chưa cập nhật";
    string address = !string.IsNullOrEmpty(candidate?.Address) ? candidate.Address : "Chưa cập nhật";
    string socialMedia = !string.IsNullOrEmpty(candidate?.SocialMediaUrl) ? candidate.SocialMediaUrl : "Chưa cập nhật";
    string avatarUrl = candidate?.ImageUrl ?? "";

    var finalAvatar = !string.IsNullOrEmpty(avatarUrl)
        ? avatarUrl
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(displayName)}&background=4640DE&color=fff&size=128";

    var addedTechIds = Model.CandidateSkills.Select(s => s.TechId).ToHashSet();
    var availableTechs = Model.AllTechnologies.Where(t => !addedTechIds.Contains(t.TechId)).ToList();
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">@TempData["ErrorMessage"]</span>
            </div>
        }

        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1 space-y-5">
                
                <!-- Basic Info Card -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] relative">
                    <div class="flex items-center gap-5">
                        <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-upload').click()">
                            <img id="avatar-preview" src="@finalAvatar" alt="Avatar" class="w-[88px] h-[88px] rounded-full object-cover group-hover:opacity-80 transition-opacity"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(displayName)&background=4640DE&color=fff&size=128'">
                            <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                        </div>
                        <input type="file" id="avatar-upload" class="hidden" accept="image/*">
                        <div>
                            <h2 class="text-[24px] font-bold text-dark leading-tight">@displayName</h2>
                            <p class="text-gray-400 text-[15px] font-medium mt-1">Ứng viên</p>
                        </div>
                        <!-- Edit Button -->
                        <button onclick="openModal()" class="absolute top-6 right-6 text-[#4640DE] hover:bg-indigo-50 p-1.5 rounded-md transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Grid Info -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-6 mt-8">
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            <span class="truncate">@displayEmail</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span>@phone</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span>@birthdate</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span>@gender</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span>@address</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            <span>@socialMedia</span>
                        </div>
                    </div>
                </div>

                <!-- CV Section -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <h3 class="text-[18px] font-bold text-dark mb-5">Hồ sơ đính kèm của bạn</h3>
                    @if (Model.Cv != null && !string.IsNullOrEmpty(Model.Cv.CvUrl))
                    {
                        <div class="flex items-center justify-between bg-[#F8F9FA] p-4 rounded-lg border border-[#D6DDEB] mb-4">
                            <div class="flex items-center gap-3">
                                <svg class="w-8 h-8 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2.5L17.5 9H13V4.5zM6 20V4h5v6h6v10H6z"/></svg>
                                <div>
                                    <p class="text-sm font-semibold text-dark">Hồ sơ hiện tại (PDF/DOCX)</p>
                                    <a href="@Model.Cv.CvUrl" target="_blank" class="text-xs text-[#4640DE] hover:underline">Xem hoặc tải xuống CV</a>
                                </div>
                            </div>
                        </div>
                    }
                    <form method="post" action="/Candidate/UploadCv" enctype="multipart/form-data" class="bg-[#F8F9FA] rounded-[8px] p-8 border border-[#D6DDEB] border-dashed flex flex-col items-center justify-center text-center relative hover:bg-gray-50 transition-colors">
                        <div class="w-12 h-12 mb-4 text-gray-300">
                            <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2.5L17.5 9H13V4.5zM6 20V4h5v6h6v10H6z"/>
                            </svg>
                        </div>
                        <p class="text-[14.5px] text-dark font-medium max-w-md mb-2 leading-relaxed">Tải lên CV (Tối đa 5MB)</p>
                        <p class="text-[13px] text-gray-400 mb-5">Định dạng hỗ trợ: .pdf, .docx</p>
                        <input type="file" name="cvFile" accept=".pdf,.docx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="this.form.submit()">
                        <button type="button" class="bg-[#4640DE] text-white px-8 py-2.5 rounded-[5px] text-[15px] font-semibold hover:bg-opacity-90 transition-all pointer-events-none">
                            @(Model.Cv != null ? "Chọn tệp thay thế" : "Tải lên ngay")
                        </button>
                    </form>
                </div>

                <!-- Skills Section -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex items-center justify-between mb-5">
                        <div>
                            <h3 class="text-[17px] font-bold text-dark">Kỹ năng</h3>
                            <p class="text-gray-400 text-[14px] mt-0.5">Các công nghệ và kỹ năng chuyên môn</p>
                        </div>
                        @if (availableTechs.Any())
                        {
                            <button onclick="document.getElementById('add-skill-panel').classList.toggle('hidden')"
                                    class="text-[#4640DE] hover:text-indigo-800 transition-colors">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </button>
                        }
                    </div>

                    <!-- Add skill form (ẩn mặc định) -->
                    @if (availableTechs.Any())
                    {
                        <div id="add-skill-panel" class="hidden mb-5 p-4 bg-[#F8F9FA] rounded-lg border border-[#D6DDEB]">
                            <form method="post" action="/Candidate/AddSkill" class="flex flex-wrap gap-3 items-end">
                                <div class="flex-1 min-w-[160px]">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Công nghệ</label>
                                    <select name="techId" required class="w-full px-3 py-2 border border-[#D6DDEB] rounded-lg text-sm focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                                        <option value="">-- Chọn --</option>
                                        @foreach (var tech in availableTechs)
                                        {
                                            <option value="@tech.TechId">@tech.TechName</option>
                                        }
                                    </select>
                                </div>
                                <div class="flex-1 min-w-[140px]">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Mức độ</label>
                                    <select name="level" class="w-full px-3 py-2 border border-[#D6DDEB] rounded-lg text-sm focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                                        <option value="Intern">Intern</option>
                                        <option value="Fresher">Fresher</option>
                                        <option value="Middle">Middle</option>
                                        <option value="Senior">Senior</option>
                                        <option value="Expert">Expert</option>
                                    </select>
                                </div>
                                <button type="submit" class="px-5 py-2 bg-[#4640DE] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition-colors">
                                    Thêm
                                </button>
                            </form>
                        </div>
                    }

                    <!-- Current skills -->
                    @if (Model.CandidateSkills.Any())
                    {
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.CandidateSkills)
                            {
                                <div class="flex items-center gap-2 px-3 py-1.5 bg-indigo-50 border border-indigo-100 rounded-full">
                                    <span class="text-[#4640DE] text-sm font-medium">@skill.Tech?.TechName</span>
                                    @if (!string.IsNullOrEmpty(skill.Level))
                                    {
                                        <span class="text-gray-400 text-xs">· @skill.Level</span>
                                    }
                                    <form method="post" action="/Candidate/RemoveSkill" class="inline">
                                        <input type="hidden" name="techId" value="@skill.TechId" />
                                        <button type="submit" class="text-gray-300 hover:text-red-400 transition-colors ml-1" title="Xóa kỹ năng này">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-gray-400 text-sm text-center py-4">Chưa có kỹ năng nào. Nhấn <strong>+</strong> để thêm.</p>
                    }
                </div>

            </div>

            <!-- Right Sidebar: Profile Completion -->
            <div class="lg:w-[300px] flex-shrink-0 mt-8 lg:mt-0">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] sticky top-6">
                    <h3 class="text-[15.5px] font-bold text-dark text-center mb-2">Độ hoàn thiện hồ sơ</h3>
                    <div class="relative w-48 h-28 mx-auto">
                        @{
                            // Avatar
                            int avatarPct = !string.IsNullOrEmpty(Model.CandidateInfo?.ImageUrl) ? 10 : 0;

                            // Basic info — từng trường cộng dần
                            int infoPct = 0;
                            if (!string.IsNullOrEmpty(Model.CandidateInfo?.Phone))           infoPct += 4;
                            if (Model.CandidateInfo?.Birthdate.HasValue == true)             infoPct += 4;
                            if (!string.IsNullOrEmpty(Model.CandidateInfo?.Gender))          infoPct += 3;
                            if (!string.IsNullOrEmpty(Model.CandidateInfo?.Address))         infoPct += 3;
                            if (!string.IsNullOrEmpty(Model.CandidateInfo?.PreferredLocation)) infoPct += 3;
                            if (Model.CandidateInfo?.ExpectedSalaryMin.HasValue == true
                                || Model.CandidateInfo?.ExpectedSalaryMax.HasValue == true)  infoPct += 3;

                            // Skills
                            int skillPct = Model.CandidateSkills.Any() ? 10 : 0;

                            // CV file
                            int cvPct = (Model.Cv != null && !string.IsNullOrEmpty(Model.Cv.CvUrl)) ? 60 : 0;

                            int totalPct = avatarPct + infoPct + skillPct + cvPct;
                            if (totalPct > 100) totalPct = 100;

                            string Color(int earned, int max) =>
                                earned == 0 ? "text-gray-400" : earned == max ? "text-green-600" : "text-amber-500";
                        }
                        <svg viewBox="0 0 100 50" class="w-full h-full overflow-visible">
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#E5E7EB" stroke-width="12" stroke-linecap="round"/>
                            @{
                                double maxOffset = 125.66;
                                double currentOffset = maxOffset - (maxOffset * totalPct / 100);
                            }
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#4640DE" stroke-width="12" stroke-linecap="round" stroke-dasharray="125.66" stroke-dashoffset="@currentOffset" class="transition-all duration-1000 ease-out"/>
                        </svg>
                        <div class="absolute bottom-0 left-0 right-0 flex flex-col items-center justify-center transform translate-y-3">
                            <span class="text-[24px] font-bold text-dark leading-none">@totalPct%</span>
                            <span class="text-[12px] text-gray-500 mt-1 font-medium">hoàn thành</span>
                        </div>
                    </div>
                    <!-- Gợi ý hoàn thiện -->
                    <div class="mt-6 space-y-2 text-sm">
                        <div class="flex items-center gap-2 @Color(avatarPct, 10)">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Ảnh đại diện (@avatarPct/10%)</span>
                        </div>
                        <div class="flex items-center gap-2 @Color(infoPct, 20)">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Thông tin cơ bản (@infoPct/20%)</span>
                        </div>
                        <div class="flex items-center gap-2 @Color(skillPct, 10)">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Kỹ năng (@skillPct/10%)</span>
                        </div>
                        <div class="flex items-center gap-2 @Color(cvPct, 60)">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>File CV (@cvPct/60%)</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal: Cập nhật thông tin cơ bản -->
<div id="basicInfoModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh]">
        <div class="px-6 py-4 border-b border-[#D6DDEB] flex justify-between items-center bg-gray-50/50">
            <h3 class="text-lg font-bold text-gray-900">Cập nhật thông tin cá nhân</h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors p-1 hover:bg-gray-100 rounded-full">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6 overflow-y-auto">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 mb-4 text-sm" role="alert">
                    <p>@TempData["ErrorMessage"]</p>
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 mb-4 text-sm" role="alert">
                    <p>@TempData["SuccessMessage"]</p>
                </div>
            }
            <form id="form-basic-info" method="post" action="/Candidate/UpdateBasicInfo" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                        <input type="text" name="FullName" value="@Model.CandidateInfo?.FullName" required maxlength="100" onblur="this.reportValidity()" placeholder="VD: Nguyễn Văn A" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        @Html.ValidationMessage("FullName", "", new { @class = "text-sm text-red-500 mt-1 block" })
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <input type="tel" name="Phone" value="@Model.CandidateInfo?.Phone" pattern="0[0-9]{9}" onblur="this.reportValidity()" placeholder="VD: 0987654321" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        @Html.ValidationMessage("Phone", "", new { @class = "text-sm text-red-500 mt-1 block" })
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày sinh</label>
                        <input type="date" name="Birthdate" value="@(Model.CandidateInfo?.Birthdate?.ToString("yyyy-MM-dd"))" max="@DateTime.Now.AddYears(-15).ToString("yyyy-MM-dd")" onblur="this.reportValidity()" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Giới tính</label>
                        <select name="Gender" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                            <option value="">-- Chọn giới tính --</option>
                            <option value="Nam" selected="@(Model.CandidateInfo?.Gender == "Nam")">Nam</option>
                            <option value="Nữ" selected="@(Model.CandidateInfo?.Gender == "Nữ")">Nữ</option>
                            <option value="Khác" selected="@(Model.CandidateInfo?.Gender == "Khác")">Khác</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ hiện tại</label>
                        <input type="text" name="Address" value="@Model.CandidateInfo?.Address" maxlength="255" placeholder="Nhập địa chỉ" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Link cá nhân (Portfolio, LinkedIn...)</label>
                        <input type="url" name="SocialMediaUrl" value="@Model.CandidateInfo?.SocialMediaUrl" onblur="this.reportValidity()" placeholder="https://" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Lương tối thiểu (VNĐ)</label>
                        <input type="text" inputmode="numeric" name="ExpectedSalaryMin" value="@((long?)Model.CandidateInfo?.ExpectedSalaryMin)" placeholder="VD: 10.000.000" class="money-input w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        @Html.ValidationMessage("ExpectedSalaryMin", "", new { @class = "text-sm text-red-500 mt-1 block" })
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Lương tối đa (VNĐ)</label>
                        <input type="text" inputmode="numeric" name="ExpectedSalaryMax" value="@((long?)Model.CandidateInfo?.ExpectedSalaryMax)" placeholder="VD: 20.000.000" class="money-input w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                        @Html.ValidationMessage("ExpectedSalaryMax", "", new { @class = "text-sm text-red-500 mt-1 block" })
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số năm kinh nghiệm</label>
                        <input type="number" name="ExperienceYears" value="@Model.CandidateInfo?.ExperienceYears" min="0" max="50" placeholder="VD: 2" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa điểm mong muốn</label>
                        <input type="text" name="PreferredLocation" value="@Model.CandidateInfo?.PreferredLocation" maxlength="100" placeholder="VD: Hồ Chí Minh" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
            </form>
        </div>
        <div class="px-6 py-4 border-t border-[#D6DDEB] flex justify-end gap-3 bg-gray-50/50">
            <button onclick="closeModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg font-medium transition-colors text-sm">Hủy</button>
            <button onclick="submitForm()" class="px-6 py-2 bg-[#4640DE] text-white rounded-lg font-medium hover:bg-opacity-90 transition-colors text-sm shadow-sm">Lưu thay đổi</button>
        </div>
    </div>
</div>

<script>
    function openModal() {
        document.getElementById('basicInfoModal').classList.remove('hidden');
    }
    function closeModal() {
        document.getElementById('basicInfoModal').classList.add('hidden');
    }
    function submitForm() {
        const form = document.getElementById('form-basic-info');
        form.querySelectorAll('.money-input').forEach(el => {
            el.value = (el.value || '').replace(/\./g, '');
        });
        if (form.reportValidity()) form.submit();
    }

    // Avatar upload
    document.getElementById('avatar-upload').addEventListener('change', function(e) {
        if (e.target.files && e.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function(event) {
                document.getElementById('avatar-preview').src = event.target.result;
            };
            reader.readAsDataURL(e.target.files[0]);

            const formData = new FormData();
            formData.append('avatar', e.target.files[0]);
            fetch('/Candidate/UploadAvatar', { method: 'POST', body: formData })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        document.querySelectorAll('header img[alt="Avatar"]').forEach(img => img.src = data.url);
                        alert(data.message || 'Cập nhật ảnh đại diện thành công!');
                        window.location.reload();
                    } else {
                        alert(data.message || 'Có lỗi xảy ra khi cập nhật ảnh đại diện.');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Đã xảy ra lỗi khi tải ảnh lên.');
                });
        }
    });
</script>

<script>
@if (TempData["ErrorMessage"] != null || !ViewData.ModelState.IsValid)
{
    <text>
    document.addEventListener('DOMContentLoaded', function() {
        openModal();
    });
    </text>
}
document.addEventListener('DOMContentLoaded', function () {
    function formatThousand(value) {
        var digits = (value || '').replace(/\D/g, '');
        if (!digits) return '';
        return digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }
    document.querySelectorAll('.money-input').forEach(function (el) {
        el.addEventListener('input', function () { this.value = formatThousand(this.value); });
        el.value = formatThousand(el.value);
    });
});
</script>
