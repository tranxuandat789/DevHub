@{
    ViewData["Title"] = "Cài đặt thông báo";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "NotificationSettings";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <!-- Alert -->
                @if (TempData["Success"] != null)
                {
                    <div id="settingsAlert" class="mb-4 flex items-center gap-3 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
                        <svg class="w-5 h-5 flex-shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        <span>@TempData["Success"]</span>
                    </div>
                }

                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="border-b border-[#D6DDEB] pb-4 mb-6">
                        <h2 class="text-[20px] font-bold text-dark">Cài đặt thông báo</h2>
                        <p class="text-sm text-gray-500 mt-1">Tùy chỉnh cách bạn nhận thông báo từ hệ thống.</p>
                    </div>

                    @await Html.PartialAsync("~/Views/Shared/_NotificationSettingsSection.cshtml")
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            const alert = document.getElementById('settingsAlert');
            if (alert) {
                alert.style.transition = 'opacity 0.5s ease';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            }
        }, 4000);
    </script>
}
