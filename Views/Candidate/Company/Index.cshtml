@{
    ViewData["Title"] = "Tất cả công ty";
}

<!-- Top Header Section -->
<section class="py-12 border-b border-bordercolor relative overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.18), transparent 35%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Breadcrumb -->
        <div class="text-sm text-muted mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span>&rsaquo;</span>
            <span class="text-dark font-medium">Tất cả công ty</span>
        </div>

        <!-- Title -->
        <h1 class="text-[32px] md:text-[40px] font-bold text-dark mb-8">
            Tất cả <span class="text-[#26A4FF]">công ty</span> <span class="text-muted text-[20px] font-normal">(128+ công ty IT)</span>
        </h1>

        <!-- Search Bar -->
        <div class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(139,92,246,0.3)] hover:shadow-[0_20px_50px_-15px_rgba(139,92,246,0.4)] transition-shadow duration-300 md:rounded-full rounded-3xl flex flex-col md:flex-row items-center border border-purple-100 relative z-20">
            <div class="flex items-center flex-1 w-full px-4 py-2 border-b md:border-b-0 md:border-r border-bordercolor mb-2 md:mb-0">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="searchInput" placeholder="Tên công ty hoặc từ khóa..." class="w-full focus:outline-none text-dark placeholder-gray-400">
            </div>
            <div class="flex items-center flex-1 w-full px-4 py-2 mb-2 md:mb-0 relative">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <select class="w-full focus:outline-none text-dark appearance-none bg-transparent cursor-pointer">
                    <option>Toàn quốc</option>
                    <option>TP Hà Nội</option>
                    <option>TP Hồ Chí Minh</option>
                    <option>Đà Nẵng</option>
                </select>
            </div>
            <button class="w-full md:w-auto bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] flex-shrink-0 shadow-md">
                Tìm kiếm
            </button>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row gap-8">
    <!-- Sidebar Filters -->
    <div class="w-full md:w-1/4 flex-shrink-0">
        <div class="border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-5 bg-white h-fit">
            <div class="flex justify-between items-center mb-5">
                <h3 class="font-bold text-dark text-[16px]">Bộ lọc</h3>
                <button id="resetFilters" class="text-primary text-[13px] font-medium hover:underline">Đặt lại</button>
            </div>

            <!-- Filter: Lĩnh vực IT -->
            <div class="mb-5 border-b border-gray-100 pb-5">
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h4 class="font-bold text-dark text-[14px]">Lĩnh vực IT</h4>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-2.5 filter-content">
                    @{
                        var itFields = new[] {
                            "Phần mềm & Ứng dụng", "Web Development", "Mobile Development",
                            "AI / Machine Learning", "Data Science & Analytics", "DevOps & Cloud",
                            "Cyber Security", "Game Development", "UI/UX Design",
                            "QA & Testing", "Blockchain", "IoT & Embedded"
                        };
                    }
                    @foreach (var field in itFields)
                    {
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" class="industry-filter form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary" value="@field">
                            <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@field</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Filter: Quy mô công ty -->
            <div class="mb-5 border-b border-gray-100 pb-5">
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h4 class="font-bold text-dark text-[14px]">Quy mô công ty</h4>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-2.5 filter-content">
                    @{
                        var sizes = new[] { "1 - 50 nhân viên", "51 - 200 nhân viên", "201 - 500 nhân viên", "500 - 1000 nhân viên", "1000+ nhân viên" };
                    }
                    @foreach (var size in sizes)
                    {
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="radio" name="companySize" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary" value="@size">
                            <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@size</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Filter: Loại công ty -->
            <div>
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h4 class="font-bold text-dark text-[14px]">Loại hình công ty</h4>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-2.5 filter-content">
                    @{
                        var types = new[] { "Công ty sản phẩm", "Công ty dịch vụ / Outsource", "Startup", "Tập đoàn đa quốc gia", "Công ty nước ngoài tại VN" };
                    }
                    @foreach (var type in types)
                    {
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" class="type-filter form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary" value="@type">
                            <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@type</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Filter: Đánh giá -->
            <div class="mt-5 pt-5 border-t border-gray-100">
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h4 class="font-bold text-dark text-[14px]">Đánh giá</h4>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-2.5 filter-content">
                    @foreach (var star in new[] { 5, 4, 3 })
                    {
                        <label class="flex items-center space-x-2 cursor-pointer group">
                            <input type="radio" name="minRating" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary" value="@star">
                            <span class="flex items-center gap-0.5">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <svg class="w-4 h-4 @(s <= star ? "text-yellow-400" : "text-gray-200")" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                }
                                <span class="text-muted text-[12px] ml-1">@star★ trở lên</span>
                            </span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Company Grid -->
    <div class="flex-1">
        <!-- Sort Bar -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <p class="text-muted text-[15px]">Hiển thị <span class="font-bold text-dark" id="resultCount">12</span> trong số <span class="font-bold text-dark">128</span> công ty</p>
            <div class="flex items-center gap-3">
                <span class="text-muted text-[14px]">Sắp xếp theo:</span>
                <select id="sortSelect" class="border border-bordercolor rounded-lg px-3 py-2 text-dark text-[14px] focus:outline-none focus:border-primary bg-white">
                    <option value="relevance">Phù hợp nhất</option>
                    <option value="jobs">Nhiều việc làm nhất</option>
                    <option value="rating">Đánh giá cao nhất</option>
                    <option value="name">Tên A - Z</option>
                </select>
            </div>
        </div>

        <!-- Industry Quick Filter Pills -->
        <div class="flex flex-wrap gap-2 mb-6" id="industryPills">
            <button class="pill-btn active px-4 py-1.5 rounded-full text-[13px] font-medium border border-primary bg-primary text-white transition-all" data-value="all">Tất cả</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="Web Development">Web Dev</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="Mobile Development">Mobile</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="AI / Machine Learning">AI / ML</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="Data Science & Analytics">Data</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="DevOps & Cloud">DevOps</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="Cyber Security">Security</button>
            <button class="pill-btn px-4 py-1.5 rounded-full text-[13px] font-medium border border-bordercolor text-muted hover:border-primary hover:text-primary transition-all" data-value="UI/UX Design">UI/UX</button>
        </div>

        <!-- Company Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="companyGrid">

            @{
                var companies = new[] {
                    new { Name = "FPT Software",    Industry = "Phần mềm & Ứng dụng", Type = "Công ty sản phẩm",             Size = "1000+ nhân viên",     Jobs = 45, Rating = 4.5, Reviews = 312, Tags = new[]{"Web Development","Mobile Development"}, Initials="F" },
                    new { Name = "VNG Corporation", Industry = "Web Development",       Type = "Startup",                      Size = "1000+ nhân viên",     Jobs = 32, Rating = 4.2, Reviews = 198, Tags = new[]{"Web Development","AI / Machine Learning"}, Initials="V" },
                    new { Name = "Tiki",            Industry = "Web Development",       Type = "Startup",                      Size = "500 - 1000 nhân viên", Jobs = 28, Rating = 3.8, Reviews = 145, Tags = new[]{"Data Science & Analytics","DevOps & Cloud"}, Initials="T" },
                    new { Name = "Grab Vietnam",    Industry = "Mobile Development",   Type = "Công ty nước ngoài tại VN",   Size = "1000+ nhân viên",     Jobs = 20, Rating = 4.7, Reviews = 423, Tags = new[]{"Mobile Development","Data Science & Analytics"}, Initials="G" },
                    new { Name = "Shopee Vietnam",  Industry = "Web Development",       Type = "Công ty nước ngoài tại VN",   Size = "1000+ nhân viên",     Jobs = 37, Rating = 4.1, Reviews = 267, Tags = new[]{"Web Development","DevOps & Cloud"}, Initials="S" },
                    new { Name = "KMS Technology",  Industry = "Phần mềm & Ứng dụng", Type = "Công ty dịch vụ / Outsource", Size = "500 - 1000 nhân viên", Jobs = 18, Rating = 4.6, Reviews = 189, Tags = new[]{"QA & Testing","Web Development"}, Initials="K" },
                    new { Name = "Axon Active",     Industry = "Phần mềm & Ứng dụng", Type = "Công ty dịch vụ / Outsource", Size = "201 - 500 nhân viên",  Jobs = 12, Rating = 4.4, Reviews = 97,  Tags = new[]{"Web Development","QA & Testing"}, Initials="A" },
                    new { Name = "Nashtech",        Industry = "Phần mềm & Ứng dụng", Type = "Công ty nước ngoài tại VN",   Size = "201 - 500 nhân viên",  Jobs = 15, Rating = 3.9, Reviews = 112, Tags = new[]{"DevOps & Cloud","Web Development"}, Initials="N" },
                    new { Name = "TymeX",           Industry = "AI / Machine Learning",Type = "Startup",                      Size = "51 - 200 nhân viên",   Jobs = 10, Rating = 4.3, Reviews = 58,  Tags = new[]{"AI / Machine Learning","Cyber Security"}, Initials="TX" },
                    new { Name = "Fossil Group VN", Industry = "IoT & Embedded",       Type = "Công ty nước ngoài tại VN",   Size = "201 - 500 nhân viên",  Jobs = 8,  Rating = 3.6, Reviews = 44,  Tags = new[]{"IoT & Embedded","Mobile Development"}, Initials="FG" },
                    new { Name = "Got It Vietnam",  Industry = "AI / Machine Learning",Type = "Startup",                      Size = "51 - 200 nhân viên",   Jobs = 14, Rating = 4.8, Reviews = 76,  Tags = new[]{"AI / Machine Learning","Data Science & Analytics"}, Initials="GI" },
                    new { Name = "Designveloper",   Industry = "UI/UX Design",          Type = "Công ty dịch vụ / Outsource", Size = "1 - 50 nhân viên",     Jobs = 6,  Rating = 4.0, Reviews = 33,  Tags = new[]{"UI/UX Design","Web Development"}, Initials="D" },
                };
            }

            @foreach (var company in companies)
            {
                <div class="company-card border border-[#DEDEDE] rounded-xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col bg-white group"
                     data-industry="@company.Industry"
                     data-size="@company.Size"
                     data-type="@company.Type"
                     data-name="@company.Name"
                     data-jobs="@company.Jobs"
                     data-rating="@company.Rating.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)">
                    <!-- Card body -->
                    <a href="/Companies/Details/1" class="p-6 flex flex-col items-center justify-center flex-1 cursor-pointer">
                        <div class="w-[80px] h-[80px] mb-4 rounded-[16px] flex items-center justify-center bg-black flex-shrink-0">
                            <span class="font-bold text-white text-[18px] tracking-wider uppercase">@company.Initials</span>
                        </div>
                        <h3 class="font-bold text-dark text-[16px] text-center group-hover:text-primary transition-colors leading-tight mb-2">@company.Name</h3>
                        <!-- Stars -->
                        <div class="flex items-center gap-0.5 mb-2">
                            @{ int fullS = (int)Math.Floor(company.Rating); bool half = (company.Rating % 1) >= 0.5; }
                            @for (int s = 1; s <= 5; s++)
                            {
                                <svg class="w-3.5 h-3.5 @(s <= fullS ? "text-yellow-400" : (s == fullS + 1 && half ? "text-yellow-300" : "text-gray-200"))" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            }
                            <span class="text-[12px] font-bold text-dark ml-1">@company.Rating.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)</span>
                            <span class="text-[11px] text-muted">(@company.Reviews)</span>
                        </div>
                        <!-- Tags -->
                        <div class="flex flex-wrap gap-1 justify-center">
                            @foreach (var tag in company.Tags)
                            {
                                <span class="px-2 py-0.5 rounded-full bg-primary/5 text-primary text-[11px] font-medium border border-primary/20">@tag</span>
                            }
                        </div>
                    </a>
                    <!-- Footer -->
                    <a href="/Jobs" class="bg-[#F8F8F8] py-3 flex items-center justify-center text-muted font-medium text-[14px] hover:text-primary hover:bg-primary/5 transition-colors border-t border-[#F1F1F1]">
                        @company.Jobs việc đang tuyển
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            }
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="hidden py-16 text-center">
            <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <p class="text-[18px] font-bold text-dark mb-2">Không tìm thấy công ty nào</p>
            <p class="text-muted text-[14px]">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
        </div>

        <!-- Pagination -->
        <div class="mt-10 flex justify-center" id="paginationArea">
            <nav class="flex items-center space-x-2">
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-muted hover:bg-gray-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-primary bg-primary text-white font-medium">1</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">2</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">3</button>
                <span class="text-muted px-2">...</span>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">11</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-muted hover:bg-gray-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </nav>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // ─── Filter & Search Logic ───────────────────────────────────────
        function applyFilters() {
            const searchVal = document.getElementById('searchInput').value.toLowerCase().trim();
            const activePill = document.querySelector('.pill-btn.active')?.dataset.value || 'all';
            const checkedIndustries = [...document.querySelectorAll('.industry-filter:checked')].map(el => el.value);
            const selectedSize = document.querySelector('input[name="companySize"]:checked')?.value || '';
            const checkedTypes = [...document.querySelectorAll('.type-filter:checked')].map(el => el.value);
            const minRating = parseFloat(document.querySelector('input[name="minRating"]:checked')?.value || '0');
            const sortVal = document.getElementById('sortSelect').value;

            const grid = document.getElementById('companyGrid');
            const cards = [...document.querySelectorAll('.company-card')];
            let visible = 0;

            cards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const size = card.dataset.size;
                const type = card.dataset.type;
                const rating = parseFloat(card.dataset.rating || '0');

                let show = true;
                if (searchVal && !name.includes(searchVal)) show = false;
                if (activePill !== 'all' && !card.innerHTML.includes(activePill)) show = false;
                if (checkedIndustries.length > 0 && !checkedIndustries.some(f => card.innerHTML.includes(f))) show = false;
                if (selectedSize && size !== selectedSize) show = false;
                if (checkedTypes.length > 0 && !checkedTypes.includes(type)) show = false;
                if (minRating > 0 && rating < minRating) show = false;

                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            // Sort
            const visibleCards = cards.filter(c => c.style.display !== 'none');
            visibleCards.sort((a, b) => {
                if (sortVal === 'jobs')   return parseInt(b.dataset.jobs) - parseInt(a.dataset.jobs);
                if (sortVal === 'rating') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
                if (sortVal === 'name')   return a.dataset.name.localeCompare(b.dataset.name);
                return 0;
            });
            visibleCards.forEach(c => grid.appendChild(c));

            document.getElementById('resultCount').textContent = visible;
            document.getElementById('emptyState').classList.toggle('hidden', visible > 0);
            document.getElementById('paginationArea').style.display = visible > 0 ? '' : 'none';
        }

        // ─── Pill Buttons ────────────────────────────────────────────────
        document.querySelectorAll('.pill-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.pill-btn').forEach(b => {
                    b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary');
                    b.classList.add('border-bordercolor', 'text-muted');
                });
                btn.classList.add('active', 'bg-primary', 'text-white', 'border-primary');
                btn.classList.remove('border-bordercolor', 'text-muted');
                applyFilters();
            });
        });

        // ─── Search input ────────────────────────────────────────────────
        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('sortSelect').addEventListener('change', applyFilters);

        // ─── Sidebar checkboxes / radios ─────────────────────────────────
        document.querySelectorAll('.industry-filter, .type-filter, input[name="companySize"], input[name="minRating"]').forEach(el => {
            el.addEventListener('change', applyFilters);
        });

        // ─── Reset ───────────────────────────────────────────────────────
        document.getElementById('resetFilters').addEventListener('click', () => {
            document.querySelectorAll('.industry-filter, .type-filter').forEach(el => el.checked = false);
            document.querySelectorAll('input[name="companySize"], input[name="minRating"]').forEach(el => el.checked = false);
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.pill-btn').forEach(b => {
                b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary');
                b.classList.add('border-bordercolor', 'text-muted');
            });
            document.querySelector('.pill-btn[data-value="all"]').classList.add('active', 'bg-primary', 'text-white', 'border-primary');
            document.querySelector('.pill-btn[data-value="all"]').classList.remove('border-bordercolor', 'text-muted');
            applyFilters();
        });

        // ─── Collapsible Filter Sections ─────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            const filterContents = document.querySelectorAll('.filter-content');
            filterContents.forEach(content => {
                content.style.maxHeight = content.scrollHeight + 'px';
                content.style.overflow = 'hidden';
                content.style.transition = 'max-height 0.3s ease, opacity 0.3s ease';
            });

            document.querySelectorAll('.filter-header').forEach(header => {
                header.addEventListener('click', () => {
                    const content = header.nextElementSibling;
                    const icon = header.querySelector('.filter-icon');
                    if (content.style.maxHeight && content.style.maxHeight !== '0px') {
                        content.style.maxHeight = '0px';
                        content.style.opacity = '0';
                        icon.classList.add('rotate-180');
                    } else {
                        content.style.maxHeight = content.scrollHeight + 'px';
                        content.style.opacity = '1';
                        icon.classList.remove('rotate-180');
                    }
                });
            });
        });
    </script>
}
