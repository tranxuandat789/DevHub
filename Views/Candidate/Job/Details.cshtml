@{
    ViewData["Title"] = "Chi Tiết Việc Làm";
}

<!-- Top Header Section -->
<section class="pt-8 pb-[200px] relative overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.18), transparent 35%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Breadcrumb -->
        <div class="text-sm text-muted mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span>&rsaquo;</span>
            <a href="/Jobs" class="hover:text-primary transition-colors">Việc làm</a>
            <span>&rsaquo;</span>
            <span class="text-dark font-medium">Chi tiết công việc</span>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 relative z-20 -mt-[150px] flex flex-col lg:flex-row gap-8">
    <!-- Left Content (Job Details) -->
    <div class="w-full lg:w-2/3">
        <!-- Job Header -->
        <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-8 mb-8">
            <h1 class="text-[32px] font-bold text-dark mb-6">Kỹ Sư Hiện Trường</h1>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/5 flex items-center justify-center text-primary flex-shrink-0">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Mức lương</p>
                        <p class="text-primary font-semibold text-[15px]">17 - 22 triệu</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/5 flex items-center justify-center text-primary flex-shrink-0">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Khu vực tuyển</p>
                        <p class="text-dark font-medium text-[15px]">Hà Nội, Bắc Ninh, Bắc Kạn, +1</p>
                    </div>
                </div>
            </div>
            
            <div class="text-muted text-[14px] mb-6 border-t border-bordercolor pt-4">
                Hạn nộp hồ sơ: <span class="font-medium text-dark">31/07/2025</span>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
                <button onclick="openApplyModal()" class="bg-primary text-white font-bold py-3 px-8 rounded-md hover:bg-opacity-90 transition-all flex-1 text-center shadow-md">
                    Ứng tuyển ngay
                </button>
                <button class="border-2 border-primary text-primary font-bold py-3 px-8 rounded-md hover:bg-primary/5 transition-colors flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                    Lưu công việc này
                </button>
            </div>
        </div>

        <!-- Description Sections -->
        <div class="space-y-8 text-dark">
            <div>
                <h3 class="text-[20px] font-bold mb-4">Mô tả công việc</h3>
                <div class="text-muted leading-relaxed space-y-2">
                    <p class="font-medium text-dark">1. Giám sát công trường:</p>
                    <ul class="list-disc pl-5 space-y-1">
                        <li>Giám sát công việc thi công trực tiếp tại công trường, Kiểm tra, theo dõi và đánh giá công việc của công nhân tại hiện trường, ghi lại tiến trình xây dựng và nhật ký xây dựng.</li>
                        <li>Đảm bảo An toàn lao động trên công trường.</li>
                    </ul>
                    <p class="font-medium text-dark mt-4">2. Theo dõi và quản lý hồ sơ thi công:</p>
                    <ul class="list-disc pl-5 space-y-1">
                        <li>Kiểm tra công tác thi công của các tổ đội, lập biên bản nghiệm thu công việc tại hiện trường.</li>
                        <li>Quản lý hồ sơ và tổ chức thi công hiện trường.</li>
                        <li>Tham gia lập, kiểm duyệt các kế hoạch thi công.</li>
                    </ul>
                </div>
            </div>

            <div>
                <h3 class="text-[20px] font-bold mb-4">Yêu cầu công việc</h3>
                <ul class="list-disc pl-5 text-muted leading-relaxed space-y-2">
                    <li>Trình độ: Đại học, Cao đẳng. Chuyên ngành: Xây dựng dân dụng và công nghiệp, hạ tầng, Giao thông, cầu đường và các chuyên ngành liên quan khác.</li>
                    <li>Kinh nghiệm: Có ít nhất 01 năm kinh nghiệm hiện trường dự án.</li>
                    <li>Kỹ năng: Đọc bản vẽ thi công, giám sát tổ đội, sử dụng được các loại máy toàn đạc, RTK,...</li>
                </ul>
            </div>

            <div>
                <h3 class="text-[20px] font-bold mb-4">Quyền lợi</h3>
                <ul class="list-disc pl-5 text-muted leading-relaxed space-y-2">
                    <li>Tháng lương 13, thưởng sản xuất kinh doanh.</li>
                    <li>Hưởng đầy đủ BHXH, BHYT, BHTN theo quy định.</li>
                    <li>Review tăng lương 02 lần/năm.</li>
                    <li>Hưởng 12 ngày/năm, sau 5 năm thêm 1 ngày phép, không dùng hết phép được quy thành tiền lương.</li>
                    <li>Công ty hỗ trợ ăn, ở tại dự án.</li>
                    <li>Thưởng các ngày lễ, tết và đầy đủ các chính sách phúc lợi khác.</li>
                </ul>
            </div>

            <!-- General Info Grid -->
            <div>
                <h3 class="text-[20px] font-bold mb-4">Thông tin chung</h3>
                <div class="grid grid-cols-2 gap-y-6 gap-x-4 border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-6 bg-gray-50/50">
                    <div>
                        <p class="text-muted text-[13px] mb-1">Ngày đăng</p>
                        <p class="text-dark font-medium">18/05/2026</p>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Cấp bậc</p>
                        <p class="text-dark font-medium">Nhân viên</p>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Số lượng tuyển</p>
                        <p class="text-dark font-medium">7</p>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Hình thức làm việc</p>
                        <p class="text-dark font-medium">Toàn thời gian cố định</p>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Yêu cầu bằng cấp</p>
                        <p class="text-dark font-medium">Cao đẳng</p>
                    </div>
                    <div>
                        <p class="text-muted text-[13px] mb-1">Yêu cầu kinh nghiệm</p>
                        <p class="text-dark font-medium">1 năm</p>
                    </div>
                </div>
            </div>

            <!-- Work Locations -->
            <div class="bg-gray-50/50 border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-6">
                <h3 class="text-[20px] font-bold mb-4">Địa điểm làm việc</h3>
                <ul class="space-y-3">
                    <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <div><span class="font-medium text-primary">Hà Nội:</span> <span class="text-muted">Hà Phong, Mê Linh</span></div>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <div><span class="font-medium text-primary">Hà Nội:</span> <span class="text-muted">275 Nguyễn Trãi, Thanh Xuân</span></div>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <div><span class="font-medium text-primary">Bắc Ninh:</span> <span class="text-muted">Mão Điền, Thuận Thành</span></div>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <div><span class="font-medium text-primary">Bắc Kạn:</span> <span class="text-muted">KCN Quảng Chu, Chợ Mới</span></div>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <div><span class="font-medium text-primary">Hải Phòng:</span> <span class="text-muted">An Phong, An Dương</span></div>
                    </li>
                </ul>
                <div class="mt-4 text-right">
                    <a href="#" class="text-primary hover:underline text-[14px] flex items-center justify-end gap-1">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
                        </svg>
                        Báo xấu
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="w-full lg:w-1/3">
        <!-- Company Info -->
        <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-6 mb-8">
            <div class="flex items-center gap-4 mb-6">
                <!-- FPT Logo representation -->
                <div class="w-16 h-16 bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-2 rounded-[20px] flex items-center justify-center flex-shrink-0">
                    <span class="text-orange-500 font-bold text-2xl italic tracking-tighter">FPT</span>
                </div>
                <div>
                    <h3 class="text-[18px] font-bold text-dark leading-tight">Công Ty Cổ Phần Ssd Việt Nam</h3>
                </div>
            </div>
            
            <div class="space-y-4 mb-6">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <p class="text-muted text-[14px]">Địa chỉ: Số 32 - TTTM LePARC by GAMUDA - Công viên Yên Sở, Phường Yên Sở, TP Hà Nội</p>
                </div>
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <p class="text-muted text-[14px]">Quy mô: 10 - 150 nhân viên</p>
                </div>
            </div>
            
            <div class="flex items-center gap-2 mb-6">
                <div class="flex text-yellow-400 gap-0.5">
                    @for (int s = 0; s < 5; s++) {
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    }
                </div>
                <span class="text-[13px] font-semibold text-dark">4.8</span>
                <span class="text-[13px] text-muted">(124 đánh giá)</span>
            </div>
            
            <a href="/Companies/Details/1" class="text-primary font-medium hover:underline flex items-center justify-center gap-2">
                Xem trang công ty &rarr;
            </a>
        </div>

        <!-- Similar Jobs -->
        <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-6">
            <h3 class="text-[18px] font-bold text-dark mb-6">Việc làm tương tự cho bạn</h3>
            
            <div class="space-y-4">
                @for (int i = 0; i < 4; i++)
                {
                    <a href="/Jobs/Details/2" class="block border border-transparent hover:border-primary shadow-[0_4px_6px_rgba(0,0,0,0.06)] rounded-[20px] p-4 transition-colors group relative overflow-hidden">
                        <button class="absolute top-4 right-4 text-gray-300 hover:text-red-500 transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                            </svg>
                        </button>
                        
                        <h4 class="font-bold text-dark text-[15px] mb-2 pr-6 group-hover:text-primary transition-colors">Kỹ Sư Hiện Trường</h4>
                        
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-10 h-10 border border-bordercolor p-1 rounded bg-white flex-shrink-0 flex items-center justify-center">
                                <span class="text-orange-500 font-bold text-xs italic tracking-tighter">FPT</span>
                            </div>
                            <div>
                                <p class="text-muted text-[13px] mb-1">Công Ty Cổ Phần Ssd Việt Nam</p>
                                <div class="flex items-center text-primary font-medium text-[13px] gap-1 mb-1">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    17 - 22 triệu
                                </div>
                                <div class="flex items-center text-muted text-[13px] gap-1">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    Hà Nội, Bắc Ninh, +1
                                </div>
                            </div>
                        </div>
                        
                        <div class="flex justify-end items-center gap-1 text-muted text-[12px] bg-gray-50 -mx-4 -mb-4 px-4 py-2 rounded-b-lg border-t border-bordercolor">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
