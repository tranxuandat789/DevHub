@{
    ViewData["Title"] = "Tìm Việc Làm";
}

<!-- Top Header Section -->
<section class="py-12 border-b border-bordercolor relative overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.18), transparent 35%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Breadcrumb -->
        <div class="text-sm text-muted mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span>&rsaquo;</span>
            <a href="/Jobs" class="hover:text-primary transition-colors">Việc làm</a>
            <span>&rsaquo;</span>
            <span class="text-dark font-medium">Tất cả công việc</span>
        </div>

        <!-- Title -->
        <h1 id="jobs-title" class="text-[32px] md:text-[40px] font-bold text-dark mb-8">
            Tất cả các <span class="text-[#26A4FF]">việc làm</span> <span class="text-muted text-[20px] font-normal">(Tất cả 200+ công việc)</span>
        </h1>

        <!-- Search Bar -->
        <div class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(139,92,246,0.3)] hover:shadow-[0_20px_50px_-15px_rgba(139,92,246,0.4)] transition-shadow duration-300 md:rounded-full rounded-3xl flex flex-col md:flex-row items-center border border-purple-100 relative z-20">
            <div class="flex items-center flex-1 w-full px-4 py-2 border-b md:border-b-0 md:border-r border-bordercolor mb-2 md:mb-0">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input id="jobs-keyword" type="text" placeholder="Job title or keyword" class="w-full focus:outline-none text-dark placeholder-gray-400">
            </div>
            <div class="flex items-center flex-1 w-full px-4 py-2 mb-2 md:mb-0 relative">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <select class="w-full focus:outline-none text-dark appearance-none bg-transparent cursor-pointer">
                    <option>TP Hà Nội</option>
                    <option>Hồ Chí Minh, Việt Nam</option>
                </select>
            </div>
            <button id="jobs-search-btn" class="w-full md:w-auto bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] flex-shrink-0 shadow-md">
                Tìm kiếm việc làm
            </button>
        </div>

        <!-- Popular Tags -->
        <div class="mt-4 text-[14px] text-muted flex items-center flex-wrap">
            <span class="mr-2">Phổ biến :</span>
            <a href="#" class="hover:text-primary transition-colors mr-2">UI Designer,</a>
            <a href="#" class="hover:text-primary transition-colors mr-2">UX Researcher,</a>
            <a href="#" class="hover:text-primary transition-colors mr-2">Android,</a>
            <a href="#" class="hover:text-primary transition-colors">Admin</a>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row gap-8">
    <!-- Sidebar Filters -->
    <div class="w-full md:w-1/4 border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] p-5 bg-white h-fit">
        <!-- Filter Category -->
        <div class="mb-5 border-b border-gray-50 pb-5 last:border-0 last:pb-0">
            <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                <h3 class="font-bold text-dark text-[15px]">Vị trí làm việc</h3>
                <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
            </div>
            <div class="space-y-2.5 filter-content overflow-hidden transition-all duration-300">
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Cơ bản</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Cơ hội thăng tiến cao</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Văn hóa và giá trị</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Lãnh đạo cấp cao</span>
                </label>
            </div>
        </div>

        <!-- Filter Category -->
        <div class="mb-5 border-b border-gray-50 pb-5 last:border-0 last:pb-0">
            <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                <h3 class="font-bold text-dark text-[15px]">Loại công việc</h3>
                <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
            </div>
            <div class="space-y-2.5 filter-content overflow-hidden transition-all duration-300">
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="jobType" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Full time</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="jobType" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Part time</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="jobType" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">Other</span>
                </label>
            </div>
        </div>

        <!-- Filter Category -->
        <div class="mb-5 border-b border-gray-50 pb-5 last:border-0 last:pb-0">
            <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                <h3 class="font-bold text-dark text-[15px]">Mức lương</h3>
                <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
            </div>
            <div class="space-y-2.5 filter-content overflow-hidden transition-all duration-300">
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">1 - 50$</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">51 - 200$</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">201 - 500$</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">501 - 1000$</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer group">
                    <input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                    <span class="text-muted text-[14px] group-hover:text-dark transition-colors">1000$+</span>
                </label>
            </div>
        </div>
    </div>

    <!-- Job List -->
    <div class="w-full md:w-3/4">
        <div class="space-y-4">
            @for (int i = 0; i < 4; i++)
            {
                <div class="block bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:border-primary hover:shadow-md transition-all rounded-[20px] p-6 group relative">
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-4">
                            <!-- Logo Placeholder for BMW -->
                            <div class="w-12 h-12 rounded-full flex items-center justify-center overflow-hidden border border-gray-200">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/BMW.svg" alt="BMW" class="w-full h-full object-cover p-1">
                            </div>
                            <div>
                                <a href="/Jobs/Details/1" class="text-[18px] font-bold text-dark group-hover:text-primary transition-colors before:absolute before:inset-0">BMW</a>
                                <div class="flex items-center text-muted text-[14px] mt-1">
                                    <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    Revolut • Madrid, Spain
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center text-dark text-[14px] font-medium bg-gray-50 px-2 py-1 rounded">
                            <svg class="w-4 h-4 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            4.5
                        </div>
                    </div>
                    
                    <p class="text-muted text-[15px] mb-4">
                        BMW là một thương hiệu xe Đức nổi tiếng với các bộ sưu tập hiện đại, thanh lịch dành cho nam giới.
                    </p>
                    
                    <div class="flex items-center gap-2 mb-4">
                        <span class="text-[#26A4FF] font-medium text-[15px] flex items-center">
                            <svg class="w-5 h-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            12-15 triệu
                        </span>
                    </div>

                    <div class="flex items-center justify-between mt-4">
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1 rounded-full border border-green-500 text-green-500 text-[13px] font-medium bg-green-50">Full-Time</span>
                            <span class="px-3 py-1 rounded-full border border-orange-500 text-orange-500 text-[13px] font-medium bg-orange-50">Marketing</span>
                            <span class="px-3 py-1 rounded-full border border-primary text-primary text-[13px] font-medium bg-primary/5">Design</span>
                        </div>
                        <div class="flex gap-3 relative z-10">
                            <button class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Lưu việc làm">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                </svg>
                            </button>
                            <button onclick="openApplyModal('BMW', 'Revolut', 'Thiết kế và phát triển các tính năng giao diện người dùng cho nền tảng fintech hàng đầu châu Âu, đảm bảo trải nghiệm mượt mà cho hàng triệu người dùng.')" class="bg-primary text-white px-6 py-2 rounded-full font-medium hover:bg-opacity-90 transition-colors">
                                Ứng tuyển
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="mt-8 flex justify-center">
            <nav class="flex items-center space-x-2">
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-muted hover:bg-gray-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-primary bg-primary text-white font-medium">1</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">2</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">3</button>
                <span class="text-muted px-2">...</span>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">9</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">10</button>
                <button class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-muted hover:bg-gray-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </nav>
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Candidate/_ApplyModal.cshtml")

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set initial max-height for open filters so transition works
            const filterContents = document.querySelectorAll('.filter-content');
            filterContents.forEach(content => {
                content.style.maxHeight = content.scrollHeight + "px";
                content.style.opacity = '1';
            });

            // Handle click events
            const headers = document.querySelectorAll('.filter-header');
            headers.forEach(header => {
                header.addEventListener('click', () => {
                    const content = header.nextElementSibling;
                    const icon = header.querySelector('.filter-icon');
                    
                    if (content.style.maxHeight && content.style.maxHeight !== '0px') {
                        // Collapse
                        content.style.maxHeight = '0px';
                        content.style.opacity = '0';
                        icon.classList.add('rotate-180');
                        content.classList.add('mt-0');
                    } else {
                        // Expand
                        content.style.maxHeight = content.scrollHeight + "px";
                        content.style.opacity = '1';
                        icon.classList.remove('rotate-180');
                        content.classList.remove('mt-0');
                    }
                });
            });
        });

        // Search title update
        function updateJobsTitle() {
            const keyword = document.getElementById('jobs-keyword').value.trim();
            const title = document.getElementById('jobs-title');
            if (keyword) {
                title.innerHTML = `K\u1ebft qu\u1ea3 <span class="text-[#26A4FF]">102 vi\u1ec7c l\u00e0m ${keyword}</span>`;
            } else {
                title.innerHTML = `T\u1ea5t c\u1ea3 c\u00e1c <span class="text-[#26A4FF]">vi\u1ec7c l\u00e0m</span> <span class="text-muted text-[20px] font-normal">(T\u1ea5t c\u1ea3 200+ c\u00f4ng vi\u1ec7c)</span>`;
            }
        }

        document.getElementById('jobs-search-btn').addEventListener('click', updateJobsTitle);
        document.getElementById('jobs-keyword').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') updateJobsTitle();
        });
    </script>
}
