@model DevHub.ViewModels.Jobs.JobSearchPageViewModel
@{
    ViewData["Title"] = "Tìm Việc Làm";
}

<!-- Top Header Section -->
<section class="py-12 border-b border-bordercolor relative overflow-hidden" style="background-color: #F7F5FC;">
    <!-- SVG Background Pattern -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-70 pointer-events-none" aria-hidden="true">
        <svg viewBox="0 0 500 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <path d="M450 -50 Q300 100 200 200 Q100 300 -50 250" stroke="#C4C4E6" stroke-width="1.5"/>
            <path d="M500 50 Q350 150 250 250 Q150 350 0 300" stroke="#C4C4E6" stroke-width="1.5"/>
            <path d="M480 0 Q320 120 220 220" stroke="#C4C4E6" stroke-width="1"/>
        </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Breadcrumb -->
        <div class="text-sm text-muted mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span>&rsaquo;</span>
            <span class="text-dark font-medium">Việc làm</span>
        </div>

        <!-- Title -->
        <h1 class="text-[32px] md:text-[40px] font-bold text-dark mb-8">
            @if (Model.Filter.TechId.HasValue)
            {
                var activeTech = Model.TopTechs.FirstOrDefault(t => t.TechId == Model.Filter.TechId.Value);
                <span>Việc làm <span class="text-primary">@(activeTech.TechName ?? "Kỹ năng")</span></span>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation))
            {
                <span>Việc làm tại <span class="text-primary">@Model.Filter.FilterLocation</span></span>
            }
            else if (Model.Filter.RecruiterId.HasValue)
            {
                var activeCompany = Model.TopCompanies.FirstOrDefault(c => c.RecruiterId == Model.Filter.RecruiterId.Value);
                <span>Việc làm tại <span class="text-primary">@(activeCompany.CompanyName ?? "Công ty")</span></span>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Filter.Keyword))
            {
                <span>Kết quả cho "<span class="text-primary">@Model.Filter.Keyword</span>"</span>
            }
            else
            {
                <span>Tất cả các <span class="text-primary">việc làm</span></span>
            }
            <span class="text-muted text-[18px] font-normal ml-2">(@Model.TotalCount việc làm)</span>
        </h1>

        <!-- Search Bar -->
        <form method="get" action="/Jobs" id="jobs-search-form">
            <!-- Giữ các filter hiện tại khi search -->
            <input type="hidden" name="workingModel" value="@Model.Filter.WorkingModel" />
            <input type="hidden" name="experienceLevel" value="@Model.Filter.ExperienceLevel" />
            <input type="hidden" name="desiredSalary" value="@Model.Filter.DesiredSalary" />
            @if (Model.Filter.TechId.HasValue) { <input type="hidden" name="techId" value="@Model.Filter.TechId" /> }
            @if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation)) { <input type="hidden" name="filterLocation" value="@Model.Filter.FilterLocation" /> }
            @if (Model.Filter.RecruiterId.HasValue) { <input type="hidden" name="recruiterId" value="@Model.Filter.RecruiterId" /> }
            <input type="hidden" name="page" value="1" />

            <div class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(70,64,222,0.15)] md:rounded-full rounded-3xl flex flex-col md:flex-row items-center border border-purple-100">
                <div class="flex items-center flex-1 w-full px-4 py-2 border-b md:border-b-0 md:border-r border-bordercolor mb-2 md:mb-0">
                    <svg class="w-5 h-5 text-gray-400 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input id="jobs-keyword"
                           name="keyword"
                           type="text"
                           value="@Model.Filter.Keyword"
                           placeholder="Tên công việc hoặc kỹ năng"
                           class="w-full focus:outline-none text-dark placeholder-gray-400 truncate" />
                </div>
                <button id="jobs-search-btn"
                        type="submit"
                        class="w-full md:w-auto bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] flex-shrink-0 shadow-md">
                    Tìm kiếm việc làm
                </button>
            </div>
        </form>
    </div>
</section>

<!-- Quick-Filter Tab Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-0">
    <div class="flex flex-wrap gap-3">
        @{
            bool techActive    = Model.Filter.TechId.HasValue;
            bool cityActive    = !string.IsNullOrWhiteSpace(Model.Filter.FilterLocation);
            bool companyActive = Model.Filter.RecruiterId.HasValue;
        }

        <!-- Nút: Việc làm theo Kỹ năng -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('tech-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(techActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Việc làm theo Kỹ năng
                @if (techActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel kỹ năng -->
            <div id="tech-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-[520px] max-h-72 overflow-y-auto">
                @if (techActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc kỹ năng
                    </a>
                }
                <div class="flex flex-wrap gap-2">
                    @foreach (var tech in Model.TopTechs)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = tech.TechId, page = 1 })"
                           class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-[13px] font-medium transition-all
                                  @(Model.Filter.TechId == tech.TechId ? "bg-primary text-white border-primary" : "border-gray-200 text-dark hover:border-primary hover:text-primary")">
                            @tech.TechName
                            <span class="text-[11px] @(Model.Filter.TechId == tech.TechId ? "opacity-80" : "text-muted")">@tech.JobCount</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Nút: Việc làm theo Thành phố -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('city-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(cityActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Việc làm theo Thành phố
                @if (cityActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel thành phố -->
            <div id="city-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-72 max-h-72 overflow-y-auto">
                @if (cityActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc thành phố
                    </a>
                }
                <div class="space-y-1">
                    @foreach (var loc in Model.TopLocations)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = loc.Location, page = 1 })"
                           class="flex justify-between items-center px-3 py-2 rounded-lg text-[14px] transition-colors
                                  @(Model.Filter.FilterLocation == loc.Location ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-50 hover:text-primary")">
                            <span>@loc.Location</span>
                            <span class="text-[12px] text-muted ml-2">@loc.JobCount việc</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Nút: Việc làm theo Công ty -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('company-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(companyActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                Việc làm theo Công ty
                @if (companyActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel công ty -->
            <div id="company-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-80 max-h-72 overflow-y-auto">
                @if (companyActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc công ty
                    </a>
                }
                <div class="space-y-1">
                    @foreach (var company in Model.TopCompanies)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = company.RecruiterId, page = 1 })"
                           class="flex justify-between items-center px-3 py-2 rounded-lg text-[14px] transition-colors
                                  @(Model.Filter.RecruiterId == company.RecruiterId ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-50 hover:text-primary")">
                            <div class="flex items-center gap-2 min-w-0">
                                @if (!string.IsNullOrEmpty(company.LogoUrl))
                                {
                                    <img src="@company.LogoUrl" class="w-6 h-6 rounded object-contain flex-shrink-0" />
                                }
                                else
                                {
                                    <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary font-bold text-[11px] flex-shrink-0">@company.CompanyName[0]</span>
                                }
                                <span class="truncate">@company.CompanyName</span>
                            </div>
                            <span class="text-[12px] text-muted ml-2 flex-shrink-0">@company.JobCount việc</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row gap-8">

    <!-- Sidebar Filters -->
    <aside class="w-full md:w-1/4 border border-bordercolor shadow-[0_8px_30px_rgb(0,0,0,0.08)] rounded-2xl p-6 bg-white h-fit">
        <form method="get" action="/Jobs" id="filter-form">
            <!-- Giữ keyword + quick-filter params khi dùng sidebar -->
            <input type="hidden" name="keyword" value="@Model.Filter.Keyword" />
            @if (Model.Filter.TechId.HasValue) { <input type="hidden" name="techId" value="@Model.Filter.TechId" /> }
            @if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation)) { <input type="hidden" name="filterLocation" value="@Model.Filter.FilterLocation" /> }
            @if (Model.Filter.RecruiterId.HasValue) { <input type="hidden" name="recruiterId" value="@Model.Filter.RecruiterId" /> }
            <input type="hidden" name="page" value="1" />

            <!-- Filter: Hình thức làm việc (load từ DB) -->
            @if (Model.WorkingModelOptions.Any())
            {
                <div class="mb-5 border-b border-gray-100 pb-5">
                    <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                        <h3 class="font-bold text-dark text-[15px]">Hình thức làm việc</h3>
                        <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                        </svg>
                    </div>
                    <div class="space-y-2.5 filter-content">
                        @foreach (var wm in Model.WorkingModelOptions)
                        {
                            <label class="flex items-center space-x-3 cursor-pointer group">
                                <input type="radio"
                                       name="workingModel"
                                       value="@wm"
                                       class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary"
                                       @(Model.Filter.WorkingModel == wm ? "checked" : "")
                                       onchange="document.getElementById('filter-form').submit()" />
                                <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@wm</span>
                            </label>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Filter.WorkingModel))
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary })"
                               class="text-primary text-[13px] hover:underline block">Xóa lọc</a>
                        }
                    </div>
                </div>
            }

            <!-- Filter: Cấp độ kinh nghiệm (load từ DB) -->
            @if (Model.ExperienceLevelOptions.Any())
            {
                <div class="mb-5 border-b border-gray-100 pb-5">
                    <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                        <h3 class="font-bold text-dark text-[15px]">Cấp độ kinh nghiệm</h3>
                        <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                        </svg>
                    </div>
                    <div class="space-y-2.5 filter-content">
                        @foreach (var level in Model.ExperienceLevelOptions)
                        {
                            <label class="flex items-center space-x-3 cursor-pointer group">
                                <input type="radio"
                                       name="experienceLevel"
                                       value="@level"
                                       class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary"
                                       @(Model.Filter.ExperienceLevel == level ? "checked" : "")
                                       onchange="document.getElementById('filter-form').submit()" />
                                <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@level</span>
                            </label>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Filter.ExperienceLevel))
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, desiredSalary = Model.Filter.DesiredSalary })"
                               class="text-primary text-[13px] hover:underline block">Xóa lọc</a>
                        }
                    </div>
                </div>
            }

            <!-- Filter: Mức lương mong muốn -->
            <div class="mb-5">
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h3 class="font-bold text-dark text-[15px]">Mức lương mong muốn</h3>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-2.5 filter-content">
                    <div class="flex items-center gap-2">
                        <input type="number" 
                               name="desiredSalary" 
                               value="@Model.Filter.DesiredSalary" 
                               placeholder="VD: 15"
                               min="1"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[14px] text-dark focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
                        <span class="text-muted text-[13px] whitespace-nowrap">Triệu</span>
                    </div>
                    <button type="submit" class="w-full mt-2 bg-primary/10 text-primary font-bold py-2 rounded-lg hover:bg-primary/20 transition-all text-[13px]">
                        Áp dụng mức lương
                    </button>
                    @if (Model.Filter.DesiredSalary.HasValue)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel })"
                           class="text-primary text-[13px] hover:underline block mt-2">Xóa bộ lọc lương</a>
                    }
                </div>
            </div>
        </form>
    </aside>

    <!-- Job List -->
    <div class="w-full md:w-3/4">
        @if (!Model.Jobs.Any())
        {
            <!-- Empty state -->
            <div class="bg-white rounded-[20px] border border-bordercolor p-12 text-center">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-muted text-[16px]">Không tìm thấy việc làm phù hợp.</p>
                <a href="/Jobs" class="mt-4 inline-block text-primary hover:underline text-[14px]">Xóa tất cả bộ lọc</a>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var job in Model.Jobs)
                {
                    <div class="relative bg-white border border-bordercolor shadow-[0_8px_30px_rgb(0,0,0,0.06)] hover:border-primary hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 rounded-[20px] p-6 group">
                        <!-- Main clickable area spanning the whole card -->
                        <a href="/Jobs/Details/@job.JobId" class="absolute inset-0 z-0 rounded-[20px]" aria-label="@job.Title"></a>

                        <!-- Header: logo + company + deadline -->
                        <div class="flex justify-between items-start mb-3 relative z-10 pointer-events-none">
                            <div class="flex items-center gap-4">
                                <!-- Company Logo -->
                                <div class="w-12 h-12 rounded-full flex items-center justify-center overflow-hidden border border-bordercolor bg-gray-50 flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(job.CompanyLogoUrl))
                                    {
                                        <img src="@job.CompanyLogoUrl" alt="@job.CompanyName" class="w-full h-full object-contain p-1" />
                                    }
                                    else
                                    {
                                        <span class="text-primary font-bold text-[18px]">@(job.CompanyName.Length > 0 ? job.CompanyName[0].ToString().ToUpper() : "?")</span>
                                    }
                                </div>

                                <div>
                                    <h3 class="text-[16px] font-bold text-dark group-hover:text-primary transition-colors">@job.Title</h3>
                                    <div class="flex items-center text-muted text-[13px] mt-1">
                                        <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                        @job.CompanyName
                                        @if (!string.IsNullOrEmpty(job.Location))
                                        {
                                            <span class="mx-1">•</span><span>@job.Location</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Right Actions -->
                            <div class="flex flex-col items-end gap-2 pointer-events-auto">
                                @if (job.Deadline.HasValue)
                                {
                                    <span class="text-muted text-[12px] bg-gray-50 px-2 py-1 rounded whitespace-nowrap">
                                        Hạn: @job.Deadline.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                                <div class="flex items-center gap-2 mt-1">
                                    <button type="button" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors shadow-sm border border-gray-100 bookmark-btn" data-job-id="@job.JobId" title="Lưu việc làm">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                        </svg>
                                    </button>
                                    <a href="/Jobs/Details/@job.JobId#apply" class="px-3 py-1.5 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all text-[12px] font-semibold border border-primary/20 shadow-sm flex items-center gap-1 group/btn">
                                        Ứng tuyển
                                        <svg class="w-3 h-3 group-hover/btn:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Salary -->
                        @if (job.SalaryMin.HasValue || job.SalaryMax.HasValue)
                        {
                            <div class="flex items-center text-[#4640DE] font-medium text-[14px] mb-3 relative z-10 pointer-events-none">
                                <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                @if (job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                                {
                                    <span>@job.SalaryMin.Value.ToString("N0") – @job.SalaryMax.Value.ToString("N0") triệu VND</span>
                                }
                                else if (job.SalaryMin.HasValue)
                                {
                                    <span>Từ @job.SalaryMin.Value.ToString("N0") triệu VND</span>
                                }
                                else
                                {
                                    <span>Đến @job.SalaryMax!.Value.ToString("N0") triệu VND</span>
                                }
                            </div>
                        }

                        <!-- Badges: WorkingModel, ExperienceLevel, Tech tags -->
                        <div class="flex flex-wrap gap-2 relative z-10 pointer-events-none">
                            @if (!string.IsNullOrEmpty(job.WorkingModel))
                            {
                                <span class="px-3 py-1 rounded-full border border-green-500 text-green-600 text-[12px] font-medium bg-green-50">@job.WorkingModel</span>
                            }
                            @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                            {
                                <span class="px-3 py-1 rounded-full border border-orange-400 text-orange-500 text-[12px] font-medium bg-orange-50">@job.ExperienceLevel</span>
                            }
                            @foreach (var tech in job.TechNames.Take(3))
                            {
                                <span class="px-3 py-1 rounded-full border border-primary text-primary text-[12px] font-medium bg-primary/5">@tech</span>
                            }
                            @if (job.TechNames.Count > 3)
                            {
                                <span class="px-3 py-1 rounded-full border border-gray-300 text-muted text-[12px]">+@(job.TechNames.Count - 3)</span>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                // Route values dùng lại cho tất cả pagination links
                var baseRoute = new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = Model.Filter.RecruiterId };
                <div class="mt-8 flex justify-center">
                    <nav class="flex items-center space-x-1" aria-label="Phân trang">
                        <!-- Prev -->
                        @if (Model.Filter.Page > 1)
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = Model.Filter.RecruiterId, page = Model.Filter.Page - 1 })"
                               class="w-10 h-10 flex items-center justify-center rounded border border-bordercolor text-muted hover:bg-gray-100 transition-colors">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                </svg>
                            </a>
                        }

                        <!-- Page numbers -->
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            if (p == Model.Filter.Page)
                            {
                                <span class="w-10 h-10 flex items-center justify-center rounded border border-primary bg-primary text-white font-medium">@p</span>
                            }
                            else if (p == 1 || p == Model.TotalPages || (p >= Model.Filter.Page - 1 && p <= Model.Filter.Page + 1))
                            {
                                <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = Model.Filter.RecruiterId, page = p })"
                                   class="w-10 h-10 flex items-center justify-center rounded border border-transparent text-dark hover:bg-gray-100 font-medium transition-colors">@p</a>
                            }
                            else if (p == Model.Filter.Page - 2 || p == Model.Filter.Page + 2)
                            {
                                <span class="text-muted px-1">...</span>
                            }
                        }

                        <!-- Next -->
                        @if (Model.Filter.Page < Model.TotalPages)
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, desiredSalary = Model.Filter.DesiredSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = Model.Filter.RecruiterId, page = Model.Filter.Page + 1 })"
                               class="w-10 h-10 flex items-center justify-center rounded border border-bordercolor text-muted hover:bg-gray-100 transition-colors">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        }
                    </nav>
                </div>
            }
        }
    </div>
</section>

@section Scripts {
    <script>
        // Collapse/expand sidebar filter sections
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.filter-header').forEach(header => {
                header.addEventListener('click', () => {
                    const content = header.nextElementSibling;
                    const icon    = header.querySelector('.filter-icon');
                    const isOpen  = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';
                    if (isOpen) {
                        content.style.maxHeight = '0px';
                        content.style.opacity   = '0';
                        icon.classList.add('rotate-180');
                    } else {
                        content.style.maxHeight = content.scrollHeight + 'px';
                        content.style.opacity   = '1';
                        icon.classList.remove('rotate-180');
                    }
                });
            });
            document.querySelectorAll('.filter-content').forEach(content => {
                content.style.maxHeight = content.scrollHeight + 'px';
                content.style.opacity   = '1';
            });

            // Quick-filter panel toggle
            window.togglePanel = function(id) {
                const panels = ['tech-panel', 'city-panel', 'company-panel'];
                panels.forEach(pid => {
                    const el = document.getElementById(pid);
                    if (pid === id) {
                        el.classList.toggle('hidden');
                    } else {
                        el.classList.add('hidden');
                    }
                });
            };

            // Click ngoài panel thì đóng lại
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.quick-filter-wrapper')) {
                    document.querySelectorAll('[id$="-panel"]').forEach(p => p.classList.add('hidden'));
                }
            });
        });
    </script>
}
