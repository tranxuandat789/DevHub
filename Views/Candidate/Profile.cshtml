@{
    ViewData["Title"] = "Hồ sơ của tôi";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Profile";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("_Sidebar")
            </div>

            <!-- Main Content -->
            <div class="flex-1 space-y-5">
                
                <!-- Basic Info Card -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] relative">
                    <div class="flex items-center gap-5">
                        <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-upload').click()">
                            <img id="avatar-preview" src="https://i.pravatar.cc/150?img=11" alt="Avatar" class="w-[88px] h-[88px] rounded-full object-cover group-hover:opacity-80 transition-opacity">
                            <div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                        </div>
                        <input type="file" id="avatar-upload" class="hidden" accept="image/*">
                        <div>
                            <h2 class="text-[24px] font-bold text-dark leading-tight">Phong Hoang</h2>
                            <p class="text-gray-400 text-[15px] font-medium mt-1">Cập nhật chức danh</p>
                        </div>
                        <!-- Edit Button -->
                        <button onclick="openModal('basic-info', 'Cập nhật thông tin cá nhân')" class="absolute top-6 right-6 text-[#4640DE] hover:bg-indigo-50 p-1.5 rounded-md transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Grid Info -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-6 mt-8">
                        <div class="flex items-center gap-3 text-gray-500 text-[14px]">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            <span class="truncate">hoangphongbq123@gmail...</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-400 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span>Số điện thoại</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-400 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span>Ngày sinh</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-400 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span>Giới tính</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-400 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span>Địa chỉ hiện tại</span>
                        </div>
                        <div class="flex items-center gap-3 text-gray-400 text-[14px]">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            <span>Link cá nhân</span>
                        </div>
                    </div>
                </div>

                <!-- CV Section -->
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <h3 class="text-[18px] font-bold text-dark mb-5">Hồ sơ đính kèm của bạn</h3>
                    <div class="bg-[#F8F9FA] rounded-[8px] p-8 border border-[#D6DDEB] flex flex-col items-center justify-center text-center">
                        <div class="w-12 h-12 mb-4 text-gray-300">
                            <svg fill="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2.5L17.5 9H13V4.5zM6 20V4h5v6h6v10H6z"/>
                            </svg>
                        </div>
                        <p class="text-[14.5px] text-dark font-medium max-w-md mb-5 leading-relaxed">
                            Tải lên CV của bạn để ứng tuyển nhanh chóng và thu hút sự chú ý của nhà tuyển dụng.
                        </p>
                        <button class="bg-[#4640DE] text-white px-8 py-2.5 rounded-[5px] text-[15px] font-semibold hover:bg-opacity-90 transition-all">
                            Tải lên ngay
                        </button>
                    </div>
                </div>

                <!-- Sections -->
                @{
                    var sections = new[] {
                        new { Id = "introduce", Title = "Giới thiệu bản thân", Desc = "Giới thiệu điểm mạnh và số năm kinh nghiệm của bạn", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" },
                        new { Id = "education", Title = "Học vấn", Desc = "Chia sẻ trình độ học vấn của bạn", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" },
                        new { Id = "experience", Title = "Kinh nghiệm làm việc", Desc = "Thể hiện những thông tin chi tiết về quá trình làm việc", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
                        new { Id = "skills", Title = "Kỹ năng", Desc = "Liệt kê các kỹ năng chuyên môn của bạn", IconColor = "bg-gray-50 text-gray-400", IconPath = "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
                        new { Id = "languages", Title = "Ngoại ngữ", Desc = "Liệt kê các ngôn ngữ mà bạn biết", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 15h4.498" },
                        new { Id = "projects", Title = "Dự án nổi bật", Desc = "Giới thiệu dự án nổi bật của bạn", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
                        new { Id = "certificates", Title = "Chứng chỉ", Desc = "Bổ sung chứng chỉ liên quan đến kỹ năng của bạn", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
                        new { Id = "awards", Title = "Giải thưởng", Desc = "Thể hiện giải thưởng hoặc thành tích mà bạn đạt được", IconColor = "bg-indigo-50 text-indigo-400", IconPath = "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" }
                    };

                    foreach (var item in sections)
                    {
                        <div onclick="openModal('@item.Id', 'Cập nhật @item.Title')" class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] flex justify-between items-center group cursor-pointer hover:border-primary/30 transition-colors">
                            <div>
                                <h3 class="text-[17px] font-bold text-dark mb-1">@item.Title</h3>
                                <p class="text-gray-400 text-[14px]">@item.Desc</p>
                            </div>
                            <div class="flex items-center gap-5">
                                <!-- Graphic icon -->
                                <div class="w-[50px] h-[50px] @item.IconColor bg-opacity-60 rounded-full flex items-center justify-center relative overflow-hidden group-hover:scale-105 transition-transform">
                                    <svg class="w-7 h-7 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@item.IconPath" />
                                    </svg>
                                    <div class="absolute inset-0 bg-white bg-opacity-20 backdrop-blur-[1px]"></div>
                                </div>
                                <!-- Plus button -->
                                <button class="text-[#4640DE] hover:text-indigo-800 transition-colors">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Right Sidebar -->
            <div class="lg:w-[300px] flex-shrink-0 mt-8 lg:mt-0">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB] sticky top-6">
                    <h3 class="text-[15.5px] font-bold text-dark text-center mb-2">Độ hoàn thiện hồ sơ</h3>
                    <div class="relative w-48 h-28 mx-auto">
                        <!-- Half Circle SVG -->
                        <svg viewBox="0 0 100 50" class="w-full h-full overflow-visible">
                            <!-- Background track -->
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#E5E7EB" stroke-width="12" stroke-linecap="round"/>
                            <!-- Progress track (5%) -->
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#4640DE" stroke-width="12" stroke-linecap="round" stroke-dasharray="125.66" stroke-dashoffset="119.38" class="transition-all duration-1000 ease-out"/>
                        </svg>
                        <!-- Center Text -->
                        <div class="absolute bottom-0 left-0 right-0 flex flex-col items-center justify-center transform translate-y-3">
                            <span class="text-[24px] font-bold text-dark leading-none">5%</span>
                            <span class="text-[12px] text-gray-500 mt-1 font-medium">hoàn thành</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modals -->
<div id="genericModal" class="fixed inset-0 z-[100] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
    
    <!-- Modal Content -->
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh] transition-all">
        <div class="px-6 py-4 border-b border-[#D6DDEB] flex justify-between items-center bg-gray-50/50">
            <h3 id="modalTitle" class="text-lg font-bold text-gray-900">Tiêu đề</h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors p-1 hover:bg-gray-100 rounded-full">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6 overflow-y-auto w-full">
            <p class="text-gray-500 mb-4 text-sm">Cập nhật thông tin chi tiết cho phần này.</p>
            
            <!-- Basic Info Form -->
            <div id="form-basic-info" class="modal-form hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên</label>
                        <input type="text" value="Phong Hoang" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Chức danh</label>
                        <input type="text" placeholder="VD: UI/UX Designer" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" value="hoangphongbq123@gmail.com" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <input type="tel" placeholder="Nhập số điện thoại" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày sinh</label>
                        <input type="date" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Giới tính</label>
                        <select class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                            <option>Nam</option>
                            <option>Nữ</option>
                            <option>Khác</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ hiện tại</label>
                        <input type="text" placeholder="Nhập địa chỉ" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Link cá nhân (Portfolio, LinkedIn...)</label>
                        <input type="url" placeholder="https://" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
            </div>

            <!-- Introduce Form -->
            <div id="form-introduce" class="modal-form hidden space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Giới thiệu bản thân</label>
                    <textarea rows="5" placeholder="Viết vài dòng giới thiệu về điểm mạnh, kinh nghiệm của bạn..." class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none"></textarea>
                </div>
            </div>

            <!-- Education Form -->
            <div id="form-education" class="modal-form hidden space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Trường học / Cơ sở đào tạo</label>
                    <input type="text" placeholder="VD: Đại học FPT" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngành học</label>
                        <input type="text" placeholder="VD: Kỹ thuật phần mềm" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bằng cấp</label>
                        <input type="text" placeholder="VD: Cử nhân" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày bắt đầu</label>
                        <input type="month" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ngày kết thúc</label>
                        <input type="month" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
            </div>

            <!-- Experience Form -->
            <div id="form-experience" class="modal-form hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Chức danh</label>
                        <input type="text" placeholder="VD: Front-end Developer" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tên công ty</label>
                        <input type="text" placeholder="VD: FPT Software" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Từ tháng</label>
                        <input type="month" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Đến tháng</label>
                        <input type="month" class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả công việc</label>
                    <textarea rows="4" placeholder="Mô tả chi tiết những việc bạn đã làm..." class="w-full px-4 py-2 border border-[#D6DDEB] rounded-lg focus:ring-2 focus:ring-[#4640DE]/20 focus:border-[#4640DE] outline-none"></textarea>
