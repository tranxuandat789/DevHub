@{
    ViewData["Title"] = "Gợi ý việc làm";
    ViewData["ActiveMenu"] = "RecommendedJobs";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <!-- Page Header -->
                <div class="mb-6">
                    <h1 class="text-[28px] font-bold text-dark">Gợi ý việc làm <span class="text-primary">dành cho bạn</span></h1>
                    <p class="text-muted text-[15px] mt-1">Có <span class="text-primary font-bold">3</span> việc làm phù hợp nhất dành cho bạn</p>
                </div>

                <!-- Horizontal Filter Bar -->
                <div class="bg-white border border-gray-200 shadow-[0_4px_20px_rgb(0,0,0,0.08)] rounded-[16px] p-4 mb-6 flex flex-wrap items-center gap-3">
                    <!-- Label -->
                    <div class="flex items-center gap-2 text-[13px] font-bold text-dark flex-shrink-0">
                        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" /></svg>
                        Bộ lọc:
                    </div>


                    <!-- Loại công việc dropdown -->
                    <div class="relative" id="filter-type">
                        <button onclick="toggleDropdown('dropdown-type')" class="flex items-center gap-2 border border-gray-200 bg-gray-50 hover:border-primary hover:bg-primary/5 text-[13px] text-dark font-medium px-3 py-2 rounded-lg transition-all">
                            Loại công việc
                            <svg class="w-3.5 h-3.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </button>
                        <div id="dropdown-type" class="hidden absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-30 p-3 min-w-[160px] space-y-2">
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 accent-primary"> Full time</label>
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 accent-primary"> Part time</label>
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="checkbox" class="form-checkbox h-4 w-4 text-primary rounded border-gray-300 accent-primary"> Remote</label>
                        </div>
                    </div>

                    <!-- Mức lương dropdown -->
                    <div class="relative" id="filter-salary">
                        <button onclick="toggleDropdown('dropdown-salary')" class="flex items-center gap-2 border border-gray-200 bg-gray-50 hover:border-primary hover:bg-primary/5 text-[13px] text-dark font-medium px-3 py-2 rounded-lg transition-all">
                            Mức lương
                            <svg class="w-3.5 h-3.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </button>
                        <div id="dropdown-salary" class="hidden absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-30 p-3 min-w-[160px] space-y-2">
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 accent-primary"> 500 - 1000$</label>
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 accent-primary"> 1000 - 2000$</label>
                            <label class="flex items-center gap-2 cursor-pointer text-[13px] text-dark"><input type="radio" name="salary" class="form-radio h-4 w-4 text-primary border-gray-300 accent-primary"> 2000$+</label>
                        </div>
                    </div>

                    <!-- Sort -->
                    <div class="ml-auto">
                        <select class="border border-gray-200 bg-white text-[13px] text-dark rounded-lg px-3 py-2 focus:ring-primary outline-none">
                            <option>Độ phù hợp cao nhất</option>
                            <option>Mới nhất</option>
                            <option>Lương cao nhất</option>
                        </select>
                    </div>
                </div>

                <!-- Job List -->
                <div class="space-y-4">

                            <!-- Job 1 -->
                            <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:border-primary transition-all rounded-[20px] p-5 relative mt-4">
                                <div class="absolute -top-3 right-4 bg-gradient-to-r from-green-400 to-green-500 text-white font-bold text-[12px] px-3 py-1 rounded-full shadow flex items-center gap-1 border-2 border-white">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                    Phù hợp 95%
                                </div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-10 h-10 rounded-full border border-gray-200 bg-white flex items-center justify-center overflow-hidden flex-shrink-0">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg" alt="Google" class="w-full h-full object-contain p-1">
                                    </div>
                                    <div>
                                        <h3 class="text-[16px] font-bold text-dark">Senior Frontend Developer (React/Next.js)</h3>
                                        <div class="flex items-center text-muted text-[13px] gap-2 mt-0.5">
                                            <span class="font-medium text-dark">Google</span>
                                            <span>•</span>
                                            <span>Mountain View, CA (Hybrid)</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-muted text-[13px] mb-3">Google đang tìm kiếm Senior Frontend Developer có kinh nghiệm sâu sắc về React để xây dựng trải nghiệm người dùng thế hệ tiếp theo.</p>
                                <div class="flex items-center justify-between">
                                    <div class="flex flex-wrap gap-2">
                                        <span class="text-[#26A4FF] font-medium text-[13px]">$120,000 - $180,000 / năm</span>
                                        <span class="px-2 py-0.5 rounded-full border border-green-500 text-green-500 text-[12px] bg-green-50">Full-Time</span>
                                        <span class="px-2 py-0.5 rounded-full border border-primary text-primary text-[12px] bg-primary/5">React</span>
                                    </div>
                                    <div class="flex gap-2 flex-shrink-0">
                                        <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Lưu">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
                                        </button>
                                        <button onclick="openApplyModal('Senior Frontend Developer (React/Next.js)', 'Google', 'Google đang tìm kiếm Senior Frontend Developer có kinh nghiệm sâu sắc về React để xây dựng trải nghiệm người dùng thế hệ tiếp theo trên nền tảng toàn cầu.')" class="bg-primary text-white px-4 py-1.5 rounded-full text-[13px] font-medium hover:bg-opacity-90 transition-colors">Ứng tuyển</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Job 2 -->
                            <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:border-primary transition-all rounded-[20px] p-5 relative mt-4">
                                <div class="absolute -top-3 right-4 bg-gradient-to-r from-green-400 to-green-500 text-white font-bold text-[12px] px-3 py-1 rounded-full shadow flex items-center gap-1 border-2 border-white">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                    Phù hợp 88%
                                </div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-10 h-10 rounded-full border border-gray-200 bg-black flex items-center justify-center overflow-hidden flex-shrink-0">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/e/e8/Tesla_logo.png" alt="Tesla" class="w-full h-full object-contain p-1 filter invert">
                                    </div>
                                    <div>
                                        <h3 class="text-[16px] font-bold text-dark">Software Engineer, UI Frameworks</h3>
                                        <div class="flex items-center text-muted text-[13px] gap-2 mt-0.5">
                                            <span class="font-medium text-dark">Tesla</span>
                                            <span>•</span>
                                            <span>Austin, TX (On-site)</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-muted text-[13px] mb-3">Gia nhập đội ngũ kỹ sư Tesla để xây dựng các UI frameworks tùy chỉnh sử dụng trên hàng triệu phương tiện toàn cầu.</p>
                                <div class="flex items-center justify-between">
                                    <div class="flex flex-wrap gap-2">
                                        <span class="text-[#26A4FF] font-medium text-[13px]">Thỏa thuận</span>
                                        <span class="px-2 py-0.5 rounded-full border border-green-500 text-green-500 text-[12px] bg-green-50">Full-Time</span>
                                        <span class="px-2 py-0.5 rounded-full border border-primary text-primary text-[12px] bg-primary/5">TypeScript</span>
                                    </div>
                                    <div class="flex gap-2 flex-shrink-0">
                                        <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Lưu">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
                                        </button>
                                        <button onclick="openApplyModal('Software Engineer, UI Frameworks', 'Tesla', 'Gia nhập đội ngũ kỹ sư Tesla để xây dựng các UI frameworks tùy chỉnh sử dụng trên hàng triệu phương tiện và ứng dụng toàn cầu.')" class="bg-primary text-white px-4 py-1.5 rounded-full text-[13px] font-medium hover:bg-opacity-90 transition-colors">Ứng tuyển</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Job 3 -->
                            <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:border-primary transition-all rounded-[20px] p-5 relative mt-4">
                                <div class="absolute -top-3 right-4 bg-gradient-to-r from-green-400 to-green-500 text-white font-bold text-[12px] px-3 py-1 rounded-full shadow flex items-center gap-1 border-2 border-white">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                    Phù hợp 82%
                                </div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-10 h-10 rounded-full border border-gray-200 bg-white flex items-center justify-center overflow-hidden flex-shrink-0">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft" class="w-full h-full object-contain p-1">
                                    </div>
                                    <div>
                                        <h3 class="text-[16px] font-bold text-dark">Full Stack Developer (.NET/React)</h3>
                                        <div class="flex items-center text-muted text-[13px] gap-2 mt-0.5">
                                            <span class="font-medium text-dark">Microsoft</span>
                                            <span>•</span>
                                            <span>Seattle, WA (Remote)</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-muted text-[13px] mb-3">Phát triển các ứng dụng doanh nghiệp quy mô lớn sử dụng .NET Core và React cho nền tảng Azure.</p>
                                <div class="flex items-center justify-between">
                                    <div class="flex flex-wrap gap-2">
                                        <span class="text-[#26A4FF] font-medium text-[13px]">$100,000 - $140,000 / năm</span>
                                        <span class="px-2 py-0.5 rounded-full border border-purple-500 text-purple-500 text-[12px] bg-purple-50">Remote</span>
                                        <span class="px-2 py-0.5 rounded-full border border-primary text-primary text-[12px] bg-primary/5">.NET</span>
                                    </div>
                                    <div class="flex gap-2 flex-shrink-0">
                                        <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Lưu">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
                                        </button>
                                        <button onclick="openApplyModal('Full Stack Developer (.NET/React)', 'Microsoft', 'Phát triển các ứng dụng doanh nghiệp quy mô lớn sử dụng .NET Core và React cho nền tảng Azure của Microsoft.')" class="bg-primary text-white px-4 py-1.5 rounded-full text-[13px] font-medium hover:bg-opacity-90 transition-colors">Ứng tuyển</button>
                                    </div>
                                </div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Candidate/_ApplyModal.cshtml")

@section Scripts {
    <script>
        function toggleDropdown(id) {
            const all = ['dropdown-match', 'dropdown-type', 'dropdown-salary'];
            all.forEach(d => {
                if (d !== id) document.getElementById(d).classList.add('hidden');
            });
            document.getElementById(id).classList.toggle('hidden');
        }
        document.addEventListener('click', e => {
            if (!e.target.closest('#filter-match, #filter-type, #filter-salary')) {
                ['dropdown-match','dropdown-type','dropdown-salary'].forEach(d => document.getElementById(d).classList.add('hidden'));
            }
        });
    </script>
}
