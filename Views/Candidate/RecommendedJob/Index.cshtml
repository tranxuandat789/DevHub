@model List<DevHub.ViewModels.Jobs.JobRecommendationViewModel>
@{
    ViewData["Title"] = "Gợi ý việc làm";
    ViewData["ActiveMenu"] = "RecommendedJobs";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <!-- Page Header -->
                <div class="mb-6">
                    <h1 class="text-[28px] font-bold text-dark">Gợi ý việc làm <span class="text-primary">dành cho bạn</span></h1>
                    <p class="text-muted text-[15px] mt-1">Có <span class="text-primary font-bold">@ViewBag.TotalJobs</span> việc làm phù hợp dành cho bạn</p>
                </div>

                <!-- Job List -->
                <div class="space-y-4">
                    @if (!Model.Any())
                    {
                        <div class="bg-white rounded-[20px] p-8 text-center border border-gray-200">
                            <h3 class="text-lg font-semibold text-gray-700">Chưa tìm thấy công việc phù hợp</h3>
                            <p class="text-gray-500 mt-2">Vui lòng cập nhật thêm thông tin Hồ sơ cá nhân (kỹ năng, mức lương, địa điểm) để nhận gợi ý chính xác hơn.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var job = item.Job;
                            var matchScore = item.MatchPercentage;
                            string formattedSalary = (job.SalaryMin.HasValue && job.SalaryMax.HasValue) 
                                ? $"{job.SalaryMin:N0} VNĐ - {job.SalaryMax:N0} VNĐ" 
                                : "Thỏa thuận";

                            <div class="bg-white border border-gray-100 shadow-sm hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:border-primary/30 hover:-translate-y-1 transition-all duration-300 rounded-[20px] p-6 relative mt-6 group">
                                <!-- Match Badge -->
                                <div class="absolute -top-3 right-6 bg-gradient-to-r from-emerald-400 to-emerald-500 text-white font-bold text-[12px] px-3.5 py-1.5 rounded-full shadow-md flex items-center gap-1.5 border-2 border-white z-10">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                    Phù hợp @matchScore%
                                </div>
                                
                                <div class="flex items-start gap-4 mb-4">
                                    <div class="w-12 h-12 rounded-xl border border-blue-100 bg-blue-50 text-blue-500 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow transition-all">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                    </div>
                                    <div class="flex-1 min-w-0 pt-0.5">
                                        <a href="/Jobs/Details/@job.JobId" class="text-[18px] font-bold text-gray-900 hover:text-primary transition-colors line-clamp-1">@job.Title</a>
                                        <div class="text-primary font-medium text-[14px] mt-1 mb-2">@job.Company?.CompanyName</div>
                                        
                                        <div class="flex flex-wrap items-center text-gray-500 text-[13px] gap-4 mt-1">
                                            <div class="flex items-center gap-1.5">
                                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                <span>@job.Location</span>
                                            </div>
                                            <div class="flex items-center gap-1.5">
                                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                                <span>@job.WorkingModel</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <p class="text-gray-600 text-[14px] mb-5 line-clamp-2 leading-relaxed">@(string.IsNullOrEmpty(job.Description) ? "Không có mô tả" : job.Description)</p>
                                
                                <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
                                    <div class="flex flex-wrap gap-2.5 items-center">
                                        <div class="flex items-center gap-1.5 text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-md font-medium text-[13px]">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            @formattedSalary
                                        </div>
                                        <div class="flex items-center gap-1.5 text-blue-600 bg-blue-50 px-2.5 py-1 rounded-md text-[13px]">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                                            @job.ExperienceLevel
                                        </div>
                                        <div class="h-4 w-px bg-gray-200 mx-1 hidden sm:block"></div>
                                        @foreach(var tech in job.Teches.Take(2))
                                        {
                                            <span class="px-2.5 py-1 rounded-md border border-gray-200 text-gray-600 text-[12px] bg-white hover:bg-gray-50 transition-colors">@tech.TechName</span>
                                        }
                                        @if(job.Teches.Count > 2)
                                        {
                                            <span class="px-2.5 py-1 rounded-md border border-gray-200 text-gray-500 text-[12px] bg-gray-50">+@(job.Teches.Count - 2)</span>
                                        }
                                    </div>
                                    <div class="flex gap-2 flex-shrink-0 ml-4 items-center" data-is-authenticated="true">
                                        @{
                                            var bookmarkedJobIds = ViewBag.BookmarkedJobIds as List<int> ?? new List<int>();
                                            bool isBookmarked = bookmarkedJobIds.Contains(job.JobId);
                                        }
                                        <button type="button"
                                                class="w-10 h-10 flex items-center justify-center rounded-xl transition-colors shadow-sm border bookmark-btn
                                                       @(isBookmarked ? "bg-primary/10 text-primary border-primary/30" : "bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100")"
                                                data-job-id="@job.JobId"
                                                data-bookmarked="@isBookmarked.ToString().ToLower()"
                                                title="@(isBookmarked ? "Bỏ lưu việc làm" : "Lưu việc làm")">
                                            <svg class="w-5 h-5" fill="@(isBookmarked ? "currentColor" : "none")" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                            </svg>
                                        </button>
                                        <a href="/Jobs/Details/@job.JobId" class="flex items-center gap-1.5 bg-primary/10 text-primary hover:bg-primary hover:text-white px-4 py-2 rounded-xl text-[14px] font-semibold transition-all duration-300">
                                            Chi tiết
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Pagination -->
                        @if (ViewBag.TotalPages > 1)
                        {
                            <div class="mt-8 flex justify-center">
                                <nav class="flex items-center gap-2">
                                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                    {
                                        if (i == ViewBag.CurrentPage)
                                        {
                                            <span class="w-10 h-10 flex items-center justify-center rounded-full bg-primary text-white font-medium">@i</span>
                                        }
                                        else
                                        {
                                            <a href="/Candidate/RecommendedJobs?page=@i" class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-600 hover:bg-primary hover:text-white transition-colors">@i</a>
                                        }
                                    }
                                </nav>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Candidate/_ApplyModal.cshtml")

@section Scripts {
    <!-- Toast container -->
    <div id="bookmark-toast" class="fixed bottom-6 right-6 z-50 hidden">
        <div class="bg-white border border-[#D6DDEB] shadow-xl rounded-2xl px-5 py-4 flex items-center gap-3 min-w-[280px]">
            <div id="bookmark-toast-icon" class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
            </div>
            <p id="bookmark-toast-msg" class="text-[14px] font-medium text-dark"></p>
        </div>
    </div>

    <script>
        function toggleDropdown(id) {
            const all = ['dropdown-match', 'dropdown-type', 'dropdown-salary'];
            all.forEach(d => {
                if (d !== id) document.getElementById(d).classList.add('hidden');
            });
            document.getElementById(id).classList.toggle('hidden');
        }
        document.addEventListener('click', e => {
            if (!e.target.closest('#filter-match, #filter-type, #filter-salary')) {
                ['dropdown-match','dropdown-type','dropdown-salary'].forEach(d => document.getElementById(d).classList.add('hidden'));
            }
        });

        // Bookmark Logic
        function showToast(message, type) {
            const toast = document.getElementById('bookmark-toast');
            const msg = document.getElementById('bookmark-toast-msg');
            const iconBox = document.getElementById('bookmark-toast-icon');
            msg.textContent = message;
            if (type === 'success') {
                iconBox.className = 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-primary/10 text-primary';
            } else {
                iconBox.className = 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-red-50 text-red-500';
            }
            toast.classList.remove('hidden');
            setTimeout(() => toast.classList.add('hidden'), 2500);
        }

        document.querySelectorAll('.bookmark-btn').forEach(btn => {
            btn.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();

                const wrapper = btn.closest('[data-is-authenticated]');
                const isAuth = wrapper && wrapper.dataset.isAuthenticated === 'true';

                if (!isAuth) {
                    showToast('Vui lòng đăng nhập để lưu việc làm', 'error');
                    setTimeout(() => { window.location.href = '/Auth/Login'; }, 2000);
                    return;
                }

                const jobId = btn.dataset.jobId;
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const res = await fetch(`/candidate/bookmarks/toggle?jobId=${jobId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    });
                    if (!res.ok) throw new Error();
                    const data = await res.json();

                    const svg = btn.querySelector('svg');
                    if (data.isBookmarked) {
                        btn.dataset.bookmarked = 'true';
                        btn.title = 'Bỏ lưu việc làm';
                        btn.className = btn.className
                            .replace('bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100', '')
                            + ' bg-primary/10 text-primary border-primary/30';
                        svg.setAttribute('fill', 'currentColor');
                        showToast('Đã lưu việc làm thành công!', 'success');
                    } else {
                        btn.dataset.bookmarked = 'false';
                        btn.title = 'Lưu việc làm';
                        btn.className = btn.className
                            .replace('bg-primary/10 text-primary border-primary/30', '')
                            + ' bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100';
                        svg.setAttribute('fill', 'none');
                        showToast('Đã bỏ lưu việc làm', 'success');
                    }
                } catch {
                    showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                }
            });
        });
    </script>
}
