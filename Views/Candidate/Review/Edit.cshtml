@model DevHub.ViewModels.Candidate.WriteReviewViewModel
@{
    ViewData["Title"] = "Chỉnh sửa đánh giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "Reviews";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("~/Views/Candidate/_Sidebar.cshtml")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <!-- Breadcrumb -->
                <div class="text-sm text-gray-500 flex items-center space-x-2 mb-6">
                    <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
                    <span>&rsaquo;</span>
                    <a href="/candidate/reviews" class="hover:text-primary transition-colors">Đánh giá của tôi</a>
                    <span>&rsaquo;</span>
                    <span class="text-gray-800 font-medium">Chỉnh sửa</span>
                </div>

                @if (Model.ExistingReview?.Status == "REJECTED" && !string.IsNullOrEmpty(Model.ExistingReview.RejectionReason))
                {
                    <div class="bg-red-50 border border-red-200 p-6 rounded-2xl mb-6 shadow-[0_8px_30px_rgb(0,0,0,0.12)]">
                        <div class="flex items-start gap-3">
                            <span class="text-red-500 text-xl mt-0.5">⚠️</span>
                            <div>
                                <h3 class="text-red-800 font-bold text-lg mb-1">Lý do từ chối trước đó</h3>
                                <p class="text-red-700">@Model.ExistingReview.RejectionReason</p>
                            </div>
                        </div>
                    </div>
                }

                <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
                    <div class="bg-[#F7F5FF] px-8 py-6 border-b border-[#E2E8F0] flex justify-between items-center">
                        <div>
                            <h1 class="text-2xl font-bold text-dark">Chỉnh sửa đánh giá</h1>
                            <p class="text-muted mt-1">Sửa đổi đánh giá của bạn cho <span class="font-bold text-primary">@Model.CompanyName</span></p>
                        </div>
                        @if (Model.ExistingReview?.Status == "PENDING")
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-yellow-50 text-yellow-600 border border-yellow-200">
                                Đang chờ duyệt
                            </span>
                        }
                    </div>

                    <form asp-action="Edit" asp-route-id="@Model.ExistingReview?.ReviewId" method="post" class="p-8">
                        <input type="hidden" asp-for="CompanyId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium"></div>

                        <!-- 1. Đánh giá tổng quan -->
                        <div class="mb-10">
                            <h2 class="text-lg font-bold text-dark mb-4">1. Đánh giá tổng quan <span class="text-red-500">*</span></h2>
                            <div class="flex flex-col items-center justify-center p-6 bg-gray-50 border border-gray-100 rounded-xl">
                                <div class="star-rating-main flex flex-row-reverse gap-2 justify-center text-4xl">
                                    <input type="radio" id="star5" asp-for="Rating" value="5" class="hidden peer" />
                                    <label for="star5" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 transition-colors">★</label>
                                    
                                    <input type="radio" id="star4" asp-for="Rating" value="4" class="hidden peer" />
                                    <label for="star4" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                    
                                    <input type="radio" id="star3" asp-for="Rating" value="3" class="hidden peer" />
                                    <label for="star3" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                    
                                    <input type="radio" id="star2" asp-for="Rating" value="2" class="hidden peer" />
                                    <label for="star2" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                    
                                    <input type="radio" id="star1" asp-for="Rating" value="1" class="hidden peer" />
                                    <label for="star1" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                </div>
                                <span asp-validation-for="Rating" class="text-red-500 text-sm mt-2 font-medium"></span>
                            </div>
                        </div>

                        <!-- 2. Đánh giá chi tiết -->
                        <div class="mb-10">
                            <h2 class="text-lg font-bold text-dark mb-4">2. Đánh giá chi tiết <span class="text-red-500">*</span></h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
                                
                                <!-- Lương thưởng -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Lương & Thưởng</label>
                                    <div class="star-rating-detail flex flex-row-reverse justify-end gap-1 text-2xl">
                                        @for(int i=5; i>=1; i--) {
                                            <input type="radio" id="salary@(i)" asp-for="SalaryRating" value="@i" class="hidden peer" />
                                            <label for="salary@(i)" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                        }
                                    </div>
                                    <span asp-validation-for="SalaryRating" class="text-red-500 text-xs font-medium"></span>
                                </div>

                                <!-- Đào tạo -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Đào tạo & Học hỏi</label>
                                    <div class="star-rating-detail flex flex-row-reverse justify-end gap-1 text-2xl">
                                        @for(int i=5; i>=1; i--) {
                                            <input type="radio" id="training@(i)" asp-for="TrainingRating" value="@i" class="hidden peer" />
                                            <label for="training@(i)" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                        }
                                    </div>
                                    <span asp-validation-for="TrainingRating" class="text-red-500 text-xs font-medium"></span>
                                </div>

                                <!-- Quan tâm nhân viên -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Sự quan tâm đến nhân viên</label>
                                    <div class="star-rating-detail flex flex-row-reverse justify-end gap-1 text-2xl">
                                        @for(int i=5; i>=1; i--) {
                                            <input type="radio" id="care@(i)" asp-for="CareRating" value="@i" class="hidden peer" />
                                            <label for="care@(i)" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                        }
                                    </div>
                                    <span asp-validation-for="CareRating" class="text-red-500 text-xs font-medium"></span>
                                </div>

                                <!-- Văn hóa -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Văn hóa công ty</label>
                                    <div class="star-rating-detail flex flex-row-reverse justify-end gap-1 text-2xl">
                                        @for(int i=5; i>=1; i--) {
                                            <input type="radio" id="culture@(i)" asp-for="CultureRating" value="@i" class="hidden peer" />
                                            <label for="culture@(i)" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                        }
                                    </div>
                                    <span asp-validation-for="CultureRating" class="text-red-500 text-xs font-medium"></span>
                                </div>

                                <!-- Không gian -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Không gian làm việc</label>
                                    <div class="star-rating-detail flex flex-row-reverse justify-end gap-1 text-2xl">
                                        @for(int i=5; i>=1; i--) {
                                            <input type="radio" id="workspace@(i)" asp-for="WorkspaceRating" value="@i" class="hidden peer" />
                                            <label for="workspace@(i)" class="cursor-pointer text-gray-300 peer-checked:text-yellow-400 hover:text-yellow-400 peer-hover:text-yellow-400 transition-colors">★</label>
                                        }
                                    </div>
                                    <span asp-validation-for="WorkspaceRating" class="text-red-500 text-xs font-medium"></span>
                                </div>

                            </div>
                        </div>

                        <!-- 3. Nhận xét -->
                        <div class="mb-10">
                            <h2 class="text-lg font-bold text-dark mb-4">3. Nhận xét chi tiết <span class="text-red-500">*</span></h2>
                            
                            <div class="space-y-6">
                                <div>
                                    <label class="block text-sm font-bold text-dark mb-2">Điều gì làm bạn thích ở công ty này? (Ưu điểm)</label>
                                    <textarea asp-for="Pros" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#4640DE] focus:border-transparent outline-none transition-all resize-none" placeholder="Chia sẻ những điểm tốt về môi trường, chế độ, đồng nghiệp..."></textarea>
                                    <span asp-validation-for="Pros" class="text-red-500 text-sm font-medium mt-1"></span>
                                </div>
                                
                                <div>
                                    <label class="block text-sm font-bold text-dark mb-2">Điều gì công ty cần cải thiện? (Nhược điểm)</label>
                                    <textarea asp-for="Cons" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-[#4640DE] focus:border-transparent outline-none transition-all resize-none" placeholder="Chia sẻ những điểm chưa tốt, cần khắc phục..."></textarea>
                                    <span asp-validation-for="Cons" class="text-red-500 text-sm font-medium mt-1"></span>
                                </div>
                            </div>
                        </div>

                        <!-- 4. Thông tin thêm -->
                        <div class="mb-10">
                            <h2 class="text-lg font-bold text-dark mb-4">4. Đánh giá thêm</h2>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div>
                                    <label class="block text-sm font-bold text-dark mb-3">Chế độ OT của công ty?</label>
                                    <div class="flex gap-4">
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="radio" asp-for="OtPolicy" value="SATISFIED" class="w-4 h-4 text-[#4640DE] focus:ring-[#4640DE]" />
                                            <span class="text-gray-700 text-sm">Hài lòng</span>
                                        </label>
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="radio" asp-for="OtPolicy" value="UNSATISFIED" class="w-4 h-4 text-[#4640DE] focus:ring-[#4640DE]" />
                                            <span class="text-gray-700 text-sm">Không hài lòng</span>
                                        </label>
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-bold text-dark mb-3">Bạn có giới thiệu công ty này cho bạn bè?</label>
                                    <div class="flex gap-4">
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="radio" asp-for="Recommend" value="true" class="w-4 h-4 text-[#4640DE] focus:ring-[#4640DE]" />
                                            <span class="text-gray-700 text-sm">Có</span>
                                        </label>
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="radio" asp-for="Recommend" value="false" class="w-4 h-4 text-[#4640DE] focus:ring-[#4640DE]" />
                                            <span class="text-gray-700 text-sm">Không</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-gray-100 flex items-center justify-end gap-4">
                            <a href="/candidate/reviews/@Model.ExistingReview?.ReviewId" class="px-6 py-2.5 rounded-xl border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">
                                Hủy
                            </a>
                            <button type="submit" class="px-8 py-2.5 rounded-xl bg-[#4640DE] text-white font-bold hover:bg-opacity-90 transition-all shadow-sm">
                                Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .star-rating-main label ~ input:checked ~ label,
        .star-rating-main input:checked ~ label {
            color: #fbbf24;
        }
        
        .star-rating-detail label ~ input:checked ~ label,
        .star-rating-detail input:checked ~ label {
            color: #fbbf24;
        }
    </style>
}
