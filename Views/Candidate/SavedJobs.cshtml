@{
    ViewData["Title"] = "Việc làm đã lưu";
    ViewData["IsCandidate"] = "true";
    ViewData["ActiveMenu"] = "SavedJobs";
}

<div class="bg-[#F8F9FA] min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <div class="lg:w-[280px] flex-shrink-0">
                @await Html.PartialAsync("_Sidebar")
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-[10px] p-6 shadow-sm border border-[#D6DDEB]">
                    <div class="flex justify-between items-center mb-6 border-b border-[#D6DDEB] pb-4">
                        <h2 class="text-[20px] font-bold text-dark">Việc làm đã lưu</h2>
                        <div class="flex gap-2">
                            <span class="bg-primary/10 text-primary text-sm font-semibold px-3 py-1 rounded-full">3 Công việc</span>
                        </div>
                    </div>

                    <!-- Saved Jobs List -->
                    <div class="space-y-4">
                        @for (int i = 0; i < 3; i++)
                        {
                            <div class="block border border-[#D6DDEB] hover:border-primary/50 hover:shadow-sm transition-all rounded-xl p-5 group">
                                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                    <div class="flex items-start gap-4">
                                        <!-- Company Logo -->
                                        <div class="w-14 h-14 rounded-lg flex items-center justify-center overflow-hidden border border-[#D6DDEB] bg-white shadow-sm flex-shrink-0">
                                            <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/BMW.svg" alt="Company" class="w-10 h-10 object-contain">
                                        </div>
                                        
                                        <!-- Job Details -->
                                        <div>
                                            <a href="/Jobs/Details/1" class="text-[17px] font-bold text-dark group-hover:text-primary transition-colors">UI/UX Designer</a>
                                            <div class="flex items-center gap-2 mt-1 text-sm text-gray-500">
                                                <span class="font-medium text-dark">BMW</span>
                                                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                                                <span class="flex items-center">
                                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                                    </svg>
                                                    Hà Nội
                                                </span>
                                            </div>
                                            
                                            <!-- Tags -->
                                            <div class="flex flex-wrap gap-2 mt-3">
                                                <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-green-50 text-green-600">Full-Time</span>
                                                <span class="px-2.5 py-1 rounded-md text-[12px] font-medium bg-blue-50 text-blue-600">Design</span>
                                                <span class="px-2.5 py-1 rounded-md text-[12px] font-medium text-gray-500 flex items-center bg-gray-50">
                                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                    15-20 triệu
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Actions -->
                                    <div class="flex flex-col items-end gap-3 w-full md:w-auto mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-[#D6DDEB]">
                                        <div class="flex items-center gap-2">
                                            <span class="text-[13px] text-gray-400 whitespace-nowrap">Đã lưu 5 ngày trước</span>
                                        </div>
                                        <div class="flex items-center justify-between w-full md:w-auto gap-3">
                                            <a href="/Jobs/Details/1" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-primary text-white border border-primary hover:bg-opacity-90 w-full text-center transition-colors">Ứng tuyển ngay</a>
                                            <button class="p-2 text-primary hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors bg-primary/5" title="Bỏ lưu">
                                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <div class="mt-8 flex justify-center">
                        <nav class="flex items-center space-x-1">
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-400 hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                            </button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-primary bg-primary text-white text-sm font-medium">1</button>
                            <button class="w-8 h-8 flex items-center justify-center rounded-lg border border-transparent text-gray-400 hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                            </button>
                        </nav>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
