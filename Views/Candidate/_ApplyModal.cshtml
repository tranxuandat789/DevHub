<!-- Apply Modal - Shared Partial View -->
<div id="apply-modal" class="fixed inset-0 z-[9999] overflow-y-auto hidden" role="dialog" aria-modal="true">
    <!-- Backdrop -->
    <div onclick="closeApplyModal()" class="fixed inset-0 bg-black/50 backdrop-blur-sm"></div>
    <!-- Scroll wrapper -->
    <div class="flex min-h-full items-center justify-center p-4 py-8">
        <!-- Modal Box -->
        <div class="relative bg-white rounded-[24px] w-full max-w-xl flex flex-col" style="max-height: 90vh;">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-gray-100">
                <div>
                    <h2 class="text-[22px] font-bold text-dark">Ứng tuyển vào vị trí</h2>
                    <p id="apply-modal-subtitle" class="text-muted text-[13px] mt-1"></p>
                </div>
                <button onclick="closeApplyModal()" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors flex-shrink-0">
                    <svg class="w-5 h-5 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <!-- Scrollable body -->
            <div class="px-6 py-4 space-y-4 overflow-y-auto flex-1">
                <!-- Thông tin ứng tuyển -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">Thông tin ứng tuyển</h3>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Họ và tên <span class="text-red-500">*</span></label>
                            <input type="text" placeholder="Nguyễn Văn A" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-dark placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Email <span class="text-red-500">*</span></label>
                            <input type="email" placeholder="example@email.com" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-dark placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                            <input type="tel" placeholder="0912 345 678" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-dark placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                        </div>
                    </div>
                </div>
                <!-- Mô tả bản thân -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">Mô tả bản thân <span class="text-muted text-[13px] font-normal">(Tùy chọn)</span></h3>
                    <textarea rows="3" placeholder="Giới thiệu ngắn gọn về bản thân, lý do ứng tuyển, điểm mạnh phù hợp với vị trí..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-dark placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-none"></textarea>
                </div>
                <!-- CV ứng tuyển -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">📄 CV ứng tuyển</h3>
                    <!-- CV có sẵn -->
                    <label class="flex items-center gap-3 p-3 border-2 border-primary rounded-xl cursor-pointer bg-primary/5 mb-2">
                        <input type="radio" name="cv-choice" value="saved" checked class="accent-primary w-4 h-4" />
                        <div class="flex-1 min-w-0">
                            <p class="text-[13px] font-semibold text-dark truncate">CV_NguyenVanA_2024.pdf</p>
                            <p class="text-[12px] text-muted">Cập nhật 01/01/2024</p>
                            <a href="#" class="text-[12px] text-primary hover:underline">Xem hồ sơ</a>
                        </div>
                        <svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </label>
                    <!-- Tải CV mới -->
                    <label class="block cursor-pointer">
                        <div class="border-2 border-dashed border-gray-200 rounded-xl p-3 text-center hover:border-primary hover:bg-primary/5 transition-all">
                            <svg class="w-8 h-8 text-primary mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                            </svg>
                            <p class="text-[12px] font-medium text-primary">Tải lên CV có sẵn</p>
                            <p class="text-[11px] text-muted mt-0.5">Hỗ trợ: doc, docx, pdf, tối đa 5MB</p>
                            <input type="file" accept=".doc,.docx,.pdf" class="hidden" />
                        </div>
                    </label>
                </div>
                <p class="text-[11px] text-muted leading-relaxed">
                    Bằng việc nhấn nút nộp hồ sơ, tôi đồng ý chia sẻ thông tin cá nhân của mình với nhà tuyển dụng.
                </p>
            </div>

            <!-- Footer -->
            <div class="px-6 pb-5 pt-2">
                <button onclick="submitApply()" class="w-full bg-primary text-white font-bold py-3 rounded-xl hover:bg-opacity-90 transition-all text-[14px]">
                    Ứng tuyển ngay
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openApplyModal(jobTitle, companyName) {
        const subtitle = document.getElementById('apply-modal-subtitle');
        if (subtitle && jobTitle && companyName) {
            subtitle.textContent = jobTitle + ' — ' + companyName;
        }
        const modal = document.getElementById('apply-modal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeApplyModal() {
        document.getElementById('apply-modal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function submitApply() {
        closeApplyModal();
        // TODO: submit form
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeApplyModal();
    });
</script>
