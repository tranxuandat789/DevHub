<!-- Apply Modal - Shared Partial View -->
<div id="apply-modal" class="fixed inset-0 z-[9999] overflow-y-auto hidden" role="dialog" aria-modal="true">
    <!-- Backdrop -->
    <div onclick="closeApplyModal()" class="fixed inset-0 bg-black/50 backdrop-blur-sm"></div>
    <!-- Scroll wrapper -->
    <div class="flex min-h-full items-center justify-center p-4 py-8">
        <!-- Modal Box -->
        <div class="relative bg-white rounded-[24px] w-full max-w-xl flex flex-col" style="max-height: 90vh;">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-gray-100">
                <div>
                    <h2 class="text-[22px] font-bold text-dark">Ứng tuyển vào vị trí</h2>
                    <p id="apply-modal-subtitle" class="text-muted text-[13px] mt-1"></p>
                </div>
                <button onclick="closeApplyModal()" class="w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors flex-shrink-0">
                    <svg class="w-5 h-5 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <!-- Scrollable body -->
            <div class="px-6 py-4 space-y-4 overflow-y-auto flex-1">
                <!-- Hidden Job ID -->
                <input type="hidden" id="apply-job-id" />
                
                <!-- Thông tin ứng tuyển -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">Thông tin cá nhân (Cố định theo hồ sơ)</h3>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Họ và tên</label>
                            <input type="text" id="apply-fullname" readonly class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-500 cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Email</label>
                            <input type="email" id="apply-email" readonly class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-500 cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Số điện thoại</label>
                            <input type="tel" id="apply-phone" readonly class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-500 cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-[12px] font-medium text-dark mb-1">Địa điểm thường trú</label>
                            <input type="text" id="apply-address" readonly class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-500 cursor-not-allowed" />
                        </div>
                    </div>
                </div>
                <!-- Mô tả bản thân -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">Thư giới thiệu / Nguyện vọng <span class="text-muted text-[13px] font-normal">(Tùy chọn)</span></h3>
                    <textarea id="apply-coverletter" rows="3" placeholder="Viết một đoạn giới thiệu ngắn về bản thân và lý do bạn phù hợp với công việc này..." class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-dark placeholder-gray-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-none"></textarea>
                </div>
                <!-- CV ứng tuyển -->
                <div>
                    <h3 class="text-[15px] font-bold text-dark mb-4">📄 CV ứng tuyển</h3>
                    <!-- CV có sẵn -->
                    <label class="flex items-center gap-3 p-3 border-2 border-primary rounded-xl bg-primary/5 mb-2">
                        <div class="flex-1 min-w-0">
                            <p class="text-[12px] text-muted mb-1">Hệ thống sẽ tự động sử dụng CV mặc định của bạn.</p>
                            <p class="text-[13px] font-semibold text-primary truncate">File: <span id="apply-cv-title"></span></p>
                        </div>
                        <svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </label>
                </div>
                <p class="text-[11px] text-muted leading-relaxed">
                    Bằng việc nhấn nút nộp hồ sơ, tôi đồng ý chia sẻ thông tin cá nhân của mình với nhà tuyển dụng.
                </p>
            </div>

            <!-- Footer -->
            <div class="px-6 pb-5 pt-2">
                <button onclick="submitApply()" id="btn-submit-apply" class="w-full bg-primary text-white font-bold py-3 rounded-xl hover:bg-opacity-90 transition-all text-[14px] flex items-center justify-center">
                    <span>Ứng tuyển ngay</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openApplyModal(jobId, jobTitle, companyName, candidateData) {
        // Set info text
        const subtitle = document.getElementById('apply-modal-subtitle');
        if (subtitle && jobTitle && companyName) {
            subtitle.textContent = jobTitle + ' — ' + companyName;
        }
        
        // Fill form fields
        document.getElementById('apply-job-id').value = jobId;
        document.getElementById('apply-fullname').value = candidateData.fullName;
        document.getElementById('apply-email').value = candidateData.email;
        document.getElementById('apply-phone').value = candidateData.phone || 'Chưa cập nhật';
        document.getElementById('apply-address').value = candidateData.address || 'Chưa cập nhật';
        document.getElementById('apply-cv-title').textContent = candidateData.defaultCvTitle;
        document.getElementById('apply-coverletter').value = '';

        // Kiểm tra các trường bắt buộc trước khi mở modal
        const missingFields = [];
        if (!candidateData.fullName || candidateData.fullName.trim() === '')
            missingFields.push('Họ và tên');
        if (!candidateData.phone || candidateData.phone.trim() === '')
            missingFields.push('Số điện thoại');
        if (!candidateData.defaultCvId)
            missingFields.push('CV ứng tuyển');

        if (missingFields.length > 0) {
            const listHtml = missingFields.map(f => `<li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-red-500 flex-shrink-0"></span>${f}</li>`).join('');
            Swal.fire({
                html: `
                    <div class="flex flex-col items-center pt-4 pb-2">
                        <div class="w-20 h-20 rounded-full bg-yellow-50 flex items-center justify-center mb-6">
                            <svg class="w-10 h-10 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h2 class="text-[20px] font-bold text-gray-800 mb-2">Hồ sơ chưa hoàn chỉnh</h2>
                        <p class="text-gray-500 text-[13px] mb-4">Vui lòng cập nhật các thông tin sau trước khi ứng tuyển:</p>
                        <ul class="text-left text-[14px] text-red-500 font-semibold space-y-2 w-full px-6">${listHtml}</ul>
                    </div>
                `,
                showConfirmButton: true,
                showCancelButton: true,
                confirmButtonText: 'Cập nhật hồ sơ',
                cancelButtonText: 'Đóng',
                buttonsStyling: false,
                customClass: {
                    popup: 'rounded-[24px] p-6 max-w-sm w-full shadow-2xl',
                    confirmButton: 'w-full bg-[#4F46E5] hover:bg-indigo-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all mt-4 block',
                    cancelButton: 'w-full bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3.5 px-6 rounded-xl transition-all mt-2 block'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Candidate/Profile';
                }
            });
            return;
        }

        const modal = document.getElementById('apply-modal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeApplyModal() {
        document.getElementById('apply-modal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function submitApply() {
        const btn = document.getElementById('btn-submit-apply');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang xử lý...';
        btn.disabled = true;

        const jobId = document.getElementById('apply-job-id').value;
        const coverLetter = document.getElementById('apply-coverletter').value;

        fetch('/Jobs/Apply', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ jobId: parseInt(jobId), coverLetter: coverLetter })
        })
        .then(res => res.json())
        .then(data => {
            closeApplyModal();
            if(data.success) {
                Swal.fire({
                    html: `
                        <div class="flex flex-col items-center pt-4 pb-2">
                            <div class="w-20 h-20 rounded-full bg-green-50 flex items-center justify-center mb-6">
                                <svg class="w-10 h-10 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <h2 class="text-[22px] font-bold text-gray-800 mb-2">Thành công!</h2>
                            <p class="text-gray-500 text-[14px] text-center px-4 leading-relaxed">${data.message}</p>
                        </div>
                    `,
                    showConfirmButton: true,
                    confirmButtonText: 'Hoàn tất',
                    buttonsStyling: false,
                    customClass: {
                        popup: 'rounded-[24px] p-6 max-w-sm w-full shadow-2xl',
                        confirmButton: 'w-full bg-[#4F46E5] hover:bg-indigo-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all mt-4'
                    }
                }).then(() => {
                    window.location.reload(); // Reload to update application count/status
                });
            } else {
                Swal.fire({
                    html: `
                        <div class="flex flex-col items-center pt-4 pb-2">
                            <div class="w-20 h-20 rounded-full bg-red-50 flex items-center justify-center mb-6">
                                <svg class="w-10 h-10 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </div>
                            <h2 class="text-[22px] font-bold text-gray-800 mb-2">Không thành công</h2>
                            <p class="text-gray-500 text-[14px] text-center px-4 leading-relaxed">${data.message}</p>
                        </div>
                    `,
                    showConfirmButton: true,
                    confirmButtonText: 'Đã hiểu',
                    buttonsStyling: false,
                    customClass: {
                        popup: 'rounded-[24px] p-6 max-w-sm w-full shadow-2xl',
                        confirmButton: 'w-full bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3.5 px-6 rounded-xl transition-all mt-4'
                    }
                });
            }
        })
        .catch(err => {
            closeApplyModal();
            Swal.fire({
                html: `
                    <div class="flex flex-col items-center pt-4 pb-2">
                        <div class="w-20 h-20 rounded-full bg-red-50 flex items-center justify-center mb-6">
                            <svg class="w-10 h-10 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h2 class="text-[22px] font-bold text-gray-800 mb-2">Đã có lỗi xảy ra</h2>
                        <p class="text-gray-500 text-[14px] text-center px-4 leading-relaxed">Vui lòng thử lại sau ít phút.</p>
                    </div>
                `,
                showConfirmButton: true,
                confirmButtonText: 'Đóng',
                buttonsStyling: false,
                customClass: {
                    popup: 'rounded-[24px] p-6 max-w-sm w-full shadow-2xl',
                    confirmButton: 'w-full bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3.5 px-6 rounded-xl transition-all mt-4'
                }
            });
        })
        .finally(() => {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !document.getElementById('apply-modal').classList.contains('hidden')) {
            closeApplyModal();
        }
    });
</script>
