@{
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="container text-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <img src="~/images/403.png" alt="403 Forbidden" class="img-fluid mb-4" style="max-width: 300px;" onerror="this.src='https://cdn.iconscout.com/icon/free/png-256/free-403-forbidden-1144211.png'" />
            <h1 class="display-1 font-weight-bold text-primary">403</h1>
            <h2 class="mb-4">Không có quyền truy cập</h2>
            
            <p class="text-muted mb-4">
                Tài khoản của bạn không có quyền để truy cập trang này.
            </p>
            
            @if (ViewBag.Reason == "unassigned")
            {
                <div class="alert alert-warning">
                    Tài khoản Moderator của bạn chưa được phân công loại công việc nào. Vui lòng liên hệ Admin.
                </div>
            }
            else if (ViewBag.Reason == "wrong_task_type")
            {
                <div class="alert alert-danger">
                    Trang này yêu cầu quyền <strong>@ViewBag.Required</strong> nhưng bạn chỉ có quyền <strong>@ViewBag.Actual</strong>.
                </div>
            }

            <a href="/" class="btn btn-primary mt-3 px-4 py-2 rounded-pill shadow-sm">
                <i class="fas fa-home me-2"></i> Quay lại trang chủ
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary mt-3 px-4 py-2 rounded-pill shadow-sm ms-2">
                Quay lại trang trước
            </a>
        </div>
    </div>
</div>
