@{
    ViewData["Title"] = "Trang không tìm thấy";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevHub</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#4640DE',
                        dark: '#25324B',
                        muted: '#515B6F',
                        bordercolor: '#D6DDEB',
                        lightbg: '#F7F5FC'
                    },
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-white text-muted m-0 p-0 flex items-center justify-center min-h-screen">

<div class="w-full py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex flex-col md:flex-row items-center justify-between gap-12">
        <!-- Left Side: Text -->
        <div class="flex-1 text-left">
            <h1 class="text-[56px] md:text-[64px] font-bold text-dark mb-2 tracking-tight">Oops....</h1>
            <h2 class="text-[28px] md:text-[32px] font-semibold text-dark mb-4">Trang không tìm thấy</h2>
            <p class="text-muted text-[15px] md:text-[16px] mb-8 max-w-sm leading-relaxed">
                Trang này không tồn tại hoặc đã bị xóa!<br />
                Chúng tôi khuyên bạn quay lại trang chủ.
            </p>
            <div class="flex flex-col sm:flex-row items-center gap-4">
                <a href="javascript:history.back()" class="w-full sm:w-auto bg-[#4640DE] text-white px-8 py-3 rounded-full hover:bg-opacity-90 transition-all font-medium flex items-center justify-center gap-2 text-[15px] shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Quay lại trang trước
                </a>
                <a href="/" class="w-full sm:w-auto border border-[#4640DE] text-[#4640DE] px-8 py-3 rounded-full hover:bg-primary/5 transition-all font-medium flex items-center justify-center gap-2 text-[15px] shadow-sm hover:shadow-md transform hover:-translate-y-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    Trang chủ
                </a>
            </div>
        </div>
        
        <!-- Right Side: Illustration -->
        <div class="flex-1 flex justify-center w-full relative">
            <img src="~/images/404-1.png" 
                 alt="404 Not Found" 
                 class="w-full max-w-[600px] object-contain animate-float drop-shadow-xl" 
                 onerror="this.src='https://illustrations.popsy.co/amber/404-error.svg'" />
        </div>
    </div>
</div>
</body>
</html>
