@model DevHub.Models.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<section id="hero-section" class="relative overflow-hidden pb-0" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.18), transparent 35%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
        <div class="flex flex-col lg:flex-row items-end justify-between gap-12 pt-12 pb-0 lg:pt-20 lg:pb-0">
            <!-- Left Content -->
            <div class="w-full lg:w-1/2 relative z-20 pb-16 lg:pb-20">
                <h1 class="text-5xl md:text-[72px] font-bold text-dark leading-[1.1] mb-6">
                    <span class="text-[#25324B]">Khám phá</span> <br class="hidden md:block" />
                    <span class="text-[#25324B]">hơn</span> <span class="text-[#26A4FF]">5000+</span> <br class="hidden md:block" />
                    <span class="text-[#26A4FF] relative inline-block">
                        công việc
                        <img src="~/images/hero-underline.png" alt="Underline" class="absolute -bottom-8 left-0 w-full pointer-events-none" />
                    </span>
                </h1>
                
                <p class="text-lg md:text-xl text-muted mb-10 max-w-[500px] leading-relaxed mt-16">
                    Nền tảng tuyệt vời dành cho những người tìm việc đang tìm kiếm những bước tiến mới trong sự nghiệp và đam mê với các startup.
                </p>

                <!-- Search Bar -->
                <form action="/Jobs" method="GET" class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(139,92,246,0.3)] hover:shadow-[0_20px_50px_-15px_rgba(139,92,246,0.4)] transition-shadow duration-300 md:rounded-full rounded-3xl flex flex-col md:flex-row gap-3 w-full lg:w-[200%] lg:-mr-[100%] max-w-none relative z-30 items-center border border-purple-100"
                      onsubmit="this.querySelectorAll('input[type=text]').forEach(i => i.value = i.value.trim())">
                    <div class="flex-1 flex items-center px-4 py-2 border-b md:border-b-0 md:border-r border-gray-200 w-full">
                        <svg class="w-6 h-6 text-gray-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        <input type="text" name="keyword" placeholder="Chức danh công việc hoặc từ khóa." class="w-full focus:outline-none text-dark placeholder-gray-400 font-inter text-base truncate" />
                    </div>
                    
                    <div class="flex-1 flex items-center px-4 py-2 relative w-full" id="location-wrapper">
                        <svg class="w-6 h-6 text-gray-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="filterLocation" id="location-input" placeholder="TP Hà Nội" class="w-full focus:outline-none text-dark placeholder-gray-400 font-inter text-base pr-8 truncate" autocomplete="off" />
                        <!-- Caret down icon -->
                        <svg id="location-caret" class="w-4 h-4 text-gray-400 absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        <!-- Custom Dropdown -->
                        <div id="location-dropdown" class="hidden absolute top-full left-0 right-0 mt-2 bg-white border border-gray-200 rounded-xl shadow-lg z-50 max-h-52 overflow-y-auto">
                        </div>
                    </div>

                    <button type="submit" class="bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] w-full md:w-auto flex-shrink-0 shadow-md">
                        Tìm kiếm việc làm
                    </button>
                </form>

                <div class="mt-6 text-base font-inter">
                    <span class="text-muted">Gợi ý : </span>
                    <a href="/Jobs?keyword=UI Designer" class="text-dark font-medium hover:text-primary transition-colors">UI Designer</a>, 
                    <a href="/Jobs?keyword=UX Researcher" class="text-dark font-medium hover:text-primary transition-colors">UX Researcher</a>, 
                    <a href="/Jobs?keyword=Android" class="text-dark font-medium hover:text-primary transition-colors">Android</a>, 
                    <a href="/Jobs?keyword=Admin" class="text-dark font-medium hover:text-primary transition-colors">Admin</a>
                </div>
            </div>

            <!-- Right Image -->
            <div class="w-full lg:w-1/2 flex justify-center lg:justify-end items-end relative z-10 lg:-ml-32">
                <div class="relative w-full max-w-lg aspect-auto z-10 flex justify-center lg:justify-end items-end">
                    <!-- Isometric Outline Plane from Figma -->
                    <img src="~/images/hero-person.png" alt="Người tìm việc" class="w-full max-w-[450px] object-contain drop-shadow-2xl translate-y-0 relative z-10 align-bottom" style="margin-bottom: 0;" />
                </div>
            </div>
        </div>
    </div>
</section>


<!-- Việc làm nổi bật (Featured Jobs) -->
<section class="py-24 bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
            <h2 class="text-4xl md:text-5xl font-bold text-dark leading-tight">
                Việc làm <span class="text-[#26A4FF]">nổi bật</span>
            </h2>
            <a href="/Jobs" class="text-primary font-bold flex items-center hover:underline group text-lg transition-all">
                Hiển thị tất cả việc làm
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>
        
        <!-- Job Cards Grid (3 columns, 2 rows) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (Model != null && Model.FeaturedJobs != null && Model.FeaturedJobs.Any())
            {
                foreach (var job in Model.FeaturedJobs)
                {
                    <div class="border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 rounded-[20px] bg-white hover:shadow-[0_15px_40px_rgba(70,64,222,0.14)] hover:border-primary transition-all duration-300 flex flex-col h-full cursor-pointer" onclick="window.location='/Jobs/Details/@job.JobId'">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 flex items-center justify-center">
                                @if (job.Company != null && !string.IsNullOrEmpty(job.Company.CompanyLogoUrl))
                                {
                                    <img src="@job.Company.CompanyLogoUrl" alt="@job.Company.CompanyName" class="w-full h-full object-contain rounded" />
                                }
                                else
                                {
                                    <span class="font-bold text-3xl text-dark italic">@(!string.IsNullOrWhiteSpace(job.Company?.CompanyName) ? job.Company.CompanyName.Substring(0, 1) : "C")</span>
                                }
                            </div>
                            @{
                                bool isBookmarked = Model?.BookmarkedJobIds?.Contains(job.JobId) == true;
                                bool isAuth = User.Identity?.IsAuthenticated == true;
                            }
                            <div data-is-authenticated="@isAuth.ToString().ToLower()">
                                <button type="button"
                                        class="bookmark-btn transition-all @(isBookmarked ? "text-primary" : "text-[#4640DE] hover:opacity-80")"
                                        data-job-id="@job.JobId"
                                        data-bookmarked="@isBookmarked.ToString().ToLower()"
                                        title="@(isBookmarked ? "Bỏ lưu việc làm" : "Lưu việc làm")">
                                    <svg class="w-6 h-6" fill="@(isBookmarked ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                                </button>
                            </div>
                        </div>
                        
                        <h3 class="text-lg font-bold text-dark mb-1 hover:text-primary transition-colors cursor-pointer line-clamp-2">@job.Title</h3>
                        <div class="flex items-center text-muted text-sm gap-2 mb-4 font-inter">
                            <span class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg> @job.Company?.CompanyName</span>
                            <span>•</span>
                            <span class="truncate max-w-[120px]">@(job.Location ?? "Không xác định")</span>
                        </div>
                        
                        <p class="text-[#26A4FF] font-semibold text-sm mb-4 flex items-center">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            @(job.SalaryMax > 0 ? $"{job.SalaryMin?.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))} - {job.SalaryMax?.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))} VND" : "Thỏa thuận")
                        </p>
                        
                        <div class="flex flex-wrap gap-2 mt-auto">
                            <span class="border border-[#56CDAD] text-[#56CDAD] px-3 py-1 text-xs rounded-full font-medium font-inter bg-white">@job.WorkingModel</span>
                            @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                            {
                                <span class="border border-[#FFB836] text-[#FFB836] px-3 py-1 text-xs rounded-full font-medium font-inter bg-white">@job.ExperienceLevel</span>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-1 md:col-span-2 lg:col-span-3 text-center py-10">
                    <p class="text-gray-500">Hiện tại chưa có công việc nổi bật nào.</p>
                </div>
            }
    </div>
</section>


<!-- Công ty nổi bật -->
<section class="py-24 relative overflow-hidden" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 25% 50%, rgba(139, 92, 246, 0.15), transparent 40%), radial-gradient(circle at 75% 80%, rgba(100, 80, 230, 0.1), transparent 40%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
            <h2 class="text-4xl md:text-5xl font-bold text-dark leading-tight">
                Công ty <span class="text-[#26A4FF]">nổi bật</span>
            </h2>
            <a href="/Company/Search" class="text-primary font-semibold flex items-center hover:underline group transition-all">
                Hiện tất cả
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-5">
            @if (Model != null && Model.FeaturedCompanies != null && Model.FeaturedCompanies.Any())
            {
                foreach (var company in Model.FeaturedCompanies)
                {
                    <div class="bg-white border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] flex flex-col items-center text-center hover:shadow-[0_15px_40px_rgba(70,64,222,0.14)] hover:border-primary transition-all duration-300 group overflow-hidden h-[286px]">
                        <!-- Top: Logo + Name → Company Detail -->
                        <a href="/Company/Detail/@company.RecruiterId" class="flex flex-col items-center px-5 pt-8 pb-5 flex-1 justify-center w-full">
                            <div class="w-[113px] h-[113px] rounded-3xl bg-dark flex items-center justify-center mb-5 shadow-md group-hover:scale-105 transition-transform duration-300 flex-shrink-0 overflow-hidden">
                                @if (!string.IsNullOrEmpty(company.CompanyLogoUrl))
                                {
                                    <img src="@company.CompanyLogoUrl" alt="@company.CompanyName" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <span class="text-white font-bold text-3xl leading-tight text-center tracking-wide">@(!string.IsNullOrWhiteSpace(company.CompanyName) ? company.CompanyName.Substring(0, 1) : "C")</span>
                                }
                            </div>
                            <h3 class="text-[16px] font-semibold text-[#121212] leading-snug line-clamp-2">@company.CompanyName</h3>
                        </a>
                        <!-- Bottom: Jobs count → All Jobs -->
                        <a href="/Jobs?recruiterId=@company.RecruiterId" class="bg-[#F8F8F8] px-6 py-4 flex items-center justify-center text-[#121212] text-sm font-semibold w-full hover:bg-gray-100 transition-colors">
                            @company.JobCount việc đang tuyển
                            <svg class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform text-[#121212]" fill="none" stroke="#121212" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-span-2 md:col-span-4 text-center py-10">
                    <p class="text-gray-500">Hiện tại chưa có công ty nổi bật nào.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Bài viết nổi bật -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
            <h2 class="text-4xl md:text-5xl font-bold text-dark leading-tight">
                Bài viết nổi bật
            </h2>
            <a href="/CareerHandbook" class="text-[#4640DE] font-bold flex items-center hover:underline group text-lg transition-all">
                Xem tất cả bài viết
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
        </div>

        <div class="flex flex-col lg:flex-row gap-6">
            @if (Model != null && Model.FeaturedBlogs != null && Model.FeaturedBlogs.Any())
            {
                var mainBlog = Model.FeaturedBlogs.First();
                var otherBlogs = Model.FeaturedBlogs.Skip(1).ToList();

                <!-- Left Large Article -->
                <div class="w-full lg:w-1/2 flex flex-col border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] overflow-hidden hover:shadow-lg transition-shadow bg-white">
                    <img src="@(string.IsNullOrEmpty(mainBlog.ThumbnailUrl) ? "https://picsum.photos/seed/blog1/800/500" : mainBlog.ThumbnailUrl)" alt="@mainBlog.Title" class="w-full aspect-[16/10] object-cover" />
                    <div class="p-8 flex flex-col flex-grow">
                        <h3 class="text-2xl font-bold text-dark mb-4 hover:text-primary transition-colors cursor-pointer" onclick="window.location='/CareerHandbook/@mainBlog.Slug'">@mainBlog.Title</h3>
                        <p class="text-muted text-base mb-6 font-inter leading-relaxed line-clamp-3">
                            @(string.IsNullOrEmpty(mainBlog.Content) ? "" : System.Text.RegularExpressions.Regex.Replace(mainBlog.Content, "<.*?>", string.Empty))
                        </p>
                        <a href="/CareerHandbook/@mainBlog.Slug" class="text-[#4640DE] font-bold mt-auto flex items-center hover:underline group text-base">
                            Đọc ngay
                            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </div>
                </div>

                @if (otherBlogs.Any())
                {
                    <!-- Right Small Articles -->
                    <div class="w-full lg:w-1/2 grid @(otherBlogs.Count <= 2 ? "grid-cols-1 sm:grid-cols-2" : "grid-cols-1 sm:grid-cols-2") auto-rows-fr gap-6">
                        @foreach(var blog in otherBlogs)
                        {
                            var excerpt = string.IsNullOrEmpty(blog.Content)
                                ? ""
                                : System.Text.RegularExpressions.Regex.Replace(blog.Content, "<.*?>", string.Empty);
                            if (excerpt.Length > 90) excerpt = excerpt.Substring(0, 90).TrimEnd() + "...";

                            <div class="flex flex-col border border-gray-200 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-[20px] overflow-hidden hover:shadow-lg transition-shadow bg-white">
                                <img src="@(string.IsNullOrEmpty(blog.ThumbnailUrl) ? "https://picsum.photos/seed/blog" + blog.BlogId + "/400/200" : blog.ThumbnailUrl)" alt="@blog.Title" class="w-full h-36 object-cover" />
                                <div class="p-5 flex flex-col flex-grow">
                                    <h4 class="text-base font-bold text-dark mb-2 line-clamp-2 hover:text-primary transition-colors cursor-pointer" onclick="window.location='/CareerHandbook/@blog.Slug'">@blog.Title</h4>
                                    @if (!string.IsNullOrEmpty(excerpt))
                                    {
                                        <p class="text-muted text-xs font-inter leading-relaxed mb-3 line-clamp-2">@excerpt</p>
                                    }
                                    <a href="/CareerHandbook/@blog.Slug" class="text-[#4640DE] font-bold mt-auto flex items-center hover:underline group text-sm">
                                        Đọc ngay
                                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="w-full text-center py-10">
                    <p class="text-gray-500">Hiện tại chưa có bài viết nổi bật nào.</p>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <!-- Toast container -->
    <div id="bookmark-toast" class="fixed bottom-6 right-6 z-50 hidden">
        <div class="bg-white border border-[#D6DDEB] shadow-xl rounded-2xl px-5 py-4 flex items-center gap-3 min-w-[280px]">
            <div id="bookmark-toast-icon" class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0"></div>
            <p id="bookmark-toast-msg" class="text-[14px] font-medium text-dark"></p>
        </div>
    </div>

    <script>
        (function () {
            function showToast(message, type) {
                const toast   = document.getElementById('bookmark-toast');
                const msg     = document.getElementById('bookmark-toast-msg');
                const iconBox = document.getElementById('bookmark-toast-icon');
                msg.textContent = message;
                iconBox.className = type === 'success'
                    ? 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-primary/10 text-primary'
                    : 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-red-50 text-red-500';
                toast.classList.remove('hidden');
                setTimeout(() => toast.classList.add('hidden'), 2500);
            }

            document.querySelectorAll('.bookmark-btn').forEach(btn => {
                btn.addEventListener('click', async function (e) {
                    e.stopPropagation(); // Không mở trang chi tiết khi click bookmark

                    const wrapper = btn.closest('[data-is-authenticated]');
                    const isAuth  = wrapper && wrapper.dataset.isAuthenticated === 'true';

                    if (!isAuth) {
                        showToast('Vui lòng đăng nhập để lưu việc làm', 'error');
                        setTimeout(() => { window.location.href = '/Auth/Login'; }, 2000);
                        return;
                    }

                    const jobId = btn.dataset.jobId;
                    try {
                        const res  = await fetch(`/candidate/bookmarks/toggle?jobId=${jobId}`, { method: 'POST' });
                        if (!res.ok) throw new Error();
                        const data = await res.json();

                        const svg = btn.querySelector('svg');
                        if (data.isBookmarked) {
                            btn.dataset.bookmarked = 'true';
                            btn.title = 'Bỏ lưu việc làm';
                            svg.setAttribute('fill', 'currentColor');
                            showToast('Đã lưu việc làm thành công!', 'success');
                        } else {
                            btn.dataset.bookmarked = 'false';
                            btn.title = 'Lưu việc làm';
                            svg.setAttribute('fill', 'none');
                            showToast('Đã bỏ lưu việc làm', 'success');
                        }
                    } catch {
                        showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                    }
                });
            });
        })();
    </script>
}

<script>
(function () {
    let allProvinces = [];
    const input = document.getElementById('location-input');
    const dropdown = document.getElementById('location-dropdown');
    const caret = document.getElementById('location-caret');

    fetch('https://provinces.open-api.vn/api/p/')
        .then(r => r.json())
        .then(data => {
            allProvinces = data.map(p => p.name.replace(/^(Tỉnh|Thành phố)\s+/i, ''));
        })
        .catch(() => {});

    function renderList(items) {
        dropdown.innerHTML = '';
        items.forEach(name => {
            const div = document.createElement('div');
            div.textContent = name;
            div.className = 'px-4 py-2 text-sm text-dark hover:bg-primary/5 hover:text-primary cursor-pointer';
            div.addEventListener('mousedown', e => {
                e.preventDefault();
                input.value = name;
                closeDropdown();
            });
            dropdown.appendChild(div);
        });
    }

    function openDropdown(filter) {
        const q = (filter || '').toLowerCase();
        const list = q ? allProvinces.filter(n => n.toLowerCase().includes(q)) : allProvinces;
        renderList(list);
        dropdown.classList.remove('hidden');
        caret.style.transform = 'translateY(-50%) rotate(180deg)';
    }

    function closeDropdown() {
        dropdown.classList.add('hidden');
        caret.style.transform = '';
    }

    input.addEventListener('focus', () => openDropdown(input.value));
    input.addEventListener('input', () => openDropdown(input.value));
    input.addEventListener('blur', () => setTimeout(closeDropdown, 150));
    caret.addEventListener('click', () => {
        if (dropdown.classList.contains('hidden')) {
            input.focus();
            openDropdown(input.value);
        } else {
            closeDropdown();
        }
    });
})();
</script>
