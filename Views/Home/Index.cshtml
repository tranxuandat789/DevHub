@{
    ViewData["Title"] = "Trang chủ";
}

<section id="hero-section" class="relative overflow-hidden pb-0" style="background-color: #F7F5FF; background-image: radial-gradient(circle at 75% 35%, rgba(139, 92, 246, 0.18), transparent 35%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
        <div class="flex flex-col lg:flex-row items-end justify-between gap-12 pt-12 pb-0 lg:pt-20 lg:pb-0">
            <!-- Left Content -->
            <div class="w-full lg:w-1/2 relative z-20 pb-16 lg:pb-20">
                <h1 class="text-5xl md:text-[72px] font-bold text-dark leading-[1.1] mb-6">
                    <span class="text-[#25324B]">Khám phá</span> <br class="hidden md:block" />
                    <span class="text-[#25324B]">hơn</span> <span class="text-[#26A4FF]">5000+</span> <br class="hidden md:block" />
                    <span class="text-[#26A4FF] relative inline-block">
                        công việc
                        <img src="~/images/hero-underline.png" alt="Underline" class="absolute -bottom-8 left-0 w-full pointer-events-none" />
                    </span>
                </h1>
                
                <p class="text-lg md:text-xl text-muted mb-10 max-w-[500px] leading-relaxed mt-16">
                    Nền tảng tuyệt vời dành cho những người tìm việc đang tìm kiếm những bước tiến mới trong sự nghiệp và đam mê với các startup.
                </p>

                <!-- Search Bar -->
                <div class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(139,92,246,0.3)] hover:shadow-[0_20px_50px_-15px_rgba(139,92,246,0.4)] transition-shadow duration-300 md:rounded-full rounded-3xl flex flex-col md:flex-row gap-3 w-full lg:w-[200%] lg:-mr-[100%] max-w-none relative z-30 items-center border border-purple-100">
                    <div class="flex-1 flex items-center px-4 py-2 border-b md:border-b-0 md:border-r border-gray-200 w-full">
                        <svg class="w-6 h-6 text-gray-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        <input type="text" placeholder="Chức danh công việc hoặc từ khóa." class="w-full focus:outline-none text-dark placeholder-gray-400 font-inter text-base truncate" />
                    </div>
                    
                    <div class="flex-1 flex items-center px-4 py-2 relative w-full">
                        <svg class="w-6 h-6 text-gray-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" placeholder="TP Hà Nội" class="w-full focus:outline-none text-dark placeholder-gray-400 font-inter text-base pr-8 truncate" />
                        <!-- Caret down icon -->
                        <svg class="w-4 h-4 text-gray-400 absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </div>

                    <button class="bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] w-full md:w-auto flex-shrink-0 shadow-md">
                        Tìm kiếm việc làm
                    </button>
                </div>

                <div class="mt-6 text-base font-inter">
                    <span class="text-muted">Gợi ý : </span>
                    <a href="#" class="text-dark font-medium hover:text-primary transition-colors">UI Designer</a>, 
                    <a href="#" class="text-dark font-medium hover:text-primary transition-colors">UX Researcher</a>, 
                    <a href="#" class="text-dark font-medium hover:text-primary transition-colors">Android</a>, 
                    <a href="#" class="text-dark font-medium hover:text-primary transition-colors">Admin</a>
                </div>
            </div>

            <!-- Right Image -->
            <div class="w-full lg:w-1/2 flex justify-center lg:justify-end items-end relative z-10 lg:-ml-32">
                <div class="relative w-full max-w-lg aspect-auto z-10 flex justify-center lg:justify-end items-end">
                    <!-- Isometric Outline Plane from Figma -->
                    <img src="~/images/hero-person.png" alt="Người tìm việc" class="w-full max-w-[450px] object-contain drop-shadow-2xl translate-y-0 relative z-10 align-bottom" style="margin-bottom: 0;" />
                </div>
            </div>
        </div>
    </div>
</section>


