@model DevHub.Models.Article
@{
    ViewData["Title"] = "Chi tiết Bài viết";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <a href="/ModeratorArticle" class="p-2 text-gray-500 hover:text-primary hover:bg-blue-50 rounded-full transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Chi tiết Bài viết NTD</h1>
            <p class="text-muted mt-1 text-sm">Xem nội dung bài đăng của @(Model.Company?.CompanyName ?? "Công ty")</p>
        </div>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <!-- Header/Cover Image -->
    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
    {
        <div class="w-full h-64 md:h-80 relative bg-gray-100">
            <img src="@Model.ThumbnailUrl" alt="Thumbnail" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6 md:p-8 w-full text-white">
                <div class="flex items-center gap-3 mb-3">
                    @if (Model.Status == "APPROVED")
                    {
                        <span class="px-3 py-1 text-xs font-medium bg-green-500/20 text-green-100 border border-green-500/30 rounded-full backdrop-blur-sm">Đã duyệt</span>
                    }
                    else if (Model.Status == "PENDING")
                    {
                        <span class="px-3 py-1 text-xs font-medium bg-yellow-500/20 text-yellow-100 border border-yellow-500/30 rounded-full backdrop-blur-sm">Chờ duyệt</span>
                    }
                    else
                    {
                        <span class="px-3 py-1 text-xs font-medium bg-red-500/20 text-red-100 border border-red-500/30 rounded-full backdrop-blur-sm">Đã từ chối</span>
                    }
                    <span class="text-sm text-gray-200">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold leading-tight">@Model.Title</h2>
            </div>
        </div>
    }
    else
    {
        <div class="p-6 md:p-8 border-b border-gray-100">
            <div class="flex items-center gap-3 mb-4">
                @if (Model.Status == "APPROVED")
                {
                    <span class="px-3 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">Đã duyệt</span>
                }
                else if (Model.Status == "PENDING")
                {
                    <span class="px-3 py-1 text-xs font-medium bg-yellow-100 text-yellow-700 rounded-full">Chờ duyệt</span>
                }
                else
                {
                    <span class="px-3 py-1 text-xs font-medium bg-red-100 text-red-700 rounded-full">Đã từ chối</span>
                }
                <span class="text-sm text-gray-500">Đăng ngày: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">@Model.Title</h2>
        </div>
    }

    <!-- Content Body -->
    <div class="grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-gray-100">
        <!-- Main Content -->
        <div class="col-span-2 p-6 md:p-8 prose prose-blue max-w-none">
            @if (!string.IsNullOrEmpty(Model.Content))
            {
                @Html.Raw(Model.Content)
            }
            else
            {
                <p class="text-gray-500 italic">Bài viết này không có nội dung.</p>
            }
        </div>

        <!-- Sidebar Info -->
        <div class="col-span-1 bg-gray-50/50 p-6 md:p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-6">Thông tin chi tiết</h3>
            
            <div class="space-y-6">
                <!-- Company Info -->
                <div>
                    <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3">Nhà tuyển dụng</h4>
                    <div class="flex items-center gap-3">
                        @if (Model.Company != null && !string.IsNullOrEmpty(Model.Company.CompanyLogoUrl))
                        {
                            <img src="@Model.Company.CompanyLogoUrl" alt="Logo" class="w-12 h-12 rounded-lg object-cover border border-gray-200" />
                        }
                        else
                        {
                            <div class="w-12 h-12 rounded-lg bg-blue-100 text-primary flex items-center justify-center font-bold text-xl">
                                @(Model.Company?.CompanyName?.Substring(0, 1) ?? "C")
                            </div>
                        }
                        <div>
                            <p class="font-bold text-gray-900">@(Model.Company?.CompanyName ?? "N/A")</p>
                            @if (Model.Company != null && !string.IsNullOrEmpty(Model.Company.Industry))
                            {
                                <p class="text-sm text-gray-500">@Model.Company.Industry</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Timestamps -->
                <div class="pt-6 border-t border-gray-200">
                    <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3">Thời gian</h4>
                    <ul class="space-y-3 text-sm">
                        <li class="flex justify-between">
                            <span class="text-gray-500">Ngày tạo:</span>
                            <span class="font-medium text-gray-900">@(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                        </li>
                        <li class="flex justify-between">
                            <span class="text-gray-500">Cập nhật cuối:</span>
                            <span class="font-medium text-gray-900">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                        </li>
                        @if (Model.Status == "APPROVED" && Model.ApprovedAt.HasValue)
                        {
                            <li class="flex justify-between">
                                <span class="text-gray-500">Ngày duyệt:</span>
                                <span class="font-medium text-green-600">@Model.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </li>
                        }
                    </ul>
                </div>

                <!-- Rejection info if rejected -->
                @if (Model.Status == "REJECTED" && !string.IsNullOrEmpty(Model.RejectReason))
                {
                    <div class="pt-6 border-t border-gray-200">
                        <h4 class="text-sm font-medium text-red-500 uppercase tracking-wider mb-2">Lý do từ chối</h4>
                        <div class="bg-red-50 border border-red-100 rounded-lg p-4 text-sm text-red-800">
                            @Model.RejectReason
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
