@{
    ViewData["Title"] = "Tao Bai Blog";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="mb-8">
    <a href="/ModeratorBlog" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">Tạo bài viết mới</h1>
    <p class="text-muted">Soạn thảo và xuất bản bài viết chia sẻ kiến thức trên nền tảng JobHuntly.</p>
</div>

<form onsubmit="event.preventDefault(); submitPost();" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Cột trái: Nội dung chính -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Tiêu đề bài viết <span class="text-red-500">*</span></label>
                <input type="text" placeholder="Nhập tiêu đề hấp dẫn..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark text-lg font-medium" required>
            </div>

            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Nội dung chi tiết <span class="text-red-500">*</span></label>
                <!-- Toolbar giả lập Rich Text -->
                <div class="border border-[#D6DDEB] border-b-0 rounded-t-lg bg-gray-50 px-3 py-2 flex gap-2">
                    <button type="button" class="p-1.5 text-gray-600 hover:bg-gray-200 rounded"><span class="font-bold">B</span></button>
                    <button type="button" class="p-1.5 text-gray-600 hover:bg-gray-200 rounded"><span class="italic">I</span></button>
                    <button type="button" class="p-1.5 text-gray-600 hover:bg-gray-200 rounded underline">U</button>
                    <div class="w-px h-6 bg-gray-300 mx-1 self-center"></div>
                    <button type="button" class="p-1.5 text-gray-600 hover:bg-gray-200 rounded">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                    </button>
                    <button type="button" class="p-1.5 text-gray-600 hover:bg-gray-200 rounded">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </button>
                </div>
                <textarea rows="15" placeholder="Viết nội dung bài viết ở đây..." class="w-full border border-[#D6DDEB] rounded-b-lg p-4 focus:outline-none focus:border-primary text-dark leading-relaxed resize-y" required></textarea>
            </div>
        </div>
    </div>

    <!-- Cột phải: Cài đặt và Publish -->
    <div class="space-y-6">
        <!-- Publish Action -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Hành động</h3>
            <div class="flex flex-col gap-3">
                <button type="button" onclick="saveDraft()" class="w-full bg-gray-100 text-dark font-bold px-4 py-3 rounded-lg hover:bg-gray-200 transition-all border border-gray-200">
                    Lưu Bản Nháp
                </button>
                <button type="submit" class="w-full bg-primary text-white font-bold px-4 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                    Đăng Bài Viết
                </button>
            </div>
        </div>

        <!-- Meta info -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Thông tin phụ</h3>
            
            <div class="mb-4">
                <label class="block text-dark font-medium mb-2 text-sm">Tác giả</label>
                <input type="text" value="Admin Vũ" class="w-full border border-[#D6DDEB] rounded-lg px-3 py-2 focus:outline-none focus:border-primary text-muted bg-gray-50" readonly>
                <p class="text-xs text-gray-400 mt-1">Tác giả tự động lấy theo user đang đăng nhập.</p>
            </div>

            <div class="mb-4">
                <label class="block text-dark font-medium mb-2 text-sm">Danh mục / Thể loại</label>
                <select class="w-full border border-[#D6DDEB] rounded-lg px-3 py-2.5 focus:outline-none focus:border-primary text-dark">
                    <option value="tech">Công nghệ thông tin</option>
                    <option value="career">Kỹ năng mềm</option>
                    <option value="news">Tin tức tuyển dụng</option>
                </select>
            </div>

            <div class="mb-2">
                <label class="block text-dark font-medium mb-2 text-sm">Thêm Tags</label>
                <input type="text" placeholder="Ví dụ: #CSharp, #React (Nhấn Enter)" class="w-full border border-[#D6DDEB] rounded-lg px-3 py-2 focus:outline-none focus:border-primary text-dark mb-2">
                <div class="flex flex-wrap gap-2">
                    <span class="bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full text-xs flex items-center gap-1">
                        .NET <button type="button" class="text-gray-400 hover:text-red-500"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                    </span>
                </div>
            </div>
        </div>

        <!-- Thumbnail -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Ảnh bìa (Thumbnail)</h3>
            
            <div class="border-2 border-dashed border-[#D6DDEB] rounded-lg p-6 flex flex-col items-center justify-center text-center cursor-pointer hover:bg-gray-50 transition-colors">
                <svg class="w-10 h-10 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <p class="text-sm text-dark font-medium mb-1">Click để tải ảnh lên</p>
                <p class="text-xs text-muted">Hoặc kéo thả file ảnh vào đây</p>
                <p class="text-[10px] text-gray-400 mt-2">Định dạng hỗ trợ: JPG, PNG, GIF</p>
            </div>
            
            <div class="mt-4">
                <label class="block text-dark font-medium mb-2 text-sm text-center">Hoặc dán URL ảnh</label>
                <input type="url" placeholder="https://..." class="w-full border border-[#D6DDEB] rounded-lg px-3 py-2 focus:outline-none focus:border-primary text-dark text-sm">
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function saveDraft() {
            // Giả lập lưu bản nháp
            alert('Đã lưu bản nháp thành công! Hệ thống đã ghi log: "Saved Draft"');
        }

        function submitPost() {
            // Giả lập đăng bài
            alert('Đăng bài viết thành công! Hệ thống đã ghi log: "Published Post"');
            window.location.href = '/ModeratorBlog';
        }
    </script>
}
