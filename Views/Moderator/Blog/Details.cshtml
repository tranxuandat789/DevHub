@model DevHub.Models.BlogPost
@{
    ViewData["Title"] = "Xem trước bài viết";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-8 border border-[#D6DDEB]">
    <div class="flex justify-between items-center mb-6">
        <a href="/ModeratorBlog/Index" class="text-primary hover:underline flex items-center gap-2 font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
        <div class="flex items-center gap-2">
            @if (Model.Status == 1)
            {
                <span class="bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full border border-green-200">Đã xuất bản</span>
            }
            else if (Model.Status == 2)
            {
                <span class="bg-red-100 text-red-800 text-xs font-bold px-3 py-1 rounded-full border border-red-200">Đã ẩn</span>
            }
            else
            {
                <span class="bg-yellow-100 text-yellow-800 text-xs font-bold px-3 py-1 rounded-full border border-yellow-200">Bản nháp</span>
            }
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold text-dark mb-4 leading-tight">@Model.Title</h1>
        
        <div class="flex items-center gap-4 text-sm text-muted mb-8 border-b border-gray-100 pb-6">
            @if (!string.IsNullOrEmpty(Model.Tag))
            {
                <span class="bg-gray-100 px-3 py-1 rounded-md font-medium text-dark">@Model.Tag</span>
            }
            <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span>@(Model.PublishedAt?.ToString("dd/MM/yyyy HH:mm") ?? Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <div class="mb-10 rounded-2xl overflow-hidden shadow-md">
                <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="w-full h-auto max-h-[500px] object-cover" />
            </div>
        }

        <!-- Nội dung Blog -->
        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed
            prose-headings:font-bold prose-headings:text-dark 
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-img:rounded-xl prose-img:shadow-sm">
            @Html.Raw(Model.Content)
        </div>
    </div>
</div>
