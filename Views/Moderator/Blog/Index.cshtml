@{
    ViewData["Title"] = "Quan Ly Blog";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Blog & Tin tức</h1>
        <p class="text-muted">Quản lý các bài viết chia sẻ kiến thức và công nghệ.</p>
    </div>
    <a href="/ModeratorBlog/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo bài viết mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Danh mục</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả danh mục</option>
                <option value="tech">Công nghệ thông tin</option>
                <option value="career">Kỹ năng mềm</option>
                <option value="news">Tin tức tuyển dụng</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Từ ngày</label>
            <input type="date" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest">Ngày đăng (Mới nhất)</option>
                <option value="oldest">Ngày đăng (Cũ nhất)</option>
                <option value="views">Lượt xem (Nhiều nhất)</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[800px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Bài viết</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Ngày tạo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-24">Lượt xem</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-40">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Row 1 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#101</td>
                    <td class="py-4 px-6 flex items-center gap-4">
                        <img src="https://via.placeholder.com/80x50" alt="Thumbnail" class="w-16 h-10 object-cover rounded shadow-sm border border-gray-200" />
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Hướng dẫn phỏng vấn .NET</div>
                            <div class="text-xs text-muted mt-1 flex gap-2">
                                <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Công nghệ</span>
                                <span>Bởi: Admin Vũ</span>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-muted">24/05/2026</td>
                    <td class="py-4 px-6 text-muted">1,245</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Đã xuất bản
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorBlog/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleVisibility(101)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors" title="Ẩn bài viết">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                        </button>
                        <button onclick="deletePost(101)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Xóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </td>
                </tr>
                
                <!-- Row 2 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#102</td>
                    <td class="py-4 px-6 flex items-center gap-4">
                        <div class="w-16 h-10 bg-gray-200 rounded flex items-center justify-center border border-gray-300">
                             <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Cách tối ưu CV lập trình viên</div>
                            <div class="text-xs text-muted mt-1 flex gap-2">
                                <span class="bg-purple-100 text-purple-700 px-2 py-0.5 rounded">Kỹ năng mềm</span>
                                <span>Bởi: Trân Xuân</span>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-muted">22/05/2026</td>
                    <td class="py-4 px-6 text-muted">0</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            Bản nháp
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorBlog/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="deletePost(102)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Xóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 2 của 2 bài viết
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleVisibility(id) {
            if (confirm(`Bạn có muốn ẩn bài viết #${id} khỏi trang chủ không? Hành động này sẽ được ghi log.`)) {
                alert(`Đã ẩn bài viết #${id}`);
            }
        }

        function deletePost(id) {
            if (confirm(`Cảnh báo: Bạn sắp xóa bài viết #${id}. Hành động này không thể hoàn tác và sẽ được ghi log.`)) {
                alert(`Đã xóa bài viết #${id}`);
            }
        }
    </script>
}
