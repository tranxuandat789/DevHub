@model IEnumerable<DevHub.Models.BlogPost>

@{
    ViewData["Title"] = "Quản lý Blog";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
    
    int currentPage = (ViewBag.CurrentPage as int?) ?? 1;
    int totalPages = (ViewBag.TotalPages as int?) ?? 1;
    int totalItems = (ViewBag.TotalItems as int?) ?? 0;
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Blog</h1>
        <p class="text-muted">Quản lý các bài blog của bạn trên hệ thống.</p>
    </div>
    <a href="/ModeratorBlog/Create" class="inline-flex items-center gap-2 bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-[0_4px_14px_rgba(37,99,235,0.39)]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo blog mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end" method="get" action="/ModeratorBlog">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Nhập tiêu đề..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Ngày tạo</label>
            <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select name="status" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Status))">Tất cả</option>
                <option value="1" selected="@(ViewBag.Status == "1")">Đã xuất bản</option>
                <option value="0" selected="@(ViewBag.Status == "0")">Bản nháp</option>
                <option value="2" selected="@(ViewBag.Status == "2")">Ẩn</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select name="sortBy" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest" selected="@(ViewBag.SortBy == "newest")">Ngày đăng (Mới nhất)</option>
                <option value="oldest" selected="@(ViewBag.SortBy == "oldest")">Ngày đăng (Cũ nhất)</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Bài viết</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Ngày tạo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-56">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-48">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @{ int rowIndex = 0; }
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        rowIndex++;
                        <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 text-muted font-medium">@rowIndex</td>
                            <td class="py-4 px-6 flex items-center gap-4">
                                @if(!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="Thumbnail" class="w-16 h-10 object-cover rounded shadow-sm border border-gray-200" />
                                }
                                else
                                {
                                    <div class="w-16 h-10 bg-gray-200 rounded flex items-center justify-center border border-gray-300">
                                         <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    </div>
                                }
                                <div>
                                    <a href="/CareerHandbook/@item.Slug" target="_blank" class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1 block">@item.Title</a>
                                    <div class="text-xs text-muted mt-1 flex gap-2">
                                        <span>Bởi: @(item.Publisher?.FullName ?? "Bạn")</span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-4 text-muted">@item.CreatedAt?.ToString("dd/MM/yyyy")</td>
                            <td class="py-4 px-4 whitespace-nowrap">
                                @if (item.Status == 1)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium whitespace-nowrap bg-green-100 text-green-800">
                                        Đã xuất bản
                                    </span>
                                }
                                else if (item.Status == 2 || item.Status == 5)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium whitespace-nowrap bg-gray-100 text-gray-800">
                                        Ẩn
                                    </span>
                                }
                                else if (item.Status == 0)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium whitespace-nowrap bg-yellow-100 text-yellow-800">
                                        Bản nháp
                                    </span>
                                }
                            <td class="py-4 px-3 text-center whitespace-nowrap">
                                <a href="/CareerHandbook/@item.Slug" target="_blank" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Xem trước">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                </a>
                                <a href="/ModeratorBlog/Edit/@item.BlogId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-orange-50 text-orange-600 hover:bg-orange-100 transition-colors" title="Chỉnh sửa">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                @if (item.Status == 1)
                                {
                                    <button onclick="toggleVisibility(@item.BlogId, 'hide')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-50 text-gray-600 hover:bg-gray-100 transition-colors" title="Ẩn bài viết">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                                    </button>
                                }
                                else
                                {
                                    <button onclick="toggleVisibility(@item.BlogId, 'show')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Xuất bản">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    </button>
                                }
                                <button onclick="openDeleteModal(@item.BlogId)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Xóa bài viết">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-4 text-center text-muted">Không có bài viết nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị @((currentPage - 1) * 10 + 1) đến @(Math.Min(currentPage * 10, totalItems)) của @totalItems bài viết
        </div>
        <div class="flex space-x-1">
            <a href="?page=@(currentPage - 1)&keyword=@ViewBag.Keyword&status=@ViewBag.Status&dateFrom=@ViewBag.DateFrom&sortBy=@ViewBag.SortBy" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">Trang trước</a>
            
            @for(int i = 1; i <= totalPages; i++)
            {
                <a href="?page=@i&keyword=@ViewBag.Keyword&status=@ViewBag.Status&dateFrom=@ViewBag.DateFrom&sortBy=@ViewBag.SortBy" class="px-3 py-1 @(i == currentPage ? "bg-primary text-white" : "border border-[#D6DDEB] text-muted hover:bg-gray-50") rounded">@i</a>
            }
            
            <a href="?page=@(currentPage + 1)&keyword=@ViewBag.Keyword&status=@ViewBag.Status&dateFrom=@ViewBag.DateFrom&sortBy=@ViewBag.SortBy" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">Trang sau</a>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="fixed inset-0 bg-black bg-opacity-40 z-[60] hidden flex items-center justify-center">
    <div class="bg-white rounded-xl p-6 flex flex-col items-center gap-3 shadow-xl">
        <svg class="animate-spin h-10 w-10 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
        <p id="loadingText" class="text-dark font-medium">Đang xử lý...</p>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <h3 class="text-xl font-bold text-dark mb-2">Xóa bài viết</h3>
        <p class="text-sm text-muted mb-4">Bạn có chắc chắn muốn xóa bài viết này không? Hành động này không thể hoàn tác.</p>
        <form id="deleteForm" onsubmit="submitDelete(event)">
            <input type="hidden" id="deleteBlogId" />
            <div class="flex justify-end gap-3">
                <button type="button" onclick="closeDeleteModal()" class="px-4 py-2 text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg font-medium transition-colors">Hủy</button>
                <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-bold transition-colors">Xác nhận xóa</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showLoading(text) {
            document.getElementById('loadingText').textContent = text || 'Đang xử lý...';
            document.getElementById('loadingOverlay').classList.remove('hidden');
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').classList.add('hidden');
        }

        async function toggleVisibility(id, action) {
            showLoading(action === 'show' ? 'Đang xuất bản...' : 'Đang ẩn...');
            try {
                const formData = new FormData();
                const response = await fetch(`/ModeratorBlog/ToggleVisibility/${id}`, {
                    method: 'POST',
                    body: formData
                });
                hideLoading();
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Đã xảy ra lỗi, vui lòng thử lại.');
                }
            } catch (error) {
                hideLoading();
                alert('Đã xảy ra lỗi, vui lòng thử lại.');
            }
        }

        function openDeleteModal(id) {
            document.getElementById('deleteBlogId').value = id;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        async function submitDelete(e) {
            e.preventDefault();
            const id = document.getElementById('deleteBlogId').value;
            closeDeleteModal();
            showLoading('Đang xóa...');
            try {
                const formData = new FormData();
                const response = await fetch(`/ModeratorBlog/Delete/${id}`, {
                    method: 'POST',
                    body: formData
                });
                hideLoading();
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Đã xảy ra lỗi, vui lòng thử lại.');
                }
            } catch (error) {
                hideLoading();
                alert('Đã xảy ra lỗi, vui lòng thử lại.');
            }
        }
    </script>
}
