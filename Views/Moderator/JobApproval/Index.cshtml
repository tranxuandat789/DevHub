@model DevHub.ViewModels.Moderator.JobApprovalViewModel
@{
    ViewData["Title"] = "Duyet Bai Dang";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";

    // Build a page URL that preserves the current filters.
    string PageUrl(int p) => Url.Action("Index", new
    {
        fromDate = Model.FromDate?.ToString("yyyy-MM-dd"),
        toDate = Model.ToDate?.ToString("yyyy-MM-dd"),
        sortOrder = Model.SortOrder,
        status = Model.Status,
        page = p
    }) ?? "#";
}

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Duyệt danh sách bài đăng</h1>
        <p class="text-muted">Quản lý và xét duyệt các bài đăng tuyển dụng đang chờ (Pending).</p>
    </div>
</div>
@if (ViewBag.ErrorMessage != null)
{
    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg flex items-center shadow-sm">
        <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>@ViewBag.ErrorMessage</span>
    </div>
}

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form method="GET" action="/moderator/job-approvals" class="flex flex-col md:flex-row gap-4 items-end">
        <div class="flex-1 w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Từ ngày</label>
            <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="flex-1 w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Đến ngày</label>
            <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="flex-1 w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select name="sortOrder" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest" selected="@(Model.SortOrder == "newest" || string.IsNullOrEmpty(Model.SortOrder))">Ngày tạo (Mới nhất)</option>
                <option value="oldest" selected="@(Model.SortOrder == "oldest")">Ngày tạo (Cũ nhất)</option>
            </select>
        </div>
        <div class="flex-1 w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select name="status" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="ALL" selected="@(Model.Status == "ALL")">Tất cả</option>
                <option value="PENDING" selected="@(string.IsNullOrEmpty(Model.Status) || Model.Status == "PENDING")">Chờ duyệt</option>
                <option value="APPROVED" selected="@(Model.Status == "APPROVED")">Đã duyệt</option>
                <option value="REJECTED" selected="@(Model.Status == "REJECTED")">Đã từ chối</option>
            </select>
        </div>
        <div>
            <button type="submit" class="bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tiêu đề công việc</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Nhà tuyển dụng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Ngày đăng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (Model != null && Model.JobPosts != null && Model.JobPosts.Any())
                {
                    foreach (var job in Model.JobPosts)
                    {
                        <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 text-muted font-medium">#@job.JobId</td>
                            <td class="py-4 px-6">
                                <div class="font-bold text-dark">@job.Title</div>
                                <div class="text-xs text-muted mt-1">@job.Location • @job.WorkingModel</div>
                            </td>
                            <td class="py-4 px-6 text-muted">@(job.Company?.CompanyName ?? "N/A")</td>
                            <td class="py-4 px-6 text-muted">@(job.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                            <td class="py-4 px-6">
                                @{
                                    var st = (job.Status ?? "Pending").ToUpper();
                                    string badgeClass = st switch
                                    {
                                        "APPROVED" => "bg-green-100 text-green-800",
                                        "REJECTED" => "bg-red-100 text-red-800",
                                        "CLOSED" => "bg-gray-100 text-gray-800",
                                        _ => "bg-yellow-100 text-yellow-800"
                                    };
                                    string statusText = st switch
                                    {
                                        "APPROVED" => "Đã duyệt",
                                        "REJECTED" => "Đã từ chối",
                                        "CLOSED" => "Đã đóng",
                                        "PENDING" => "Chờ duyệt",
                                        _ => char.ToUpper(st[0]) + st.Substring(1).ToLower()
                                    };
                                }
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @badgeClass">
                                    @statusText
                                </span>
                            </td>
                            <td class="py-4 px-6 text-center space-x-2 flex justify-center items-center">
                                <button onclick="openDetailModal(@job.JobId)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 text-blue-600 hover:bg-blue-200 transition-colors" title="Chi tiết">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                </button>
                                @if (st == "PENDING")
                                {
                                    <button onclick="openApproveModal(@job.JobId)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-100 text-green-600 hover:bg-green-200 transition-colors" title="Duyệt">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    </button>
                                    <button onclick="openRejectModal(@job.JobId)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-100 text-red-600 hover:bg-red-200 transition-colors" title="Từ chối">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-8 px-6 text-center text-muted">
                            Không có bài đăng nào đang chờ duyệt.
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

    <!-- Pagination -->
    @if (Model != null)
    {
        <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
            <div class="text-sm text-muted">
                Hiển thị <span class="font-medium text-dark">@Model.FromItem</span> đến <span class="font-medium text-dark">@Model.ToItem</span> của <span class="font-medium text-dark">@Model.TotalCount</span> kết quả
            </div>
        @if (Model.TotalPages > 1)
        {
            <div class="flex space-x-1">
                @if (Model.Page > 1)
                {
                    <a href="@PageUrl(Model.Page - 1)" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang trước</a>
                }
                else
                {
                    <span class="px-3 py-1 border border-[#D6DDEB] rounded text-muted opacity-50 cursor-not-allowed">Trang trước</span>
                }

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    if (p == Model.Page)
                    {
                        <span class="px-3 py-1 bg-primary text-white rounded">@p</span>
                    }
                    else
                    {
                        <a href="@PageUrl(p)" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">@p</a>
                    }
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a href="@PageUrl(Model.Page + 1)" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</a>
                }
                else
                {
                    <span class="px-3 py-1 border border-[#D6DDEB] rounded text-muted opacity-50 cursor-not-allowed">Trang sau</span>
                }
            </div>
        }
    </div>
    }
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="fixed inset-0 z-[200] hidden bg-black bg-opacity-50 flex items-center justify-center px-4">
    <div class="bg-white rounded-[20px] shadow-2xl w-full max-w-lg p-6 relative">
        <button onclick="closeRejectModal()" class="absolute top-4 right-4 text-gray-400 hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <h3 class="text-2xl font-bold text-dark mb-2">Từ chối bài đăng</h3>
        <p class="text-muted text-sm mb-6">Vui lòng cung cấp lý do từ chối bài đăng <span id="rejectJobId" class="font-bold"></span>.</p>
        
        <div class="mb-6">
            <label class="block text-dark font-medium mb-2">Lý do từ chối <span class="text-red-500">*</span></label>
            <textarea id="rejectReason" rows="4" class="w-full border border-[#D6DDEB] rounded-lg p-3 focus:outline-none focus:border-primary text-dark placeholder-gray-400" placeholder="Nhập lý do cụ thể..."></textarea>
        </div>
        
        <div class="flex justify-end space-x-3">
            <button onclick="closeRejectModal()" class="px-5 py-2.5 rounded-lg border border-[#D6DDEB] text-dark font-medium hover:bg-gray-50 transition-colors">Hủy bỏ</button>
            <button onclick="submitReject()" class="px-5 py-2.5 rounded-lg bg-red-600 text-white font-bold hover:bg-red-700 transition-colors shadow-sm">Xác nhận Từ chối</button>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div id="approveModal" class="fixed inset-0 z-[200] hidden bg-black bg-opacity-50 flex items-center justify-center px-4">
    <div class="bg-white rounded-[20px] shadow-2xl w-full max-w-sm p-6 relative">
        <button onclick="closeApproveModal()" class="absolute top-4 right-4 text-gray-400 hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <div class="text-center mb-6">
            <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-dark mb-2">Duyệt bài đăng</h3>
            <p class="text-muted text-sm">Bạn có chắc chắn muốn duyệt bài đăng <span id="approveJobId" class="font-bold"></span>?</p>
        </div>
        
        <div class="flex justify-end space-x-3">
            <button onclick="closeApproveModal()" class="flex-1 px-5 py-2.5 rounded-lg border border-[#D6DDEB] text-dark font-medium hover:bg-gray-50 transition-colors">Hủy bỏ</button>
            <button onclick="submitApprove()" class="flex-1 px-5 py-2.5 rounded-lg bg-primary text-white font-bold hover:bg-opacity-90 transition-colors shadow-sm">Xác nhận</button>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div id="detailModal" class="fixed inset-0 z-[200] hidden bg-black bg-opacity-50 flex items-center justify-center px-4 py-8">
    <div class="bg-white rounded-[20px] shadow-2xl w-full max-w-4xl max-h-full overflow-y-auto p-6 relative">
        <button onclick="closeDetailModal()" class="absolute top-4 right-4 text-gray-400 hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <h3 class="text-2xl font-bold text-dark mb-6" id="detailTitle">Chi tiết bài đăng</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                <p class="text-sm text-gray-500 font-medium">Khu vực làm việc</p>
                <p class="text-dark font-semibold" id="detailLocation">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Hình thức làm việc</p>
                <p class="text-dark font-semibold" id="detailWorkingModel">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Mức lương</p>
                <p class="text-dark font-semibold" id="detailSalary">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Cấp bậc</p>
                <p class="text-dark font-semibold" id="detailExperienceLevel">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Kỹ năng</p>
                <p class="text-dark font-semibold" id="detailSkill">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Số lượng cần tuyển</p>
                <p class="text-dark font-semibold" id="detailHiringQuota">-</p>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-medium">Hạn nộp hồ sơ</p>
                <p class="text-red-500 font-bold" id="detailDeadline">-</p>
            </div>
        </div>

        <div class="space-y-6 border-t border-gray-200 pt-6">
            <div>
                <h4 class="text-lg font-bold text-dark mb-2">Mô tả công việc</h4>
                <div class="text-muted text-sm whitespace-pre-wrap" id="detailDescription"></div>
            </div>
            <div>
                <h4 class="text-lg font-bold text-dark mb-2">Yêu cầu ứng viên</h4>
                <div class="text-muted text-sm whitespace-pre-wrap" id="detailRequirement"></div>
            </div>
            <div>
                <h4 class="text-lg font-bold text-dark mb-2">Quyền lợi</h4>
                <div class="text-muted text-sm whitespace-pre-wrap" id="detailBenefit"></div>
            </div>
        </div>
        
        <div class="flex justify-end space-x-3 mt-8 border-t border-gray-200 pt-6">
            <button onclick="closeDetailModal()" class="px-5 py-2.5 rounded-lg border border-[#D6DDEB] text-dark font-medium hover:bg-gray-50 transition-colors">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentRejectId = null;

        async function openDetailModal(id) {
            try {
                const res = await fetch(`/moderator/job-approvals/detail/${id}`);
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('detailTitle').innerText = data.title || "Chi tiết công việc";
                    document.getElementById('detailLocation').innerText = data.location || "-";
                    document.getElementById('detailWorkingModel').innerText = data.workingModel || "-";
                    document.getElementById('detailExperienceLevel').innerText = data.experienceLevel || "-";
                    document.getElementById('detailSkill').innerText = data.skill || "-";
                    document.getElementById('detailHiringQuota').innerText = data.hiringQuota ? `${data.hiringQuota} người` : "Không giới hạn";
                    document.getElementById('detailDeadline').innerText = data.deadline || "Không thời hạn";
                    
                    let salary = "Thỏa thuận";
                    if (data.salaryMin != null && data.salaryMax != null) salary = `$${data.salaryMin} - $${data.salaryMax}`;
                    else if (data.salaryMin != null) salary = `Từ $${data.salaryMin}`;
                    else if (data.salaryMax != null) salary = `Lên đến $${data.salaryMax}`;
                    document.getElementById('detailSalary').innerText = salary;

                    document.getElementById('detailDescription').innerHTML = data.description || "<i>Chưa cập nhật</i>";
                    document.getElementById('detailRequirement').innerHTML = data.requirement || "<i>Chưa cập nhật</i>";
                    document.getElementById('detailBenefit').innerHTML = data.benefit || "<i>Chưa cập nhật</i>";

                    document.getElementById('detailModal').classList.remove('hidden');
                } else {
                    alert('Không thể lấy thông tin chi tiết bài đăng.');
                }
            } catch (e) {
                console.error(e);
                alert('Có lỗi xảy ra.');
            }
        }

        function closeDetailModal() {
            document.getElementById('detailModal').classList.add('hidden');
        }

        let currentApproveId = null;

        function openApproveModal(id) {
            currentApproveId = id;
            document.getElementById('approveJobId').innerText = `#${id}`;
            document.getElementById('approveModal').classList.remove('hidden');
        }

        function closeApproveModal() {
            document.getElementById('approveModal').classList.add('hidden');
            currentApproveId = null;
        }

        async function submitApprove() {
            if (!currentApproveId) return;
            const btn = document.querySelector('#approveModal button.bg-primary');
            const originalText = btn.innerText;
            btn.innerText = 'Đang xử lý...';
            btn.disabled = true;
            
            try {
                const response = await fetch(`/moderator/job-approvals/approve/${currentApproveId}`, { method: 'POST' });
                if (response.ok) {
                    window.location.reload();
                } else {
                    // Mute error or show in UI, no alert
                    console.error("Lỗi khi duyệt bài đăng.");
                    btn.innerText = 'Thử lại';
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                btn.innerText = 'Thử lại';
                btn.disabled = false;
            }
        }

        function openRejectModal(id) {
            currentRejectId = id;
            document.getElementById('rejectJobId').innerText = `#${id}`;
            document.getElementById('rejectReason').value = '';
            document.getElementById('rejectModal').classList.remove('hidden');
        }

        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            currentRejectId = null;
        }

        async function submitReject() {
            const reason = document.getElementById('rejectReason').value.trim();
            if (!reason) {
                // Focus thay vì alert
                document.getElementById('rejectReason').focus();
                return;
            }
            
            const btn = document.querySelector('#rejectModal button.bg-red-600');
            const originalText = btn.innerText;
            btn.innerText = 'Đang xử lý...';
            btn.disabled = true;
            
            try {
                const formData = new FormData();
                formData.append('reason', reason);
                const response = await fetch(`/moderator/job-approvals/reject/${currentRejectId}`, {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    window.location.reload();
                } else {
                    console.error("Lỗi khi từ chối bài đăng.");
                    btn.innerText = 'Thử lại';
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                btn.innerText = 'Thử lại';
                btn.disabled = false;
            }
        }
    </script>
}
