@model IEnumerable<DevHub.Models.CommonJobPosition>
@{
    ViewData["Title"] = "Quan Ly Job Position";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Vị trí Tuyển dụng</h1>
        <p class="text-muted">Định nghĩa các vị trí (Job Position) chuẩn trên hệ thống (VD: Developer, Tester, Designer...).</p>
    </div>
    <a href="/ModeratorPosition/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Vị trí mới
    </a>
</div>
@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded-r-lg shadow-sm">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <p class="text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    </div>
}

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form method="get" action="/ModeratorPosition" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div class="w-full md:col-span-2">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm vị trí</label>
            <input type="text" name="keyword" value="@ViewData["Keyword"]" placeholder="Nhập tên vị trí (Ví dụ: Frontend Developer)..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select name="status" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="" selected="@(ViewData["Status"]?.ToString() == "" ? "selected" : null)">Tất cả</option>
                <option value="1" selected="@(ViewData["Status"]?.ToString() == "1" ? "selected" : null)">Đang hoạt động</option>
                <option value="0" selected="@(ViewData["Status"]?.ToString() == "0" ? "selected" : null)">Tạm ẩn</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[700px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-20">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tên Vị Trí (Position Name)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-40">Ngày tạo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-40">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (Model != null && Model.Any())
                {
                    foreach (var pos in Model)
                    {
                        bool isActive = pos.IsActive ?? true;
                        <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 text-muted font-medium">#@pos.PositionId</td>
                            <td class="py-4 px-6">
                                <div class="font-bold text-dark text-base">@pos.PositionName</div>
                            </td>
                            <td class="py-4 px-6 text-muted">@(pos.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                            <td class="py-4 px-6">
                                @if (isActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Tạm ẩn</span>
                                }
                            </td>
                            <td class="py-4 px-6 text-center space-x-1">
                                <a href="/ModeratorPosition/edit/@pos.PositionId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                <button onclick="toggleStatus(@pos.PositionId, this)" class="inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors @(isActive ? "bg-gray-100 text-gray-600 hover:bg-gray-200" : "bg-green-50 text-green-600 hover:bg-green-100")" title="@(isActive ? "Vô hiệu hóa" : "Hiển thị lại")">
                                    @if (isActive)
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="py-8 px-6 text-center text-muted">Không tìm thấy vị trí tuyển dụng nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-[#D6DDEB] flex flex-col md:flex-row items-center justify-between bg-gray-50 gap-4">
            <span class="text-sm text-muted">
                Hiển thị trang <span class="font-bold text-dark">@ViewBag.CurrentPage</span> / @ViewBag.TotalPages 
                (Tổng số <span class="font-bold text-dark">@ViewBag.TotalItems</span> vị trí)
            </span>
            <div class="flex gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@(ViewBag.CurrentPage - 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang trước</a>
                }
                
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@i" class="px-3 py-1 border rounded text-sm font-medium transition-colors @(i == ViewBag.CurrentPage ? "bg-primary text-white border-primary" : "bg-white border-[#D6DDEB] text-dark hover:bg-gray-100")">@i</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@(ViewBag.CurrentPage + 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang sau</a>
                }
            </div>
        </div>
    }
</div>
</div>

@section Scripts {
    <script>
        async function toggleStatus(id, btnElement) {
            try {
                const response = await fetch(`/ModeratorPosition/toggle-status/${id}`, {
                    method: 'POST'
                });
                
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Có lỗi xảy ra khi thay đổi trạng thái.');
                }
            } catch (error) {
                console.error(error);
                alert('Có lỗi xảy ra.');
            }
        }
    </script>
}
