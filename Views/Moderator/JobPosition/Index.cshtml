@model IEnumerable<DevHub.Models.CommonJobPosition>
@{
    ViewData["Title"] = "Quản Lý Vị Trí Công Việc";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Vị trí Tuyển dụng</h1>
        <p class="text-muted">Định nghĩa các vị trí (Job Position) chuẩn trên hệ thống (VD: Developer, Tester, Designer...).</p>
    </div>
    <a href="/ModeratorPosition/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Vị trí mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form method="get" action="/moderator/job-positions" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div class="w-full md:col-span-2">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm vị trí</label>
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Nhập tên vị trí (Ví dụ: Frontend Developer)..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select name="status" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Status) ? "selected" : null)">Tất cả</option>
                <option value="1" selected="@(ViewBag.Status == "1" ? "selected" : null)">Đang hoạt động</option>
                <option value="0" selected="@(ViewBag.Status == "0" ? "selected" : null)">Tạm ẩn</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[700px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-20">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tên Vị Trí (Position Name)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-40">Ngày tạo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-40">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @foreach (var item in Model)
                {
                    <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                        <td class="py-4 px-6 text-muted font-medium">#@item.PositionId</td>
                        <td class="py-4 px-6">
                            <div class="font-bold text-dark text-base">@item.PositionName</div>
                        </td>
                        <td class="py-4 px-6 text-muted">@(item.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="py-4 px-6">
                            @if (item.IsActive == true)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                    Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                    Tạm ẩn
                                </span>
                            }
                        </td>
                        <td class="py-4 px-6 text-center space-x-1">
                            <a href="/moderator/job-positions/edit/@item.PositionId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            </a>
                            <button onclick="toggleStatus(@item.PositionId)" class="inline-flex items-center justify-center w-8 h-8 rounded-full @(item.IsActive == true ? "bg-gray-100 text-gray-600 hover:bg-gray-200" : "bg-green-50 text-green-600 hover:bg-green-100") transition-colors" title="@(item.IsActive == true ? "Vô hiệu hóa" : "Hiển thị lại")">
                                @if (item.IsActive == true)
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                                }
                                else
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                }
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 3 của 45 Vị trí
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">2</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">3</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('@TempData["SuccessMessage"]', 'success');
            });
            </text>
        }

        async function toggleStatus(id) {
            if (await showConfirm(`Bạn có chắc muốn thay đổi trạng thái của Vị trí #${id}?`)) {
                try {
                    const response = await fetch(`/moderator/job-positions/toggle-status/${id}`, {
                        method: 'POST'
                    });
                    if (response.ok) {
                        showToast(`Đã cập nhật trạng thái Vị trí #${id}!`, 'success');
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        showToast('Có lỗi xảy ra khi cập nhật!', 'error');
                    }
                } catch (error) {
                    showToast('Lỗi kết nối server!', 'error');
                }
            }
        }
    </script>
}
