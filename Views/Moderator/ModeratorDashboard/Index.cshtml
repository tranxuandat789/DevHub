@{
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
    ViewData["Title"] = "Moderator Dashboard";
    var taskType = ViewBag.TaskType as string;
}

<div class="p-6 md:p-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-dark mb-2">Xin chào, Moderator!</h1>
        <p class="text-muted">Chào mừng bạn đến với hệ thống quản lý kiểm duyệt của DevHub.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-bordercolor p-8 mb-8 text-center">
        <div class="w-20 h-20 bg-blue-50 text-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
        </div>
        <h2 class="text-2xl font-bold text-dark mb-3">Thông tin vai trò</h2>
        <p class="text-lg text-muted mb-6">
            Vai trò của bạn hiện tại là: 
            <span class="font-bold text-primary">
                @(taskType == "COMPANY_APPROVAL" ? "Duyệt công ty" : 
                  taskType == "JOB_POST" ? "Duyệt bài đăng" : 
                  taskType == "REVIEW" ? "Duyệt đánh giá" : 
                  "Quản trị chung")
            </span>
        </p>

        <div class="flex justify-center gap-4">
            @if (string.IsNullOrEmpty(taskType) || taskType == "JOB_POST")
            {
                <a href="/moderator/job-approvals" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-opacity-90 transition font-medium shadow-sm">
                    Đi tới Duyệt bài đăng
                </a>
            }
            @if (string.IsNullOrEmpty(taskType) || taskType == "COMPANY_APPROVAL")
            {
                <a href="/moderator/company-approvals" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-opacity-90 transition font-medium shadow-sm">
                    Đi tới Duyệt công ty
                </a>
            }
            @if (string.IsNullOrEmpty(taskType) || taskType == "REVIEW")
            {
                <a href="/moderator/reviews" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-opacity-90 transition font-medium shadow-sm">
                    Đi tới Duyệt đánh giá
                </a>
            }
        </div>
    </div>
</div>
