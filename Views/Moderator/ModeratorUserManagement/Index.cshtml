@{
    Layout = "_ModeratorLayout";
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Người dùng</h1>
        <p class="text-muted">Theo dõi, kiểm tra báo cáo và xử lý các tài khoản vi phạm trong hệ thống.</p>
    </div>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" placeholder="Tên hoặc Email..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Vai trò</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả vai trò</option>
                <option value="candidate">Ứng viên (Candidate)</option>
                <option value="recruiter">Nhà tuyển dụng (Recruiter)</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="name_asc">Tên (A-Z)</option>
                <option value="name_desc">Tên (Z-A)</option>
                <option value="spending_desc">Chi tiêu (Cao đến thấp)</option>
                <option value="spending_asc">Chi tiêu (Thấp đến cao)</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Người dùng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Vai trò</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Chi tiêu (VNĐ)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-28">Báo cáo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-40">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Row 1: Candidate -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#501</td>
                    <td class="py-4 px-6 flex items-center gap-3">
                        <img src="https://i.pravatar.cc/150?img=11" alt="Avatar" class="w-10 h-10 object-cover rounded-full border border-gray-200" />
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Trần Nguyễn Cẩm Tiên</div>
                            <div class="text-xs text-muted mt-0.5">camtien@gmail.com</div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-blue-50 text-blue-700 px-2.5 py-1 rounded-md text-xs font-semibold">Ứng viên</span>
                    </td>
                    <td class="py-4 px-6 text-muted">-</td>
                    <td class="py-4 px-6">
                        <span class="text-muted font-medium">0</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Hoạt động
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <button onclick="viewReport(501)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors" title="Xem báo cáo">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        </button>
                        <button onclick="toggleLock(501, 'lock')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Khóa tài khoản">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        </button>
                    </td>
                </tr>
                
                <!-- Row 2: Recruiter -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#502</td>
                    <td class="py-4 px-6 flex items-center gap-3">
                        <img src="https://i.pravatar.cc/150?img=33" alt="Avatar" class="w-10 h-10 object-cover rounded-full border border-gray-200" />
                        <div>
                            <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">Lê Đình Vũ (FPT)</div>
                            <div class="text-xs text-muted mt-0.5">vule@fpt.com.vn</div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-purple-50 text-purple-700 px-2.5 py-1 rounded-md text-xs font-semibold">Nhà tuyển dụng</span>
                    </td>
                    <td class="py-4 px-6 font-bold text-dark">15,000,000</td>
                    <td class="py-4 px-6">
                        <span class="text-red-500 font-bold flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                            3
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            Bị Khóa
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <button onclick="viewReport(502)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors" title="Xem báo cáo">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        </button>
                        <button onclick="toggleLock(502, 'unlock')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Mở khóa tài khoản">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 2 của 25 người dùng
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">2</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">3</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>

<!-- Modal Xem Báo cáo -->
<div id="reportModal" class="fixed inset-0 z-[200] hidden bg-black bg-opacity-50 flex items-center justify-center px-4">
    <div class="bg-white rounded-[20px] shadow-2xl w-full max-w-2xl p-6 relative">
        <button onclick="closeReportModal()" class="absolute top-4 right-4 text-gray-400 hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <h3 class="text-2xl font-bold text-dark mb-2">Chi tiết Báo cáo</h3>
        <p class="text-muted text-sm mb-6">Danh sách các báo cáo vi phạm liên quan đến người dùng <span id="reportUserId" class="font-bold text-dark"></span>.</p>
        
        <div class="space-y-4 max-h-[60vh] overflow-y-auto mb-6">
            <!-- Mock Report Item -->
            <div class="p-4 border border-[#D6DDEB] rounded-lg bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <div class="font-bold text-dark">Hành vi lừa đảo</div>
                    <span class="text-xs text-muted">24/05/2026</span>
                </div>
                <p class="text-sm text-muted">Nhà tuyển dụng này yêu cầu ứng viên đóng phí trước khi phỏng vấn.</p>
                <div class="text-xs text-primary mt-2">Người báo cáo: #129 (Ứng viên ẩn danh)</div>
            </div>
            
            <div class="p-4 border border-[#D6DDEB] rounded-lg bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <div class="font-bold text-dark">Tin tuyển dụng sai sự thật</div>
                    <span class="text-xs text-muted">20/05/2026</span>
                </div>
                <p class="text-sm text-muted">Đăng mức lương 50 triệu nhưng thực tế chỉ offer 10 triệu.</p>
                <div class="text-xs text-primary mt-2">Người báo cáo: #344 (Phạm Văn A)</div>
            </div>
        </div>
        
        <div class="flex justify-end">
            <button onclick="closeReportModal()" class="px-5 py-2.5 rounded-lg border border-[#D6DDEB] text-dark font-medium hover:bg-gray-50 transition-colors">Đóng cửa sổ</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewReport(id) {
            document.getElementById('reportUserId').innerText = `#${id}`;
            document.getElementById('reportModal').classList.remove('hidden');
        }
        
        function closeReportModal() {
            document.getElementById('reportModal').classList.add('hidden');
        }

        function toggleLock(id, action) {
            if (action === 'lock') {
                if (confirm(`Cảnh báo: Bạn có chắc chắn muốn KHÓA tài khoản #${id} không? Người dùng này sẽ không thể đăng nhập. Hành động này sẽ được ghi log.`)) {
                    alert(`Đã KHÓA tài khoản #${id} thành công! Log đã được ghi nhận.`);
                }
            } else {
                if (confirm(`Bạn có muốn MỞ KHÓA tài khoản #${id}? Hành động này sẽ được ghi log.`)) {
                    alert(`Đã MỞ KHÓA tài khoản #${id} thành công! Log đã được ghi nhận.`);
                }
            }
        }
    </script>
}
