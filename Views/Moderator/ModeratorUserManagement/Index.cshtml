@model IEnumerable<DevHub.Models.UserAccount>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Người dùng</h1>
        <p class="text-muted">Theo dõi, kiểm tra báo cáo và xử lý các tài khoản vi phạm trong hệ thống.</p>
    </div>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form method="GET" action="/moderator/users" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Tên hoặc Email..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Vai trò</label>
            <select name="role" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả vai trò</option>
                <option value="Candidate" selected="@(ViewBag.Role == "Candidate" ? "selected" : null)">Ứng viên</option>
                <option value="Recruiter" selected="@(ViewBag.Role == "Recruiter" ? "selected" : null)">Nhà tuyển dụng</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select name="sort" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Mới nhất</option>
                <option value="name_asc" selected="@(ViewBag.Sort == "name_asc" ? "selected" : null)">Tên (A-Z)</option>
                <option value="name_desc" selected="@(ViewBag.Sort == "name_desc" ? "selected" : null)">Tên (Z-A)</option>
                <option value="spending_desc" selected="@(ViewBag.Sort == "spending_desc" ? "selected" : null)">Chi tiêu (Cao đến thấp)</option>
                <option value="spending_asc" selected="@(ViewBag.Sort == "spending_asc" ? "selected" : null)">Chi tiêu (Thấp đến cao)</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Người dùng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Vai trò</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Chi tiêu (VNĐ)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-28">Báo cáo</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-40">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="py-8 text-center text-muted">Không tìm thấy người dùng nào.</td>
                    </tr>
                }
                @{ int rowIndex = 1; }
                @foreach (var user in Model)
                {
                    var name = user.Email;
                    var imageUrl = "https://ui-avatars.com/api/?name=" + user.Email + "&background=random";
                    var spent = 0m;
                    var userType = user.UserType?.ToLower() ?? "";

                    if (userType == "candidate" && user.Candidate != null)
                    {
                        name = user.Candidate.FullName ?? user.Email;
                        if (!string.IsNullOrEmpty(user.Candidate.ImageUrl)) imageUrl = user.Candidate.ImageUrl;
                    }
                    else if (userType == "recruiter" && user.Recruiter != null)
                    {
                        name = user.Recruiter.Company?.CompanyName ?? user.Recruiter.FullName ?? user.Email;
                        if (!string.IsNullOrEmpty(user.Recruiter.Company?.CompanyLogoUrl)) imageUrl = user.Recruiter.Company?.CompanyLogoUrl;
                        spent = user.Recruiter.Company?.TotalSpent ?? 0;
                    }

                    var isActive = user.IsActive ?? true;

                    <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                        <td class="py-4 px-6 text-muted font-medium">@rowIndex</td>
                        <td class="py-4 px-6 flex items-center gap-3">
                            <img src="@imageUrl" alt="Avatar" class="w-10 h-10 object-cover rounded-full border border-gray-200" onerror="this.src='https://ui-avatars.com/api/?name=@(name)&background=random'" />
                            <div>
                                <div class="font-bold text-dark hover:text-primary cursor-pointer line-clamp-1">@name</div>
                                <div class="text-xs text-muted mt-0.5">@user.Email</div>
                            </div>
                        </td>
                        <td class="py-4 px-6">
                            @if (userType == "candidate")
                            {
                                <span class="whitespace-nowrap bg-blue-50 text-blue-700 px-2.5 py-1 rounded-md text-xs font-semibold">Ứng viên</span>
                            }
                            else if (userType == "recruiter")
                            {
                                <span class="whitespace-nowrap bg-purple-50 text-purple-700 px-2.5 py-1 rounded-md text-xs font-semibold">Nhà tuyển dụng</span>
                            }
                            else if (userType == "admin")
                            {
                                <span class="whitespace-nowrap bg-red-50 text-red-700 px-2.5 py-1 rounded-md text-xs font-semibold">Quản trị viên</span>
                            }
                            else if (userType == "moderator")
                            {
                                <span class="whitespace-nowrap bg-orange-50 text-orange-700 px-2.5 py-1 rounded-md text-xs font-semibold">Kiểm duyệt viên</span>
                            }
                            else
                            {
                                <span class="whitespace-nowrap bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-xs font-semibold">@user.UserType</span>
                            }
                        </td>
                        <td class="py-4 px-6 @(spent > 0 ? "font-bold text-dark" : "text-muted")">
                            @(spent > 0 ? string.Format("{0:N0}", spent) : "-")
                        </td>
                        <td class="py-4 px-6">
                            <span class="text-muted font-medium">0</span>
                        </td>
                        <td class="py-4 px-6">
                            @if (isActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                    Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                    Bị Khóa
                                </span>
                            }
                        </td>
                        <td class="py-4 px-6 text-center space-x-1">
                            <a href="/moderator/users/details/@user.UserId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Xem chi tiết">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                            </a>
                        </td>
                    </tr>
                    rowIndex++;
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="px-6 py-4 border-t border-[#D6DDEB] flex flex-col md:flex-row items-center justify-between bg-gray-50 gap-4">
        <span class="text-sm text-muted">
            Hiển thị trang <span class="font-bold text-dark">@ViewBag.CurrentPage</span> / @ViewBag.TotalPages 
            (Tổng số <span class="font-bold text-dark">@ViewBag.TotalItems</span> người dùng)
        </span>
        <div class="flex items-center gap-2">
            @if (ViewBag.CurrentPage > 1)
            {
                <a href="?search=@ViewBag.Search&role=@ViewBag.Role&sort=@ViewBag.Sort&page=@(ViewBag.CurrentPage - 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang trước</a>
            }
            
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="?search=@ViewBag.Search&role=@ViewBag.Role&sort=@ViewBag.Sort&page=@i" class="px-3 py-1 border rounded text-sm font-medium transition-colors @(i == ViewBag.CurrentPage ? "bg-primary text-white border-primary" : "bg-white border-[#D6DDEB] text-dark hover:bg-gray-100")">@i</a>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a href="?search=@ViewBag.Search&role=@ViewBag.Role&sort=@ViewBag.Sort&page=@(ViewBag.CurrentPage + 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang sau</a>
            }
        </div>
    </div>
}

<!-- Modal Xem Báo cáo -->
<div id="reportModal" class="fixed inset-0 z-[200] hidden bg-black bg-opacity-50 flex items-center justify-center px-4">
    <div class="bg-white rounded-[20px] shadow-2xl w-full max-w-2xl p-6 relative">
        <button onclick="closeReportModal()" class="absolute top-4 right-4 text-gray-400 hover:text-dark">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        
        <h3 class="text-2xl font-bold text-dark mb-2">Chi tiết Báo cáo</h3>
        <p class="text-muted text-sm mb-6">Danh sách các báo cáo vi phạm liên quan đến người dùng <span id="reportUserId" class="font-bold text-dark"></span>.</p>
        
        <div class="space-y-4 max-h-[60vh] overflow-y-auto mb-6">
            <!-- Mock Report Item -->
            <div class="p-4 border border-[#D6DDEB] rounded-lg bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <div class="font-bold text-dark">Chưa có báo cáo nào</div>
                    <span class="text-xs text-muted">Hôm nay</span>
                </div>
                <p class="text-sm text-muted">Người dùng này chưa vi phạm quy định nào của nền tảng.</p>
            </div>
        </div>
        
        <div class="flex justify-end">
            <button onclick="closeReportModal()" class="px-5 py-2.5 rounded-lg border border-[#D6DDEB] text-dark font-medium hover:bg-gray-50 transition-colors">Đóng cửa sổ</button>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function viewReport(id) {
            document.getElementById('reportUserId').innerText = `#${id}`;
            document.getElementById('reportModal').classList.remove('hidden');
        }
        
        function closeReportModal() {
            document.getElementById('reportModal').classList.add('hidden');
        }
    </script>
}
