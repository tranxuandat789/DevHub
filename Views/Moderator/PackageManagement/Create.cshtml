@{
    Layout = "_ModeratorLayout";
    ViewData["Title"] = "Thêm/Sửa Gói dịch vụ";
}

<div class="mb-8">
    <a href="/ModeratorPackage" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">Tạo / Chỉnh sửa Gói Dịch Vụ</h1>
    <p class="text-muted">Thiết lập cấu hình giá, thời hạn và quyền lợi cho gói dịch vụ tuyển dụng.</p>
</div>

<form onsubmit="event.preventDefault(); submitPackage();" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Cột trái: Thông tin chính -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Thông tin cơ bản</h3>
            
            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Tên gói dịch vụ <span class="text-red-500">*</span></label>
                <input type="text" placeholder="Ví dụ: Gói Cơ Bản, Gói Premium..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-dark font-bold mb-2">Giá (Coin) <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="number" min="0" placeholder="0" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-bold text-lg" required>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-muted font-medium">Coin</span>
                    </div>
                </div>
                <div>
                    <label class="block text-dark font-bold mb-2">Thời hạn sử dụng (Ngày) <span class="text-red-500">*</span></label>
                    <input type="number" min="1" placeholder="Ví dụ: 30" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark" required>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Giới hạn bài đăng <span class="text-red-500">*</span></label>
                <input type="number" min="1" placeholder="Ví dụ: 10 (để trống nếu không giới hạn)" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark">
                <p class="text-xs text-muted mt-1">Số lượng bài tuyển dụng được phép đăng trong thời gian hiệu lực.</p>
            </div>
            
            <div class="mb-2">
                <label class="block text-dark font-bold mb-2">Mô tả ngắn</label>
                <textarea rows="3" placeholder="Mô tả chung về gói này..." class="w-full border border-[#D6DDEB] rounded-lg p-3 focus:outline-none focus:border-primary text-dark resize-y"></textarea>
            </div>
        </div>
        
        <!-- Tính năng ưu tiên -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Tính năng ưu tiên hiển thị</h3>
            
            <div class="space-y-4">
                <label class="flex items-center gap-3 cursor-pointer p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                    <input type="checkbox" class="w-5 h-5 text-primary rounded focus:ring-primary">
                    <div>
                        <div class="font-bold text-dark">Đẩy lên Top tìm kiếm</div>
                        <div class="text-xs text-muted">Bài đăng sẽ luôn xuất hiện ở những trang đầu tiên khi ứng viên tìm việc.</div>
                    </div>
                </label>
                
                <label class="flex items-center gap-3 cursor-pointer p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                    <input type="checkbox" class="w-5 h-5 text-primary rounded focus:ring-primary">
                    <div>
                        <div class="font-bold text-dark">Gắn nhãn HOT</div>
                        <div class="text-xs text-muted">Hiển thị badge "HOT" nổi bật màu đỏ để thu hút sự chú ý.</div>
                    </div>
                </label>
                
                <label class="flex items-center gap-3 cursor-pointer p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                    <input type="checkbox" class="w-5 h-5 text-primary rounded focus:ring-primary">
                    <div>
                        <div class="font-bold text-dark">Làm nổi bật Background</div>
                        <div class="text-xs text-muted">Đổi màu nền thẻ bài đăng sang màu vàng nhạt hoặc viền primary.</div>
                    </div>
                </label>
            </div>
        </div>
    </div>

    <!-- Cột phải: Quyền lợi chi tiết & Lưu -->
    <div class="space-y-6">
        <!-- Publish Action -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Lưu hệ thống</h3>
            <div class="flex flex-col gap-3">
                <button type="submit" class="w-full bg-primary text-white font-bold px-4 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                    Lưu Gói Dịch Vụ
                </button>
                <a href="/ModeratorPackage" class="w-full block text-center bg-gray-100 text-dark font-bold px-4 py-3 rounded-lg hover:bg-gray-200 transition-all border border-gray-200">
                    Hủy Bỏ
                </a>
            </div>
            <p class="text-xs text-muted text-center mt-3">Mọi thay đổi sẽ được ghi log.</p>
        </div>

        <!-- Quyền lợi (Checklist) -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Quyền lợi hiển thị cho khách</h3>
            <p class="text-xs text-muted mb-4">Các gạch đầu dòng này sẽ hiển thị ở bảng giá cho Nhà tuyển dụng.</p>
            
            <div class="space-y-3 mb-4" id="benefitList">
                <div class="flex gap-2 items-center">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <input type="text" value="Đăng 10 bài tuyển dụng" class="w-full border-b border-[#D6DDEB] py-1 focus:outline-none focus:border-primary text-dark text-sm">
                    <button type="button" class="text-red-400 hover:text-red-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                </div>
                <div class="flex gap-2 items-center">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <input type="text" value="Hỗ trợ kỹ thuật 24/7" class="w-full border-b border-[#D6DDEB] py-1 focus:outline-none focus:border-primary text-dark text-sm">
                    <button type="button" class="text-red-400 hover:text-red-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                </div>
            </div>
            
            <button type="button" class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg> Thêm quyền lợi mới
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function submitPackage() {
            // Giả lập lưu thành công
            alert('Lưu gói dịch vụ thành công! Hệ thống đã ghi log cập nhật.');
            window.location.href = '/ModeratorPackage';
        }
    </script>
}
