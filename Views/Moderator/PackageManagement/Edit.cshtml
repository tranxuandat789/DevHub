@model DevHub.Models.ServicePackage
@{
    ViewData["Title"] = Model?.ServiceId > 0 ? "Chỉnh Sửa Gói Dịch Vụ" : "Tạo Gói Dịch Vụ";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="mb-8">
    <a href="/ModeratorPackage" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">@(Model?.ServiceId > 0 ? "Chỉnh sửa Gói Dịch Vụ" : "Tạo Gói Dịch Vụ mới")</h1>
    <p class="text-muted">Thiết lập cấu hình giá, thời hạn và quyền lợi cho gói dịch vụ tuyển dụng.</p>
</div>

<form method="post" action="@(Model?.ServiceId > 0 ? $"/ModeratorPackage/Edit/{Model.ServiceId}" : "/ModeratorPackage/Create")" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    @Html.AntiForgeryToken()
    @if (Model?.ServiceId > 0)
    {
        <input type="hidden" asp-for="ServiceId" />
        <input type="hidden" asp-for="IsActive" />
        <input type="hidden" asp-for="CreatedAt" />
    }

    <!-- Cột trái: Thông tin chính -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Thông tin cơ bản</h3>
            
            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Tên gói dịch vụ <span class="text-red-500">*</span></label>
                <input type="text" asp-for="PackageName" placeholder="Ví dụ: Gói Cơ Bản, Gói Premium..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>

            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Tiêu đề (Hiển thị) <span class="text-red-500">*</span></label>
                <input type="text" asp-for="Title" placeholder="Tuyển dụng thông thường..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-dark font-bold mb-2">Giá (VNĐ/Coin) <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="number" step="0.01" min="0" asp-for="Price" placeholder="0" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-bold text-lg" required>
                    </div>
                </div>
                <div>
                    <label class="block text-dark font-bold mb-2">Thời hạn sử dụng (Ngày) <span class="text-red-500">*</span></label>
                    <input type="number" min="0" asp-for="DurationDays" placeholder="Để trống hoặc 0 nếu vĩnh viễn" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-dark font-bold mb-2">Credit (Token)</label>
                    <input type="number" min="0" asp-for="Credit" placeholder="0" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium">
                </div>
                <div>
                    <label class="block text-dark font-bold mb-2">Giới hạn bài đăng <span class="text-red-500">*</span></label>
                    <input type="number" min="0" asp-for="MaxPosts" placeholder="Để 0 nếu không giới hạn" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark" required>
                </div>
            </div>
            
            <div class="mb-2">
                <label class="block text-dark font-bold mb-2">Mô tả ngắn</label>
                <textarea rows="3" asp-for="Description" placeholder="Mô tả chung về gói này..." class="w-full border border-[#D6DDEB] rounded-lg p-3 focus:outline-none focus:border-primary text-dark resize-y"></textarea>
            </div>
        </div>
        
        <!-- Tính năng ưu tiên -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Tính năng ưu tiên hiển thị</h3>
            
            <div class="space-y-4">
                <div class="mb-4">
                    <label class="block text-dark font-bold mb-2">Điểm ưu tiên Push (Priority Push)</label>
                    <input type="number" min="0" asp-for="PriorityPush" placeholder="0" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark">
                    <p class="text-xs text-muted mt-1">Bài đăng có điểm cao sẽ ưu tiên hiển thị lên Top.</p>
                </div>
                
                <label class="flex items-center gap-3 cursor-pointer p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                    <input type="checkbox" name="HasAiChatbot" value="true" @(Model?.HasAiChatbot == true ? "checked" : "") class="w-5 h-5 text-primary rounded focus:ring-primary">
                    <input type="hidden" name="HasAiChatbot" value="false">
                    <div>
                        <div class="font-bold text-dark">Tích hợp AI Chatbot</div>
                        <div class="text-xs text-muted">Hỗ trợ trả lời ứng viên tự động.</div>
                    </div>
                </label>
            </div>
        </div>
    </div>

    <!-- Cột phải: Lưu -->
    <div class="space-y-6">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Lưu hệ thống</h3>
            <div class="flex flex-col gap-3">
                <button type="submit" class="w-full bg-primary text-white font-bold px-4 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                    Lưu Gói Dịch Vụ
                </button>
                <a href="/ModeratorPackage" class="w-full block text-center bg-gray-100 text-dark font-bold px-4 py-3 rounded-lg hover:bg-gray-200 transition-all border border-gray-200">
                    Hủy Bỏ
                </a>
            </div>
        </div>
    </div>
</form>

@if (!ViewData.ModelState.IsValid)
{
    <div class="fixed bottom-4 right-4 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg">
        Vui lòng kiểm tra lại thông tin nhập!
    </div>
}
