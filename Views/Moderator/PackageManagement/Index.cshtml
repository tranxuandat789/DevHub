@{
    ViewData["Title"] = "Quan Ly Goi Dich Vu";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Gói dịch vụ</h1>
        <p class="text-muted">Xem, chỉnh sửa và quản lý các gói dịch vụ dành cho Nhà tuyển dụng.</p>
    </div>
    <a href="/ModeratorPackage/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Gói mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái gói</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả</option>
                <option value="active">Đang kích hoạt</option>
                <option value="inactive">Đã vô hiệu hóa</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="price_asc">Giá (Thấp đến cao)</option>
                <option value="price_desc">Giá (Cao đến thấp)</option>
                <option value="duration_desc">Thời hạn (Dài nhất)</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tên Gói</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-right">Giá (Coin)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Giới hạn bài</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Thời hạn (Ngày)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Row 1 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#10</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark">Gói Cơ Bản (Basic)</div>
                        <div class="text-xs text-muted mt-1 truncate max-w-xs">Tuyển dụng thông thường.</div>
                    </td>
                    <td class="py-4 px-6 text-right font-bold text-primary">500</td>
                    <td class="py-4 px-6 text-center text-muted">10 bài</td>
                    <td class="py-4 px-6 text-center text-muted">30 ngày</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Đang kích hoạt
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorPackage/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleStatus(10, 'deactivate')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Vô hiệu hóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </button>
                    </td>
                </tr>
                
                <!-- Row 2 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#11</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark">Gói Cao Cấp (Premium)</div>
                        <div class="text-xs text-muted mt-1 truncate max-w-xs">Gắn nhãn Hot, đẩy Top tìm kiếm.</div>
                    </td>
                    <td class="py-4 px-6 text-right font-bold text-primary">2,500</td>
                    <td class="py-4 px-6 text-center text-muted">Không giới hạn</td>
                    <td class="py-4 px-6 text-center text-muted">90 ngày</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            Vô hiệu hóa
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorPackage/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleStatus(11, 'activate')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Kích hoạt">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 2 của 2 gói dịch vụ
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(id, action) {
            if (action === 'deactivate') {
                if (confirm(`Bạn có chắc muốn vô hiệu hóa Gói #${id}? Khách hàng đã mua vẫn có thể dùng đến hết hạn. Hành động này sẽ được ghi log.`)) {
                    alert(`Đã vô hiệu hóa Gói #${id} thành công!`);
                }
            } else {
                if (confirm(`Bạn có muốn kích hoạt lại Gói #${id}? Hành động này sẽ được ghi log.`)) {
                    alert(`Đã kích hoạt Gói #${id} thành công!`);
                }
            }
        }
    </script>
}
