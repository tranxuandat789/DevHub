@model IEnumerable<DevHub.Models.ServicePackage>
@{
    ViewData["Title"] = "Quản Lý Gói Dịch Vụ";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalCount = ViewBag.TotalCount ?? 0;
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
    string searchTerm = ViewBag.SearchTerm ?? "";
    string statusFilter = ViewBag.StatusFilter ?? "all";
    string sortOrder = ViewBag.SortOrder ?? "newest";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Gói dịch vụ</h1>
        <p class="text-muted">Xem, chỉnh sửa và quản lý các gói dịch vụ dành cho Nhà tuyển dụng.</p>
    </div>
    <a href="/ModeratorPackage/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Gói mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" method="get" action="/ModeratorPackage">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" name="searchTerm" value="@searchTerm" placeholder="Tên gói..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái gói</label>
            <select name="statusFilter" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="all" selected="@(statusFilter == "all")">Tất cả</option>
                <option value="active" selected="@(statusFilter == "active")">Đang kích hoạt</option>
                <option value="inactive" selected="@(statusFilter == "inactive")">Đã vô hiệu hóa</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select name="sortOrder" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest" selected="@(sortOrder == "newest")">Mới nhất</option>
                <option value="price_asc" selected="@(sortOrder == "price_asc")">Giá (Thấp đến cao)</option>
                <option value="price_desc" selected="@(sortOrder == "price_desc")">Giá (Cao đến thấp)</option>
                <option value="duration_desc" selected="@(sortOrder == "duration_desc")">Thời hạn (Dài nhất)</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tên Gói</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-right">Giá</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Giới hạn bài</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Thời hạn</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 text-muted font-medium">#@item.ServiceId</td>
                            <td class="py-4 px-6">
                                <div class="font-bold text-dark">@item.PackageName</div>
                                <div class="text-xs text-muted mt-1 truncate max-w-xs">@item.Title</div>
                            </td>
                            <td class="py-4 px-6 text-right font-bold text-primary">@item.Price.ToString("N0")</td>
                            <td class="py-4 px-6 text-center text-muted">@(item.MaxPosts > 0 ? $"{item.MaxPosts} bài" : "Không giới hạn")</td>
                            <td class="py-4 px-6 text-center text-muted">@(item.DurationDays > 0 ? $"{item.DurationDays} ngày" : "Vĩnh viễn")</td>
                            <td class="py-4 px-6">
                                @if (item.IsActive == true)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Đang kích hoạt
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        Vô hiệu hóa
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-6 text-center space-x-1">
                                <a href="/ModeratorPackage/Edit/@item.ServiceId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                @if (item.IsActive == true)
                                {
                                    <form action="/moderator/packages/toggle-status/@item.ServiceId" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="activate" value="false" />
                                        <button type="button" onclick="showConfirmModal(this, 'Bạn có chắc muốn vô hiệu hóa Gói #@item.ServiceId? Khách hàng đã mua vẫn có thể dùng đến hết hạn.')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Vô hiệu hóa">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form action="/moderator/packages/toggle-status/@item.ServiceId" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="activate" value="true" />
                                        <button type="button" onclick="showConfirmModal(this, 'Bạn có muốn kích hoạt lại Gói #@item.ServiceId?')" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Kích hoạt">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="py-4 px-6 text-center text-muted">Không tìm thấy dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
            <div class="text-sm text-muted">
                Hiển thị trang @currentPage / @totalPages (@totalCount gói dịch vụ)
            </div>
            <div class="flex space-x-1">
                <a href="/ModeratorPackage?page=@(currentPage - 1)&searchTerm=@searchTerm&statusFilter=@statusFilter&sortOrder=@sortOrder" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")">Trang trước</a>
                
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="/ModeratorPackage?page=@i&searchTerm=@searchTerm&statusFilter=@statusFilter&sortOrder=@sortOrder" class="px-3 py-1 border border-[#D6DDEB] rounded @(i == currentPage ? "bg-primary text-white" : "text-muted hover:bg-gray-50")">@i</a>
                }

                <a href="/ModeratorPackage?page=@(currentPage + 1)&searchTerm=@searchTerm&statusFilter=@statusFilter&sortOrder=@sortOrder" class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")">Trang sau</a>
            </div>
        </div>
    }
</div>

<!-- Custom Confirm Modal -->
<div id="confirmModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black bg-opacity-50">
    <div class="bg-white rounded-[16px] p-6 max-w-sm w-full shadow-2xl transform transition-all">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-500 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-dark">Xác nhận</h3>
        </div>
        <p id="confirmMessage" class="text-muted text-sm mb-6"></p>
        <div class="flex justify-end gap-3">
            <button type="button" onclick="closeConfirmModal()" class="px-5 py-2.5 bg-gray-100 text-dark rounded-lg hover:bg-gray-200 font-bold transition-colors">Hủy</button>
            <button type="button" id="confirmBtn" class="px-5 py-2.5 bg-primary text-white rounded-lg hover:bg-opacity-90 font-bold transition-colors shadow-sm">Xác nhận</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentForm = null;
        function showConfirmModal(btn, message) {
            currentForm = btn.closest('form');
            document.getElementById('confirmMessage').innerText = message;
            const modal = document.getElementById('confirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        function closeConfirmModal() {
            const modal = document.getElementById('confirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            currentForm = null;
        }
        document.getElementById('confirmBtn').addEventListener('click', function() {
            if (currentForm) {
                currentForm.submit();
            }
        });
    </script>
}

@if (TempData["SuccessMsg"] != null)
{
    <div class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg">
        @TempData["SuccessMsg"]
    </div>
}
@if (TempData["ErrorMsg"] != null)
{
    <div class="fixed bottom-4 right-4 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg">
        @TempData["ErrorMsg"]
    </div>
}
