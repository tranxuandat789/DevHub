@{
    ViewData["Title"] = "Thêm mới Tỉnh/Thành phố";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Thêm Tỉnh/Thành phố mới</h1>
        <p class="text-muted">Nhập thông tin cho địa điểm mới.</p>
    </div>
    <a href="/ModeratorProvince" class="bg-white border border-[#D6DDEB] text-dark font-bold px-6 py-3 rounded-lg hover:bg-gray-50 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
</div>

<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden max-w-2xl">
    <div class="p-6 md:p-8">
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    <p class="text-red-700 font-medium">@ViewBag.ErrorMessage</p>
                </div>
            </div>
        }

        <form method="post" action="/ModeratorProvince/Create" class="space-y-6">
            <div>
                <label for="provinceName" class="block text-dark font-medium mb-2">Tên Tỉnh/Thành phố <span class="text-red-500">*</span></label>
                <input type="text" id="provinceName" name="provinceName" required placeholder="Ví dụ: Hà Nội, Hồ Chí Minh..." 
                       class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-muted transition-colors">
            </div>



            <div class="pt-4 border-t border-[#D6DDEB]">
                <button type="submit" class="bg-primary text-white font-bold px-8 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                    Lưu dữ liệu
                </button>
            </div>
        </form>
    </div>
</div>
