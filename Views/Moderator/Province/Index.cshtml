@model List<DevHub.Models.Province>
@{
    ViewData["Title"] = "Quản lý Tỉnh/Thành phố";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
    var keyword = ViewData["Keyword"] as string ?? "";
    var status = ViewData["Status"] as string ?? "";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Quản lý Tỉnh/Thành phố</h1>
        <p class="text-muted">Định nghĩa các tỉnh/thành phố để sử dụng cho mục địa điểm làm việc của ứng viên và bài đăng tuyển dụng.</p>
    </div>
    <a href="/ModeratorProvince/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Thêm Tỉnh/Thành phố
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded-r-lg">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <p class="text-green-700 font-medium">@TempData["SuccessMessage"]</p>
        </div>
    </div>
}

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form method="get" action="/ModeratorProvince" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div class="w-full md:col-span-2">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm tên</label>
            <input type="text" name="keyword" value="@keyword" placeholder="Nhập tên tỉnh/thành phố..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select name="status" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="" selected="@(status == "" ? "selected" : null)">Tất cả</option>
                <option value="1" selected="@(status == "1" ? "selected" : null)">Đang hoạt động</option>
                <option value="0" selected="@(status == "0" ? "selected" : null)">Tạm ngưng</option>
            </select>
        </div>
        <div>
            <button type="submit" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[700px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-20">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Tên Tỉnh/Thành phố</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-40">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (Model != null && Model.Any())
                {
                    foreach (var p in Model)
                    {
                        var isActive = p.IsActive;
                        <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 text-muted font-medium">#@p.ProvinceId</td>
                            <td class="py-4 px-6">
                                <div class="font-bold text-dark text-base">@p.ProvinceName</div>
                            </td>
                            <td class="py-4 px-6">
                                @if (isActive)
                                {
                                    <span id="status-badge-@p.ProvinceId" class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span id="status-badge-@p.ProvinceId" class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        Tạm ngưng
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-6 text-center">
                                <button onclick="toggleStatus(@p.ProvinceId, this)" class="inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors @(isActive ? "bg-red-50 text-red-600 hover:bg-red-100" : "bg-green-50 text-green-600 hover:bg-green-100")" title="@(isActive ? "Ngừng hoạt động" : "Kích hoạt")">
                                    @if (isActive)
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="py-8 text-center text-muted">Không tìm thấy tỉnh/thành phố nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-[#D6DDEB] flex flex-col md:flex-row items-center justify-between bg-gray-50 gap-4">
            <span class="text-sm text-muted">
                Hiển thị trang <span class="font-bold text-dark">@ViewBag.CurrentPage</span> / @ViewBag.TotalPages 
                (Tổng số <span class="font-bold text-dark">@ViewBag.TotalItems</span> mục)
            </span>
            <div class="flex gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@(ViewBag.CurrentPage - 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang trước</a>
                }
                
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@i" class="px-3 py-1 border rounded text-sm font-medium transition-colors @(i == ViewBag.CurrentPage ? "bg-primary text-white border-primary" : "bg-white border-[#D6DDEB] text-dark hover:bg-gray-100")">@i</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?keyword=@ViewData["Keyword"]&status=@ViewData["Status"]&page=@(ViewBag.CurrentPage + 1)" class="px-3 py-1 bg-white border border-[#D6DDEB] rounded hover:bg-gray-100 text-sm font-medium text-dark transition-colors">Trang sau</a>
                }
            </div>
        </div>
    }
</div>

<!-- Toast Notification -->
<div id="toast-container" class="fixed bottom-5 right-5 z-50 flex flex-col gap-2"></div>

<!-- Confirmation Modal -->
<div id="confirmModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-0">
    <div class="fixed inset-0 bg-gray-900 bg-opacity-50 transition-opacity" onclick="closeConfirmModal()"></div>
    <div class="bg-white rounded-xl shadow-xl transform transition-all sm:max-w-md w-full relative z-10 overflow-hidden">
        <div class="p-6 text-center">
            <svg class="mx-auto mb-4 text-yellow-400 w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            <h3 class="mb-5 text-lg font-medium text-dark">Xác nhận thay đổi trạng thái?</h3>
            <p class="text-sm text-muted mb-6">Bạn có chắc chắn muốn đổi trạng thái của tỉnh/thành phố này không? Thao tác này sẽ ảnh hưởng trực tiếp đến hệ thống.</p>
            <div class="flex justify-center gap-3">
                <button type="button" onclick="closeConfirmModal()" class="text-muted bg-white hover:bg-gray-100 border border-[#D6DDEB] focus:ring-4 focus:outline-none focus:ring-gray-100 rounded-lg text-sm font-medium px-5 py-2.5 transition-colors">
                    Hủy bỏ
                </button>
                <button type="button" onclick="executeToggle()" class="text-white bg-primary hover:bg-opacity-90 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm inline-flex items-center px-5 py-2.5 text-center transition-colors">
                    Đồng ý
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentToggleId = null;

        function showToast(message, isSuccess = true) {
            const toast = document.createElement('div');
            toast.className = `flex items-center p-4 rounded-lg shadow-lg text-white transform transition-all duration-300 translate-y-10 opacity-0 ${isSuccess ? 'bg-green-500' : 'bg-red-500'}`;
            toast.innerHTML = `
                <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    ${isSuccess 
                        ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>'
                        : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>'
                    }
                </svg>
                <span class="font-medium">${message}</span>
            `;
            
            document.getElementById('toast-container').appendChild(toast);
            
            setTimeout(() => {
                toast.classList.remove('translate-y-10', 'opacity-0');
            }, 10);

            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-10');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function toggleStatus(id, btnElement) {
            currentToggleId = id;
            document.getElementById('confirmModal').classList.remove('hidden');
            document.getElementById('confirmModal').classList.add('flex');
        }

        function closeConfirmModal() {
            currentToggleId = null;
            document.getElementById('confirmModal').classList.add('hidden');
            document.getElementById('confirmModal').classList.remove('flex');
        }

        async function executeToggle() {
            if (!currentToggleId) return;
            
            const id = currentToggleId;
            closeConfirmModal();
            
            try {
                const response = await fetch(`/ModeratorProvince/toggle-status/${id}`, {
                    method: 'POST'
                });
                
                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        showToast(result.message);
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        showToast("Có lỗi xảy ra", false);
                    }
                } else {
                    showToast("Lỗi kết nối server", false);
                }
            } catch (error) {
                showToast("Lỗi kết nối server", false);
            }
        }
    </script>
}
