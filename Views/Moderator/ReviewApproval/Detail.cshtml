@model DevHub.Models.ReviewCompany
@{
    ViewData["Title"] = "Chi tiết đánh giá - Moderator";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="bg-[#F8FAFC] min-h-screen py-10 font-['Inter',sans-serif]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
        
        <!-- Header -->
        <div>
            <a href="/moderator/reviews" class="inline-flex items-center text-[#64748B] hover:text-[#4640DE] transition-colors text-sm font-medium mb-4">
                <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                Quay lại
            </a>
            
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h1 class="text-[28px] font-bold text-[#0F172A] leading-tight">Chi tiết đánh giá</h1>
                    <p class="text-[#64748B] text-base mt-1">
                        Đánh giá về <span class="font-semibold text-[#334155]">@Model.Company?.CompanyName</span>
                        • @(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))
                    </p>
                </div>

                <div>
                    @switch (Model.Status)
                    {
                        case "PENDING":
                            <span class="inline-flex items-center px-[18px] py-2 rounded-full text-[15px] font-semibold bg-[#FEF3C7] text-[#D97706] shadow-sm">
                                ● Đang chờ duyệt
                            </span>
                            break;
                        case "APPROVED":
                            <span class="inline-flex items-center px-[18px] py-2 rounded-full text-[15px] font-semibold bg-[#DCFCE7] text-[#16A34A] shadow-sm">
                                ✓ Đã duyệt
                            </span>
                            break;
                        case "REJECTED":
                            <span class="inline-flex items-center px-[18px] py-2 rounded-full text-[15px] font-semibold bg-[#FEE2E2] text-[#DC2626] shadow-sm">
                                ✕ Đã từ chối
                            </span>
                            break;
                    }
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="text-xl">✅</span>
                <p class="font-bold">@TempData["SuccessMessage"]</p>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-6 py-4 rounded-xl flex items-center gap-3">
                <span class="text-xl">⚠️</span>
                <p class="font-bold">@TempData["ErrorMessage"]</p>
            </div>
        }

        <!-- Responsive Layout: Content | Info -->
        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Left Column: Main Review Content -->
            <div class="w-full lg:w-2/3 space-y-8">
                
                <!-- Main Card -->
                <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.05)] hover:-translate-y-0.5 transition-transform duration-300 border border-[#E2E8F0] overflow-hidden">
                    <div class="p-8">
                        
                        <!-- Timeline / Meta Info -->
                        <div class="flex flex-wrap items-center gap-6 mb-8 text-[15px] text-[#475569] bg-[#F8FAFC] p-4 rounded-xl border border-[#F1F5F9]">
                            <div class="flex items-center gap-2">
                                <span>📅</span> 
                                <span class="font-medium">@(Model.CreatedAt?.ToString("dd/MM/yyyy"))</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>🕒</span> 
                                <span class="font-medium">@(Model.CreatedAt?.ToString("HH:mm"))</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span>👤</span> 
                                <span class="font-medium">@(Model.IsAnonymous == true ? "Review ẩn danh" : "Review công khai")</span>
                            </div>
                            @if (Model.IsAnonymous != true) {
                                <div class="flex items-center gap-2 text-[#16A34A]">
                                    <span>✔</span> 
                                    <span class="font-semibold">Đã xác minh</span>
                                </div>
                            }
                        </div>

                        <!-- Rating Area -->
                        <div class="mb-10">
                            <h3 class="text-[22px] font-bold text-[#1E293B] mb-6">Đánh giá chung</h3>
                            
                            <div class="flex flex-col md:flex-row gap-8 items-start">
                                <!-- Big Overview Rating -->
                                <div class="flex-shrink-0 text-center md:text-left">
                                    <div class="text-[48px] font-extrabold text-[#4640DE] leading-none mb-2">
                                        @Model.Rating.ToString("F1")
                                    </div>
                                    <div class="flex gap-1 text-[24px] text-[#EAB308] justify-center md:justify-start mb-2">
                                        @for(int i=1; i<=5; i++) {
                                            <span>★</span>
                                        }
                                    </div>
                                    <div class="text-[16px] text-[#64748B] font-medium uppercase tracking-wider">Tổng quan</div>
                                </div>

                                <!-- Small Cards Rating Grid -->
                                <div class="flex-grow grid grid-cols-2 gap-4 w-full">
                                    <div class="bg-[#FAFAFA] rounded-[14px] p-[18px] border border-[#F1F5F9]">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[#EAB308] text-lg font-bold">★ @(Model.SalaryRating?.ToString("F1") ?? "0.0")</span>
                                        </div>
                                        <div class="text-[15px] font-semibold text-[#475569]">Lương & Thưởng</div>
                                    </div>
                                    
                                    <div class="bg-[#FAFAFA] rounded-[14px] p-[18px] border border-[#F1F5F9]">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[#EAB308] text-lg font-bold">★ @(Model.CultureRating?.ToString("F1") ?? "0.0")</span>
                                        </div>
                                        <div class="text-[15px] font-semibold text-[#475569]">Văn hóa</div>
                                    </div>

                                    <div class="bg-[#FAFAFA] rounded-[14px] p-[18px] border border-[#F1F5F9]">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[#EAB308] text-lg font-bold">★ @(Model.TrainingRating?.ToString("F1") ?? "0.0")</span>
                                        </div>
                                        <div class="text-[15px] font-semibold text-[#475569]">Đào tạo</div>
                                    </div>

                                    <div class="bg-[#FAFAFA] rounded-[14px] p-[18px] border border-[#F1F5F9]">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[#EAB308] text-lg font-bold">★ @(Model.CareRating?.ToString("F1") ?? "0.0")</span>
                                        </div>
                                        <div class="text-[15px] font-semibold text-[#475569]">Quan tâm NV</div>
                                    </div>

                                    <div class="bg-[#FAFAFA] rounded-[14px] p-[18px] border border-[#F1F5F9]">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[#EAB308] text-lg font-bold">★ @(Model.WorkspaceRating?.ToString("F1") ?? "0.0")</span>
                                        </div>
                                        <div class="text-[15px] font-semibold text-[#475569]">Không gian</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Texts Area: Pros and Cons -->
                        <div class="space-y-6 mb-8">
                            <!-- Pros (Glassdoor style) -->
                            <div class="bg-[#F8FAFC] border-l-4 border-l-[#22C55E] rounded-r-[12px] p-6 shadow-sm">
                                <h4 class="text-[18px] font-bold text-[#1E293B] mb-2 flex items-center gap-2">
                                    <span class="text-[20px]">💚</span> Ưu điểm
                                </h4>
                                <p class="text-[16px] text-[#475569] leading-relaxed whitespace-pre-line">@Model.Pros</p>
                            </div>

                            <!-- Cons (Glassdoor style) -->
                            <div class="bg-[#FEF2F2] border-l-4 border-l-[#EF4444] rounded-r-[12px] p-6 shadow-sm">
                                <h4 class="text-[18px] font-bold text-[#1E293B] mb-2 flex items-center gap-2">
                                    <span class="text-[20px]">❤️</span> Nhược điểm
                                </h4>
                                <p class="text-[16px] text-[#475569] leading-relaxed whitespace-pre-line">@Model.Cons</p>
                            </div>
                        </div>

                        <!-- Extra details (OT & Recommend) -->
                        <div class="flex flex-wrap gap-8 pt-6 border-t border-[#E2E8F0]">
                            <div class="flex items-center gap-3">
                                <span class="text-[24px]">🕒</span>
                                <div>
                                    <div class="text-[14px] text-[#64748B] font-medium">Chế độ OT</div>
                                    <div class="text-[16px] font-bold text-[#1E293B]">
                                        @(Model.OtPolicy == "SATISFIED" ? "😊 Hài lòng" : Model.OtPolicy == "UNSATISFIED" ? "😞 Không hài lòng" : "N/A")
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-[24px]">🤝</span>
                                <div>
                                    <div class="text-[14px] text-[#64748B] font-medium">Khuyên làm</div>
                                    <div class="text-[16px] font-bold text-[#1E293B]">
                                        @(Model.Recommend.HasValue ? (Model.Recommend.Value ? "👍 Có giới thiệu" : "👎 Không giới thiệu") : "N/A")
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Rejection Details (If Rejected) -->
                @if (Model.Status == "REJECTED" && !string.IsNullOrEmpty(Model.RejectionReason))
                {
                    <div class="bg-[#FEF2F2] rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.05)] border border-[#FECACA] overflow-hidden p-8">
                        <h3 class="text-[20px] text-[#991B1B] font-bold mb-3 flex items-center gap-2">
                            <span>⚠️</span> Lý do bị từ chối
                        </h3>
                        <p class="text-[16px] text-[#B91C1C] font-medium mb-4">@Model.RejectionReason</p>
                        <div class="text-[14px] text-[#EF4444] border-t border-[#FCA5A5] pt-4">
                            Đã xử lý bởi Moderator ID: <strong>@Model.ModeratorId</strong> lúc @(Model.ModeratedAt?.ToString("dd/MM/yyyy HH:mm"))
                        </div>
                    </div>
                }

            </div>

            <!-- Right Column: Info Cards & CTA -->
            <div class="w-full lg:w-1/3 space-y-6">
                
                <!-- CTA Action Box (Sticky if possible) -->
                @if (Model.Status == "PENDING")
                {
                    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.05)] border border-[#E2E8F0] p-6 lg:sticky lg:top-6">
                        <h2 class="text-[18px] font-bold text-[#1E293B] mb-5">Hành động kiểm duyệt</h2>
                        
                        <form asp-action="Approve" asp-route-id="@Model.ReviewId" method="post" class="mb-3">
                            <button type="submit" class="w-full bg-[#16A34A] hover:bg-[#15803D] text-white font-bold py-3 px-4 rounded-[12px] transition-all duration-200 shadow-sm flex justify-center items-center gap-2 hover:-translate-y-0.5">
                                <span class="text-xl">✓</span> Phê duyệt
                            </button>
                        </form>

                        <button type="button" onclick="document.getElementById('rejectFormContainer').classList.toggle('hidden')" class="w-full bg-[#DC2626] hover:bg-[#B91C1C] text-white font-bold py-3 px-4 rounded-[12px] transition-all duration-200 shadow-sm flex justify-center items-center gap-2 hover:-translate-y-0.5">
                            <span class="text-xl">✕</span> Từ chối
                        </button>

                        <div id="rejectFormContainer" class="hidden mt-4 p-5 bg-[#F8FAFC] rounded-[14px] border border-[#E2E8F0]">
                            <form asp-action="Reject" asp-route-id="@Model.ReviewId" method="post">
                                <label class="block text-[14px] font-bold text-[#334155] mb-2">Lý do từ chối <span class="text-[#DC2626]">*</span></label>
                                <textarea name="rejectionReason" required rows="3" class="w-full p-3 border border-[#CBD5E1] rounded-[10px] text-[15px] mb-4 focus:ring-2 focus:ring-[#4640DE] focus:border-transparent outline-none transition-all" placeholder="Ví dụ: Đánh giá chứa từ ngữ không phù hợp..."></textarea>
                                <div class="flex justify-end gap-3">
                                    <button type="button" onclick="document.getElementById('rejectFormContainer').classList.add('hidden')" class="px-4 py-2 text-[15px] font-semibold text-[#64748B] hover:text-[#334155] hover:bg-[#F1F5F9] rounded-[8px] transition-colors">Hủy</button>
                                    <button type="submit" class="bg-[#DC2626] hover:bg-[#B91C1C] text-white px-5 py-2 rounded-[8px] text-[15px] font-bold shadow-sm">Xác nhận từ chối</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }

                <!-- Company Card -->
                <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.05)] border border-[#E2E8F0] p-6 hover:-translate-y-0.5 transition-transform duration-300">
                    <h2 class="text-[18px] font-bold text-[#1E293B] mb-5">Thông tin công ty</h2>
                    <div class="flex items-center gap-4 mb-5">
                        <div class="w-16 h-16 rounded-[12px] border border-[#F1F5F9] bg-white p-1.5 flex items-center justify-center flex-shrink-0 shadow-sm">
                            @if (!string.IsNullOrEmpty(Model.Company?.CompanyLogoUrl))
                            {
                                <img src="@Model.Company.CompanyLogoUrl" class="max-w-full max-h-full object-contain rounded-lg" alt="@Model.Company.CompanyName" />
                            }
                            else
                            {
                                <span class="text-2xl font-bold text-gray-300">@Model.Company?.CompanyName?.Substring(0,1)</span>
                            }
                        </div>
                        <div>
                            <p class="text-[16px] font-bold text-[#1E293B]">@Model.Company?.CompanyName</p>
                            <p class="text-[14px] text-[#64748B] mt-1 flex items-center gap-1">
                                <span class="text-[#EAB308]">★</span> @(Model.Company?.AverageRating?.ToString("F1") ?? "N/A")
                            </p>
                        </div>
                    </div>
                    <div class="space-y-3 text-[15px] text-[#475569]">
                        <div class="flex justify-between items-center border-b border-[#F1F5F9] pb-2">
                            <span>Ngành nghề</span>
                            <span class="font-medium text-[#1E293B]">@(string.IsNullOrEmpty(Model.Company?.Industry) ? "Chưa cập nhật" : Model.Company.Industry)</span>
                        </div>
                        <div class="flex justify-between items-center border-b border-[#F1F5F9] pb-2">
                            <span>Đã xác minh</span>
                            <span class="font-medium text-[#16A34A]">@(Model.Company?.IsVerified == true ? "✔ Có" : "Không")</span>
                        </div>
                    </div>
                    <a href="/Company/Detail/@Model.CompanyId" target="_blank" class="mt-5 block text-center w-full bg-[#F8FAFC] hover:bg-[#F1F5F9] text-[#4640DE] font-bold py-2.5 rounded-[12px] transition-colors border border-[#E2E8F0]">
                        [ Xem hồ sơ ]
                    </a>
                </div>

                <!-- Candidate Card -->
                <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgba(0,0,0,0.05)] border border-[#E2E8F0] p-6 hover:-translate-y-0.5 transition-transform duration-300">
                    <h2 class="text-[18px] font-bold text-[#1E293B] mb-5">Người gửi đánh giá</h2>
                    <div class="flex items-center gap-4 mb-5">
                        <div class="w-[48px] h-[48px] rounded-full overflow-hidden border border-[#E2E8F0] bg-gray-100 flex-shrink-0">
                            @if (!string.IsNullOrEmpty(Model.Candidate?.ImageUrl))
                            {
                                <img src="@Model.Candidate.ImageUrl" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Candidate?.FullName ?? "U")&background=EEF2FF&color=4640DE&rounded=true" class="w-full h-full object-cover" />
                            }
                        </div>
                        <div>
                            <p class="text-[16px] font-bold text-[#1E293B]">@Model.Candidate?.FullName</p>
                            <p class="text-[14px] text-[#64748B] mt-0.5">Ứng viên</p>
                        </div>
                    </div>
                    <div class="space-y-3 text-[14px]">
                        <div class="bg-[#F8FAFC] p-3 rounded-[10px] break-all border border-[#F1F5F9]">
                            <span class="text-[#64748B] block mb-1">Email:</span>
                            <span class="font-medium text-[#334155]">@Model.Candidate?.CandidateNavigation?.Email</span>
                        </div>
                        <div class="bg-[#F8FAFC] p-3 rounded-[10px] border border-[#F1F5F9]">
                            <span class="text-[#64748B] block mb-1">ID Hệ thống:</span>
                            <span class="font-medium text-[#334155] font-mono">@Model.CandidateId</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>
