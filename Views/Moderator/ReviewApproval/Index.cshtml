@{
    Layout = "_ModeratorLayout";
    ViewData["Title"] = "Duyệt Đánh giá";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Duyệt Đánh giá Công ty</h1>
        <p class="text-muted">Kiểm duyệt các bình luận, đánh giá của ứng viên về nhà tuyển dụng trước khi hiển thị công khai.</p>
    </div>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái duyệt</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="pending">Chờ duyệt (Pending)</option>
                <option value="approved">Đã duyệt (Approved)</option>
                <option value="rejected">Đã từ chối (Rejected)</option>
                <option value="">Tất cả</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Đánh giá (Sao)</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả số sao</option>
                <option value="5">5 Sao (Rất tốt)</option>
                <option value="1">1-2 Sao (Cần chú ý)</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Từ ngày</label>
            <input type="date" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[1000px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-48">Ứng viên đánh giá</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-48">Công ty nhận</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Nội dung đánh giá</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm w-32">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Review 1: Pending -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6">
                        <div class="font-bold text-dark text-base">Trần Văn Nam</div>
                        <div class="text-xs text-muted mt-1">24/05/2026 14:30</div>
                    </td>
                    <td class="py-4 px-6 font-bold text-primary">
                        FPT Software
                    </td>
                    <td class="py-4 px-6">
