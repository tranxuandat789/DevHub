@{
    Layout = "_ModeratorLayout";
    ViewData["Title"] = "Thêm/Sửa Voucher";
}

<div class="mb-8">
    <a href="/ModeratorVoucher" class="inline-flex items-center text-muted hover:text-primary mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-dark mb-2">Tạo / Chỉnh sửa Voucher</h1>
    <p class="text-muted">Tạo mới hoặc cập nhật thông tin khuyến mãi hệ thống.</p>
</div>

<form onsubmit="event.preventDefault(); submitVoucher();" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Cột trái: Thông tin chính -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Thông tin Khuyến mãi</h3>
            
            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Tiêu đề (Title) <span class="text-red-500">*</span></label>
                <input type="text" placeholder="Ví dụ: Giảm giá mùa hè, Tri ân khách hàng..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-medium" required>
            </div>

            <div class="mb-6">
                <label class="block text-dark font-bold mb-2">Mã Khuyến mãi (Promo Code) <span class="text-red-500">*</span></label>
                <div class="flex gap-2">
                    <input type="text" placeholder="Ví dụ: SUMMER20" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-primary font-mono font-bold uppercase tracking-widest" required>
                    <button type="button" class="bg-gray-100 text-dark font-medium px-4 py-2 rounded-lg border border-gray-200 hover:bg-gray-200 whitespace-nowrap">Tạo ngẫu nhiên</button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-dark font-bold mb-2">Mức giảm giá (%) <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="number" min="0" max="100" step="0.01" placeholder="0.00" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-bold" required>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-muted">%</span>
                    </div>
                </div>
                <div>
                    <label class="block text-dark font-bold mb-2">Giảm tối đa (Coin) <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="number" min="0" step="0.01" placeholder="0.00" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark font-bold" required>
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-muted">Coin</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-2">
                <div>
                    <label class="block text-dark font-bold mb-2">Số lượng (Quantity)</label>
                    <input type="number" min="0" placeholder="Để trống nếu không giới hạn" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark">
                </div>
            </div>
        </div>
        
    </div>

    <!-- Cột phải: Cài đặt Ngày & Lưu -->
    <div class="space-y-6">
        
        <!-- Setting Thời gian -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Thời gian áp dụng</h3>
            
            <div class="mb-4">
                <label class="block text-dark font-bold mb-2">Ngày bắt đầu (Start Date)</label>
                <input type="date" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark" required>
            </div>
            
            <div class="mb-4">
                <label class="block text-dark font-bold mb-2">Ngày kết thúc (End Date)</label>
                <input type="date" class="w-full border border-[#D6DDEB] rounded-lg px-4 py-3 focus:outline-none focus:border-primary text-dark" required>
            </div>

            <label class="flex items-center gap-3 cursor-pointer mt-6 pt-4 border-t border-gray-100">
                <input type="checkbox" checked class="w-5 h-5 text-primary rounded focus:ring-primary">
                <span class="font-bold text-dark">Kích hoạt Voucher (Is Active)</span>
            </label>
        </div>

        <!-- Publish Action -->
        <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 border border-[#D6DDEB]">
            <h3 class="font-bold text-dark text-lg mb-4 border-b pb-2">Lưu dữ liệu</h3>
            <div class="flex flex-col gap-3">
                <button type="submit" class="w-full bg-primary text-white font-bold px-4 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                    Lưu Voucher
                </button>
                <a href="/ModeratorVoucher" class="w-full block text-center bg-gray-100 text-dark font-bold px-4 py-3 rounded-lg hover:bg-gray-200 transition-all border border-gray-200">
                    Hủy Bỏ
                </a>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    <script>
        function submitVoucher() {
            alert('Lưu Voucher thành công!');
            window.location.href = '/ModeratorVoucher';
        }
    </script>
}
