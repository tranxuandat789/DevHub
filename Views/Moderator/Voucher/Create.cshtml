@model DevHub.Models.Promotion
@{
    ViewData["Title"] = "Tạo mã giảm giá";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="mb-8">
    <a href="/moderator/vouchers" class="inline-flex items-center text-[#515B6F] hover:text-[#4640DE] mb-4 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
    <h1 class="text-[32px] font-bold text-[#25324B]">Tạo mã giảm giá mới</h1>
</div>

<form action="/moderator/vouchers/create" method="post" id="voucherForm" class="max-w-4xl">
    <div class="bg-white rounded-lg shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-8 border border-[#D6DDEB]">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center shadow-sm mb-6">
                <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="Title">Tên chương trình / Voucher <span class="text-red-500">*</span></label>
                <input type="text" id="Title" name="Title" value="@Model.Title" required
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all"
                       placeholder="VD: Khuyến mãi mùa hè">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="PromoCode">Mã code <span class="text-red-500">*</span></label>
                <div class="flex shadow-sm rounded-lg">
                    <input type="text" id="PromoCode" name="PromoCode" value="@Model.PromoCode" required minlength="8" maxlength="10"
                           class="w-full py-3 px-4 rounded-l-lg border border-[#D6DDEB] text-[#25324B] font-mono focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] transition-all"
                           placeholder="8-10 ký tự">
                    <button type="button" id="btnGenerate" class="bg-[#F7F5FC] hover:bg-[#E8E6F5] text-[#4640DE] font-bold py-3 px-6 rounded-r-lg border border-l-0 border-[#D6DDEB] transition-colors whitespace-nowrap flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                        Tạo ngẫu nhiên
                    </button>
                </div>
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="DiscountPercent">Phần trăm giảm (%)</label>
                <input type="number" id="DiscountPercent" name="DiscountPercent" value="@Model.DiscountPercent" min="0" max="100" step="0.1"
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all"
                       placeholder="0 - 100">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="MaxDiscount">Giảm tối đa (VNĐ)</label>
                <input type="text" id="MaxDiscount" name="MaxDiscount" value="@Model.MaxDiscount"
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all money-input"
                       placeholder="Số tiền tối đa">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="StartDate">Ngày bắt đầu</label>
                <input type="date" id="StartDate" name="StartDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))"
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="EndDate">Ngày kết thúc</label>
                <input type="date" id="EndDate" name="EndDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))"
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-[#25324B] text-[16px] font-bold mb-2" for="Quantity">Số lượng (Để trống = Vô hạn)</label>
                <input type="number" id="Quantity" name="Quantity" value="@Model.Quantity" min="1"
                       class="w-full py-3 px-4 rounded-lg border border-[#D6DDEB] text-[#25324B] focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm transition-all"
                       placeholder="Ví dụ: 100">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="flex items-center gap-3 cursor-pointer p-4 mt-6 border border-[#D6DDEB] rounded-lg bg-[#F7F5FC] hover:bg-[#E8E6F5] transition-colors">
                    <input type="checkbox" name="IsActive" value="true" @(Model.IsActive == true ? "checked" : "") class="w-5 h-5 text-[#4640DE] rounded focus:ring-[#4640DE]">
                    <div>
                        <span class="font-bold text-[#25324B] block">Kích hoạt ngay</span>
                    </div>
                </label>
            </div>
            
        </div>

        <div class="flex gap-4 pt-8 mt-8 border-t border-[#D6DDEB]">
            <button type="submit" class="bg-[#4640DE] text-white font-bold px-8 py-3 rounded-lg hover:bg-opacity-90 transition-all shadow-sm">
                Lưu mã giảm giá
            </button>
            <a href="/moderator/vouchers" class="bg-white text-[#25324B] font-bold px-8 py-3 rounded-lg border border-[#D6DDEB] hover:bg-gray-50 transition-all">
                Hủy bỏ
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('btnGenerate').addEventListener('click', function() {
            fetch('/moderator/vouchers/generate-code')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('PromoCode').value = data.code;
                })
                .catch(error => console.error('Error:', error));
        });

        document.getElementById('voucherForm').addEventListener('submit', function(e) {
            var startDate = document.getElementById('StartDate').value;
            var endDate = document.getElementById('EndDate').value;
            
            if (startDate && endDate) {
                var start = new Date(startDate);
                var end = new Date(endDate);
                
                var minEnd = new Date(start);
                minEnd.setDate(minEnd.getDate() + 1);
                
                if (end < minEnd) {
                    e.preventDefault();
                    alert('Ngày kết thúc phải sau ngày bắt đầu ít nhất 1 ngày.');
                }
            }
        });

        document.addEventListener('DOMContentLoaded', function () {
            // Currency type format(ex: 20000000 -> 20.000.000)
            function formatThousand(value) {
                var digits = (value || '').toString().replace(/\D/g, '');
                if (!digits) return '';
                return digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            }

            var discountInputs = document.querySelectorAll('.money-input');
            discountInputs.forEach(function (el) {
                // applying format while typing
                el.addEventListener('input', function () {
                    this.value = formatThousand(this.value);
                });
                // re-format after reloading form after validation error
                el.value = formatThousand(el.value);
            });

            // remove '.' before submiting so the model binding can parse to number successfully.
            var form = document.getElementById('voucherForm');
            if (form) {
                form.addEventListener('submit', function () {
                    discountInputs.forEach(function (el) {
                        el.value = (el.value || '').replace(/\./g, '');
                    });
                });
            }
        });
    </script>
}
