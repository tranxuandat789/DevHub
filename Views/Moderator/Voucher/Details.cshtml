@model DevHub.Models.Promotion
@{
    ViewData["Title"] = "Chi tiết mã giảm giá";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="mb-8 flex flex-col md:flex-row items-center justify-between">
    <div>
        <a href="/moderator/vouchers" class="inline-flex items-center text-[#515B6F] hover:text-[#4640DE] mb-2 transition-colors">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại danh sách
        </a>
        <h1 class="text-[32px] font-bold text-[#25324B]">Chi tiết mã giảm giá</h1>
    </div>
    <div class="mt-4 md:mt-0 flex space-x-4">
        <a href="/moderator/vouchers/edit/@Model.PromotionId" class="bg-[#4640DE] text-white font-bold py-3 px-6 rounded-lg shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:bg-opacity-90 transition-all flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
            Chỉnh sửa
        </a>
    </div>
</div>

<div class="bg-white rounded-lg shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-8 max-w-4xl mx-auto border border-[#D6DDEB]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
        
        <div class="col-span-2 border-b border-[#D6DDEB] pb-6 mb-2">
            <h3 class="text-[24px] font-bold text-[#25324B]">@Model.Title</h3>
            <div class="mt-3 flex items-center space-x-4">
                <span class="bg-indigo-50 border border-indigo-100 text-[#4640DE] font-mono px-4 py-2 rounded font-bold shadow-sm text-lg">
                    @Model.PromoCode
                </span>
                @if (Model.IsActive == true)
                {
                    <span class="inline-flex items-center px-4 py-2 rounded text-green-700 bg-green-100 font-semibold border border-green-200">
                        <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span> Đang hoạt động
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-4 py-2 rounded text-red-700 bg-red-100 font-semibold border border-red-200">
                        <span class="w-2 h-2 rounded-full bg-red-500 mr-2"></span> Đã vô hiệu
                    </span>
                }
            </div>
        </div>

        <div class="p-4 bg-[#F7F5FC] rounded-lg border border-[#D6DDEB]">
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Mức giảm giá</p>
            <p class="text-[#25324B] text-[20px] font-bold">
                @(Model.DiscountPercent?.ToString() ?? "0")%
            </p>
        </div>

        <div class="p-4 bg-[#F7F5FC] rounded-lg border border-[#D6DDEB]">
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Giảm tối đa</p>
            <p class="text-[#25324B] text-[20px] font-bold">
                @(Model.MaxDiscount.HasValue ? Model.MaxDiscount.Value.ToString("N0") + " VNĐ" : "Không giới hạn")
            </p>
        </div>

        <div>
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Ngày bắt đầu</p>
            <p class="text-[#25324B] text-[18px]">
                @(Model.StartDate?.ToString("dd/MM/yyyy") ?? "Không chỉ định")
            </p>
        </div>

        <div>
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Ngày kết thúc</p>
            <p class="text-[#25324B] text-[18px]">
                @(Model.EndDate?.ToString("dd/MM/yyyy") ?? "Không chỉ định")
            </p>
        </div>

        <div>
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Số lượng</p>
            <p class="text-[#25324B] text-[18px]">
                @(Model.Quantity?.ToString() ?? "Không giới hạn")
            </p>
        </div>
        
        <div>
            <p class="text-[#515B6F] text-[14px] font-semibold uppercase tracking-wider mb-1">Ngày tạo</p>
            <p class="text-[#25324B] text-[18px]">
                @(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
            </p>
        </div>

    </div>
</div>
