@model List<DevHub.Models.Promotion>
@{
    ViewData["Title"] = "Quản lý mã giảm giá";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string sortBy = ViewBag.SortBy ?? "date_desc";
    string keyword = ViewBag.Keyword ?? "";
}

<div class="mb-6 flex flex-col md:flex-row justify-between items-center bg-[#F7F5FC] p-6 rounded-lg">
    <div>
        <h1 class="text-[32px] md:text-[40px] font-bold text-[#25324B] leading-tight">Quản lý mã giảm giá</h1>
        <p class="text-[#515B6F] text-[16px]">Xem, tạo mới và quản lý các chương trình khuyến mãi (Vouchers).</p>
    </div>
    <div class="mt-4 md:mt-0">
        <a href="/moderator/vouchers/create" class="bg-[#4640DE] hover:bg-opacity-90 text-white font-bold py-3 px-6 rounded-lg shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-transform hover:-translate-y-1 flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tạo mã mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg shadow-sm flex items-center" role="alert">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg shadow-sm flex items-center" role="alert">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        @TempData["ErrorMessage"]
    </div>
}

<!-- Filters and Search Bar -->
<div class="bg-white shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-lg p-6 mb-8 border border-[#D6DDEB]">
    <form action="/moderator/vouchers" method="get" class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <!-- Search Box -->
        <div class="relative w-full md:w-1/2">
            <input type="text" name="keyword" value="@keyword" placeholder="Tìm kiếm tên voucher, mã code..." 
                   class="w-full pl-4 pr-32 py-3 rounded-lg border border-[#D6DDEB] text-[#25324B] placeholder-gray-400 focus:outline-none focus:border-[#4640DE] focus:ring-1 focus:ring-[#4640DE] shadow-sm">
            <button type="submit" class="absolute right-1 top-1 bottom-1 bg-[#4640DE] text-white px-6 font-bold rounded-lg hover:bg-opacity-90 transition flex items-center">
                Tìm kiếm
            </button>
        </div>

        <!-- Sort Dropdown -->
        <div class="w-full md:w-1/3">
            <select name="sortBy" onchange="this.form.submit()" 
                    class="w-full appearance-none bg-white border border-[#D6DDEB] text-[#515B6F] py-3 px-4 pr-8 rounded-lg focus:outline-none focus:border-[#4640DE] shadow-sm cursor-pointer">
                <option value="date_desc" selected="@(sortBy == "date_desc" ? "selected" : null)">Sắp xếp: Mới nhất</option>
                <option value="date_asc" selected="@(sortBy == "date_asc" ? "selected" : null)">Sắp xếp: Cũ nhất</option>
                <option value="quantity_desc" selected="@(sortBy == "quantity_desc" ? "selected" : null)">Sắp xếp: Số lượng nhiều nhất</option>
                <option value="quantity_asc" selected="@(sortBy == "quantity_asc" ? "selected" : null)">Sắp xếp: Số lượng ít nhất</option>
            </select>
        </div>
    </form>
</div>

<div class="bg-white shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-lg overflow-hidden border border-[#D6DDEB]">
    <div class="overflow-x-auto">
        <table class="min-w-full leading-normal">
            <thead>
                <tr>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-left text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Tên voucher
                    </th>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-left text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Mã code
                    </th>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-left text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Giảm giá
                    </th>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-left text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Thời hạn
                    </th>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-center text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Trạng thái
                    </th>
                    <th class="px-5 py-4 border-b border-[#D6DDEB] bg-[#F7F5FC] text-center text-[14px] font-bold text-[#25324B] uppercase tracking-wider">
                        Thao tác
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-[16px]">
                                <p class="text-[#25324B] font-bold">@item.Title</p>
                            </td>
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-[16px]">
                                <span class="bg-indigo-50 border border-indigo-100 text-[#4640DE] font-mono px-3 py-1 rounded font-bold shadow-sm">
                                    @item.PromoCode
                                </span>
                            </td>
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-[16px]">
                                <p class="text-[#25324B]">
                                    @if (item.DiscountPercent.HasValue)
                                    {
                                        <span class="font-bold text-green-600">@item.DiscountPercent%</span>
                                    }
                                    @if (item.MaxDiscount.HasValue)
                                    {
                                        <span class="text-[#515B6F] text-[14px] block mt-1">Tối đa: @item.MaxDiscount.Value.ToString("N0")đ</span>
                                    }
                                </p>
                            </td>
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-[16px]">
                                <p class="text-[#515B6F]">
                                    @(item.StartDate?.ToString("dd/MM/yyyy") ?? "N/A") 
                                    <svg class="inline-block w-4 h-4 mx-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg> 
                                    @(item.EndDate?.ToString("dd/MM/yyyy") ?? "N/A")
                                    @if (item.EndDate.HasValue)
                                    {
                                        var today = DateOnly.FromDateTime(DateTime.Now);
                                        if (item.EndDate.Value < today)
                                        {
                                            <span class="text-[12px] text-red-500 font-bold ml-1 block mt-1">(Đã hết hạn)</span>
                                        }
                                        else if (item.EndDate.Value <= today.AddDays(3))
                                        {
                                            <span class="text-[12px] text-orange-500 font-bold ml-1 block mt-1">(Sắp hết hạn)</span>
                                        }
                                    }
                                </p>
                            </td>
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-[14px] text-center">
                                @if (item.IsActive == true)
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded text-green-700 bg-green-100 font-semibold border border-green-200">
                                        <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span> Đang hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded text-red-700 bg-red-100 font-semibold border border-red-200">
                                        <span class="w-2 h-2 rounded-full bg-red-500 mr-2"></span> Đã vô hiệu
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-4 border-b border-[#D6DDEB] text-center">
                                <div class="flex justify-center items-center space-x-3">
                                    <a href="/moderator/vouchers/details/@item.PromotionId" class="text-blue-500 hover:text-blue-700 transition flex items-center justify-center p-2 rounded hover:bg-blue-50" title="Xem chi tiết">
                                        <!-- Eye icon -->
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a href="/moderator/vouchers/edit/@item.PromotionId" class="text-orange-500 hover:text-orange-700 transition flex items-center justify-center p-2 rounded hover:bg-orange-50" title="Chỉnh sửa">
                                        <!-- Pen icon -->
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    @if (item.IsActive == true)
                                    {
                                        <button type="button" onclick="openConfirmModal('/moderator/vouchers/deactivate/@item.PromotionId', 'Bạn có chắc chắn muốn vô hiệu hóa mã giảm giá này không?')" class="text-red-500 hover:text-red-700 transition flex items-center justify-center p-2 rounded hover:bg-red-50" title="Vô hiệu hóa">
                                            <!-- Lock icon -->
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" onclick="openConfirmModal('/moderator/vouchers/activate/@item.PromotionId', 'Bạn có chắc chắn muốn kích hoạt lại mã giảm giá này không?')" class="text-green-500 hover:text-green-700 transition flex items-center justify-center p-2 rounded hover:bg-green-50" title="Kích hoạt">
                                            <!-- Unlock icon -->
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-5 py-12 text-center border-b border-[#D6DDEB]">
                            <div class="flex flex-col items-center justify-center text-[#515B6F]">
                                <svg class="w-12 h-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                                <p class="text-lg">Không tìm thấy mã giảm giá nào.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="px-6 py-5 border-t border-[#D6DDEB] flex flex-col md:flex-row items-center justify-between">
            <span class="text-[14px] text-[#515B6F] mb-4 md:mb-0">
                Hiển thị trang <span class="font-bold text-[#25324B]">@currentPage</span> / @totalPages
            </span>
            <div class="inline-flex space-x-1">
                @{
                    int window = 2;
                    int startPage = Math.Max(1, currentPage - window);
                    int endPage = Math.Min(totalPages, currentPage + window);
                }

                @if (currentPage > 1)
                {
                    <a href="?page=@(currentPage - 1)&sortBy=@sortBy&keyword=@keyword" class="px-4 py-2 rounded-lg border border-[#D6DDEB] text-[#515B6F] hover:bg-gray-50 transition flex items-center">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </a>
                }
                
                @if (startPage > 1)
                {
                    <a href="?page=1&sortBy=@sortBy&keyword=@keyword" class="px-4 py-2 rounded-lg border border-[#D6DDEB] text-[#515B6F] hover:bg-[#4640DE] hover:text-white transition">1</a>
                    @if (startPage > 2)
                    {
                        <span class="px-4 py-2 text-[#515B6F]">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="px-4 py-2 rounded-lg bg-[#4640DE] text-white font-bold shadow-sm border border-[#4640DE]">@i</span>
                    }
                    else
                    {
                        <a href="?page=@i&sortBy=@sortBy&keyword=@keyword" class="px-4 py-2 rounded-lg border border-[#D6DDEB] text-[#515B6F] hover:bg-[#4640DE] hover:text-white transition">@i</a>
                    }
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <span class="px-4 py-2 text-[#515B6F]">...</span>
                    }
                    <a href="?page=@totalPages&sortBy=@sortBy&keyword=@keyword" class="px-4 py-2 rounded-lg border border-[#D6DDEB] text-[#515B6F] hover:bg-[#4640DE] hover:text-white transition">@totalPages</a>
                }

                @if (currentPage < totalPages)
                {
                    <a href="?page=@(currentPage + 1)&sortBy=@sortBy&keyword=@keyword" class="px-4 py-2 rounded-lg border border-[#D6DDEB] text-[#515B6F] hover:bg-gray-50 transition flex items-center">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- Custom Confirm Modal -->
<div id="confirmModal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black bg-opacity-50 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 max-w-sm w-full transform scale-95 transition-transform duration-300 border border-[#D6DDEB]">
        <h3 class="text-[20px] font-bold text-[#25324B] mb-2">Xác nhận thao tác</h3>
        <p id="confirmMessage" class="text-[#515B6F] text-[16px] mb-6"></p>
        <div class="flex justify-end space-x-3">
            <button type="button" onclick="closeConfirmModal()" class="px-5 py-2 text-[#515B6F] bg-gray-100 hover:bg-gray-200 rounded-lg font-bold transition-colors">
                Hủy bỏ
            </button>
            <form id="confirmForm" method="post" action="">
                <button type="submit" class="px-5 py-2 text-white bg-[#4640DE] hover:bg-opacity-90 rounded-lg font-bold shadow-sm transition-transform hover:-translate-y-0.5">
                    Đồng ý
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openConfirmModal(actionUrl, message) {
            const modal = document.getElementById('confirmModal');
            const confirmMessage = document.getElementById('confirmMessage');
            const confirmForm = document.getElementById('confirmForm');

            confirmMessage.textContent = message;
            confirmForm.action = actionUrl;

            modal.classList.remove('opacity-0', 'pointer-events-none');
            modal.querySelector('div').classList.remove('scale-95');
        }

        function closeConfirmModal() {
            const modal = document.getElementById('confirmModal');
            
            modal.classList.add('opacity-0', 'pointer-events-none');
            modal.querySelector('div').classList.add('scale-95');
        }
    </script>
}
