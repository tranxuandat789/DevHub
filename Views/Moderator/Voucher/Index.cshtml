@{
    Layout = "_ModeratorLayout";
    ViewData["Title"] = "Quản lý Khuyến mãi & Voucher";
}

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
        <h1 class="text-[32px] font-bold text-dark mb-2">Khuyến mãi & Voucher</h1>
        <p class="text-muted">Quản lý mã giảm giá áp dụng cho các giao dịch mua gói dịch vụ.</p>
    </div>
    <a href="/ModeratorVoucher/Create" class="bg-primary text-white font-bold px-6 py-3 rounded-lg hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Tạo Voucher mới
    </a>
</div>

<!-- Filters & Sort -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-6 mb-8 border border-[#D6DDEB]">
    <form class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end" onsubmit="event.preventDefault();">
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Tìm kiếm</label>
            <input type="text" placeholder="Mã Code hoặc Tên..." class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Trạng thái</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="">Tất cả</option>
                <option value="1">Đang hoạt động</option>
                <option value="0">Đã vô hiệu hóa/Hết hạn</option>
            </select>
        </div>
        <div class="w-full">
            <label class="block text-dark font-medium mb-2 text-sm">Sắp xếp theo</label>
            <select class="w-full border border-[#D6DDEB] rounded-lg px-4 py-2.5 focus:outline-none focus:border-primary text-muted">
                <option value="newest">Ngày tạo (Mới nhất)</option>
                <option value="discount_desc">Mức giảm (Cao đến thấp)</option>
                <option value="expiring_soon">Sắp hết hạn</option>
            </select>
        </div>
        <div>
            <button type="button" class="w-full bg-primary text-white font-bold px-6 py-2.5 rounded-lg hover:bg-opacity-90 transition-all">Lọc dữ liệu</button>
        </div>
    </form>
</div>

<!-- Data Table -->
<div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-[#D6DDEB] overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[1000px]">
            <thead>
                <tr class="bg-gray-50 border-b border-[#D6DDEB]">
                    <th class="py-4 px-6 text-dark font-bold text-sm w-16">ID</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Mã Voucher & Tiêu đề</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-right">Giảm giá (%)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-right">Tối đa (Coin)</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Số lượng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center">Hạn sử dụng</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm">Trạng thái</th>
                    <th class="py-4 px-6 text-dark font-bold text-sm text-center w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <!-- Row 1 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#1</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-primary font-mono text-base mb-1">SUMMER26</div>
                        <div class="text-xs text-muted truncate max-w-[200px]">Siêu sale chào hè 2026</div>
                    </td>
                    <td class="py-4 px-6 text-right font-bold text-dark">20.00%</td>
                    <td class="py-4 px-6 text-right text-muted">500.00</td>
                    <td class="py-4 px-6 text-center">
                        <span class="font-bold text-dark">15</span><span class="text-gray-400">/100</span>
                    </td>
                    <td class="py-4 px-6 text-center text-muted">
                        01/06/2026<br/>
                        <span class="text-xs text-gray-400">- 30/06/2026</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Hoạt động
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorVoucher/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleStatus(1)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors" title="Vô hiệu hóa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                        </button>
                    </td>
                </tr>
                
                <!-- Row 2 -->
                <tr class="border-b border-[#D6DDEB] hover:bg-gray-50 transition-colors">
                    <td class="py-4 px-6 text-muted font-medium">#2</td>
                    <td class="py-4 px-6">
                        <div class="font-bold text-gray-500 font-mono text-base mb-1 line-through">NEWYEAR</div>
                        <div class="text-xs text-muted truncate max-w-[200px]">Lì xì đầu năm</div>
                    </td>
                    <td class="py-4 px-6 text-right font-bold text-dark">50.00%</td>
                    <td class="py-4 px-6 text-right text-muted">1,000.00</td>
                    <td class="py-4 px-6 text-center">
                        <span class="font-bold text-red-500">0</span><span class="text-gray-400">/50</span>
                    </td>
                    <td class="py-4 px-6 text-center text-muted">
                        01/01/2026<br/>
                        <span class="text-xs text-gray-400">- 15/01/2026</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            Vô hiệu hóa
                        </span>
                    </td>
                    <td class="py-4 px-6 text-center space-x-1">
                        <a href="/ModeratorVoucher/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Chỉnh sửa">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                        <button onclick="toggleStatus(2)" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Kích hoạt lại">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-[#D6DDEB]">
        <div class="text-sm text-muted">
            Hiển thị 1 đến 2 của 2 vouchers
        </div>
        <div class="flex space-x-1">
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50 disabled:opacity-50" disabled>Trang trước</button>
            <button class="px-3 py-1 bg-primary text-white rounded">1</button>
            <button class="px-3 py-1 border border-[#D6DDEB] rounded text-muted hover:bg-gray-50">Trang sau</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(id) {
            if (confirm(`Bạn có chắc muốn thay đổi trạng thái của Voucher #${id}?`)) {
                alert(`Đã cập nhật trạng thái Voucher #${id}! Hành động đã được ghi log.`);
            }
        }
    </script>
}
