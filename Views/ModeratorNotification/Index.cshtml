@model IEnumerable<DevHub.Models.Notification>
@{
    ViewData["Title"] = "Danh sách thông báo";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="bg-white rounded-lg shadow-sm border border-gray-100 mb-6">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 rounded-t-lg">
        <h2 class="text-lg font-bold text-gray-900 m-0">Tất cả thông báo</h2>
    </div>
    
    <div class="p-0">
        @if (Model != null && Model.Any())
        {
            <div class="divide-y divide-gray-100">
                @foreach (var item in Model)
                {
                    string bgColor = item.IsRead == true ? "bg-white opacity-80" : "bg-[#f8f9fc]";
                    string titleColor = item.IsRead == true ? "text-gray-600" : "text-gray-900 font-medium";
                    string dotColor = item.IsRead == true ? "bg-transparent" : "bg-[#0f62fe]";

                    <a href="/ModeratorNotification/Details/@item.NotificationId" class="block hover:bg-gray-50 transition-colors @bgColor text-decoration-none">
                        <div class="px-6 py-4 flex gap-4 items-start">
                            <div class="flex-1 min-w-0">
                                <p class="text-[14px] @titleColor mb-1">@item.Title</p>
                                <p class="text-[13px] text-gray-500 line-clamp-2 mb-2">@item.Message</p>
                                <p class="text-[12px] text-gray-400">@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="w-2.5 h-2.5 @dotColor rounded-full flex-shrink-0 mt-2"></div>
                        </div>
                    </a>
                }
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
                    <nav class="flex items-center gap-1">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a href="/ModeratorNotification?page=@(ViewBag.CurrentPage - 1)" class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary transition-colors text-decoration-none">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="w-8 h-8 flex items-center justify-center rounded bg-primary text-white font-medium text-sm">@i</span>
                            }
                            else if (i == 1 || i == ViewBag.TotalPages || Math.Abs(i - ViewBag.CurrentPage) <= 2)
                            {
                                <a href="/ModeratorNotification?page=@i" class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors text-sm text-decoration-none">@i</a>
                            }
                            else if (Math.Abs(i - ViewBag.CurrentPage) == 3)
                            {
                                <span class="w-8 h-8 flex items-center justify-center text-gray-400 text-sm">...</span>
                            }
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a href="/ModeratorNotification?page=@(ViewBag.CurrentPage + 1)" class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-primary transition-colors text-decoration-none">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </a>
                        }
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="px-6 py-12 text-center text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                <p>Bạn chưa có thông báo nào.</p>
            </div>
        }
    </div>
</div>
