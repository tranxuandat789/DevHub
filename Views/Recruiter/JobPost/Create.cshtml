<!--AnhPT-03/06/2026-->
@model DevHub.ViewModels.Recruiter.JobPostCreateViewModel
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Đăng tin tuyển dụng";
    ViewData["ActiveMenu"] = "Jobs";

    // Originating list filters, carried so cancel/save returns to the same filtered list.
    var q = ViewBag.Q as string;
    var status = ViewBag.Status as string;
    var page = ViewBag.Page ?? 1;
}

<div class="space-y-6">
    <!-- Header/Title -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-dark">Đăng tin tuyển dụng mới</h1>
            <p class="text-muted text-sm mt-1">Điền đầy đủ thông tin để tìm kiếm ứng viên phù hợp nhất</p>
        </div>
        <a href="@Url.Action("Index", new { q, status, page })" class="inline-flex items-center justify-center px-4 py-2 bg-gray-100 text-dark text-[15px] font-bold rounded-lg hover:bg-gray-200 transition-all">
            Hủy và quay lại
        </a>
    </div>

    <!-- Form Container -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 md:p-8 shadow-sm">
        <form asp-action="Create" asp-controller="JobPost" method="post" class="space-y-8">
            @Html.AntiForgeryToken()
            <input type="hidden" name="q" value="@q" />
            <input type="hidden" name="status" value="@status" />
            <input type="hidden" name="page" value="@(page)" />

            <div asp-validation-summary="All" class="text-sm text-red-600 bg-red-50 border border-red-100 rounded-lg px-4 py-3 [&:empty]:hidden"></div>

            <!-- Overall information -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">1. Thông tin chung</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-dark mb-2">Tiêu đề công việc <span class="text-red-500">*</span></label>
                        <input type="text" name="Title" value="@Model?.Title" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Lập trình viên .NET Core (Senior)" required>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Vị trí (Job Position) <span class="text-red-500">*</span></label>
                        <div class="single-choices">
                            <select id="position-dropdown" name="PositionId" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                                <option value="">Chọn vị trí...</option>
                                @if (ViewBag.Positions != null)
                                {
                                    foreach (var p in (List<DevHub.Models.CommonJobPosition>)ViewBag.Positions)
                                    {
                                         <option value="@p.PositionId" selected="@(Model?.PositionId == p.PositionId)">@p.PositionName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Cấp bậc (Experience Level) <span class="text-red-500">*</span></label>
                        <div class="single-choices">
                            <select id="experience-dropdown" name="ExperienceLevel" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                                <option value="">Chọn cấp bậc...</option>
                                @foreach (var lv in new[] { "Intern", "Fresher", "Junior", "Middle", "Senior", "Lead" })
                                {
                                    <option value="@lv" selected="@(string.Equals(Model?.ExperienceLevel, lv, StringComparison.OrdinalIgnoreCase))">@(lv == "Lead" ? "Lead / Manager" : lv)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Hình thức làm việc (Working Model) <span class="text-red-500">*</span></label>
                        <div class="single-choices">
                            <select id="working-model-dropdown" name="WorkingModel" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                                <option value="">Chọn hình thức...</option>
                                @foreach (var wm in new[] { "Fulltime Onsite", "Fulltime Remote", "Parttime", "Hybrid", "Freelance" })
                                {
                                    var label = wm == "Fulltime Onsite" ? "Full-time Onsite" : (wm == "Fulltime Remote" ? "Full-time Remote" : (wm == "Parttime" ? "Part-time" : (wm == "Hybrid" ? "Hybrid (Linh hoạt)" : wm)));
                                    var isSelected = Model?.WorkingModel != null && string.Equals(Model.WorkingModel.Replace("-", "").Replace(" ", ""), wm.Replace("-", "").Replace(" ", ""), StringComparison.OrdinalIgnoreCase);
                                    <option value="@wm" selected="@isSelected">@label</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Địa điểm làm việc (Tỉnh/Thành) <span class="text-red-500">*</span></label>
                        <div id="province-choices">
                            <select id="province-dropdown" name="ProvinceIds" multiple required>
                                @if (ViewBag.Provinces != null)
                                {
                                    var selectedProvinceIds = (Model?.ProvinceIds ?? new List<int>());
                                    foreach (var province in (List<DevHub.Models.Province>)ViewBag.Provinces)
                                    {
                                        <option value="@province.ProvinceId" selected="@(selectedProvinceIds.Contains(province.ProvinceId))">@province.ProvinceName</option>
                                    }
                                }
                            </select>
                        </div>
                        <small class="text-muted block mt-1">Chọn một hoặc nhiều tỉnh/thành nơi làm việc.</small>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Hạn nhận hồ sơ (Deadline) <span class="text-red-500">*</span></label>
                        <input type="text" id="deadline-input" name="Deadline" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors bg-white cursor-pointer" placeholder="dd/mm/yyyy" required>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Chỉ tiêu tuyển dụng <span class="text-red-500">*</span></label>
                        <input type="number" name="HiringQuota" min="1" max="1000" value="@(Model?.HiringQuota > 0 ? Model.HiringQuota : 1)" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: 5" required>
                        <small class="text-muted block mt-1">Số lượng ứng viên cần tuyển (1 - 1000).</small>
                    </div>
                </div>
            </div>

            <!-- Technologies requirement -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">2. Yêu cầu chuyên môn & Kỹ năng</h2>
                <div class="grid grid-cols-1 gap-6">
                <div class="form-group">
                    <label class="text-sm font-bold text-dark block mb-2">Công nghệ / Tech Stack <span class="text-red-500">*</span></label>
                    <div id="tech-choices">
                        <select id="tech-dropdown" name="TechnologyIds" multiple required>
                            @if (ViewBag.Techs != null)
                            {
                                var selectedTechIds = (Model?.TechnologyIds ?? new List<int>());
                                foreach (var tech in (List<DevHub.Models.CommonTechnology>)ViewBag.Techs)
                                {
                                    <option value="@tech.TechId" selected="@(selectedTechIds.Contains(tech.TechId))">@tech.TechName</option>
                                }
                            }
                        </select>
                    </div>
                    <small class="text-muted block mt-1">Chỉ chọn từ danh sách hệ thống. Có thể chọn nhiều công nghệ, không trùng lặp.</small>
                </div>

                <style>
                    /* Theme Choices.js for Tech Stack */
                    #tech-choices .choices { margin-bottom: 0; }
                    #tech-choices .choices__inner {
                        background: #fff;
                        border: 1px solid #D6DDEB;
                        border-radius: 0.5rem;
                        min-height: 48px;
                        padding: 6px 8px;
                        font-size: 14px;
                    }
                    #tech-choices .choices.is-focused .choices__inner {
                        border-color: #4640DE;
                        box-shadow: 0 0 0 1px #4640DE;
                    }
                    #tech-choices .choices__list--multiple .choices__item {
                        background: #4640DE;
                        border: 1px solid #4640DE;
                        border-radius: 9999px;
                        padding: 4px 12px;
                        font-size: 13px;
                        font-weight: 600;
                    }
                    #tech-choices .choices__list--multiple .choices__item .choices__button {
                        border-left-color: rgba(255, 255, 255, 0.5);
                        margin-left: 8px;
                    }
                    #tech-choices .choices__list--dropdown {
                        border-color: #D6DDEB;
                        border-radius: 0.5rem;
                    }
                    #tech-choices .choices__list--dropdown .choices__item--selectable.is-highlighted {
                        background: #F7F5FC;
                        color: #25324B;
                    }
                    #tech-choices .choices__input { background: transparent; font-size: 14px; }
                </style>

                <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const techDropdown = document.getElementById('tech-dropdown');
                    if (!techDropdown) return;

                    // Choices.js is injected in layout.cshtml, just fix placeholde in Vietnamese
                    if (window.Choices) {
                        new Choices(techDropdown, {
                            removeItemButton: true,
                            duplicateItemsAllowed: false,
                            placeholder: true,
                            placeholderValue: 'Chọn công nghệ...',
                            searchPlaceholderValue: 'Tìm công nghệ...',
                            shouldSort: false,
                            itemSelectText: 'Nhấn để chọn',
                            noResultsText: 'Không tìm thấy công nghệ',
                            noChoicesText: 'Đã chọn hết công nghệ'
                        });
                    } else {
                        console.warn('Choices.js không được tải. Sẽ sử dụng dropdown bình thường.');
                    }

                    // Init single selects for searchable dropdowns
                    if (window.Choices) {
                        const singleOpts = { searchEnabled: true, shouldSort: false, itemSelectText: '', placeholder: true, allowHTML: false };
                        const positionDropdown = document.getElementById('position-dropdown');
                        if (positionDropdown) {
                            new Choices(positionDropdown, { ...singleOpts, searchPlaceholderValue: 'Tìm vị trí...' });
                        }
                        const experienceDropdown = document.getElementById('experience-dropdown');
                        if (experienceDropdown) {
                            new Choices(experienceDropdown, { ...singleOpts, searchPlaceholderValue: 'Tìm cấp bậc...' });
                        }
                        const workingModelDropdown = document.getElementById('working-model-dropdown');
                        if (workingModelDropdown) {
                            new Choices(workingModelDropdown, { ...singleOpts, searchPlaceholderValue: 'Tìm hình thức...' });
                        }

                        // Validation
                        const form = document.querySelector('form');
                        if (form) {
                            form.addEventListener('submit', function (e) {
                                const requiredSelects = [positionDropdown, experienceDropdown, workingModelDropdown];
                                for (const sel of requiredSelects) {
                                    if (sel && !sel.value) {
                                        e.preventDefault();
                                        const inner = sel.closest('.single-choices')?.querySelector('.choices__inner');
                                        if (inner) inner.classList.add('!border-red-500');
                                        sel.closest('.single-choices')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                        return;
                                    } else if (sel && sel.value) {
                                        const inner = sel.closest('.single-choices')?.querySelector('.choices__inner');
                                        if (inner) inner.classList.remove('!border-red-500');
                                    }
                                }
                            });
                        }
                    }
                });
                </script>

                <style>
                    /* Theme Choices.js for Single Selects */
                    .single-choices .choices { margin-bottom: 0; }
                    .single-choices .choices__inner {
                        background: #fff;
                        border: 1px solid #D6DDEB;
                        border-radius: 0.5rem;
                        min-height: 48px;
                        padding: 10px 12px;
                        font-size: 14px;
                    }
                    .single-choices .choices.is-focused .choices__inner {
                        border-color: #4640DE;
                        box-shadow: 0 0 0 1px #4640DE;
                    }
                    .single-choices .choices__list--single .choices__item {
                        padding: 0;
                        font-weight: 500;
                        color: #25324B;
                    }
                    .single-choices .choices__list--dropdown {
                        border-color: #D6DDEB;
                        border-radius: 0.5rem;
                    }
                    .single-choices .choices__list--dropdown .choices__item--selectable.is-highlighted {
                        background: #F7F5FC;
                        color: #25324B;
                    }
                    .single-choices .choices__input { font-size: 14px; }

                    /* Theme Choices.js for Province (reuse tech styling) */
                    #province-choices .choices { margin-bottom: 0; }
                    #province-choices .choices__inner {
                        background: #fff; border: 1px solid #D6DDEB; border-radius: 0.5rem;
                        min-height: 48px; padding: 6px 8px; font-size: 14px;
                    }
                    #province-choices .choices.is-focused .choices__inner {
                        border-color: #4640DE; box-shadow: 0 0 0 1px #4640DE;
                    }
                    #province-choices .choices__list--multiple .choices__item {
                        background: #4640DE; border: 1px solid #4640DE; border-radius: 9999px;
                        padding: 4px 12px; font-size: 13px; font-weight: 600;
                    }
                    #province-choices .choices__list--multiple .choices__item .choices__button {
                        border-left-color: rgba(255, 255, 255, 0.5); margin-left: 8px;
                    }
                    #province-choices .choices__list--dropdown { border-color: #D6DDEB; border-radius: 0.5rem; }
                    #province-choices .choices__list--dropdown .choices__item--selectable.is-highlighted {
                        background: #F7F5FC; color: #25324B;
                    }
                    #province-choices .choices__input { background: transparent; font-size: 14px; }
                </style>
                <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const provinceDropdown = document.getElementById('province-dropdown');
                    if (provinceDropdown && window.Choices) {
                        new Choices(provinceDropdown, {
                            removeItemButton: true,
                            duplicateItemsAllowed: false,
                            placeholder: true,
                            placeholderValue: 'Chọn tỉnh/thành...',
                            searchPlaceholderValue: 'Tìm tỉnh/thành...',
                            shouldSort: false,
                            itemSelectText: 'Nhấn để chọn',
                            noResultsText: 'Không tìm thấy tỉnh/thành',
                            noChoicesText: 'Đã chọn hết tỉnh/thành'
                        });
                    }
                });
                </script>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Kỹ năng mềm (Skills)</label>
                        <input type="text" name="Skill" value="@Model?.Skill" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Kỹ năng lãnh đạo, Giao tiếp khách hàng...">
                    </div>
                </div>
            </div>

            <!-- Salary range and benefits -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">3. Mức lương & Chế độ phúc lợi</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    @{
                        var createSalaryType = Model?.SalaryType ?? "RANGE";
                    }
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-dark mb-2">Loại lương <span class="text-red-500">*</span></label>
                        <select id="salary-type" name="SalaryType" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                            <option value="RANGE" selected="@(createSalaryType == "RANGE")">Khoảng lương cụ thể</option>
                            <option value="UPTO" selected="@(createSalaryType == "UPTO")">Lên đến (tối đa)</option>
                            <option value="NEGOTIABLE" selected="@(createSalaryType == "NEGOTIABLE")">Thỏa thuận</option>
                        </select>
                    </div>
                    <div id="salary-min-group">
                        <label class="block text-sm font-bold text-dark mb-2">Lương tối thiểu (VND) <span class="text-red-500">*</span></label>
                        <input type="text" inputmode="numeric" name="SalaryMin" id="salary-min" value="@(Model?.SalaryMin != null ? ((long)Model.SalaryMin).ToString() : "")" class="money-input w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: 10.000.000">
                    </div>
                    <div id="salary-max-group">
                        <label class="block text-sm font-bold text-dark mb-2">Lương tối đa (VND) <span class="text-red-500">*</span></label>
                        <input type="text" inputmode="numeric" name="SalaryMax" id="salary-max" value="@(Model?.SalaryMax != null ? ((long)Model.SalaryMax).ToString() : "")" class="money-input w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: 25.000.000">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-dark mb-2">Chế độ phúc lợi (Benefits) <span class="text-red-500">*</span></label>
                        <textarea name="Benefit" rows="4" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD:- Lương tháng 13&#10;- 15 ngày nghỉ phép/năm&#10;- Bảo hiểm y tế PVI" required>@Model?.Benefit</textarea>
                    </div>
                </div>
            </div>

            <!-- More about job description -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">4. Chi tiết công việc</h2>
                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Mô tả công việc (Description) <span class="text-red-500">*</span></label>
                        <textarea name="Description" rows="6" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Mô tả chi tiết nhiệm vụ và trách nhiệm của công việc..." required>@Model?.Description</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Yêu cầu công việc (Requirement) <span class="text-red-500">*</span></label>
                        <textarea name="Requirement" rows="6" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Ít nhất 2 năm kinh nghiệm làm việc với domain ngân hàng/ tài chính..." required>@Model?.Requirement</textarea>
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-100 flex justify-end gap-4"
                <!-- Cancel button, back to index -->
                <a href="@Url.Action("Index", new { q, status, page })" class="px-6 py-3 bg-white border border-gray-200 text-dark text-[15px] font-bold rounded-lg hover:bg-gray-50 transition-colors">
                    Hủy bỏ
                </a     
                <!-- Submit Button -->
                <button type="submit" class="px-8 py-3 bg-primary text-white text-[15px] font-bold rounded-lg hover:bg-primary-dark shadow-md shadow-primary/20 transition-all">
                    Đăng tin ngay
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Currency type format(ex: 20000000 -> 20.000.000)
    function formatThousand(value) {
        var digits = (value || '').replace(/\D/g, '');
        if (!digits) return '';
        return digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }

    var moneyInputs = document.querySelectorAll('.money-input');
    moneyInputs.forEach(function (el) {
        // applying format while typing
        el.addEventListener('input', function () {
            this.value = formatThousand(this.value);
        });
        // re-format after reloading form after validation error
        el.value = formatThousand(el.value);
    });

    // remove '.' before submiting so the model binding can parse to number successfully.
    var form = moneyInputs.length ? moneyInputs[0].form : null;
    if (form) {
        form.addEventListener('submit', function () {
            moneyInputs.forEach(function (el) {
                el.value = (el.value || '').replace(/\./g, '');
            });
        });
    }

    // Show/hide salary min & max based on the selected salary type.
    function updateSalaryFieldsVisibility() {
        var salaryType = document.getElementById('salary-type');
        if (!salaryType) return;
        var type = salaryType.value;
        var minGroup = document.getElementById('salary-min-group');
        var maxGroup = document.getElementById('salary-max-group');
        var minInput = document.getElementById('salary-min');
        var maxInput = document.getElementById('salary-max');

        if (type === 'NEGOTIABLE') {
            minGroup.classList.add('hidden'); maxGroup.classList.add('hidden');
            minInput.required = false; maxInput.required = false;
            minInput.value = ''; maxInput.value = '';
        } else if (type === 'UPTO') {
            minGroup.classList.add('hidden'); maxGroup.classList.remove('hidden');
            minInput.required = false; maxInput.required = true;
            minInput.value = '';
        } else { // RANGE
            minGroup.classList.remove('hidden'); maxGroup.classList.remove('hidden');
            minInput.required = true; maxInput.required = true;
        }
    }

    var salaryTypeEl = document.getElementById('salary-type');
    if (salaryTypeEl) {
        updateSalaryFieldsVisibility();
        salaryTypeEl.addEventListener('change', updateSalaryFieldsVisibility);
    }
});
</script>

<!-- Flatpickr for Date inputs -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/vn.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        flatpickr("#deadline-input", {
            altInput: true,
            altFormat: "d/m/Y",
            dateFormat: "Y-m-d",
            locale: "vn",
            minDate: "today",
            allowInput: false // Disable manual keyboard input
        });
    });
</script>
