@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Chỉnh sửa tin tuyển dụng";
    ViewData["ActiveMenu"] = "Jobs";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-dark">Chỉnh sửa tin tuyển dụng</h1>
            <p class="text-muted text-sm mt-1">Cập nhật thông tin chi tiết của tin tuyển dụng đã đăng</p>
        </div>
        <a href="/Recruiter/JobPost" class="inline-flex items-center justify-center px-4 py-2 bg-gray-100 text-dark text-[15px] font-bold rounded-lg hover:bg-gray-200 transition-all">
            Hủy và quay lại
        </a>
    </div>

    <!-- Form Container -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 md:p-8 shadow-sm">
        <form action="/Recruiter/JobPost" method="get" class="space-y-8">
            
            <!-- 1. Thông tin chung -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">1. Thông tin chung</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-dark mb-2">Tiêu đề công việc <span class="text-red-500">*</span></label>
                        <input type="text" name="Title" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Lập trình viên .NET Core (Senior)" value="Lập trình viên .NET Core (Senior)" required>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Vị trí (Job Position) <span class="text-red-500">*</span></label>
                        <select name="JobPosition" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                            <option value="">Chọn vị trí...</option>
                            <option value="Dev" selected>Developer (Backend/Frontend/Fullstack)</option>
                            <option value="BA">Business Analyst (BA)</option>
                            <option value="Tester">Tester / QC / QA</option>
                            <option value="PM">Project Manager (PM)</option>
                            <option value="DevOps">DevOps Engineer</option>
                            <option value="Data">Data Engineer / Data Scientist</option>
                            <option value="UIUX">UI/UX Designer</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Cấp bậc (Experience Level) <span class="text-red-500">*</span></label>
                        <select name="ExperienceLevel" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                            <option value="">Chọn cấp bậc...</option>
                            <option value="Intern">Intern</option>
                            <option value="Fresher">Fresher</option>
                            <option value="Junior">Junior</option>
                            <option value="Middle">Middle</option>
                            <option value="Senior" selected>Senior</option>
                            <option value="Lead">Lead / Manager</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Hình thức làm việc (Working Model) <span class="text-red-500">*</span></label>
                        <select name="WorkingModel" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" required>
                            <option value="">Chọn hình thức...</option>
                            <option value="Fulltime Onsite" selected>Full-time Onsite</option>
                            <option value="Fulltime Remote">Full-time Remote</option>
                            <option value="Parttime">Part-time</option>
                            <option value="Hybrid">Hybrid (Linh hoạt)</option>
                            <option value="Freelance">Freelance</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Địa điểm làm việc <span class="text-red-500">*</span></label>
                        <input type="text" name="Location" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Quận 1, TP. Hồ Chí Minh" value="Quận 1, TP. Hồ Chí Minh" required>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Hạn nhận hồ sơ (Deadline) <span class="text-red-500">*</span></label>
                        <input type="date" name="Deadline" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" value="2026-06-30" required>
                    </div>
                </div>
            </div>

            <!-- 2. Yêu cầu kĩ năng -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">2. Yêu cầu chuyên môn & Kỹ năng</h2>
                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Công nghệ sử dụng (Tech Stack) <span class="text-red-500">*</span></label>
                        <input type="text" name="TechStack" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: .NET, Java, C++, ReactJS..." value=".NET Core, ASP.NET Core MVC, Entity Framework Core, SQL Server" required>
                        <p class="text-xs text-muted mt-2">Ngăn cách các công nghệ bằng dấu phẩy (,)</p>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Kỹ năng mềm (Skills)</label>
                        <input type="text" name="Skills" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Kỹ năng lãnh đạo, Giao tiếp khách hàng..." value="Làm việc nhóm, Tư duy giải quyết vấn đề, Quản lý thời gian">
                    </div>
                </div>
            </div>

            <!-- 3. Mức lương & Phúc lợi -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">3. Mức lương & Chế độ phúc lợi</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Lương tối thiểu (VND) <span class="text-red-500">*</span></label>
                        <input type="number" name="SalaryMin" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: 10000000" value="25000000" required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Lương tối đa (VND) <span class="text-red-500">*</span></label>
                        <input type="number" name="SalaryMax" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: 25000000" value="45000000" required>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-dark mb-2">Chế độ phúc lợi (Benefits) <span class="text-red-500">*</span></label>
                        <textarea name="Benefits" rows="4" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD:- Lương tháng 13&#10;- 15 ngày nghỉ phép/năm&#10;- Bảo hiểm y tế PVI" required>- Lương tháng 13 & thưởng hiệu quả công việc định kỳ
- Bảo hiểm sức khỏe PVI Premium cho cá nhân và gia đình
- 15 ngày phép năm + 3 ngày nghỉ ốm hưởng nguyên lương
- Trợ cấp cơm trưa, gửi xe miễn phí, teambuilding hàng quý</textarea>
                    </div>
                </div>
            </div>

            <!-- 4. Chi tiết công việc -->
            <div>
                <h2 class="text-lg font-bold text-dark mb-4 pb-2 border-b border-gray-100">4. Chi tiết công việc</h2>
                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Mô tả công việc (Description) <span class="text-red-500">*</span></label>
                        <textarea name="Description" rows="6" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Mô tả chi tiết nhiệm vụ và trách nhiệm của công việc..." required>- Tham gia nghiên cứu, thiết kế và phát triển các hệ thống backend ứng dụng kiến trúc Microservices.
- Xây dựng API và tích hợp dịch vụ bên thứ ba bằng ASP.NET Core Web API.
- Tối ưu hóa hiệu năng cơ sở dữ liệu SQL Server, viết các stored procedure và xử lý truy vấn phức tạp.
- Hỗ trợ các thành viên khác trong đội ngũ phát triển và tham gia rà soát mã nguồn (code review).</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-dark mb-2">Yêu cầu công việc (Requirement) <span class="text-red-500">*</span></label>
                        <textarea name="Requirement" rows="6" class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: Ít nhất 2 năm kinh nghiệm làm việc với domain ngân hàng/ tài chính..." required>- Tối thiểu 3 năm kinh nghiệm thực chiến phát triển ứng dụng với ngôn ngữ C# và .NET Core.
- Nắm vững kiến thức OOP, SOLID principles, Design Patterns và RESTful API.
- Có kinh nghiệm làm việc với các hệ quản trị CSDL quan hệ SQL Server/PostgreSQL.
- Có kiến thức cơ bản hoặc kinh nghiệm làm việc với Git, Docker và quy trình CI/CD là điểm cộng lớn.</textarea>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-6 border-t border-gray-100 flex justify-end gap-4">
                <a href="/Recruiter/JobPost" class="px-6 py-3 bg-white border border-gray-200 text-dark text-[15px] font-bold rounded-lg hover:bg-gray-50 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-8 py-3 bg-primary text-white text-[15px] font-bold rounded-lg hover:bg-primary-dark shadow-md shadow-primary/20 transition-all">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>
