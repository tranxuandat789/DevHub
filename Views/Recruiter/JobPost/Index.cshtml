@model List<DevHub.Models.JobPost>
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Quản lý tin tuyển dụng";
    ViewData["ActiveMenu"] = "Jobs";

    var jobs = Model ?? new List<DevHub.Models.JobPost>();

    bool IsActive(string? s) => (s ?? "").ToLower() is "approved" or "active" or "open" or "published";
    bool IsClosed(string? s) => (s ?? "").ToLower() is "closed" or "expired";

    (string Cls, string Label) StatusBadge(string? status)
    {
        var s = (status ?? "").ToLower();
        if (IsActive(s)) return ("bg-green-100 text-green-700", "Đang hiển thị");
        if (s == "pending") return ("bg-amber-100 text-amber-700", "Chờ duyệt");
        if (s == "rejected") return ("bg-red-100 text-red-700", "Từ chối");
        if (IsClosed(s)) return ("bg-gray-100 text-gray-600", "Đã đóng");
        return ("bg-gray-100 text-gray-600", string.IsNullOrEmpty(status) ? "Không rõ" : status);
    }

    int cntAll = jobs.Count;
    int cntActive = jobs.Count(j => IsActive(j.Status));
    int cntPending = jobs.Count(j => (j.Status ?? "").ToLower() == "pending");
    int cntClosed = jobs.Count(j => IsClosed(j.Status));
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-dark">Quản lý tin tuyển dụng</h1>
            <p class="text-muted text-sm mt-1">Quản lý các tin tuyển dụng và theo dõi hồ sơ ứng viên</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/Recruiter/JobPost/Create" class="inline-flex items-center justify-center px-6 py-2.5 bg-primary text-white text-[15px] font-bold rounded-lg hover:bg-primary-dark shadow-md shadow-primary/20 transition-all">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Tạo tin tuyển dụng mới
            </a>
        </div>
    </div>

    <!-- Tabs & Filters -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] p-4 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Tabs -->
        <div class="flex items-center space-x-1 border-b md:border-b-0 border-gray-100 overflow-x-auto pb-2 md:pb-0">
            <button class="px-4 py-2 text-sm font-bold text-primary border-b-2 border-primary whitespace-nowrap">Tất cả tin (@cntAll)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Đang hiển thị (@cntActive)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Chờ duyệt (@cntPending)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Đã đóng (@cntClosed)</button>
        </div>
        
        <!-- Search -->
        <div class="relative min-w-[250px]">
            <input type="text" class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-colors" placeholder="Tìm kiếm theo tiêu đề...">
            <svg class="w-4 h-4 text-gray-400 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100 text-sm font-medium text-muted uppercase tracking-wider">
                        <th class="p-4 whitespace-nowrap font-bold">Vị trí / Chức danh</th>
                        <th class="p-4 whitespace-nowrap font-bold">Trạng thái</th>
                        <th class="p-4 whitespace-nowrap font-bold">Ngày đăng</th>
                        <th class="p-4 whitespace-nowrap font-bold">Hạn nhận CV</th>
                        <th class="p-4 whitespace-nowrap font-bold text-center">Ứng viên</th>
                        <th class="p-4 whitespace-nowrap font-bold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (jobs.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="p-10 text-center text-muted text-sm">
                                Chưa có tin tuyển dụng nào. Nhấn “Tạo tin tuyển dụng mới” để bắt đầu.
                            </td>
                        </tr>
                    }
                    @foreach (var j in jobs)
                    {
                        var badge = StatusBadge(j.Status);
                        var title = j.Title ?? "";
                        var initials = string.IsNullOrWhiteSpace(title)
                            ? "?"
                            : (title.Trim().Length >= 2 ? title.Trim().Substring(0, 2) : title.Trim());
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-[#F6F5FD] flex items-center justify-center text-primary font-bold uppercase">
                                        @initials
                                    </div>
                                    <div>
                                        <a href="/Recruiter/JobPost/Edit" class="text-[15px] font-bold text-dark group-hover:text-primary transition-colors cursor-pointer block">@title</a>
                                        <p class="text-sm text-muted mt-0.5">@j.Position?.PositionName • @j.WorkingModel</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="status-badge inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold @badge.Cls whitespace-nowrap">@badge.Label</span>
                            </td>
                            <td class="p-4 text-sm text-dark font-medium">@(j.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="p-4 text-sm text-dark font-medium">@(j.Deadline?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="p-4 text-center">
                                <span class="inline-flex items-center justify-center px-3 py-1 bg-primary/10 text-primary font-bold rounded-lg text-sm">@(j.ApplicationCount ?? 0)</span>
                            </td>
                            <td class="p-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Recruiter/JobPost/Edit" class="p-1.5 text-gray-400 hover:text-primary transition-colors" title="Chỉnh sửa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="p-4 border-t border-gray-100 flex items-center justify-between">
            <p class="text-sm text-muted">Hiển thị <span class="font-bold text-dark">@cntAll</span> trong số <span class="font-bold text-dark">@cntAll</span> tin</p>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const dropdownBtns = document.querySelectorAll('.btn-dropdown');
    
    dropdownBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            document.querySelectorAll('.dropdown-menu').forEach(menu => {
                if (menu !== btn.nextElementSibling) {
                    menu.classList.add('hidden');
                }
            });
            const menu = btn.nextElementSibling;
            if (menu) {
                menu.classList.toggle('hidden');
            }
        });
    });

    document.addEventListener('click', function() {
        document.querySelectorAll('.dropdown-menu').forEach(menu => {
            menu.classList.add('hidden');
        });
    });

    const statusButtons = document.querySelectorAll('.btn-status');
    statusButtons.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const status = btn.getAttribute('data-status');
            const row = btn.closest('tr');
            const badge = row.querySelector('.status-badge');
            
            if (badge) {
                badge.className = 'status-badge inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold whitespace-nowrap';
                
                if (status === 'duyet') {
                    badge.textContent = 'Đang hiển thị';
                    badge.classList.add('bg-green-100', 'text-green-700');
                } else if (status === 'tuchoi') {
                    badge.textContent = 'Từ chối';
                    badge.classList.add('bg-red-100', 'text-red-700');
                } else if (status === 'choxemxet') {
                    badge.textContent = 'Chờ xem xét';
                    badge.classList.add('bg-amber-100', 'text-amber-700');
                }
            }
            
            const menu = btn.closest('.dropdown-menu');
            if (menu) {
                menu.classList.add('hidden');
            }
        });
    });
});
</script>
