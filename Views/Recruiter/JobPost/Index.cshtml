@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Quản lý tin tuyển dụng";
    ViewData["ActiveMenu"] = "Jobs";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-dark">Quản lý tin tuyển dụng</h1>
            <p class="text-muted text-sm mt-1">Quản lý các tin tuyển dụng và theo dõi hồ sơ ứng viên</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/Recruiter/JobPost/Create" class="inline-flex items-center justify-center px-6 py-2.5 bg-primary text-white text-[15px] font-bold rounded-lg hover:bg-primary-dark shadow-md shadow-primary/20 transition-all">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Tạo tin tuyển dụng mới
            </a>
        </div>
    </div>

    <!-- Tabs & Filters -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] p-4 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Tabs -->
        <div class="flex items-center space-x-1 border-b md:border-b-0 border-gray-100 overflow-x-auto pb-2 md:pb-0">
            <button class="px-4 py-2 text-sm font-bold text-primary border-b-2 border-primary whitespace-nowrap">Tất cả tin (12)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Đang hiển thị (8)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Chờ duyệt (2)</button>
            <button class="px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap">Đã đóng (2)</button>
        </div>
        
        <!-- Search -->
        <div class="relative min-w-[250px]">
            <input type="text" class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-colors" placeholder="Tìm kiếm theo tiêu đề...">
            <svg class="w-4 h-4 text-gray-400 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100 text-sm font-medium text-muted uppercase tracking-wider">
                        <th class="p-4 whitespace-nowrap font-bold">Vị trí / Chức danh</th>
                        <th class="p-4 whitespace-nowrap font-bold">Trạng thái</th>
                        <th class="p-4 whitespace-nowrap font-bold">Ngày đăng</th>
                        <th class="p-4 whitespace-nowrap font-bold">Hạn nhận CV</th>
                        <th class="p-4 whitespace-nowrap font-bold text-center">Ứng viên</th>
                        <th class="p-4 whitespace-nowrap font-bold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <!-- Row 1 -->
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="p-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-[#F6F5FD] flex items-center justify-center text-primary font-bold">
                                    .N
                                </div>
                                <div>
                                    <h3 class="text-[15px] font-bold text-dark group-hover:text-primary transition-colors cursor-pointer">Senior .NET Core Backend Engineer</h3>
                                    <p class="text-sm text-muted mt-0.5">Developer • Full-time Onsite</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700 whitespace-nowrap">Đang hiển thị</span>
                        </td>
                        <td class="p-4 text-sm text-dark font-medium">10/05/2026</td>
                        <td class="p-4 text-sm text-dark font-medium">10/06/2026</td>
                        <td class="p-4 text-center">
                            <a href="#" class="inline-flex items-center justify-center px-3 py-1 bg-primary/10 text-primary font-bold rounded-lg hover:bg-primary hover:text-white transition-colors text-sm">
                                42
                            </a>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button class="p-1.5 text-gray-400 hover:text-primary transition-colors" title="Chỉnh sửa">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </button>
                                <button class="p-1.5 text-gray-400 hover:text-red-500 transition-colors" title="Tạm dừng">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </button>
                                <button class="p-1.5 text-gray-400 hover:text-dark transition-colors" title="Thêm">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                    
                    <!-- Row 2 -->
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="p-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-[#F6F5FD] flex items-center justify-center text-primary font-bold">
                                    BA
                                </div>
                                <div>
                                    <h3 class="text-[15px] font-bold text-dark group-hover:text-primary transition-colors cursor-pointer">Business Analyst (Banking Domain)</h3>
                                    <p class="text-sm text-muted mt-0.5">BA • Hybrid</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-700 whitespace-nowrap">Chờ duyệt</span>
                        </td>
                        <td class="p-4 text-sm text-dark font-medium">12/05/2026</td>
                        <td class="p-4 text-sm text-dark font-medium">12/06/2026</td>
                        <td class="p-4 text-center">
                            <span class="inline-flex items-center justify-center px-3 py-1 bg-gray-100 text-muted font-bold rounded-lg text-sm">
                                0
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button class="p-1.5 text-gray-400 hover:text-primary transition-colors" title="Chỉnh sửa">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </button>
                                <button class="p-1.5 text-gray-400 hover:text-red-500 transition-colors" title="Tạm dừng">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </button>
                                <button class="p-1.5 text-gray-400 hover:text-dark transition-colors" title="Thêm">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                    
                    <!-- Row 3 -->
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="p-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-[#F6F5FD] flex items-center justify-center text-primary font-bold">
                                    Re
                                </div>
                                <div>
                                    <h3 class="text-[15px] font-bold text-dark group-hover:text-primary transition-colors cursor-pointer">ReactJS Frontend Engineer (Fresher/Junior)</h3>
                                    <p class="text-sm text-muted mt-0.5">Developer • Full-time Onsite</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-gray-100 text-gray-600 whitespace-nowrap">Đã đóng</span>
                        </td>
                        <td class="p-4 text-sm text-dark font-medium">01/04/2026</td>
                        <td class="p-4 text-sm text-dark font-medium">01/05/2026</td>
                        <td class="p-4 text-center">
                            <a href="#" class="inline-flex items-center justify-center px-3 py-1 bg-primary/10 text-primary font-bold rounded-lg hover:bg-primary hover:text-white transition-colors text-sm">
                                128
                            </a>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button class="p-1.5 text-gray-400 hover:text-primary transition-colors" title="Mở lại">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                </button>
                                <button class="p-1.5 text-gray-400 hover:text-dark transition-colors" title="Thêm">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="p-4 border-t border-gray-100 flex items-center justify-between">
            <p class="text-sm text-muted">Hiển thị <span class="font-bold text-dark">1</span> đến <span class="font-bold text-dark">3</span> trong số <span class="font-bold text-dark">12</span> tin</p>
            <div class="flex items-center gap-1">
                <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-400 hover:text-primary hover:border-primary transition-colors" disabled>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded bg-primary text-white font-medium text-sm">1</button>
                <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-dark hover:text-primary hover:border-primary transition-colors text-sm font-medium">2</button>
                <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-dark hover:text-primary hover:border-primary transition-colors text-sm font-medium">3</button>
                <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-400 hover:text-primary hover:border-primary transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            </div>
        </div>
    </div>
</div>
