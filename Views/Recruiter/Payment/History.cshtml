@model DevHub.ViewModels.Payment.PaymentHistoryListVm
@{
    ViewData["Title"] = "Lịch Sử Thanh Toán - DevHub";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
}

<div class="p-6 max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 mb-2">Lịch Sử Thanh Toán</h1>
            <p class="text-gray-600">Quản lý các giao dịch mua gói dịch vụ và gia hạn.</p>
        </div>
        <div>
            <form action="/Recruiter/Payment/HistoryExport" method="get" class="inline">
                <input type="hidden" name="from" value="@ViewBag.From" />
                <input type="hidden" name="to" value="@ViewBag.To" />
                <input type="hidden" name="serviceId" value="@ViewBag.ServiceId" />
                <button type="submit" class="flex items-center gap-2 bg-green-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-green-700 transition-colors">
                    <i class="fa-solid fa-file-excel"></i> Xuất Excel
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg">
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Filters -->
    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6">
        <form action="/Recruiter/Payment/History" method="get" class="flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Từ ngày</label>
                <input type="date" name="from" value="@ViewBag.From" class="border border-gray-300 rounded-md shadow-sm px-3 py-2 focus:ring-primary focus:border-primary sm:text-sm">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Đến ngày</label>
                <input type="date" name="to" value="@ViewBag.To" class="border border-gray-300 rounded-md shadow-sm px-3 py-2 focus:ring-primary focus:border-primary sm:text-sm">
            </div>
            <button type="submit" class="bg-primary text-white px-4 py-2 rounded-md font-medium hover:bg-primary-dark transition-colors border border-transparent shadow-sm text-sm">
                Lọc
            </button>
            <a href="/Recruiter/Payment/History" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                Xóa lọc
            </a>
        </form>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        @if (Model.Items.Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mã GD</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Thời gian</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gói</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Loại</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tổng tiền</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trạng thái</th>
                            <th scope="col" class="relative px-6 py-3"><span class="sr-only">Chi tiết</span></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#@item.TransactionId</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@item.PackageName</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @if (item.TransactionType == "PURCHASE") { <span class="text-blue-600">Mua mới</span> }
                                    else if (item.TransactionType == "RENEW") { <span class="text-purple-600">Gia hạn</span> }
                                    else if (item.TransactionType == "UPGRADE") { <span class="text-orange-600">Nâng cấp</span> }
                                    else { @item.TransactionType }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900">@item.FinalAmount.ToString("N0") đ</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (item.Status == "SUCCESSFUL")
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Thành công</span>
                                    }
                                    else if (item.Status == "FAILED")
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Thất bại</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Đang xử lý</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="/Recruiter/Payment/HistoryDetails/@item.TransactionId" class="text-primary hover:text-primary-dark">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="bg-white px-4 py-3 border-t border-gray-200 flex items-center justify-between sm:px-6">
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-700">
                                Hiển thị trang <span class="font-medium">@Model.CurrentPage</span> / <span class="font-medium">@Model.TotalPages</span>
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <a href="/Recruiter/Payment/History?page=@i&from=@ViewBag.From&to=@ViewBag.To&serviceId=@ViewBag.ServiceId" 
                                       class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50
                                       @(i == Model.CurrentPage ? "z-10 bg-indigo-50 border-primary text-primary" : "")">
                                        @i
                                    </a>
                                }
                            </nav>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="p-12 text-center text-gray-500">
                <i class="fa-solid fa-receipt text-4xl mb-3 opacity-30"></i>
                <p>Không tìm thấy giao dịch nào phù hợp.</p>
            </div>
        }
    </div>
</div>
