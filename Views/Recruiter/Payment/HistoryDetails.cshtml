@model DevHub.ViewModels.Payment.PaymentHistoryDetailVm
@{
    ViewData["Title"] = "Chi Tiết Giao Dịch - DevHub";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
}

<div class="p-6 max-w-4xl mx-auto">
    <div class="mb-6 flex justify-between items-center">
        <a href="/Recruiter/Payment/History" class="text-gray-500 hover:text-primary transition-colors flex items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i> Quay lại lịch sử
        </a>
        <button onclick="window.print()" class="text-gray-500 hover:text-gray-900 px-3 py-1 border border-gray-300 rounded hover:bg-gray-50 text-sm">
            <i class="fa-solid fa-print"></i> In hóa đơn
        </button>
    </div>

    <div class="print-area bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden print:border-none print:shadow-none">
        <!-- Header -->
        <div class="bg-gray-50 p-6 border-b border-gray-200">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Chi Tiết Giao Dịch</h1>
                    <p class="text-gray-500 mt-1">Mã tham chiếu: @Model.VnpayTxnRef</p>
                </div>
                <div class="text-right">
                    @if (Model.Status == "SUCCESS")
                    {
                        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-green-100 text-green-800">Thành công</span>
                    }
                    else if (Model.Status == "FAILED")
                    {
                        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-red-100 text-red-800">Thất bại</span>
                    }
                    else
                    {
                        <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Đang xử lý</span>
                    }
                    <p class="text-sm text-gray-500 mt-2">@Model.TransactionDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">Thông tin thanh toán</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8 mb-8">
                <div>
                    <span class="block text-sm text-gray-500">Gói dịch vụ</span>
                    <span class="block font-medium text-gray-900">@Model.PackageName</span>
                </div>
                <div>
                    <span class="block text-sm text-gray-500">Phương thức thanh toán</span>
                    <span class="block font-medium text-gray-900">@Model.PaymentMethod</span>
                </div>
                <div>
                    <span class="block text-sm text-gray-500">Mã giao dịch cổng (VNPay)</span>
                    <span class="block font-medium text-gray-900">@(Model.VnpayTransactionNo ?? "N/A")</span>
                </div>
                <div>
                    <span class="block text-sm text-gray-500">Mã ngân hàng</span>
                    <span class="block font-medium text-gray-900">@(Model.VnpayBankCode ?? "N/A")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.BuyerTaxCode))
                {
                    <div>
                        <span class="block text-sm text-gray-500">Mã số thuế (Người mua)</span>
                        <span class="block font-medium text-gray-900">@Model.BuyerTaxCode</span>
                    </div>
                }
            </div>

            <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">Chi tiết số tiền</h3>
            <div class="space-y-3">
                <div class="flex justify-between text-gray-700">
                    <span>Giá gốc gói dịch vụ</span>
                    <span>@Model.AmountVnd.ToString("N0") VND</span>
                </div>
                
                @if (Model.DiscountAmount > 0 || !string.IsNullOrEmpty(Model.PromoCode))
                {
                    <div class="flex justify-between text-green-600">
                        <span>Mã giảm giá (@Model.PromoCode)</span>
                        <span>- @Model.DiscountAmount.ToString("N0") VND</span>
                    </div>
                }

                @{
                    var deduction = Model.AmountVnd - Model.DiscountAmount - Model.FinalAmount;
                    if (deduction > 0)
                    {
                        <div class="flex justify-between text-blue-600">
                            <span>Khấu trừ nâng cấp</span>
                            <span>- @deduction.ToString("N0") VND</span>
                        </div>
                    }
                }

                <div class="flex justify-between font-medium text-gray-900 border-t pt-3 mt-3">
                    <span>Thành tiền (Trước thuế)</span>
                    <span>@Model.FinalAmount.ToString("N0") VND</span>
                </div>
                
                @if (Model.VatAmount > 0)
                {
                    <div class="flex justify-between text-gray-700">
                        <span>Thuế GTGT (@Model.VatRate.ToString("0.##")%)</span>
                        <span>@Model.VatAmount.ToString("N0") VND</span>
                    </div>
                }

                <div class="flex justify-between font-bold text-xl text-gray-900 border-t border-gray-200 pt-3 mt-3">
                    <span>Tổng thanh toán</span>
                    <span class="text-primary">@(Model.TotalAmount > 0 ? Model.TotalAmount.ToString("N0") : Model.FinalAmount.ToString("N0")) VND</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        body {
            visibility: hidden;
            background-color: white !important;
        }
        .print-area, .print-area * {
            visibility: visible;
        }
        .print-area {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            margin: 0 !important;
            padding: 0 !important;
            box-shadow: none !important;
        }
        button, a, i {
            display: none !important;
        }
    }
</style>
