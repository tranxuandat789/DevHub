@model DevHub.ViewModels.Payment.SubscriptionPageVm
@{
    ViewData["Title"] = "Dịch vụ & Gói cước";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10 space-y-6 max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Dịch vụ & Gói cước</h1>
            <p class="text-sm text-gray-500 mt-1">Nâng cấp gói dịch vụ để tận hưởng các tính năng nổi bật và tiếp cận ứng viên tiềm năng nhanh chóng.</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Active Package & Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Active Package Card -->
        @if (Model.ActivePackage != null)
        {
            <div class="bg-gradient-to-br from-[#4640DE] to-indigo-700 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden">
                <!-- decorative circles -->
                <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-white opacity-10"></div>
                <div class="absolute bottom-0 right-10 -mb-10 w-24 h-24 rounded-full bg-white opacity-10"></div>
                
                <div class="relative z-10">
                    <p class="text-indigo-100 text-sm font-medium mb-1">Gói hiện tại</p>
                    <div class="flex items-baseline gap-2 mb-2">
                        <span class="text-3xl font-bold">@Model.ActivePackage.PackageName</span>
                    </div>
                    <p class="text-sm text-indigo-100 mb-1">Hết hạn: @Model.ActivePackage.EndDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <div class="mt-4">
                        <span class="inline-block bg-white bg-opacity-20 px-3 py-1 rounded-full text-sm font-medium">Còn @Model.ActivePackage.PostsRemaining / @Model.ActivePackage.PostsGranted lượt đăng</span>
                    </div>
                    <div class="mt-6 flex gap-3">
                        <button onclick="window.location.href='/Recruiter/Payment/History'" class="bg-white text-[#4640DE] px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-indigo-50 transition-colors shadow-sm w-full">
                            Lịch sử thanh toán
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="bg-gradient-to-br from-gray-600 to-gray-800 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden flex flex-col justify-center items-center text-center">
                <i class="fa-solid fa-box-open text-4xl mb-3 opacity-50"></i>
                <h3 class="text-lg font-bold">Chưa có gói dịch vụ</h3>
                <p class="text-sm text-gray-300 mt-2">Hãy chọn mua một gói dịch vụ bên dưới để bắt đầu đăng tin tuyển dụng.</p>
                <div class="mt-6 flex gap-3 w-full">
                    <button onclick="window.location.href='/Recruiter/Payment/History'" class="bg-white text-gray-800 px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-gray-100 transition-colors shadow-sm w-full">
                        Lịch sử thanh toán
                    </button>
                </div>
            </div>
        }

        <!-- Info Card -->
        <div class="lg:col-span-2 bg-white rounded-2xl p-6 border border-gray-200 shadow-sm flex flex-col justify-center">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
                Quy định về Gói dịch vụ & Nâng cấp
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-8">
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Chính sách nâng cấp</p>
                        <p class="text-gray-500 text-sm mt-0.5">Hệ thống sẽ tự động tính toán <span class="font-bold text-[#4640DE]">khấu trừ giá trị gói cũ</span> dựa trên thời gian và số lượt đăng còn lại.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-indigo-50 text-[#4640DE] flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Cộng dồn tự động</p>
                        <p class="text-gray-500 text-sm mt-0.5">Mua cùng một gói đang sử dụng sẽ cộng dồn số lượt đăng bài và kéo dài thời hạn theo gói mới.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pricing Section -->
    <div class="mt-10">
        <div class="text-center mb-10">
            <h2 class="text-2xl font-bold text-gray-900">Chọn gói dịch vụ phù hợp</h2>
            <p class="text-gray-500 mt-2">Đăng lẻ khi cần hoặc tiết kiệm tới 60% với các gói ưu đãi.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            @foreach (var pkg in Model.Packages)
            {
                var isDowngrade = Model.ActivePackage != null && pkg.Price < Model.ActivePackage.Price;
                var isSamePackage = Model.ActivePackage != null && Model.ActivePackage.ServiceId == pkg.ServiceId;
                
                var pkgNameLower = pkg.PackageName.ToLower();
                
                var borderClass = "border-gray-200 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group";
                var btnClass = "border-2 border-[#4640DE] text-[#4640DE] hover:bg-[#4640DE] hover:text-white";
                var badgeHtml = "";
                var iconColor = "text-[#4640DE]";

                if (pkgNameLower.Contains("đồng") || pkgNameLower.Contains("bronze") || pkgNameLower.Contains("cơ bản"))
                {
                    borderClass = "border-orange-200 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group";
                    btnClass = "bg-orange-500 text-white hover:bg-orange-600 shadow-sm shadow-orange-200 border-none";
                    iconColor = "text-orange-500";
                    badgeHtml = "<div class='mb-4 mt-1'><span class='inline-flex items-center py-1.5 px-3 rounded-md text-xs font-bold bg-orange-100 text-orange-700 border border-orange-200'>" + pkg.PackageName + "</span></div>";
                }
                else if (pkgNameLower.Contains("bạc") || pkgNameLower.Contains("tiêu chuẩn") || pkgNameLower.Contains("silver"))
                {
                    borderClass = "border-2 border-[#4640DE] shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group";
                    btnClass = "bg-[#4640DE] text-white hover:bg-indigo-700 shadow-sm shadow-indigo-200 border-none";
                    iconColor = "text-[#4640DE]";
                    badgeHtml = "<div class='absolute -top-3.5 inset-x-0 flex justify-center'><span class='bg-[#4640DE] text-white text-[11px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm'>Phổ biến nhất</span></div><div class='mb-4 mt-2'><span class='inline-flex items-center py-1.5 px-3 rounded-md text-xs font-bold bg-indigo-50 text-[#4640DE] border border-indigo-200'>" + pkg.PackageName + "</span></div>";
                }
                else if (pkgNameLower.Contains("vàng") || pkgNameLower.Contains("cao cấp") || pkgNameLower.Contains("gold") || pkgNameLower.Contains("premium"))
                {
                    borderClass = "border-yellow-300 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group";
                    btnClass = "bg-gradient-to-r from-yellow-400 to-yellow-500 text-white hover:from-yellow-500 hover:to-yellow-600 shadow-sm shadow-yellow-200 border-none";
                    iconColor = "text-yellow-500";
                    badgeHtml = "<div class='mb-4 mt-1'><span class='inline-flex items-center py-1.5 px-3 rounded-md text-xs font-bold bg-yellow-100 text-yellow-700 border border-yellow-300'>" + pkg.PackageName + "</span></div>";
                }
                else
                {
                    badgeHtml = "<div class='mb-4 mt-1'><span class='inline-flex items-center py-1.5 px-3 rounded-md text-xs font-bold bg-gray-100 text-gray-700'>" + pkg.PackageName + "</span></div>";
                }
                
                if (isDowngrade)
                {
                    btnClass = "bg-gray-200 text-gray-500 cursor-not-allowed border-none";
                }

                <div class="bg-white rounded-2xl border shadow-sm p-6 flex flex-col relative @borderClass">
                    @Html.Raw(badgeHtml)
                    
                    <h3 class="text-xl font-bold text-gray-900 mb-2">@pkg.PackageName</h3>
                    <p class="text-gray-500 text-sm mb-6 flex-grow">@pkg.Description</p>
                    
                    <div class="mb-6">
                        <div class="flex items-end gap-1">
                            <span class="text-3xl font-extrabold text-gray-900">@pkg.Price.ToString("N0")</span>
                            <span class="text-gray-500 font-medium pb-1">VNĐ</span>
                        </div>
                    </div>

                    <ul class="space-y-3 mb-8">
                        <li class="flex items-start gap-2 text-sm text-gray-800 font-medium">
                            <svg class="w-5 h-5 @iconColor shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Đăng tối đa @pkg.MaxPosts bài tuyển dụng
                        </li>
                        <li class="flex items-start gap-2 text-sm text-gray-600">
                            <svg class="w-5 h-5 @iconColor shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Thời hạn sử dụng @pkg.DurationDays ngày
                        </li>
                        
                        @if ((pkg.PriorityPush ?? 0) > 0)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-800 font-medium bg-indigo-50 -mx-2 px-2 py-1 rounded-md">
                                <svg class="w-5 h-5 @iconColor shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                Ưu tiên đẩy bài mức @pkg.PriorityPush
                            </li>
                        }
                        else
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-400">
                                <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                Không hỗ trợ đẩy bài
                            </li>
                        }

                        @if (pkg.HasAiChatbot)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-800 font-medium bg-green-50 -mx-2 px-2 py-1 rounded-md mt-2">
                                <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                Có Chatbot AI hỗ trợ
                            </li>
                        }
                        else
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-400 mt-2">
                                <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                Không có AI Chatbot
                            </li>
                        }
                    </ul>

                    <button type="button" 
                            onclick="@(isDowngrade ? "" : $"openPaymentModal({pkg.ServiceId}, '{pkg.PackageName}', {pkg.Price})")"
                            class="w-full py-2.5 px-4 rounded-lg font-bold transition-colors mt-auto @btnClass"
                            @(isDowngrade ? "disabled" : "")>
                        @(isDowngrade ? "Không thể hạ gói địch vụ" : (isSamePackage ? "Gia hạn / Mua thêm" : "Chọn mua"))
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Thanh Toán -->
<div id="paymentModal" class="fixed inset-0 bg-black/50 hidden z-[9999] flex items-center justify-center">
    <div class="bg-white rounded-xl p-6 max-w-md w-full mx-4 shadow-xl transform scale-95 opacity-0 transition-all duration-200 border border-gray-200" id="paymentModalContent">
        <div class="flex justify-between items-center mb-4 pb-4 border-b border-gray-100">
            <h2 class="font-bold text-gray-800 text-lg">Tổng quan đơn hàng</h2>
            <button type="button" onclick="closePaymentModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <div class="space-y-3 mb-6">
            <div class="flex justify-between text-gray-600 text-sm">
                <span id="modalPackageName">Gói dịch vụ</span>
                <span class="font-medium text-gray-900" id="modalOriginalPrice">0 VNĐ</span>
            </div>
            <div id="deductionRow" class="flex justify-between text-gray-600 text-sm hidden">
                <span>Khấu trừ gói hiện tại</span>
                <span class="font-medium text-blue-600" id="modalDeductionPrice">- 0 VNĐ</span>
            </div>
            <div id="discountRow" class="flex justify-between text-gray-600 text-sm hidden">
                <span>Giảm giá</span>
                <span class="font-medium text-green-600" id="modalDiscountPrice">- 0 VNĐ</span>
            </div>
            <div class="border-t border-gray-100 pt-3 flex justify-between items-center">
                <span class="font-bold text-gray-800">Tổng cộng</span>
                <span class="text-2xl font-bold text-[#4640DE]" id="modalFinalPrice">0 VNĐ</span>
            </div>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Mã giảm giá (có giới hạn)</label>
            <div class="flex items-stretch gap-1.5 h-10 w-full">
                <input type="text" id="promoCodeInput" name="PromoCodeInput" class="flex-1 min-w-0 border border-gray-300 rounded-lg px-3 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none" placeholder="Nhập mã voucher">
                <button type="button" onclick="applyVoucher()" class="bg-[#4640DE] text-white px-3.5 border border-transparent rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors whitespace-nowrap flex items-center justify-center shrink-0">
                    Áp dụng
                </button>
            </div>
            <p id="voucherMessage" class="mt-2 text-xs"></p>
        </div>

        <form asp-action="Create" asp-controller="RecruiterPayment" method="post" id="paymentForm">
            <input type="hidden" id="modalServiceId" name="ServiceId" />
            <input type="hidden" id="formPromoCode" name="PromoCode" />
            
            <button type="submit" onclick="copyPromoCode()" class="w-full bg-[#4640DE] text-white py-3 rounded-lg font-bold hover:bg-indigo-700 transition-colors shadow-sm flex items-center justify-center gap-2">
                Thanh toán VNPay <i class="fas fa-arrow-right"></i>
            </button>
            <p class="text-xs text-center text-gray-500 mt-4">Bằng việc thanh toán, bạn đồng ý với Điều khoản dịch vụ của DevHub.</p>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentServiceId = 0;
        let currentPrice = 0;

        function openPaymentModal(serviceId, packageName, price) {
            currentServiceId = serviceId;
            currentPrice = price;
            
            document.getElementById('modalServiceId').value = serviceId;
            document.getElementById('modalPackageName').innerText = packageName;
            document.getElementById('modalOriginalPrice').innerText = price.toLocaleString('vi-VN') + ' VNĐ';
            document.getElementById('modalFinalPrice').innerText = price.toLocaleString('vi-VN') + ' VNĐ';
            
            // Reset voucher
            document.getElementById('promoCodeInput').value = '';
            document.getElementById('formPromoCode').value = '';
            document.getElementById('voucherMessage').innerText = '';
            document.getElementById('discountRow').classList.add('hidden');
            
            // Auto check deduction (free upgrade without voucher)
            applyVoucher();
            
            const modal = document.getElementById('paymentModal');
            const content = document.getElementById('paymentModalContent');
            modal.classList.remove('hidden');
            // Small delay for transition
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closePaymentModal() {
            const content = document.getElementById('paymentModalContent');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                document.getElementById('paymentModal').classList.add('hidden');
            }, 200);
        }
        
        function copyPromoCode() {
            document.getElementById('formPromoCode').value = document.getElementById('promoCodeInput').value;
        }

        function applyVoucher() {
            const code = document.getElementById('promoCodeInput').value;
            const msgEl = document.getElementById('voucherMessage');
            
            msgEl.innerText = 'Đang kiểm tra...';
            msgEl.className = 'mt-2 text-sm text-gray-500';

            fetch(`/Recruiter/Payment/CheckVoucher?serviceId=${currentServiceId}&code=${encodeURIComponent(code)}`)
                .then(res => res.json())
                .then(data => {
                    if(data.isValid || !code) {
                        if(code) {
                            msgEl.innerText = data.message;
                            msgEl.className = 'mt-2 text-sm text-green-600';
                        } else {
                            msgEl.innerText = '';
                        }

                        if (data.discountAmount > 0) {
                            document.getElementById('modalDiscountPrice').innerText = '- ' + data.discountAmount.toLocaleString('vi-VN') + ' VNĐ';
                            document.getElementById('discountRow').classList.remove('hidden');
                        } else {
                            document.getElementById('discountRow').classList.add('hidden');
                        }

                        if (data.deductionAmount > 0) {
                            document.getElementById('modalDeductionPrice').innerText = '- ' + data.deductionAmount.toLocaleString('vi-VN') + ' VNĐ';
                            document.getElementById('deductionRow').classList.remove('hidden');
                        } else {
                            document.getElementById('deductionRow').classList.add('hidden');
                        }

                        document.getElementById('modalFinalPrice').innerText = data.finalAmount.toLocaleString('vi-VN') + ' VNĐ';
                    } else {
                        msgEl.innerText = data.message;
                        msgEl.className = 'mt-2 text-xs text-red-500';
                        document.getElementById('discountRow').classList.add('hidden');
                        
                        // Still update deduction if valid but voucher invalid
                        if (data.deductionAmount > 0) {
                            document.getElementById('modalDeductionPrice').innerText = '- ' + data.deductionAmount.toLocaleString('vi-VN') + ' VNĐ';
                            document.getElementById('deductionRow').classList.remove('hidden');
                        }
                        document.getElementById('modalFinalPrice').innerText = data.finalAmount.toLocaleString('vi-VN') + ' VNĐ';
                    }
                })
                .catch(err => {
                    msgEl.innerText = 'Lỗi kết nối.';
                    msgEl.className = 'mt-2 text-sm text-red-600';
                });
        }
    </script>
}
