@{
    ViewData["Title"] = "Kết Quả Thanh Toán - DevHub";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
    bool isSuccess = ViewBag.Success == true;
}

<div class="max-w-2xl mx-auto mt-12 p-8 bg-white rounded-2xl shadow-sm border border-gray-100 text-center">
    @if (isSuccess)
    {
        <div class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-check text-4xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Thanh toán thành công!</h1>
        <p class="text-gray-600 mb-8">Cảm ơn bạn đã sử dụng dịch vụ của DevHub. Gói dịch vụ của bạn đã được kích hoạt.</p>
    }
    else
    {
        <div class="w-20 h-20 bg-red-100 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-xmark text-4xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Thanh toán thất bại</h1>
        <p class="text-red-600 mb-8">@ViewBag.Message</p>
    }

    <div class="flex justify-center gap-4">
        <a href="/Recruiter/Payment/History" class="px-6 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
            Xem lịch sử
        </a>
        <a href="/Recruiter/Payment/Subscription" class="px-6 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary-dark transition-colors">
            Quay lại Gói dịch vụ
        </a>
    </div>
</div>
