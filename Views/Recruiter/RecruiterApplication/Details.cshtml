@model DevHub.ViewModels.Recruiter.CandidateProfileViewModel
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Chi tiết hồ sơ ứng viên";
    ViewData["ActiveMenu"] = "Candidates";

    (string Cls, string Label) StatusBadge(string? status)
    {
        switch ((status ?? "").ToUpper())
        {
            case "APPROVED": return ("bg-green-100 text-green-700", "Đã duyệt");
            case "PENDING": return ("bg-amber-100 text-amber-700", "Đang chờ duyệt");
            case "REJECTED": return ("bg-red-100 text-red-700", "Đã từ chối");
            default: return ("bg-gray-100 text-gray-600", status ?? "—");
        }
    }
    var badge = StatusBadge(Model.Status);
    string avatar = !string.IsNullOrEmpty(Model.AvatarUrl)
        ? Model.AvatarUrl!
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName)}&background=4640DE&color=fff&size=128";

    string Salary(decimal? v) => v.HasValue ? v.Value.ToString("#,##0").Replace(",", ".") : null;
    string salaryRange = (Model.ExpectedSalaryMin.HasValue || Model.ExpectedSalaryMax.HasValue)
        ? $"{Salary(Model.ExpectedSalaryMin) ?? "?"} - {Salary(Model.ExpectedSalaryMax) ?? "?"} VND"
        : "Chưa cập nhật";
}

<div class="space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg px-4 py-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3">@TempData["Error"]</div>
    }

    @if (Model.IsFrozen)
    {
        <div class="flex items-start gap-3 rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-sm text-yellow-800">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
            </svg>
            <div>
                <p class="font-medium">Tin tuyển dụng đang chờ kiểm duyệt lại</p>
                <p class="mt-0.5 text-yellow-700">Bạn vừa cập nhật tin này. Chức năng duyệt / từ chối ứng viên sẽ được mở lại sau khi kiểm duyệt viên phê duyệt tin. Đơn ứng tuyển vẫn được giữ nguyên.</p>
            </div>
        </div>
    }

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-muted mb-2">
                <a href="/Recruiter/RecruiterApplication?jobId=@Model.JobId" class="hover:text-primary transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Danh sách ứng viên
                </a>
                <span>/</span>
                <span class="text-dark">Chi tiết hồ sơ</span>
            </div>
            <h1 class="text-2xl font-bold text-dark">Hồ sơ: @Model.FullName</h1>
            <p class="text-muted text-sm mt-1">Ứng tuyển vị trí: <span class="font-medium text-dark">@Model.JobTitle</span></p>
        </div>
        <div class="flex items-center gap-3">
            @if (Model.CanReject)
            {
                <form id="rejectForm" method="post" action="/Recruiter/RecruiterApplication/Reject/@Model.ApplicationId">
                    @Html.AntiForgeryToken()
                    <button type="button" data-decision="reject" class="js-decision-btn px-4 py-2 bg-white border border-gray-200 text-red-600 font-semibold rounded-lg hover:bg-red-50 hover:border-red-200 transition-colors shadow-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Từ chối
                    </button>
                </form>
            }
            @if (Model.CanApprove)
            {
                <form id="approveForm" method="post" action="/Recruiter/RecruiterApplication/Approve/@Model.ApplicationId">
                    @Html.AntiForgeryToken()
                    <button type="button" data-decision="approve" class="js-decision-btn px-4 py-2 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors shadow-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Phê duyệt
                    </button>
                </form>
            }
            @if (Model.CanScheduleInterview)
            {
                <a href="/Recruiter/RecruiterInterview/Create?applicationId=@Model.ApplicationId" class="px-4 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors shadow-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    Lên lịch phỏng vấn
                </a>
            }
        </div>
    </div>

    <!-- Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left: Profile info -->
        <div class="space-y-6">
            <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm">
                <div class="flex items-center gap-4 mb-6">
                    <img src="@avatar" alt="Avatar" class="w-16 h-16 rounded-full object-cover border border-gray-200">
                    <div>
                        <h2 class="text-xl font-bold text-dark">@Model.FullName</h2>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold @badge.Cls">@badge.Label</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            <div><p class="text-xs text-muted mb-0.5">Email</p><p class="text-sm font-medium text-dark">@Model.Email</p></div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <div><p class="text-xs text-muted mb-0.5">Số điện thoại</p><p class="text-sm font-medium text-dark">@Model.Phone</p></div>
                        </div>
                    }
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <div><p class="text-xs text-muted mb-0.5">Khu vực mong muốn</p><p class="text-sm font-medium text-dark">@(Model.PreferredLocation ?? Model.Address ?? "Chưa cập nhật")</p></div>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>
                        <div><p class="text-xs text-muted mb-0.5">Mức lương mong muốn</p><p class="text-sm font-medium text-dark">@salaryRange</p></div>
                    </div>
                    @if (Model.AppliedAt.HasValue)
                    {
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <div><p class="text-xs text-muted mb-0.5">Ngày ứng tuyển</p><p class="text-sm font-medium text-dark">@Model.AppliedAt.Value.ToString("dd/MM/yyyy")</p></div>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm">
                <h3 class="text-sm font-bold text-dark uppercase tracking-wider mb-4">Kỹ năng chuyên môn</h3>
                <div class="flex flex-wrap gap-2">
                    @if (Model.Skills.Count == 0)
                    {
                        <span class="text-sm text-muted">Ứng viên chưa cập nhật kỹ năng.</span>
                    }
                    @foreach (var s in Model.Skills)
                    {
                        <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">@s.Tech@(string.IsNullOrEmpty(s.Level) ? "" : $" · {s.Level}")</span>
                    }
                </div>

                <h3 class="text-sm font-bold text-dark uppercase tracking-wider mb-2 mt-6">Kinh nghiệm</h3>
                <p class="text-sm text-dark font-medium">@(Model.ExperienceYears.HasValue ? $"{Model.ExperienceYears} năm kinh nghiệm" : "Chưa cập nhật")</p>
            </div>
        </div>

        <!-- Right: CV + cover letter -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm flex flex-col min-h-[420px]">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-bold text-dark">CV đính kèm</h3>
                    @if (!string.IsNullOrEmpty(Model.CvUrl))
                    {
                        <a href="@Model.CvUrl" target="_blank" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            Mở / Tải CV
                        </a>
                    }
                </div>
                <div class="flex-1 w-full bg-gray-50 rounded-lg border border-gray-200 overflow-hidden relative">
                    @if (!string.IsNullOrEmpty(Model.CvUrl))
                    {
                        <iframe src="@Model.CvUrl" class="absolute inset-0 w-full h-full" title="CV"></iframe>
                    }
                    else
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
                            <svg class="w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                            <p class="text-sm font-medium text-dark mb-1">@(Model.CvTitle ?? "Không có CV đính kèm")</p>
                            <p class="text-xs text-muted">Ứng viên chưa cung cấp đường dẫn CV.</p>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.CoverLetter))
            {
                <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm">
                    <h3 class="text-lg font-bold text-dark mb-3">Thư giới thiệu</h3>
                    <p class="text-sm text-dark whitespace-pre-line leading-relaxed">@Model.CoverLetter</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Custom confirm modal for Approve / Reject (no default JS confirm) -->
<div id="decisionModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.12)] max-w-md w-full mx-4 p-8" style="font-family:Inter,sans-serif">
        <div id="decisionIcon" class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 id="decisionTitle" class="text-lg font-bold text-[#25324B] text-center mb-2"></h3>
        <p id="decisionMessage" class="text-[#515B6F] text-sm text-center mb-6"></p>
        <div class="flex gap-3">
            <button type="button" id="decisionCancel" class="flex-1 px-6 py-2.5 bg-white border border-gray-200 text-dark text-[15px] font-bold rounded-lg hover:bg-gray-50 transition-colors">Hủy</button>
            <button type="button" id="decisionConfirm" class="flex-1 px-6 py-2.5 text-white text-[15px] font-bold rounded-lg transition-colors">Xác nhận</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('decisionModal');
            var iconBox = document.getElementById('decisionIcon');
            var titleEl = document.getElementById('decisionTitle');
            var msgEl = document.getElementById('decisionMessage');
            var confirmBtn = document.getElementById('decisionConfirm');
            var cancelBtn = document.getElementById('decisionCancel');
            var candidateName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FullName));
            var targetForm = null;

            function openModal(decision) {
                if (decision === 'approve') {
                    targetForm = document.getElementById('approveForm');
                    iconBox.className = 'w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4 bg-green-100 text-green-600';
                    titleEl.textContent = 'Xác nhận phê duyệt';
                    msgEl.innerHTML = 'Bạn sắp <b>phê duyệt</b> hồ sơ của <b>' + candidateName + '</b>. Ứng viên sẽ nhận thông báo và bạn có thể lên lịch phỏng vấn.';
                    confirmBtn.className = 'flex-1 px-6 py-2.5 text-white text-[15px] font-bold rounded-lg transition-colors bg-green-600 hover:bg-green-700';
                    confirmBtn.textContent = 'Phê duyệt';
                } else {
                    targetForm = document.getElementById('rejectForm');
                    iconBox.className = 'w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4 bg-red-100 text-red-600';
                    titleEl.textContent = 'Xác nhận từ chối';
                    msgEl.innerHTML = 'Bạn sắp <b>từ chối</b> hồ sơ của <b>' + candidateName + '</b>. Ứng viên sẽ nhận thông báo về quyết định này.';
                    confirmBtn.className = 'flex-1 px-6 py-2.5 text-white text-[15px] font-bold rounded-lg transition-colors bg-red-600 hover:bg-red-700';
                    confirmBtn.textContent = 'Từ chối';
                }
                modal.classList.remove('hidden');
            }

            function closeModal() { modal.classList.add('hidden'); targetForm = null; }

            document.querySelectorAll('.js-decision-btn').forEach(function (btn) {
                btn.addEventListener('click', function () { openModal(this.getAttribute('data-decision')); });
            });

            cancelBtn.addEventListener('click', closeModal);
            confirmBtn.addEventListener('click', function () { if (targetForm) targetForm.submit(); });
            modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
        });
    </script>
}
