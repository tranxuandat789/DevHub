@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Chi tiết hồ sơ ứng viên";
    ViewData["ActiveMenu"] = "Candidates";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-sm text-muted mb-2">
                <a href="/Recruiter/RecruiterApplication" class="hover:text-primary transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Quản lý CV ứng tuyển
                </a>
                <span>/</span>
                <span class="text-dark">Chi tiết hồ sơ</span>
            </div>
            <h1 class="text-2xl font-bold text-dark">Hồ sơ: Nguyễn Văn A</h1>
            <p class="text-muted text-sm mt-1">Ứng tuyển vị trí: <span class="font-medium text-dark">Senior .NET Core Backend Engineer</span></p>
        </div>
        <div class="flex items-center gap-3">
            <button class="px-4 py-2 bg-white border border-gray-200 text-red-600 font-semibold rounded-lg hover:bg-red-50 hover:border-red-200 transition-colors shadow-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                Từ chối
            </button>
            <button class="px-4 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors shadow-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Phê duyệt
            </button>
        </div>
    </div>

    <!-- Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column: Profile Info -->
        <div class="space-y-6">
            <!-- Profile Card -->
            <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm">
                <div class="flex items-center gap-4 mb-6">
                    <img src="https://i.pravatar.cc/150?img=33" alt="Avatar" class="w-16 h-16 rounded-full object-cover border border-gray-200">
                    <div>
                        <h2 class="text-xl font-bold text-dark">Nguyễn Văn A</h2>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-amber-100 text-amber-700">Đang chờ duyệt</span>
                        </div>
                    </div>
                </div>
                
                <div class="space-y-4">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        <div>
                            <p class="text-xs text-muted mb-0.5">Email</p>
                            <p class="text-sm font-medium text-dark">nguyenvana@example.com</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        <div>
                            <p class="text-xs text-muted mb-0.5">Số điện thoại</p>
                            <p class="text-sm font-medium text-dark">0901234567</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <div>
                            <p class="text-xs text-muted mb-0.5">Khu vực</p>
                            <p class="text-sm font-medium text-dark">Hồ Chí Minh, Việt Nam</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Skills & More -->
            <div class="bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm">
                <h3 class="text-sm font-bold text-dark uppercase tracking-wider mb-4">Kỹ năng chuyên môn</h3>
                <div class="flex flex-wrap gap-2">
                    <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">C#</span>
                    <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">.NET Core</span>
                    <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">SQL Server</span>
                    <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">Docker</span>
                    <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">Microservices</span>
                </div>
                
                <h3 class="text-sm font-bold text-dark uppercase tracking-wider mb-4 mt-6">Kinh nghiệm</h3>
                <p class="text-sm text-dark font-medium">3 năm kinh nghiệm</p>
            </div>
        </div>

        <!-- Right Column: CV Preview -->
        <div class="lg:col-span-2 bg-white rounded-xl border border-[#F6F5FD] p-6 shadow-sm flex flex-col h-full min-h-[600px]">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-dark">CV Đính kèm</h3>
                <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Tải xuống CV
                </a>
            </div>
            <div class="flex-1 w-full bg-gray-50 rounded-lg border border-gray-200 overflow-hidden relative group">
                <!-- Fallback CV Preview Design -->
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
                    <svg class="w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <p class="text-sm font-medium text-dark mb-1">NguyenVanA_CV_Backend.pdf</p>
                    <p class="text-xs text-muted mb-4">PDF Document • 1.2 MB</p>
                    <button class="px-4 py-2 bg-white border border-gray-200 text-dark font-medium rounded-lg hover:bg-gray-50 transition-colors shadow-sm text-sm">
                        Mở xem chi tiết
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
