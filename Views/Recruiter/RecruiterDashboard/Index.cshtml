@model DevHub.Models.RecruiterDashboard
@{
    ViewData["Title"] = "Dashboard Nhà Tuyển Dụng";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
    ViewData["ActiveMenu"] = "Dashboard";
}

<div class="w-full pt-6 pb-10">
    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 xl:px-12">

        @if (ViewBag.LoadError != null)
        {
            <div class="mb-6 flex items-start gap-3 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                <span>@ViewBag.LoadError</span>
            </div>
        }

        <!-- Header -->
        <div class="mb-8 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Tổng quan tuyển dụng</h1>
                <p class="text-gray-500 text-base mt-1">Theo dõi hoạt động và hiệu quả tuyển dụng của bạn</p>
            </div>
            <div class="flex items-center gap-3">
                @* [#10] Verification status badge *@
                @if (Model.IsVerified)
                {
                    <span class="flex items-center gap-1.5 px-3 py-1.5 bg-green-50 border border-green-200 text-green-700 rounded-full text-sm font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        Đã xác thực
                    </span>
                }
                else if (Model.HasPendingVerification)
                {
                    <span class="flex items-center gap-1.5 px-3 py-1.5 bg-yellow-50 border border-yellow-200 text-yellow-700 rounded-full text-sm font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Chờ xác thực
                    </span>
                }
                else
                {
                    <a href="/Recruiter/Settings?tab=license" class="flex items-center gap-1.5 px-3 py-1.5 bg-gray-50 border border-gray-200 text-gray-600 rounded-full text-sm font-medium hover:bg-gray-100 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        Chưa xác thực
                    </a>
                }
            </div>
        </div>

        @* [#7] Quick Actions Bar *@
        <div class="flex flex-wrap gap-3 mb-8">
            <a href="/Recruiter/JobPost/Create" class="flex items-center gap-2 px-4 py-2 bg-[#4640DE] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Đăng tin mới
            </a>
            <a href="/Recruiter/JobPost?status=pending" class="flex items-center gap-2 px-4 py-2 bg-yellow-50 border border-yellow-200 text-yellow-700 text-sm font-medium rounded-lg hover:bg-yellow-100 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Tin chờ duyệt
            </a>
            <a href="/Recruiter/Settings?tab=company" class="flex items-center gap-2 px-4 py-2 bg-gray-50 border border-gray-200 text-gray-600 text-sm font-medium rounded-lg hover:bg-gray-100 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Cài đặt hồ sơ
            </a>
        </div>

        @* [#4] Profile Completion Banner — only when below 100% *@
        @if (Model.ProfileCompletion < 100)
        {
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                        <svg class="w-5 h-5 text-amber-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <p class="font-semibold text-amber-800">Hoàn thiện hồ sơ công ty — @Model.ProfileCompletion%</p>
                    </div>
                    <div class="w-full bg-amber-100 rounded-full h-2 mb-2">
                        <div class="bg-amber-500 h-2 rounded-full transition-all" style="width: @Model.ProfileCompletion%"></div>
                    </div>
                    @if (Model.MissingProfileFields.Any())
                    {
                        <p class="text-sm text-amber-700">Còn thiếu: <span class="font-medium">@string.Join(", ", Model.MissingProfileFields)</span></p>
                    }
                </div>
                <a href="/Recruiter/Settings?tab=company" class="flex-shrink-0 px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold rounded-lg transition-colors">Cập nhật ngay →</a>
            </div>
        }

        @* [#5] Deadline Alert — only when there are jobs expiring within 7 days *@
        @if (Model.ExpiringJobs.Any())
        {
            <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-8">
                <div class="flex items-center gap-2 mb-3">
                    <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    <p class="font-semibold text-red-800">@Model.ExpiringJobs.Count tin tuyển dụng sắp hết hạn trong 7 ngày tới</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    @foreach (var job in Model.ExpiringJobs)
                    {
                        <a href="/Recruiter/JobPost/Detail/@job.JobId" class="flex items-center gap-2 px-3 py-1.5 bg-white border border-red-200 rounded-lg text-sm text-red-700 hover:bg-red-50 transition-colors">
                            <span class="font-medium">@job.Title</span>
                            <span class="px-2 py-0.5 bg-red-100 rounded-full text-xs font-bold">@(job.DaysLeft == 0 ? "Hôm nay" : $"Còn {job.DaysLeft} ngày")</span>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 xl:gap-10 mb-8 xl:mb-10">
            <!-- Job Posts -->
            <a href="/Recruiter/JobPost" class="bg-white rounded-xl p-8 shadow-sm border border-[#F6F5FD] flex items-center justify-between transition-transform hover:-translate-y-1 hover:shadow-md cursor-pointer">
                <div class="flex flex-col h-full justify-center">
                    <p class="text-4xl font-bold text-[#2563EB] counter-number leading-none mb-2" data-target="@Model.TotalJobPosts">@Model.TotalJobPosts</p>
                    <h4 class="text-gray-600 font-medium text-base">Tin tuyển dụng</h4>
                </div>
                <div class="w-16 h-16 bg-[#EEF4FF] rounded-full flex items-center justify-center text-[#2563EB]">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
            </a>

            <!-- Total Applications -->
            <a href="/Recruiter/RecruiterApplication/All" class="bg-white rounded-xl p-8 shadow-sm border border-[#F6F5FD] flex items-center justify-between transition-transform hover:-translate-y-1 hover:shadow-md cursor-pointer">
                <div class="flex flex-col h-full justify-center">
                    <p class="text-4xl font-bold text-[#8B5CF6] counter-number leading-none mb-2" data-target="@Model.TotalApplications">@Model.TotalApplications</p>
                    <h4 class="text-gray-600 font-medium text-base">Tổng ứng viên</h4>
                </div>
                <div class="w-16 h-16 bg-[#F5F3FF] rounded-full flex items-center justify-center text-[#8B5CF6]">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
            </a>

            <!-- Scheduled Interviews -->
            <a href="/Recruiter/RecruiterInterview" class="bg-white rounded-xl p-8 shadow-sm border border-[#F6F5FD] flex items-center justify-between transition-transform hover:-translate-y-1 hover:shadow-md cursor-pointer">
                <div class="flex flex-col h-full justify-center">
                    <p class="text-4xl font-bold text-[#F59E0B] counter-number leading-none mb-2" data-target="@Model.TotalScheduledInterviews">@Model.TotalScheduledInterviews</p>
                    <h4 class="text-gray-600 font-medium text-base">Phỏng vấn sắp tới</h4>
                </div>
                <div class="w-16 h-16 bg-[#FEF3C7] rounded-full flex items-center justify-center text-[#F59E0B]">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
            </a>

            <!-- [#8] Conversion Rate -->
            <a href="/Recruiter/RecruiterInterview" class="bg-white rounded-xl p-8 shadow-sm border border-[#F6F5FD] flex items-center justify-between transition-transform hover:-translate-y-1 hover:shadow-md cursor-pointer">
                <div class="flex flex-col h-full justify-center">
                    <p class="text-4xl font-bold text-[#10B981] leading-none mb-2">@Model.InterviewConversionRate<span class="text-2xl">%</span></p>
                    <h4 class="text-gray-600 font-medium text-base">Tỷ lệ phỏng vấn</h4>
                    <p class="text-xs text-gray-400 mt-1">@(Model.TotalScheduledInterviews + Model.TotalCompletedInterviews) / @Model.TotalApplications ứng viên</p>
                </div>
                <div class="w-16 h-16 bg-[#D1FAE5] rounded-full flex items-center justify-center text-[#10B981]">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
            </a>
        </div>

        @* [#3] Service Package Widget *@
        <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] p-6 mb-8 xl:mb-10">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-[#4640DE] flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <div>
                        @if (Model.HasActivePackage)
                        {
                            <p class="font-semibold text-gray-900">Gói: <span class="text-[#4640DE]">@Model.ActivePackageName</span></p>
                            <p class="text-sm text-gray-500 mt-0.5">Hết hạn: @(Model.PackageExpiry?.ToString("dd/MM/yyyy") ?? "—") · Còn <strong>@Model.PostsRemaining</strong> lượt đăng</p>
                        }
                        else
                        {
                            <p class="font-semibold text-gray-900">Chưa có gói dịch vụ đang hoạt động</p>
                            <p class="text-sm text-gray-500 mt-0.5">Mua gói để bắt đầu đăng tin tuyển dụng</p>
                        }
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    @if (Model.HasActivePackage)
                    {
                        <div class="hidden sm:block">
                            <p class="text-xs text-gray-500 mb-1 text-right">@Model.PostsRemaining / @Model.PostsGranted lượt còn lại</p>
                            @{
                                var pct = Model.PostsGranted > 0 ? (int)((double)Model.PostsRemaining / Model.PostsGranted * 100) : 0;
                            }
                            <div class="w-40 bg-gray-100 rounded-full h-2">
                                <div class="h-2 rounded-full @(pct <= 20 ? "bg-red-500" : "bg-[#4640DE]")" style="width: @pct%"></div>
                            </div>
                        </div>
                        <a href="/Recruiter/RecruiterService" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors">Nâng cấp</a>
                    }
                    else
                    {
                        <a href="/Recruiter/RecruiterService" class="px-5 py-2.5 bg-[#4640DE] hover:bg-opacity-90 text-white text-sm font-semibold rounded-lg transition-colors shadow-md">Mua gói ngay</a>
                    }
                </div>
            </div>
        </div>

        <!-- Statistics Chart -->
        <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] p-8 mb-8 xl:mb-10 overflow-hidden">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                <div>
                    <h3 class="text-xl font-bold text-gray-900">Thống kê ứng tuyển & Phỏng vấn</h3>
                    <p class="text-sm text-gray-500 mt-1">
                        Biểu đồ thể hiện sự tương tác của ứng viên
                        @switch (Model.StatsRange)
                        {
                            case "7": <text>trong 7 ngày qua</text> break;
                            case "year": <text>trong 1 năm qua (theo tháng)</text> break;
                            default: <text>trong 30 ngày qua</text> break;
                        }
                    </p>
                </div>
                <select onchange="window.location.href='/recruiter/dashboard?range=' + this.value"
                        class="bg-gray-50 border border-[#F6F5FD] text-gray-700 rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5 text-sm outline-none font-medium cursor-pointer">
                    <option value="7" selected="@(Model.StatsRange == "7")">7 ngày qua</option>
                    <option value="30" selected="@(Model.StatsRange == "30")">30 ngày qua</option>
                    <option value="year" selected="@(Model.StatsRange == "year")">1 năm qua (theo tháng)</option>
                </select>
            </div>
            <div class="relative h-[380px] w-full">
                <canvas id="dashboardChart"></canvas>
            </div>
        </div>

        @* [#9] Applicants per job — bar chart *@
        <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] p-8 mb-8 xl:mb-10">
            <h3 class="text-xl font-bold text-gray-900 mb-1">Ứng viên theo tin tuyển dụng</h3>
            <p class="text-sm text-gray-500 mb-6">Số lượt ứng tuyển của các tin gần đây</p>
            <div class="relative h-[300px] w-full">
                <canvas id="jobApplicantChart"></canvas>
            </div>
        </div>

        @* [#6] Recent Applicants *@
        <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] p-8 mb-8 xl:mb-10">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h3 class="text-xl font-bold text-gray-900">Ứng viên mới nhất</h3>
                    <p class="text-sm text-gray-500 mt-1">Các lượt ứng tuyển gần đây nhất</p>
                </div>
            </div>
            @if (Model.RecentApplications.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var app in Model.RecentApplications)
                    {
                        var avatarUrl = !string.IsNullOrEmpty(app.AvatarUrl)
                            ? app.AvatarUrl
                            : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(app.CandidateName)}&background=4640DE&color=fff&size=64";
                        var (appBadgeCss, appBadgeLabel) = app.ApplicationStatus.ToUpper() switch
                        {
                            "PENDING" => ("bg-yellow-100 text-yellow-700", "Chờ duyệt"),
                            "APPROVED" or "FINISHED" => ("bg-green-100 text-green-700", "Đã duyệt"),
                            "HIRED" => ("bg-blue-100 text-blue-700", "Trúng tuyển"),
                            "REJECTED" => ("bg-red-100 text-red-700", "Từ chối"),
                            "FAILED" => ("bg-red-100 text-red-700", "Không đạt"),
                            "CANCELLED" => ("bg-gray-100 text-gray-600", "Đã hủy"),
                            _ => ("bg-gray-100 text-gray-600", app.ApplicationStatus)
                        };
                        <div class="flex items-center gap-4 p-4 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
                            <img src="@avatarUrl" alt="@app.CandidateName" class="w-12 h-12 rounded-full object-cover flex-shrink-0 border-2 border-white shadow-sm">
                            <div class="min-w-0 flex-1">
                                <p class="font-semibold text-gray-900 text-sm truncate">@app.CandidateName</p>
                                <p class="text-xs text-gray-500 truncate mt-0.5">@app.JobTitle</p>
                                <div class="flex items-center gap-2 mt-1.5">
                                    <span class="px-2 py-0.5 rounded-full text-xs font-medium @appBadgeCss">@appBadgeLabel</span>
                                    <span class="text-xs text-gray-400">@(app.AppliedAt?.ToString("dd/MM HH:mm"))</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="py-10 text-center text-gray-400">
                    <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
                    <p class="text-sm">Chưa có ứng viên nào ứng tuyển.</p>
                </div>
            }
        </div>

        <!-- Two Columns -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 xl:gap-10">
            <!-- Left Column: Recent Job Posts -->
            <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] flex flex-col h-full overflow-hidden">
                <div class="p-8 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Tin tuyển dụng gần đây</h3>
                        <p class="text-sm text-gray-500 mt-1">Trạng thái và lượt ứng tuyển</p>
                    </div>
                    <a href="/Recruiter/JobPost" class="text-[#4640DE] font-semibold text-sm hover:underline flex items-center gap-1">
                        Xem tất cả
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
                <div class="p-0 flex-1 overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50 text-gray-500 text-sm border-b border-gray-100">
                                <th class="px-8 py-4 font-medium uppercase tracking-wider">Vị trí</th>
                                <th class="px-8 py-4 font-medium uppercase tracking-wider">Ứng viên</th>
                                <th class="px-8 py-4 font-medium uppercase tracking-wider">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 text-sm">
                            @if (Model.JobPostApplicantCounts.Any())
                            {
                                foreach (var job in Model.JobPostApplicantCounts)
                                {
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-8 py-5">
                                            @if ((job.Status ?? "").ToUpper() != "REJECTED")
                                            {
                                                <a href="/Recruiter/RecruiterApplication?jobId=@job.JobId" class="font-bold text-gray-900 text-base hover:text-blue-600 hover:underline transition-colors" title="Xem danh sách ứng viên">@job.Title</a>
                                            }
                                            else
                                            {
                                                <div class="font-bold text-gray-900 text-base">@job.Title</div>
                                            }
                                            <div class="text-gray-500 text-xs mt-1">@job.CreatedAt?.ToString("dd/MM/yyyy")</div>
                                        </td>
                                        <td class="px-8 py-5">
                                            <div class="flex items-center gap-2">
                                                @if (job.ApplicantAvatars.Any())
                                                {
                                                    <div class="flex -space-x-2">
                                                        @foreach (var av in job.ApplicantAvatars)
                                                        {
                                                            <img class="w-8 h-8 rounded-full border-2 border-white object-cover bg-gray-100" src="@av" alt="">
                                                        }
                                                    </div>
                                                }
                                                <span class="font-bold text-gray-700 bg-gray-100 px-2 py-1 rounded-md">@job.ApplicantCount</span>
                                            </div>
                                        </td>
                                        <td class="px-8 py-5">
                                            @{
                                                var (badgeCss, badgeLabel) = (job.Status?.ToUpper()) switch
                                                {
                                                    "APPROVED" => ("bg-blue-100 text-blue-800 border-blue-200", "Đang tuyển"),
                                                    "PENDING" => ("bg-yellow-100 text-yellow-800 border-yellow-200", "Chờ duyệt"),
                                                    "REJECTED" => ("bg-red-100 text-red-800 border-red-200", "Bị từ chối"),
                                                    "CLOSED" => ("bg-gray-100 text-gray-800 border-gray-200", "Đã đóng"),
                                                    _ => ("bg-gray-100 text-gray-800 border-gray-200", job.Status ?? "")
                                                };
                                            }
                                            <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-full border @badgeCss whitespace-nowrap">@badgeLabel</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="px-8 py-10 text-center text-gray-500 text-base">
                                        Chưa có tin tuyển dụng nào.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right Column: Interviews -->
            <div class="bg-white rounded-xl shadow-sm border border-[#F6F5FD] flex flex-col h-full overflow-hidden">
                <div class="p-8 border-b border-gray-100 bg-gray-50/50 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Lịch phỏng vấn</h3>
                        <p class="text-sm text-gray-500 mt-1">Danh sách phỏng vấn ứng viên</p>
                    </div>
                    <div class="flex bg-gray-100 p-1 rounded-lg">
                        <button onclick="filterInterviews('scheduled')" id="btn-scheduled" class="px-5 py-2 text-sm font-medium rounded-md bg-white text-gray-900 shadow-sm transition-all focus:outline-none">Sắp tới</button>
                        <button onclick="filterInterviews('completed')" id="btn-completed" class="px-5 py-2 text-sm font-medium rounded-md text-gray-500 hover:text-gray-900 transition-all focus:outline-none">Đã xong</button>
                    </div>
                </div>

                <div class="p-0 flex-1 overflow-y-auto max-h-[500px]">
                    <!-- Scheduled List -->
                    <div id="scheduled-interviews" class="divide-y divide-gray-100">
                        @if (Model.ScheduledInterviews.Any())
                        {
                            foreach (var interview in Model.ScheduledInterviews)
                            {
                                <div class="p-8 hover:bg-gray-50 transition-colors">
                                    <div class="flex items-start justify-between">
                                        <div class="flex gap-4">
                                            <div class="flex flex-col items-center justify-center bg-[#FEF3C7] text-[#F59E0B] rounded-lg w-16 h-16 flex-shrink-0">
                                                <span class="text-base font-bold uppercase">@interview.ScheduledTime.ToString("MMM")</span>
                                                <span class="text-2xl font-bold leading-none mt-0.5">@interview.ScheduledTime.ToString("dd")</span>
                                            </div>
                                            <div>
                                                <h4 class="text-base font-bold text-gray-900">@interview.Candidate?.FullName</h4>
                                                <p class="text-sm text-gray-500 mt-1">@interview.Application?.Job?.Title</p>
                                                <div class="flex items-center gap-4 mt-2.5 text-sm text-gray-500">
                                                    <span class="flex items-center gap-1.5">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                        @interview.ScheduledTime.ToString("HH:mm")
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(interview.MeetingLink))
                                                    {
                                                        <span class="flex items-center gap-1.5 text-[#4640DE]">
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                                            Online
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Sắp tới</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-10 text-center text-gray-500 text-base">
                                Không có lịch phỏng vấn sắp tới.
                            </div>
                        }
                    </div>

                    <!-- Completed List -->
                    <div id="completed-interviews" class="divide-y divide-gray-100 hidden">
                        @if (Model.CompletedInterviews.Any())
                        {
                            foreach (var interview in Model.CompletedInterviews)
                            {
                                <div class="p-8 bg-gray-50">
                                    <div class="flex items-start justify-between opacity-75">
                                        <div class="flex gap-4">
                                            <div class="flex flex-col items-center justify-center bg-gray-200 text-gray-600 rounded-lg w-16 h-16 flex-shrink-0">
                                                <span class="text-base font-bold uppercase">@interview.ScheduledTime.ToString("MMM")</span>
                                                <span class="text-2xl font-bold leading-none mt-0.5">@interview.ScheduledTime.ToString("dd")</span>
                                            </div>
                                            <div>
                                                <h4 class="text-base font-bold text-gray-900">@interview.Candidate?.FullName</h4>
                                                <p class="text-sm text-gray-500 mt-1">@interview.Application?.Job?.Title</p>
                                                <div class="flex items-center gap-4 mt-2.5 text-sm text-gray-500">
                                                    <span class="flex items-center gap-1.5">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                        @interview.ScheduledTime.ToString("HH:mm")
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Hoàn thành</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-10 text-center text-gray-500 text-base">
                                Chưa có buổi phỏng vấn nào hoàn thành.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Animate counters
        document.addEventListener('DOMContentLoaded', () => {
            const counters = document.querySelectorAll('.counter-number');
            const speed = 200;

            counters.forEach(counter => {
                const animate = () => {
                    const target = +counter.getAttribute('data-target');
                    const count = +counter.innerText || 0;
                    const increment = target / speed;

                    if (count < target) {
                        counter.innerText = Math.ceil(count + increment);
                        setTimeout(animate, 1);
                    } else {
                        counter.innerText = target;
                    }
                };
                animate();
            });
        });

        // Filter interviews
        function filterInterviews(status) {
            const scheduledList = document.getElementById('scheduled-interviews');
            const completedList = document.getElementById('completed-interviews');
            const btnScheduled = document.getElementById('btn-scheduled');
            const btnCompleted = document.getElementById('btn-completed');

            if (status === 'scheduled') {
                scheduledList.classList.remove('hidden');
                completedList.classList.add('hidden');
                
                btnScheduled.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
                btnScheduled.classList.remove('text-gray-500', 'hover:text-gray-900');
                
                btnCompleted.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
                btnCompleted.classList.add('text-gray-500', 'hover:text-gray-900');
            } else {
                scheduledList.classList.add('hidden');
                completedList.classList.remove('hidden');
                
                btnCompleted.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
                btnCompleted.classList.remove('text-gray-500', 'hover:text-gray-900');
                
                btnScheduled.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
                btnScheduled.classList.add('text-gray-500', 'hover:text-gray-900');
            }
        }

        // Initialize Chart
        document.addEventListener('DOMContentLoaded', () => {
            if (document.getElementById('dashboardChart')) {
                const ctx = document.getElementById('dashboardChart').getContext('2d');
                const gradientBlue = ctx.createLinearGradient(0, 0, 0, 380);
                gradientBlue.addColorStop(0, 'rgba(37, 99, 235, 0.15)');
                gradientBlue.addColorStop(1, 'rgba(37, 99, 235, 0)');

                const gradientOrange = ctx.createLinearGradient(0, 0, 0, 380);
                gradientOrange.addColorStop(0, 'rgba(249, 115, 22, 0.18)');
                gradientOrange.addColorStop(1, 'rgba(249, 115, 22, 0)');

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatsLabels)),
                        datasets: [
                            {
                                label: 'Lượt ứng tuyển',
                                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatsApplications)),
                                borderColor: '#2563EB',
                                backgroundColor: gradientBlue,
                                borderWidth: 3,
                                pointBackgroundColor: '#ffffff',
                                pointBorderColor: '#2563EB',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                fill: true,
                                tension: 0.4
                            },
                            {
                                label: 'Lượt phỏng vấn',
                                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatsInterviews)),
                                borderColor: '#F97316',
                                backgroundColor: gradientOrange,
                                borderWidth: 3,
                                pointBackgroundColor: '#ffffff',
                                pointBorderColor: '#F97316',
                                pointBorderWidth: 2,
                                pointStyle: 'triangle',
                                pointRadius: 6,
                                pointHoverRadius: 8,
                                fill: true,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                align: 'end',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8,
                                    boxHeight: 8,
                                    padding: 20,
                                    font: {
                                        family: "'Inter', sans-serif",
                                        size: 13,
                                        weight: '500'
                                    }
                                }
                            },
                            tooltip: {
                                backgroundColor: '#1F2937',
                                padding: 12,
                                titleFont: {
                                    family: "'Inter', sans-serif",
                                    size: 13
                                },
                                bodyFont: {
                                    family: "'Inter', sans-serif",
                                    size: 13
                                },
                                displayColors: true,
                                usePointStyle: true
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                border: {
                                    display: false
                                },
                                grid: {
                                    color: '#F3F4F6'
                                },
                                ticks: {
                                    font: {
                                        family: "'Inter', sans-serif",
                                        size: 12
                                    },
                                    color: '#6B7280',
                                    padding: 10
                                }
                            },
                            x: {
                                border: {
                                    display: false
                                },
                                grid: {
                                    display: false
                                },
                                ticks: {
                                    font: {
                                        family: "'Inter', sans-serif",
                                        size: 12
                                    },
                                    color: '#6B7280',
                                    padding: 10
                                }
                            }
                        },
                        interaction: {
                            intersect: false,
                            mode: 'index',
                        },
                    }
                });
            }
        });

        // [#9] Bar chart: applicants per recent job post
        document.addEventListener('DOMContentLoaded', () => {
            const barCanvas = document.getElementById('jobApplicantChart');
            if (!barCanvas) return;
            const jobLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.JobPostApplicantCounts.Select(j => (j.Title != null && j.Title.Length > 22) ? j.Title.Substring(0, 22) + "…" : (j.Title ?? "")).ToList()
            ));
            const jobData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.JobPostApplicantCounts.Select(j => j.ApplicantCount).ToList()
            ));
            new Chart(barCanvas.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: jobLabels,
                    datasets: [{
                        label: 'Số ứng viên',
                        data: jobData,
                        backgroundColor: 'rgba(70, 64, 222, 0.15)',
                        borderColor: '#4640DE',
                        borderWidth: 2,
                        borderRadius: 8,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#1F2937', callbacks: { label: c => `${c.raw} ứng viên` } }
                    },
                    scales: {
                        x: { beginAtZero: true, ticks: { precision: 0, color: '#6B7280' }, grid: { color: '#F3F4F6' } },
                        y: { grid: { display: false }, ticks: { color: '#374151', font: { size: 12 } } }
                    }
                }
            });
        });
    </script>
}
