@using DevHub.ViewModels.Recruiter
@model RecruiterInterviewViewModel
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Quản lý lịch phỏng vấn";
    ViewData["ActiveMenu"] = "Interviews";
}

<div class="space-y-6">
    @if (Context.Request.Query["message"] == "success")
    {
        <div class="p-4 mb-4 text-sm text-green-700 bg-green-100 rounded-lg font-medium" role="alert">
            Đã đặt lịch phỏng vấn thành công. Lịch mới đã được cập nhật vào hệ thống và gửi email thông báo cho ứng viên.
        </div>
    }
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-dark">Quản lý lịch phỏng vấn</h1>
            <p class="text-muted text-sm mt-1">Sắp xếp lịch hẹn và đánh giá kết quả phỏng vấn ứng viên</p>
        </div>
        <div class="flex items-center gap-3">
            <form id="jobFilterForm" method="get" class="relative" onchange="this.submit()">
                <input type="hidden" name="tab" value="@Model.ActiveTab" />
                <input type="hidden" name="search" value="@Model.SearchTerm" />
                <select name="jobId" class="appearance-none pl-4 pr-10 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm font-medium text-dark cursor-pointer shadow-sm">
                    <option value="">Tất cả bài tuyển dụng</option>
                    @foreach (var job in Model.JobPosts)
                    {
                        if (Model.SelectedJobId == job.JobId)
                        {
                            <option value="@job.JobId" selected>@job.Title</option>
                        }
                        else
                        {
                            <option value="@job.JobId">@job.Title</option>
                        }
                    }
                </select>
                <svg class="w-4 h-4 text-gray-500 absolute right-3.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </form>
            <a href="/Recruiter/RecruiterInterview/Create" class="inline-flex items-center justify-center px-4 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-sm text-sm whitespace-nowrap">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Tạo lịch phỏng vấn
            </a>
        </div>
    </div>

    <!-- Tabs & Filters -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] p-4 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Tabs -->
        <div class="flex items-center space-x-1 border-b md:border-b-0 border-gray-100 overflow-x-auto pb-2 md:pb-0">
            @{
                string BaseUrl = $"?jobId={Model.SelectedJobId}&search={Model.SearchTerm}";
                string GetTabClass(string tab) => Model.ActiveTab == tab 
                    ? "px-4 py-2 text-sm font-bold text-primary border-b-2 border-primary whitespace-nowrap" 
                    : "px-4 py-2 text-sm font-medium text-muted hover:text-dark transition-colors whitespace-nowrap";
            }
            <a href="@(BaseUrl)&tab=all" class="@GetTabClass("all")">Tất cả (@Model.AllCount)</a>
            <a href="@(BaseUrl)&tab=scheduled" class="@GetTabClass("scheduled")">Sắp tới (@Model.ScheduledCount)</a>
            <a href="@(BaseUrl)&tab=passed" class="@GetTabClass("passed")">Trúng tuyển (@Model.PassedCount)</a>
            <a href="@(BaseUrl)&tab=rejected" class="@GetTabClass("rejected")">Không đạt (@Model.RejectedCount)</a>
            <a href="@(BaseUrl)&tab=cancelled" class="@GetTabClass("cancelled")">Đã hủy (@Model.CancelledCount)</a>
        </div>
        
        <!-- Search -->
        <form method="get" class="relative min-w-[250px]" onsubmit="if(this.search) this.search.value = this.search.value.trim();">
            <input type="hidden" name="tab" value="@Model.ActiveTab" />
            <input type="hidden" name="jobId" value="@Model.SelectedJobId" />
            <input type="text" name="search" value="@Model.SearchTerm" class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm transition-colors" placeholder="Tìm tên ứng viên...">
            <button type="submit" class="absolute left-3.5 top-1/2 -translate-y-1/2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </button>
        </form>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl border border-[#F6F5FD] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            @if (Model.Interviews.Any())
            {
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100 text-sm font-medium text-muted uppercase tracking-wider">
                            <th class="p-4 whitespace-nowrap font-bold">Ứng viên</th>
                            <th class="p-4 whitespace-nowrap font-bold">Vị trí ứng tuyển</th>
                            <th class="p-4 whitespace-nowrap font-bold">Lịch hẹn</th>
                            <th class="p-4 whitespace-nowrap font-bold">Trạng thái</th>
                            <th class="p-4 whitespace-nowrap font-bold text-right">XEM CHI TIẾT</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model.Interviews)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="p-4">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.Candidate?.ImageUrl))
                                        {
                                            <img src="@item.Candidate.ImageUrl" alt="Avatar" class="w-10 h-10 rounded-full object-cover border border-gray-200">
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-lg border border-gray-200">
                                                @(string.IsNullOrEmpty(item.Candidate?.FullName) ? "?" : item.Candidate.FullName.Substring(0, 1).ToUpper())
                                            </div>
                                        }
                                        <div class="min-w-0">
                                            <h3 class="text-[15px] font-bold text-dark group-hover:text-primary transition-colors cursor-pointer truncate max-w-[180px]">@item.Candidate?.FullName</h3>
                                            <p class="text-sm text-muted mt-0.5 truncate max-w-[180px]">@item.Candidate?.CandidateNavigation?.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 max-w-[200px]">
                                    <div class="text-sm font-medium text-dark line-clamp-2">@item.Application?.Job?.Title</div>
                                </td>
                                <td class="p-4">
                                    <div class="text-sm font-bold text-dark">@item.ScheduledTime.ToString("HH:mm")</div>
                                    <div class="text-sm text-muted mt-0.5">@item.ScheduledTime.ToString("dd/MM/yyyy")</div>
                                    <div class="flex items-center gap-1 mt-1 text-xs @(item.InterviewType == "ONLINE" ? "text-blue-600" : "text-muted")">
                                        @if (item.InterviewType == "ONLINE")
                                        {
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                            <a href="@item.MeetingLink" target="_blank" class="hover:underline truncate max-w-[100px]">Trực tuyến</a>
                                        }
                                        else
                                        {
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                            <span class="truncate max-w-[120px] inline-block">@item.Location</span>
                                        }
                                    </div>
                                </td>
                                <td class="p-4">
                                    @if (item.Status == "scheduled")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-700 whitespace-nowrap">Đã lên lịch</span>
                                    }
                                    else if (item.Status == "completed_pending")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700 whitespace-nowrap">Chờ kết quả</span>
                                    }
                                    else if (item.Status == "passed")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700 whitespace-nowrap">Trúng tuyển</span>
                                    }
                                    else if (item.Status == "rejected")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-700 whitespace-nowrap">Không đạt</span>
                                    }
                                    else if (item.Status == "cancelled")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-gray-100 text-gray-700 whitespace-nowrap">Đã hủy</span>
                                    }
                                </td>
                                <td class="p-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Recruiter/RecruiterInterview/Details/@item.InterviewId" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-dark font-semibold rounded-lg hover:bg-gray-50 hover:text-primary transition-colors text-sm shadow-sm">
                                            Chi tiết
                                        </a>
                                        @if (item.Status == "scheduled" || item.Status == "completed_pending")
                                        {
                                            <a href="/Recruiter/RecruiterInterview/Edit/@item.InterviewId" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-dark font-semibold rounded-lg hover:bg-gray-50 hover:text-primary transition-colors text-sm shadow-sm">
                                                Chỉnh sửa
                                            </a>
                                            <button onclick="showCancelModal(@item.InterviewId)" class="inline-flex items-center px-3 py-1.5 bg-white border border-gray-200 text-red-600 font-semibold rounded-lg hover:bg-red-50 transition-colors text-sm shadow-sm">
                                                Hủy lịch
                                            </button>
                                        }
                                        @if (item.Status == "cancelled")
                                        {
                                            <a href="/Recruiter/RecruiterInterview/Create?jobId=@item.Application?.JobId&applicationId=@item.ApplicationId" class="inline-flex items-center px-3 py-1.5 bg-primary text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors text-sm shadow-sm">
                                                Tạo lại lịch
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-10 text-center">
                    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    </svg>
                    <h3 class="mt-2 text-sm font-semibold text-gray-900">Không có dữ liệu</h3>
                    <p class="mt-1 text-sm text-gray-500">Hiện chưa có lịch phỏng vấn nào phù hợp với bộ lọc.</p>
                </div>
            }
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="border-t border-gray-100 p-4 flex items-center justify-center">
                <div class="flex items-center gap-1">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="w-8 h-8 rounded-lg bg-primary text-white font-medium text-sm flex items-center justify-center">@i</span>
                        }
                        else
                        {
                            <a href="@(BaseUrl)&tab=@Model.ActiveTab&page=@i" class="w-8 h-8 rounded-lg text-dark hover:bg-gray-100 font-medium text-sm flex items-center justify-center transition-colors">@i</a>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Cancel Modal -->
<div id="cancelModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden transform transition-all">
        <div class="p-6">
            <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-1">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-bold text-dark">Hủy lịch phỏng vấn</h3>
                    <p class="text-sm text-muted mt-1 leading-relaxed">Bạn có chắc chắn muốn hủy lịch này không? Vui lòng cung cấp lý do hủy để thông báo cho ứng viên.</p>
                </div>
            </div>
            
            <div class="mt-4">
                <label for="cancelReason" class="block text-sm font-medium text-dark mb-1">Lý do hủy <span class="text-red-500">*</span></label>
                <textarea id="cancelReason" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 text-sm" placeholder="Nhập lý do hủy..."></textarea>
                <p id="cancelReasonError" class="text-red-500 text-xs mt-1 hidden">Vui lòng nhập lý do hủy.</p>
            </div>

            <div class="flex items-center justify-end gap-3 mt-6">
                <button type="button" onclick="closeCancelModal()" class="px-4 py-2.5 bg-white border border-gray-200 text-dark font-bold rounded-lg hover:bg-gray-50 transition-colors text-sm">Quay lại</button>
                <button type="button" id="confirmCancelBtn" onclick="confirmCancel()" class="px-4 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-700 transition-colors shadow-sm text-sm flex items-center justify-center">Xác nhận hủy</button>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="fixed inset-0 bg-black/30 z-[100] hidden flex flex-col items-center justify-center backdrop-blur-sm transition-all duration-300">
    <div class="bg-white p-6 rounded-xl shadow-xl flex flex-col items-center">
        <svg class="animate-spin h-10 w-10 text-primary mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="text-dark font-medium">Đang xử lý...</p>
    </div>
</div>

@section Scripts {
    <script>
        function toggleDropdown(button) {
            document.querySelectorAll('.dropdown-menu').forEach(menu => {
                if (menu !== button.nextElementSibling) {
                    menu.classList.add('hidden');
                }
            });
            const menu = button.nextElementSibling;
            menu.classList.toggle('hidden');
        }

        document.addEventListener('click', function(event) {
            if (!event.target.closest('.dropdown-container')) {
                document.querySelectorAll('.dropdown-menu').forEach(menu => {
                    menu.classList.add('hidden');
                });
            }
        });

        let cancelInterviewId = null;

        function showCancelModal(id) {
            cancelInterviewId = id;
            document.getElementById('cancelReason').value = '';
            document.getElementById('cancelReasonError').classList.add('hidden');
            document.getElementById('confirmCancelBtn').disabled = false;
            document.getElementById('cancelModal').classList.remove('hidden');
        }

        function closeCancelModal() {
            document.getElementById('cancelModal').classList.add('hidden');
            cancelInterviewId = null;
        }

        function confirmCancel() {
            if (cancelInterviewId) {
                const reason = document.getElementById('cancelReason').value.trim();
                const errorEl = document.getElementById('cancelReasonError');
                
                if (!reason) {
                    errorEl.classList.remove('hidden');
                    document.getElementById('cancelReason').focus();
                    return;
                }
                
                errorEl.classList.add('hidden');
                document.getElementById('confirmCancelBtn').disabled = true;
                
                updateStatus(cancelInterviewId, 'cancelled', reason);
            }
        }

        function updateStatus(id, status, reason = '') {
            let url = `/Recruiter/RecruiterInterview/UpdateStatus/${id}?status=${status}`;
            if (reason) {
                url += `&reason=${encodeURIComponent(reason)}`;
            }

            document.getElementById('loadingOverlay').classList.remove('hidden');

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                } else {
                    document.getElementById('loadingOverlay').classList.add('hidden');
                    alert(data.message || 'Có lỗi xảy ra');
                    if (status === 'cancelled') {
                        document.getElementById('confirmCancelBtn').disabled = false;
                    }
                }
            })
            .catch(err => {
                document.getElementById('loadingOverlay').classList.add('hidden');
                alert('Có lỗi xảy ra');
                if (status === 'cancelled') {
                    document.getElementById('confirmCancelBtn').disabled = false;
                }
            });
        }
    </script>
}
