@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Chi tiết thông báo";
}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10">
    <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb & Back -->
        <div class="mb-6">
            <button onclick="window.location.href='/recruiter/notifications'" class="text-gray-500 hover:text-[#4640DE] font-medium text-sm flex items-center gap-2 transition-colors border-none outline-none bg-transparent">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Quay lại danh sách thông báo
            </button>
        </div>

        <!-- Detail Content -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <!-- Header section depends on severity, let's mock a 'Critical' one -->
            <div class="p-6 sm:p-8 border-b border-gray-100 bg-red-50/20 relative">
                <div class="absolute top-0 left-0 w-1.5 h-full bg-red-500"></div>
                
                <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-red-100 text-red-600 flex items-center justify-center text-xl shadow-sm flex-shrink-0">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-800 border border-red-200 mb-1.5">
                                Mức độ: Quan trọng
                            </span>
                            <div class="text-sm font-medium text-gray-500 flex items-center gap-2">
                                <i class="far fa-clock"></i> 24/05/2026 14:30
                            </div>
                        </div>
                    </div>
                </div>
                
                <h1 class="text-2xl font-bold text-gray-900 leading-tight">Cảnh báo: Tài khoản của bạn sắp hết hạn đăng bài</h1>
            </div>

            <!-- Body -->
            <div class="p-6 sm:p-8 text-gray-700 leading-relaxed text-[15px]">
                <p class="mb-4">Chào bạn,</p>
                
                <p class="mb-4">Hệ thống DevHub thông báo: Gói dịch vụ <strong class="text-gray-900">"Gói Đồng"</strong> của bạn sẽ chính thức hết hạn trong vòng <strong class="text-red-600">3 ngày tới</strong> (vào ngày 27/05/2026).</p>
                
                <p class="mb-4">Nếu không gia hạn, các bài đăng tuyển dụng hiện tại của bạn có thể bị tạm dừng hiển thị đối với ứng viên. Để công việc tuyển dụng không bị gián đoạn và tiếp tục sử dụng các quyền lợi đăng bài, vui lòng thực hiện gia hạn hoặc mua gói mới.</p>
                
                <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-5 my-6 relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-4 opacity-10">
                        <i class="fas fa-gift text-6xl text-indigo-500"></i>
                    </div>
                    <div class="relative z-10">
                        <h4 class="text-indigo-800 font-bold mb-2 flex items-center gap-2"><i class="fas fa-gift"></i> Ưu đãi dành riêng cho bạn</h4>
                        <p class="text-indigo-700 text-sm m-0">Nhập mã <strong class="bg-indigo-100 px-2 py-0.5 rounded text-indigo-900">RENEW20</strong> để được giảm ngay 20% khi gia hạn Gói Đồng hoặc nâng cấp lên các gói cao hơn trong vòng 24h tới.</p>
                    </div>
                </div>
                
                <p class="mt-8">Trân trọng,<br><strong class="text-gray-900">Đội ngũ hỗ trợ DevHub</strong></p>
            </div>
            
            <!-- Actions -->
            <div class="p-5 sm:px-8 border-t border-gray-100 bg-gray-50 flex flex-wrap gap-3 justify-end items-center">
                <button onclick="window.location.href='/recruiter/notifications'" class="px-5 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg font-medium text-sm hover:bg-gray-50 transition-colors shadow-sm">
                    Đóng
                </button>
                <button onclick="window.location.href='/Recruiter/RecruiterService'" class="px-5 py-2.5 bg-[#4640DE] text-white rounded-lg font-bold text-sm hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                    <i class="fas fa-bolt"></i> Gia hạn dịch vụ ngay
                </button>
            </div>
        </div>
    </div>
</div>
