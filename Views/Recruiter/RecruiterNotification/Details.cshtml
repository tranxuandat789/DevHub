@model DevHub.Models.Notification
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Chi tiết thông báo";

    if (Model == null)
    {
        <div class="p-6 text-center text-gray-500">Thông báo không tồn tại.</div>
        return;
    }


}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10">
    <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb & Back -->
        <!-- Detail Content -->
        <div class="bg-white rounded-[10px] p-8 border border-gray-200 shadow-sm">
            <!-- Back Button & Header -->
            <div class="mb-6">
                <a href="/recruiter/notifications" class="inline-flex items-center text-[14px] font-medium text-gray-500 hover:text-[#4640DE] transition-colors mb-4">
                    <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Quay lại danh sách
                </a>
                <h1 class="text-[20px] font-bold text-gray-900 mb-2">@Model.Title</h1>
                <div class="text-[14px] text-gray-500 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <hr class="border-gray-100 mb-6" />

            @{
                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Nhà tuyển dụng";
                var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
                var companyName = ViewBag.CompanyName as string ?? "";
            }
            @if (Model.Type == "Welcome" || (Model.ReferenceType == "System" && Model.Title != null && Model.Title.Contains("Chào mừng")))
            {
                <!-- Nội dung mở đầu -->
                <p class="text-[15px] text-gray-700 mb-6 leading-relaxed">@Model.Message</p>



                <!-- Banner gợi ý -->
                <div class="bg-blue-50 border border-blue-100 rounded-xl px-5 py-4 flex items-start gap-4 mb-6">

                    <div>
                        <p class="text-[14px] font-semibold text-gray-800">Bạn đã sẵn sàng đăng tuyển và tìm kiếm nhân tài!</p>
                        <p class="text-[13px] text-gray-500 mt-0.5">Xác minh công ty để tăng uy tín và tiếp cận nhiều ứng viên hơn.</p>
                    </div>
                </div>

                <!-- Bạn có thể làm ngay -->
                <p class="text-[14px] font-semibold text-gray-700 mb-3">Bạn có thể làm ngay</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
                    <a href="/recruiter/settings?tab=company" class="flex items-center justify-between border border-gray-200 rounded-xl px-4 py-4 hover:border-[#4640DE] hover:bg-indigo-50 transition-all group">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 bg-[#4640DE] rounded-lg flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                            </div>
                            <div>
                                <div class="text-[13px] font-semibold text-gray-800">Xác minh hồ sơ công ty</div>
                                <div class="text-[12px] text-gray-500 mt-0.5">Tăng uy tín tuyển dụng</div>
                            </div>
                        </div>
                        <svg class="w-4 h-4 text-gray-400 group-hover:text-[#4640DE] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                    <a href="/recruiter/jobpost/create" class="flex items-center justify-between border border-gray-200 rounded-xl px-4 py-4 hover:border-green-400 hover:bg-green-50 transition-all group">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </div>
                            <div>
                                <div class="text-[13px] font-semibold text-gray-800">Đăng tin tuyển dụng</div>
                                <div class="text-[12px] text-gray-500 mt-0.5">Tiếp cận ứng viên chất lượng</div>
                            </div>
                        </div>
                        <svg class="w-4 h-4 text-gray-400 group-hover:text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                    <a href="/recruiter/jobpost" class="flex items-center justify-between border border-gray-200 rounded-xl px-4 py-4 hover:border-orange-400 hover:bg-orange-50 transition-all group">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <div>
                                <div class="text-[13px] font-semibold text-gray-800">Quản lý tin tuyển dụng</div>
                                <div class="text-[12px] text-gray-500 mt-0.5">Theo dõi tin đăng của bạn</div>
                            </div>
                        </div>
                        <svg class="w-4 h-4 text-gray-400 group-hover:text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-wrap gap-3">
                    <a href="/recruiter/jobpost/create" class="bg-[#4640DE] text-white px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-indigo-700 transition-colors inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Đăng tin tuyển dụng ngay
                    </a>
                    <a href="/recruiter/dashboard" class="bg-white border border-[#D6DDEB] text-gray-700 px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-gray-50 transition-colors">
                        Về trang chủ
                    </a>
                </div>
            }
            else
            {
                <!-- Content thông thường -->
                <div class="text-[15px] text-gray-700 whitespace-pre-wrap leading-relaxed">@Model.Message</div>
            }

            @if (Model.ReferenceType == "Application" && ViewBag.ApplicationData != null)
            {
                var app = (DevHub.Models.Application)ViewBag.ApplicationData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Ứng viên</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@(app.Candidate?.FullName ?? "N/A")</div>
                    </div>
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Vị trí ứng tuyển</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@(app.Job?.Title ?? "N/A")</div>
                    </div>

                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Trạng thái đơn</div>
                        <div class="flex-1">
                            @{
                                string statusClass = app.Status == "REJECTED" || app.Status == "Rejected" ? "bg-red-50 text-red-600" : (app.Status == "APPROVED" || app.Status == "Approved" || app.Status == "HIRED" ? "bg-green-50 text-green-600" : "bg-blue-50 text-[#4640DE]");
                                string statusText = app.Status == "REJECTED" || app.Status == "Rejected" ? "Từ chối" : (app.Status == "APPROVED" || app.Status == "Approved" ? "Đã duyệt" : (app.Status == "PENDING" || app.Status == "Pending" ? "Mới" : app.Status));
                            }
                            <span class="inline-flex px-2.5 py-1 rounded-md @statusClass font-medium text-xs">@statusText</span>
                        </div>
                    </div>
                </div>
            }
            else if (Model.ReferenceType == "JobPost" && ViewBag.JobData != null)
            {
                var job = (DevHub.Models.JobPost)ViewBag.JobData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Tin tuyển dụng</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@job.Title</div>
                    </div>

                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Trạng thái tin</div>
                        <div class="flex-1">
                            @{
                                string statusClass = job.Status == "REJECTED" || job.Status == "Rejected" ? "bg-red-50 text-red-600" : (job.Status == "APPROVED" || job.Status == "Approved" || job.Status == "PUBLISHED" || job.Status == "Published" ? "bg-green-50 text-green-600" : "bg-blue-50 text-[#4640DE]");
                                string statusText = job.Status == "REJECTED" || job.Status == "Rejected" ? "Từ chối" : (job.Status == "APPROVED" || job.Status == "Approved" || job.Status == "PUBLISHED" || job.Status == "Published" ? "Đã duyệt" : job.Status);
                            }
                            <span class="inline-flex px-2.5 py-1 rounded-md @statusClass font-medium text-xs">@statusText</span>
                        </div>
                    </div>
                    @if (job.ApprovedAt.HasValue)
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày duyệt</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@job.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    }
                </div>
            }
            else if (Model.ReferenceType == "Interview" && ViewBag.InterviewData != null)
            {
                var interview = (DevHub.Models.Interview)ViewBag.InterviewData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Vị trí</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@(interview.Application?.Job?.Title ?? "N/A")</div>
                    </div>
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày phỏng vấn</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@interview.ScheduledTime.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Giờ phỏng vấn</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@interview.ScheduledTime.ToString("HH:mm")</div>
                    </div>
                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Hình thức</div>
                        <div class="flex-1">
                            <span class="inline-flex px-2.5 py-1 rounded-md bg-blue-50 text-[#4640DE] font-medium text-xs">@(interview.InterviewType == "ONLINE" || interview.InterviewType == "Online" ? "Trực tuyến" : "Trực tiếp")</span>
                        </div>
                    </div>
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">@(interview.InterviewType?.ToUpper() == "ONLINE" ? "Link cuộc họp" : "Địa điểm")</div>
                        <div class="flex-1 text-[15px]">
                            @if (interview.InterviewType?.ToUpper() == "ONLINE" && !string.IsNullOrEmpty(interview.MeetingLink))
                            {
                                <a href="@interview.MeetingLink" target="_blank" class="text-blue-600 hover:underline break-all">@interview.MeetingLink</a>
                            }
                            else
                            {
                                <span class="text-gray-900">@interview.Location</span>
                            }
                        </div>
                    </div>
                </div>
            }
            else if (Model.ReferenceType == "Company" && ViewBag.CompanyData != null)
            {
                var company = (DevHub.Models.Company)ViewBag.CompanyData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Công ty</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@company.CompanyName</div>
                    </div>
                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Trạng thái</div>
                        <div class="flex-1">
                            @{
                                string statusClass = company.Status == "REJECTED" || company.Status == "Rejected" ? "bg-red-50 text-red-600" : (company.Status == "APPROVED" || company.Status == "Approved" || company.Status == "VERIFIED" ? "bg-green-50 text-green-600" : "bg-blue-50 text-[#4640DE]");
                                string statusText = company.Status == "REJECTED" || company.Status == "Rejected" ? "Từ chối" : (company.Status == "APPROVED" || company.Status == "Approved" || company.Status == "VERIFIED" ? "Đã duyệt" : company.Status);
                            }
                            <span class="inline-flex px-2.5 py-1 rounded-md @statusClass font-medium text-xs">@statusText</span>
                        </div>
                    </div>
                    @if ((company.Status == "REJECTED" || company.Status == "Rejected") && !string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Lý do từ chối</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@Model.Message</div>
                        </div>
                    }
                    @if (Model.CreatedAt.HasValue)
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày phản hồi</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    }
                </div>
            }
            else if (Model.ReferenceType == "Review" && ViewBag.ReviewData != null)
            {
                var review = (DevHub.Models.ReviewCompany)ViewBag.ReviewData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Công ty được đánh giá</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@(review.Company?.CompanyName ?? "N/A")</div>
                    </div>
                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Trạng thái đánh giá</div>
                        <div class="flex-1">
                            @{
                                string statusClass = review.Status == "REJECTED" || review.Status == "rejected" ? "bg-red-50 text-red-600" : (review.Status == "APPROVED" || review.Status == "approved" ? "bg-green-50 text-green-600" : "bg-blue-50 text-[#4640DE]");
                                string statusText = review.Status == "REJECTED" || review.Status == "rejected" ? "Từ chối" : (review.Status == "APPROVED" || review.Status == "approved" ? "Đã duyệt" : review.Status);
                            }
                            <span class="inline-flex px-2.5 py-1 rounded-md @statusClass font-medium text-xs">@statusText</span>
                        </div>
                    </div>
                    @if (review.ModeratedAt.HasValue)
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày duyệt</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@review.ModeratedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    }
                </div>
            }
            else if (Model.ReferenceType == "Payment" && ViewBag.PaymentData != null)
            {
                var payment = (DevHub.Models.PackageTransaction)ViewBag.PaymentData;
                bool isReminder = Model.Type == "PaymentReminder" || Model.Title.Contains("hết hạn", StringComparison.OrdinalIgnoreCase);
                
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Gói dịch vụ</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@(payment.Service?.PackageName ?? "N/A")</div>
                    </div>
                    
                    @if (!isReminder)
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Số tiền</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@payment.FinalAmount.ToString("N0") VNĐ</div>
                        </div>
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày thanh toán</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@(payment.TransactionDate?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</div>
                        </div>
                    }
                    
                    @{
                        DateTime? expiryDate = null;
                        if (payment.CompletedAt.HasValue && payment.Service != null && payment.Service.DurationDays.HasValue)
                        {
                            expiryDate = payment.CompletedAt.Value.AddDays(payment.Service.DurationDays.Value);
                        }
                    }
                    @if (expiryDate.HasValue)
                    {
                        <div class="flex">
                            <div class="w-48 text-gray-500 font-medium text-[15px]">Ngày hết hạn</div>
                            <div class="flex-1 text-gray-900 text-[15px]">@expiryDate.Value.ToString("dd/MM/yyyy")</div>
                        </div>
                        @if (isReminder)
                        {
                            int daysLeft = (int)(expiryDate.Value - DateTime.Now).TotalDays;
                            <div class="flex">
                                <div class="w-48 text-gray-500 font-medium text-[15px]">Thời gian còn lại</div>
                                <div class="flex-1 text-red-600 font-medium text-[15px]">@(daysLeft > 0 ? $"{daysLeft} ngày" : "Đã hết hạn")</div>
                            </div>
                        }
                    }
                </div>
            }
            else if (Model.ReferenceType == "Article" && ViewBag.ArticleData != null)
            {
                var article = (DevHub.Models.Article)ViewBag.ArticleData;
                <hr class="border-gray-100 my-6" />
                <div class="space-y-4">
                    <div class="flex">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Bài báo</div>
                        <div class="flex-1 text-gray-900 text-[15px]">@article.Title</div>
                    </div>
                    <div class="flex items-center">
                        <div class="w-48 text-gray-500 font-medium text-[15px]">Trạng thái</div>
                        <div class="flex-1">
                            @{
                                bool isHiddenByMod = article.Status == "HIDDEN" && !string.IsNullOrEmpty(article.RejectReason);
                                string statusClass = isHiddenByMod ? "bg-red-50 text-red-600" : (article.Status == "PUBLISHED" ? "bg-green-50 text-green-600" : "bg-gray-50 text-gray-600");
                                string statusText = isHiddenByMod ? "Bị ẩn" : (article.Status == "PUBLISHED" ? "Đã xuất bản" : article.Status);
                            }
                            <span class="inline-flex px-2.5 py-1 rounded-md @statusClass font-medium text-xs">@statusText</span>
                        </div>
                    </div>
                </div>
            }

            <!-- Actions -->
            @{
                bool isSystemRemind = Model.Title != null && Model.Title.Contains("hết hạn", StringComparison.OrdinalIgnoreCase) && (Model.ReferenceType == null || Model.ReferenceType == "System");
                bool hasAction = (Model.ReferenceId.HasValue && Model.ReferenceType != "System") || isSystemRemind;
            }
            @if (hasAction)
            {
                <div class="mt-8 flex flex-wrap gap-4 items-center">
                    @{
                        string ctaText = "";
                        string ctaUrl = "";
                        
                        if (isSystemRemind)
                        {
                            ctaText = "Gia hạn gói dịch vụ";
                            ctaUrl = "/recruiter/payment/subscription";
                        }
                        else if (Model.ReferenceType != null)
                        {
                            switch (Model.ReferenceType)
                            {
                                case "Application":
                                    ctaText = "Xem hồ sơ ứng tuyển";
                                    ctaUrl = $"/recruiter/recruiterapplication/details/{Model.ReferenceId}";
                                    break;
                                case "JobPost":
                                    ctaText = "Xem tin tuyển dụng";
                                    ctaUrl = $"/recruiter/jobpost/detail/{Model.ReferenceId}";
                                    break;
                                case "Company":
                                case "Account":
                                    ctaText = "Xem hồ sơ công ty";
                                    ctaUrl = "/recruiter/settings?tab=company";
                                    break;
                                case "Interview":
                                    ctaText = "Xem lịch phỏng vấn";
                                    ctaUrl = $"/recruiter/recruiterinterview/details/{Model.ReferenceId}";
                                    break;
                                case "Review":
                                    ctaText = "Xem đánh giá";
                                    ctaUrl = $"/company/reviews/{Model.ReferenceId}";
                                    break;
                                case "Payment":
                                    bool isRemind = Model.Type == "PaymentReminder" || Model.Title.Contains("hết hạn", StringComparison.OrdinalIgnoreCase);
                                    if (isRemind)
                                    {
                                        ctaText = "Gia hạn gói dịch vụ";
                                        ctaUrl = "/recruiter/payment/subscription";
                                    }
                                    else
                                    {
                                        ctaText = "Xem hóa đơn";
                                        ctaUrl = $"/recruiter/payment/historydetails/{Model.ReferenceId}";
                                    }
                                    break;
                                case "Article":
                                    ctaText = "Xem chi tiết bài báo";
                                    ctaUrl = $"/articles/{Model.ReferenceId}";
                                    break;
                            }
                        }
                    }
                    @if (!string.IsNullOrEmpty(ctaText) && !string.IsNullOrEmpty(ctaUrl))
                    {
                        <a href="@ctaUrl" class="bg-[#4640DE] text-white px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-indigo-700 transition-colors">@ctaText</a>
                    }
                    
                    @if (Model.ReferenceType == "Interview" && ViewBag.InterviewData != null)
                    {
                        var interview = (DevHub.Models.Interview)ViewBag.InterviewData;
                        if (interview.InterviewType == "Online" && !string.IsNullOrEmpty(interview.MeetingLink))
                        {
                            var interviewDateTime = interview.ScheduledTime;
                            var endTime = interviewDateTime.AddHours(1);
                            if (DateTime.Now >= interviewDateTime.AddMinutes(-30) && DateTime.Now <= endTime)
                            {
                                <a href="@interview.MeetingLink" target="_blank" class="bg-white border border-[#D6DDEB] text-gray-700 flex items-center gap-2 px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-gray-50 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                    Tham gia cuộc họp
                                </a>
                            }
                        }
                    }
                    else if (Model.ReferenceType == "Company")
                    {
                        var company = (DevHub.Models.Company)ViewBag.CompanyData;
                        if (company != null && (company.Status == "REJECTED" || company.Status == "Rejected"))
                        {
                            <a href="/recruiter/settings?tab=company" class="bg-white border border-[#D6DDEB] text-[#4640DE] flex items-center gap-2 px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                Gửi lại hồ sơ
                            </a>
                        }
                    }
                    else if (Model.ReferenceType == "Payment")
                    {
                        bool isRemind = Model.Type == "PaymentReminder" || Model.Title.Contains("hết hạn", StringComparison.OrdinalIgnoreCase);
                        if (!isRemind)
                        {
                            <a href="/recruiter/payment/subscription" class="bg-white border border-[#D6DDEB] text-gray-700 flex items-center gap-2 px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                Quản lý gói dịch vụ
                            </a>
                        }
                    }
                    else if (Model.ReferenceType == "Article")
                    {
                        <a href="/recruiter/article" class="bg-white border border-[#D6DDEB] text-gray-700 flex items-center gap-2 px-6 py-2.5 rounded-lg text-[14px] font-medium hover:bg-gray-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                            Quản lý bài báo
                        </a>
                    }
                </div>
            }
        </div>
        </div>
    </div>
</div>
