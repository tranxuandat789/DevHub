@model List<DevHub.Models.Notification>
@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Quản lý thông báo";
}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10">
    <div class="max-w-5xl mx-auto">
        <!-- Header -->
        <div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Thông báo hệ thống</h1>
                <p class="text-gray-500 text-sm mt-1">Quản lý và xem chi tiết các thông báo từ hệ thống DevHub</p>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="markAllAsRead()" class="text-gray-600 bg-white border border-gray-200 px-4 py-2 rounded-lg font-medium text-sm hover:bg-gray-50 transition-colors shadow-sm flex items-center gap-2">
                    <i class="fas fa-check-double"></i> Đánh dấu tất cả đã đọc
                </button>
            </div>
        </div>

        <!-- Filter Bar -->
        <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm mb-6 flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Mức độ quan trọng</label>
                <select id="filterSeverity" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none min-w-[180px]">
                    <option value="">Tất cả</option>
                    <option value="critical">Quan trọng (Đỏ)</option>
                    <option value="warning">Cảnh báo (Vàng)</option>
                    <option value="info">Thông tin (Xanh)</option>
                </select>
            </div>
            
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Trạng thái</label>
                <select id="filterStatus" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none min-w-[150px]">
                    <option value="">Tất cả trạng thái</option>
                    <option value="unread">Chưa đọc</option>
                    <option value="read">Đã đọc</option>
                </select>
            </div>

            <button onclick="applyFilters()" class="bg-[#4640DE] text-white px-5 py-2 rounded-lg font-medium text-sm hover:bg-indigo-700 transition-colors shadow-sm">
                <i class="fas fa-filter mr-1"></i> Lọc
            </button>
        </div>

        <!-- Notification List -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden" id="notificationList">
            
            @if (Model != null && Model.Any())
            {
                foreach (var notif in Model)
                {
                    string severityClass = notif.SeverityLevel == "critical" ? "bg-red-50/20 hover:bg-red-50/50" : 
                                           notif.SeverityLevel == "warning" ? "bg-yellow-50/20 hover:bg-yellow-50/50" : 
                                           "hover:bg-gray-50";
                    string severityTextClass = notif.SeverityLevel == "critical" ? "text-red-600" : 
                                               notif.SeverityLevel == "warning" ? "text-yellow-600" : 
                                               "text-blue-500";
                    string severityLabel = notif.SeverityLevel == "critical" ? "Quan trọng" : 
                                           notif.SeverityLevel == "warning" ? "Cảnh báo" : 
                                           "Thông tin";
                    string status = notif.IsRead == true ? "read" : "unread";
                    string opacityClass = notif.IsRead == true ? "opacity-75" : "opacity-100";

                    <a href="/recruiter/notifications/details/@notif.NotificationId" class="notification-item block p-5 border-b border-gray-100 transition-colors @severityClass @opacityClass" data-severity="@(notif.SeverityLevel ?? "info")" data-status="@status">
                        <div class="flex items-start gap-4">
                            <div class="flex-1">
                                <div class="flex items-start justify-between gap-4">
                                    <h3 class="font-bold text-gray-900 text-base">@notif.Title</h3>
                                    @if (notif.IsRead != true)
                                    {
                                        <span class="text-[10px] uppercase tracking-wide font-bold text-red-700 bg-red-100 px-2 py-0.5 rounded whitespace-nowrap">Mới</span>
                                    }
                                </div>
                                <p class="text-gray-600 text-sm mt-1.5 line-clamp-2 leading-relaxed">@notif.Message</p>
                                <div class="flex items-center gap-4 mt-3 text-xs text-gray-500 font-medium">
                                    <span class="flex items-center gap-1.5"><i class="far fa-clock"></i> @(notif.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</span>
                                    <span class="flex items-center gap-1.5 @severityTextClass"><i class="fas fa-circle text-[6px]"></i> @severityLabel</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            }
            
            <!-- Empty state -->
            <div id="noNotifications" class="@((Model != null && Model.Any()) ? "hidden" : "") p-12 text-center text-gray-500">
                <i class="far fa-bell-slash text-5xl mb-4 text-gray-300"></i>
                <p class="text-lg font-medium text-gray-700">Không có thông báo nào</p>
                <p class="text-sm mt-1">Không tìm thấy thông báo phù hợp với bộ lọc của bạn.</p>
            </div>
            
        </div>
        
        <!-- Pagination -->
        <div class="mt-6 flex justify-between items-center" id="paginationControls">
            <span class="text-sm text-gray-500">Hiển thị <span class="font-medium text-gray-900">1</span> đến <span class="font-medium text-gray-900">3</span> trong số <span class="font-medium text-gray-900">3</span> thông báo</span>
            <div class="flex gap-1.5">
                <button class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-400 cursor-not-allowed shadow-sm">
                    <i class="fas fa-chevron-left text-xs"></i>
                </button>
                <button class="w-9 h-9 flex items-center justify-center rounded-lg bg-[#4640DE] text-white font-bold text-sm shadow-sm border border-[#4640DE]">
                    1
                </button>
                <button class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 font-bold text-sm transition-colors shadow-sm">
                    <i class="fas fa-chevron-right text-xs"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const severity = $('#filterSeverity').val();
            const status = $('#filterStatus').val();

            let visibleCount = 0;

            $('.notification-item').each(function() {
                const item = $(this);
                const itemSeverity = item.data('severity');
                const itemStatus = item.data('status');
                
                let show = true;

                if (severity && itemSeverity !== severity) show = false;
                if (status && itemStatus !== status) show = false;

                if (show) {
                    item.show();
                    visibleCount++;
                } else {
                    item.hide();
                }
            });

            if (visibleCount === 0) {
                $('#noNotifications').removeClass('hidden');
                $('#paginationControls').hide();
            } else {
                $('#noNotifications').addClass('hidden');
                $('#paginationControls').show();
            }
        }
        
        function markAllAsRead() {
            $.post('/api/Notification/mark-all-read')
                .done(function(res) {
                    if (res.success) {
                        toastr.success('Đã đánh dấu tất cả là đã đọc.');
                        setTimeout(() => window.location.reload(), 1000);
                    }
                })
                .fail(function() {
                    toastr.error('Có lỗi xảy ra.');
                });
        }
    </script>
}
