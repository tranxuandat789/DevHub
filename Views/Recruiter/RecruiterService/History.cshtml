@{
    Layout = "_RecruiterLayout";
    ViewData["Title"] = "Lịch sử giao dịch";
}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Lịch sử giao dịch</h1>
                <p class="text-gray-500 text-sm mt-1">Tracking đơn giá, thời gian mua và quản lý các giao dịch gói dịch vụ</p>
            </div>
            <button onclick="window.location.href='/Recruiter/RecruiterService'" class="text-white bg-[#4640DE] px-4 py-2 rounded-lg font-medium text-sm hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                <i class="fas fa-plus"></i> Đăng ký dịch vụ
            </button>
        </div>

        <!-- Filter Bar -->
        <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm mb-6 flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Lọc theo gói</label>
                <select id="filterService" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none min-w-[150px]">
                    <option value="">Tất cả dịch vụ</option>
                    <option value="coin">Nạp Coin</option>
                    <option value="single">Bài đăng lẻ</option>
                    <option value="bronze">Gói Đồng</option>
                    <option value="silver">Gói Bạc</option>
                    <option value="gold">Gói Vàng</option>
                </select>
            </div>
            
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Từ ngày</label>
                <input type="date" id="filterFromDate" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none" />
            </div>

            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Đến ngày</label>
                <input type="date" id="filterToDate" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-[#4640DE] focus:border-[#4640DE] outline-none" />
            </div>

            <button onclick="applyFilters()" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg font-medium text-sm hover:bg-gray-200 transition-colors border border-gray-200">
                <i class="fas fa-filter mr-1"></i> Lọc
            </button>
            <button onclick="resetFilters()" class="text-gray-500 hover:text-gray-700 text-sm font-medium ml-1">
                Xóa bộ lọc
            </button>
        </div>

        <!-- Transaction Table -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[800px]">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100 text-xs text-gray-500 uppercase tracking-wider">
                            <th class="px-6 py-4 font-medium">Mã GD</th>
                            <th class="px-6 py-4 font-medium">Dịch vụ</th>
                            <th class="px-6 py-4 font-medium">Thời gian mua</th>
                            <th class="px-6 py-4 font-medium">Đơn giá</th>
                            <th class="px-6 py-4 font-medium">Voucher</th>
                            <th class="px-6 py-4 font-medium">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-sm" id="transactionTableBody">
                        <!-- Mock row 1 -->
                        <tr class="hover:bg-gray-50 transition-colors transaction-row" data-service="gold" data-date="2026-05-24">
                            <td class="px-6 py-4 font-medium text-gray-900">#VNP2026052401</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded bg-yellow-100 text-yellow-600 flex items-center justify-center text-xs"><i class="fas fa-crown"></i></div>
                                    <span class="font-medium text-gray-900">Gói Vàng</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-500">24/05/2026 14:30</td>
                            <td class="px-6 py-4 font-bold text-gray-900">180.000đ</td>
                            <td class="px-6 py-4 text-gray-500 text-xs">DevHub</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                                    Thành công
                                </span>
                            </td>
                        </tr>
                        <!-- Mock row 2 -->
                        <tr class="hover:bg-gray-50 transition-colors transaction-row" data-service="coin" data-date="2026-05-15">
                            <td class="px-6 py-4 font-medium text-gray-900">#VNP2026051508</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded bg-amber-100 text-amber-500 flex items-center justify-center text-xs"><i class="fas fa-coins"></i></div>
                                    <span class="font-medium text-gray-900">Nạp Coin</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-500">15/05/2026 09:15</td>
                            <td class="px-6 py-4 font-bold text-gray-900">100.000đ</td>
                            <td class="px-6 py-4 text-gray-400 text-xs">-</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                                    Thành công
                                </span>
                            </td>
                        </tr>
                        <!-- Mock row 3 -->
                        <tr class="hover:bg-gray-50 transition-colors transaction-row" data-service="bronze" data-date="2026-05-10">
                            <td class="px-6 py-4 font-medium text-gray-900">#VNP2026051002</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded bg-orange-100 text-orange-500 flex items-center justify-center text-xs"><i class="fas fa-medal"></i></div>
                                    <span class="font-medium text-gray-900">Gói Đồng</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-gray-500">10/05/2026 11:20</td>
                            <td class="px-6 py-4 font-bold text-gray-900">40.000đ</td>
                            <td class="px-6 py-4 text-gray-400 text-xs">-</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 border border-red-200">
                                    Thất bại
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <div id="noResults" class="hidden p-8 text-center text-gray-500">
                    <i class="fas fa-box-open text-3xl mb-3 text-gray-300"></i>
                    <p>Không tìm thấy giao dịch nào phù hợp với bộ lọc.</p>
                </div>
            </div>
            
            <!-- Pagination -->
            <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between" id="pagination">
                <span class="text-sm text-gray-500">Hiển thị <span class="font-medium text-gray-900">1</span> đến <span class="font-medium text-gray-900">3</span> trong số <span class="font-medium text-gray-900">3</span> kết quả</span>
                <div class="flex gap-1">
                    <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-400 cursor-not-allowed">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded bg-[#4640DE] text-white font-medium text-sm">
                        1
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-600 hover:bg-gray-50 font-medium text-sm transition-colors cursor-not-allowed">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const service = $('#filterService').val();
            const fromDate = $('#filterFromDate').val();
            const toDate = $('#filterToDate').val();

            let visibleCount = 0;

            $('.transaction-row').each(function() {
                const row = $(this);
                const rowService = row.data('service');
                const rowDateStr = row.data('date'); // YYYY-MM-DD
                
                let show = true;

                if (service && rowService !== service) {
                    show = false;
                }

                if (show && fromDate && rowDateStr < fromDate) {
                    show = false;
                }

                if (show && toDate && rowDateStr > toDate) {
                    show = false;
                }

                if (show) {
                    row.show();
                    visibleCount++;
                } else {
                    row.hide();
                }
            });

            if (visibleCount === 0) {
                $('#noResults').removeClass('hidden');
                $('#pagination').hide();
            } else {
                $('#noResults').addClass('hidden');
                $('#pagination').show();
            }
        }

        function resetFilters() {
            $('#filterService').val('');
            $('#filterFromDate').val('');
            $('#filterToDate').val('');
            applyFilters();
        }
    </script>
}
