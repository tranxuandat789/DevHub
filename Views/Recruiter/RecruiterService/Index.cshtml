@{
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
    ViewData["Title"] = "Dịch vụ & Gói cước";
}

<div class="p-6 sm:px-10 sm:pt-4 sm:pb-10 space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Dịch vụ & Gói cước</h1>
            <p class="text-sm text-gray-500 mt-1">Quản lý số dư Coin và mua các gói dịch vụ tuyển dụng ưu đãi.</p>
        </div>
    </div>

    <!-- Coin Balance & Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Balance Card -->
        <div class="bg-gradient-to-br from-[#4640DE] to-indigo-700 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden">
            <!-- decorative circles -->
            <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-white opacity-10"></div>
            <div class="absolute bottom-0 right-10 -mb-10 w-24 h-24 rounded-full bg-white opacity-10"></div>
            
            <div class="relative z-10">
                <p class="text-indigo-100 text-sm font-medium mb-1">Số dư hiện tại</p>
                <div class="flex items-baseline gap-2">
                    <span class="text-4xl font-bold">150</span>
                    <span class="text-lg font-semibold text-indigo-200">Coin</span>
                </div>
                <div class="mt-6 flex gap-3">
                    <button onclick="window.location.href='/Recruiter/RecruiterService/Checkout?package=coin'" class="bg-white text-[#4640DE] px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-indigo-50 transition-colors shadow-sm">
                        Nạp Coin
                    </button>
                    <button onclick="window.location.href='/Recruiter/RecruiterService/History'" class="bg-[#4640DE]/30 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-[#4640DE]/50 transition-colors border border-indigo-400/30">
                        Lịch sử
                    </button>
                </div>
            </div>
        </div>

        <!-- Info Card -->
        <div class="lg:col-span-2 bg-white rounded-2xl p-6 border border-gray-200 shadow-sm flex flex-col justify-center">
            <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
                Quy định về Coin & Dịch vụ
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-8">
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Tỷ giá quy đổi</p>
                        <p class="text-gray-500 text-sm mt-0.5"><span class="font-bold text-[#4640DE]">1 Coin = 1,000 VNĐ</span>. Bạn có thể nạp Coin bằng tiền mặt thông qua chuyển khoản hoặc thẻ.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-indigo-50 text-[#4640DE] flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Không hết hạn</p>
                        <p class="text-gray-500 text-sm mt-0.5">Số Coin bạn đã nạp sẽ được lưu trữ vĩnh viễn trong tài khoản và không bao giờ hết hạn.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pricing Section -->
    <div class="mt-10">
        <div class="text-center mb-10">
            <h2 class="text-2xl font-bold text-gray-900">Chọn phương thức đăng bài</h2>
            <p class="text-gray-500 mt-2">Đăng lẻ khi cần hoặc tiết kiệm tới 60% với các gói ưu đãi.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
            
            <!-- Đăng bài lẻ (Pay as you go) -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col relative group">
                <div class="mb-4">
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-md text-xs font-semibold bg-gray-100 text-gray-700">
                        Linh hoạt
                    </span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Đăng lẻ</h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">Dành cho nhu cầu tuyển dụng ít, không thường xuyên.</p>
                
                <div class="mb-6">
                    <div class="flex items-end gap-1">
                        <span class="text-3xl font-extrabold text-gray-900">10</span>
                        <span class="text-gray-500 font-medium pb-1">Coin / bài</span>
                    </div>
                    <p class="text-xs text-transparent font-medium mt-1 select-none">Mức giá cơ bản</p> <!-- Invisible spacer -->
                </div>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-[#4640DE] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Không giới hạn thời gian đăng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-[#4640DE] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Hiển thị tiêu chuẩn
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Không hỗ trợ đẩy bài
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Không có AI Chatbot
                    </li>
                </ul>

                <button onclick="window.location.href='/Recruiter/RecruiterService/Checkout?package=single'" class="w-full py-2.5 px-4 border-2 border-[#4640DE] text-[#4640DE] rounded-lg font-bold hover:bg-[#4640DE] hover:text-white transition-colors mt-auto">
                    Thanh toán lẻ
                </button>
            </div>

            <!-- Gói Đồng -->
            <div class="bg-white rounded-2xl border border-orange-200 shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col relative overflow-hidden group">
                <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-orange-400 to-amber-600 group-hover:h-1.5 transition-all"></div>
                <div class="mb-4 mt-1">
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-md text-xs font-bold bg-orange-100 text-orange-700 border border-orange-200">
                        Gói Đồng
                    </span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Khởi động</h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">Phù hợp cho startup và doanh nghiệp nhỏ.</p>
                
                <div class="mb-6">
                    <div class="flex items-end gap-1">
                        <span class="text-3xl font-extrabold text-gray-900">40</span>
                        <span class="text-gray-500 font-medium pb-1">Coin</span>
                    </div>
                    <p class="text-xs text-green-600 font-medium mt-1">Tiết kiệm 20% so với đăng lẻ</p>
                </div>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium">
                        <svg class="w-5 h-5 text-orange-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Đăng 5 bài tuyển dụng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-orange-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Thời hạn sử dụng 1 tháng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Không hỗ trợ đẩy bài
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Không có AI Chatbot
                    </li>
                </ul>

                <button onclick="window.location.href='/Recruiter/RecruiterService/Checkout?package=bronze'" class="w-full py-2.5 px-4 bg-orange-500 text-white rounded-lg font-bold hover:bg-orange-600 transition-colors shadow-sm shadow-orange-200 mt-auto">
                    Mua Gói Đồng
                </button>
            </div>

            <!-- Gói Bạc -->
            <div class="bg-white rounded-2xl border-2 border-[#4640DE] shadow-xl relative p-6 flex flex-col transform md:-translate-y-3 hover:-translate-y-4 transition-transform group">
                <div class="absolute -top-3.5 inset-x-0 flex justify-center">
                    <span class="bg-[#4640DE] text-white text-[11px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm">
                        Phổ biến nhất
                    </span>
                </div>
                
                <div class="mb-4 mt-2">
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-md text-xs font-bold bg-indigo-50 text-[#4640DE] border border-indigo-200">
                        Gói Bạc
                    </span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Tăng tốc</h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">Tuyệt vời cho công ty đang trên đà mở rộng.</p>
                
                <div class="mb-6">
                    <div class="flex items-end gap-1">
                        <span class="text-3xl font-extrabold text-[#4640DE]">120</span>
                        <span class="text-gray-500 font-medium pb-1">Coin</span>
                    </div>
                    <p class="text-xs text-green-600 font-medium mt-1">Tiết kiệm 40% so với đăng lẻ</p>
                </div>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium">
                        <svg class="w-5 h-5 text-[#4640DE] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Đăng 20 bài tuyển dụng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-[#4640DE] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Thời hạn sử dụng 3 tháng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium bg-indigo-50 -mx-2 px-2 py-1 rounded-md">
                        <svg class="w-5 h-5 text-[#4640DE] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                        Hỗ trợ tính năng Đẩy bài
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400 mt-2">
                        <svg class="w-5 h-5 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        Không có AI Chatbot
                    </li>
                </ul>

                <button onclick="window.location.href='/Recruiter/RecruiterService/Checkout?package=silver'" class="w-full py-2.5 px-4 bg-[#4640DE] text-white rounded-lg font-bold hover:bg-indigo-700 transition-colors shadow-md shadow-indigo-200 mt-auto">
                    Mua Gói Bạc
                </button>
            </div>

            <!-- Gói Vàng -->
            <div class="bg-gradient-to-b from-[#FFFDF0] to-white rounded-2xl border border-yellow-300 shadow-sm hover:shadow-md transition-shadow p-6 flex flex-col relative overflow-hidden group">
                <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-yellow-400 to-yellow-600 group-hover:h-1.5 transition-all"></div>
                <div class="mb-4 mt-1">
                    <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-md text-xs font-bold bg-yellow-100 text-yellow-800 border border-yellow-300">
                        Gói Vàng
                    </span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Chuyên nghiệp</h3>
                <p class="text-gray-500 text-sm mb-6 flex-grow">Giải pháp toàn diện cho doanh nghiệp lớn.</p>
                
                <div class="mb-6">
                    <div class="flex items-end gap-1">
                        <span class="text-3xl font-extrabold text-yellow-600">200</span>
                        <span class="text-gray-500 font-medium pb-1">Coin</span>
                    </div>
                    <p class="text-xs text-green-600 font-medium mt-1">Tiết kiệm tới 60%</p>
                </div>

                <ul class="space-y-3 mb-8">
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium">
                        <svg class="w-5 h-5 text-yellow-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Đăng 50 bài tuyển dụng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-yellow-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Thời hạn sử dụng 6 tháng
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium bg-yellow-50 -mx-2 px-2 py-1 rounded-md">
                        <svg class="w-5 h-5 text-yellow-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v8l9-11h-7z"></path></svg>
                        Đẩy bài Ưu tiên nhất
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-800 font-medium bg-indigo-50 -mx-2 px-2 py-1 rounded-md">
                        <svg class="w-5 h-5 text-indigo-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        AI Chatbot tuyển dụng
                    </li>
                </ul>

                <button onclick="window.location.href='/Recruiter/RecruiterService/Checkout?package=gold'" class="w-full py-2.5 px-4 bg-gradient-to-r from-yellow-500 to-yellow-600 text-white rounded-lg font-bold hover:from-yellow-600 hover:to-yellow-700 transition-colors shadow-sm shadow-yellow-200 mt-auto">
                    Mua Gói Vàng
                </button>
            </div>

        </div>
    </div>
</div>
