@model DevHub.Models.Recruiter
@{
    ViewData["Title"] = "Cài đặt";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
    var activeTab = ViewBag.ActiveTab as string ?? "account";
}

<div class="max-w-6xl mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Cài đặt</h1>
        <p class="text-gray-500 mt-1">Quản lý thông tin tài khoản, mật khẩu, thông tin công ty và giấy phép kinh doanh.</p>
    </div>

    @* Hiển thị thông báo sau khi thao tác (lưu hồ sơ, tải giấy phép, gửi yêu cầu xác minh...) *@
    @if (TempData["Success"] != null)
    {
        <div id="settingsAlert" class="mb-6 flex items-start gap-3 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
            <svg class="w-5 h-5 flex-shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div id="settingsAlert" class="mb-6 flex items-start gap-3 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
            <svg class="w-5 h-5 flex-shrink-0 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Tabs -->
        <div class="border-b border-gray-100 px-6 bg-gray-50/50">
            <nav class="flex space-x-8" aria-label="Tabs">
                <a href="/Recruiter/Settings?tab=account" class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm @(activeTab == "account" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                    Thông tin tài khoản
                </a>
                <a href="/Recruiter/Settings?tab=password" class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm @(activeTab == "password" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                    Đổi mật khẩu
                </a>
                <a href="/Recruiter/Settings?tab=company" class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm @(activeTab == "company" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                    Thông tin công ty
                </a>
                <a href="/Recruiter/Settings?tab=license" class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm @(activeTab == "license" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                    Giấy phép kinh doanh
                </a>
                @if (Model.IsCompanyAdmin == true)
                {
                    <a href="/Recruiter/Settings?tab=members" class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm @(activeTab == "members" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                        Quản lý thành viên
                    </a>
                }
            </nav>
        </div>

        <!-- Tab Content -->
        <div class="p-6">
            @if (activeTab == "account")
            {
                @await Html.PartialAsync("_AccountTab", Model)
            }
            else if (activeTab == "password")
            {
                @await Html.PartialAsync("_PasswordTab")
            }
            else if (activeTab == "company")
            {
                @await Html.PartialAsync("_CompanyTab")
            }
            else if (activeTab == "license")
            {
                @await Html.PartialAsync("_LicenseTab")
            }
            else if (activeTab == "members" && Model.IsCompanyAdmin == true)
            {
                @await Html.PartialAsync("_MembersTab")
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            const alert = document.getElementById('settingsAlert');
            if(alert) {
                alert.style.transition = 'opacity 0.5s ease';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            }
        }, 5000);
    </script>
}
