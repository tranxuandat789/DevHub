@model DevHub.Models.Recruiter
@using System.Security.Claims
@{
    var displayName = Model.FullName;
    var displayAvatar = !string.IsNullOrEmpty(Model.CompanyLogoUrl)
        ? Model.CompanyLogoUrl
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(displayName)}&background=4640DE&color=fff&size=128";
    var email = Model.RecruiterNavigation?.Email ?? User.FindFirstValue(ClaimTypes.Email) ?? "";
}
<div>
    <h2 class="text-lg font-medium text-gray-900 mb-6">Thông tin cá nhân</h2>
    
    <form class="space-y-6">
        <!-- Avatar -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Ảnh đại diện</label>
            <div class="flex items-center gap-6">
                <img src="@displayAvatar" alt="Avatar" class="w-24 h-24 rounded-full object-cover border-2 border-white shadow-sm" id="avatarPreview"
                     onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(displayName)&background=4640DE&color=fff&size=128'">
                <div>
                    <div class="flex items-center gap-3">
                        <label class="px-4 py-2 bg-blue-50 text-blue-600 hover:bg-blue-100 rounded-lg font-medium text-sm transition-colors cursor-pointer border border-blue-100">
                            Thay đổi ảnh
                            <input type="file" class="hidden" accept="image/*" onchange="previewImage(this, 'avatarPreview')">
                        </label>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Định dạng JPG, GIF hoặc PNG. Tối đa 2MB.</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên</label>
                <input type="text" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors" value="@Model.FullName" placeholder="Nhập họ và tên">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                <input type="tel" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors" value="@Model.Phone" placeholder="Nhập số điện thoại">
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-500 cursor-not-allowed" value="@email" disabled>
                <p class="text-xs text-gray-500 mt-1">Email không thể thay đổi vì được dùng làm tên đăng nhập.</p>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Chức vụ trong công ty</label>
                <input type="text" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors" value="@Model.Position" placeholder="Ví dụ: Giám đốc, Trưởng phòng HR...">
            </div>
        </div>

        <div class="pt-4 flex justify-end">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors shadow-sm shadow-blue-500/20">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>

<script>
    function previewImage(input, previewId) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById(previewId).src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
