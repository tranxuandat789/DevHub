@model DevHub.Models.Recruiter
@{
    //get logo company, if null generate default logo by user name
    var logoSrc = !string.IsNullOrEmpty(Model.Company?.CompanyLogoUrl)
        ? Model.Company?.CompanyLogoUrl
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.Company?.CompanyName ?? "C")}&background=4640DE&color=fff&size=128";

    //saved the typed information in form from user in case it got failed by validation
    string FieldValue(string key, string? fallback) =>
        ViewData.ModelState.TryGetValue(key, out var entry) && entry.AttemptedValue != null
            ? entry.AttemptedValue
            : (fallback ?? "");

    bool isAdmin = Model.IsCompanyAdmin == true || Model.CompanyId == null;
    string readonlyAttr = isAdmin ? "" : "readonly";
    string disabledClass = isAdmin ? "" : "opacity-50 cursor-not-allowed bg-gray-100";
    string actionName = Model.CompanyId == null ? "RegisterCompany" : "UpdateCompany";
    string submitText = Model.CompanyId == null ? "Đăng ký công ty" : "Lưu thay đổi";
}
<div>
    <div class="flex items-center gap-2 mb-6">
        <h2 class="text-lg font-medium text-gray-900">Thông tin công ty</h2>
        @if (Model.Company?.IsVerified == true)
        {
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700" title="Doanh nghiệp đã được xác thực">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                Đã xác thực
            </span>
        }
    </div>

    <form asp-action="@actionName" asp-controller="Settings" method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-sm text-red-600 bg-red-50 border border-red-100 rounded-lg px-4 py-3 [&:empty]:hidden"></div>

        <input type="hidden" name="FullName" value="@Model.FullName" />
        <input type="hidden" name="Position" value="@Model.Position" />
        <input type="hidden" name="Phone" value="@Model.Phone" />
        <input type="hidden" name="AdditionalDocumentsUrl" value="@Model.Company?.AdditionalDocumentsUrl" />
        <input type="hidden" name="BusinessLicenseUrl" value="@Model.Company?.BusinessLicenseUrl" />

        <!-- Logo -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Logo công ty</label>
            <div class="flex items-center gap-6">
                <div class="w-24 h-24 rounded-lg bg-gray-50 border border-gray-200 flex items-center justify-center overflow-hidden">
                    <img src="@(string.IsNullOrEmpty(Model.Company?.CompanyLogoUrl)
                             ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.Company?.CompanyName ?? "C")}&background=random"
                             : Model.Company?.CompanyLogoUrl)"
                         alt="Company Logo" class="w-full h-full object-contain" id="logoPreview">
                </div>
                @if (isAdmin)
                {
                    <div>
                        <label class="px-4 py-2 bg-blue-50 text-blue-600 hover:bg-blue-100 rounded-lg font-medium text-sm transition-colors cursor-pointer border border-blue-100">
                            Tải logo lên
                            <input type="file" name="logoFile" id="logoFile" class="hidden"
                                   accept="image/png,image/jpeg" onchange="handleLogoChange(this)">
                        </label>
                        <p class="text-xs text-gray-500 mt-2">Kích thước khuyến nghị: 400x400px. Tối đa 5MB. Định dạng JPG hoặc PNG.</p>
                        <p id="logoError" class="text-xs text-red-500 mt-1 hidden"></p>
                    </div>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-gray-100">
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Tên công ty</label>
                <input type="text" name="CompanyName" @readonlyAttr
                       class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors @disabledClass"
                       value="@FieldValue("CompanyName", Model.Company?.CompanyName)" placeholder="Ví dụ: Công ty Cổ phần VNG">
                <span asp-validation-for="Company.CompanyName" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Mã số thuế</label>
                <input type="text" name="TaxCode" maxlength="14" @readonlyAttr
                       class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors @disabledClass"
                       value="@FieldValue("TaxCode", Model.Company?.TaxCode)" placeholder="10 chữ số, vd: 0123456789">
                @Html.ValidationMessage("TaxCode", new { @class = "text-xs text-red-500 mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                <input type="url" name="Website" @readonlyAttr
                       class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors @disabledClass"
                       value="@FieldValue("Website", Model.Company?.Website)" placeholder="https://">
                @Html.ValidationMessage("Website", new { @class = "text-xs text-red-500 mt-1 block" })
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Lĩnh vực - Ngành nghề</label>
                <input type="text" name="Industry" @readonlyAttr class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg
           focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors @disabledClass"
                       value="@FieldValue("Industry", Model.Company?.Industry)" placeholder="Ví dụ: Công nghệ thông tin">
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ trụ sở</label>
                <input type="text" name="CompanyAddress" @readonlyAttr
                       class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors @disabledClass"
                       value="@FieldValue("CompanyAddress", Model.Company?.CompanyAddress)" placeholder="Nhập địa chỉ chi tiết">
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Giới thiệu ngắn</label>
                <textarea rows="4" name="CompanyDescription" @readonlyAttr
                          class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors resize-none @disabledClass"
                          placeholder="Viết một đoạn ngắn giới thiệu về công ty của bạn...">@FieldValue("CompanyDescription", Model.Company?.CompanyDescription)</textarea>
            </div>
        </div>

        @if (isAdmin)
        {
            <div class="pt-4 flex justify-end border-t border-gray-100">
                <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white font-medium text-sm rounded-lg hover:bg-blue-700 transition-colors shadow-sm shadow-blue-200">
                    @submitText
                </button>
            </div>
        }
        else
        {
            <div class="pt-4 flex justify-end border-t border-gray-100">
                <p class="text-sm text-gray-500 italic">Chỉ Quản trị viên công ty mới có thể cập nhật thông tin này.</p>
            </div>
        }
    </form>
</div>

<script>
function handleLogoChange(input) {
    const errorEl = document.getElementById('logoError');
    errorEl.classList.add('hidden');

    if (!input.files || !input.files[0]) return;
    const file = input.files[0];

    // Validate size <= 5MB
    if (file.size > 5 * 1024 * 1024) {
        errorEl.textContent = 'Logo không được vượt quá 5MB.';
        errorEl.classList.remove('hidden');
        input.value = '';
        return;
    }
    // Validate type
    if (!['image/png', 'image/jpeg'].includes(file.type)) {
        errorEl.textContent = 'Chỉ chấp nhận định dạng PNG hoặc JPG.';
        errorEl.classList.remove('hidden');
        input.value = '';
        return;
    }

    // Preview
    const reader = new FileReader();
    reader.onload = e => { document.getElementById('logoPreview').src = e.target.result; };
    reader.readAsDataURL(file);
}
</script>




