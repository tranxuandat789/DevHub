@model DevHub.Models.Recruiter
@{
    var members = ViewBag.Members as IEnumerable<dynamic>;
    var invitations = ViewBag.Invitations as IEnumerable<DevHub.Models.CompanyInvitation>;
}

<div>
    <h2 class="text-xl font-semibold text-gray-900 mb-6">Quản lý thành viên</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 rounded-lg bg-green-50 border border-green-200 text-green-700">
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Form Invite Member -->
    <div class="mb-8 p-6 bg-gray-50 border border-gray-100 rounded-xl">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Mời đồng nghiệp</h3>
        <form action="/Recruiter/Settings/invite-member" method="post" class="flex flex-col sm:flex-row gap-4">
            @Html.AntiForgeryToken()
            <div class="flex-grow">
                <input type="email" name="email" required placeholder="Nhập địa chỉ email đồng nghiệp..." class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all">
            </div>
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Gửi lời mời
            </button>
        </form>
    </div>

    <!-- Active Members -->
    <div class="mb-8">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Thành viên hiện tại (@(members?.Count() ?? 0))</h3>
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Họ tên</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Chức vụ</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vai trò</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (members != null && members.Any())
                    {
                        foreach (var member in members)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900">@member.FullName</div>
                                    @if (member.RecruiterId == Model.RecruiterId)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 mt-1">Bạn</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @(member.Position ?? "Chưa cập nhật")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @if (member.IsCompanyAdmin == true)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Member</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-4 text-center text-sm text-gray-500">Chưa có thành viên nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pending Invitations -->
    @if (invitations != null && invitations.Any())
    {
        <div>
            <h3 class="text-lg font-medium text-gray-900 mb-4">Lời mời chờ xác nhận (@invitations.Count())</h3>
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email được mời</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ngày gửi</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Hết hạn lúc</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var inv in invitations)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    @inv.Email
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @inv.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <span class="@(inv.ExpiresAt < DateTime.UtcNow ? "text-red-500" : "")">
                                        @inv.ExpiresAt.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <form action="/Recruiter/Settings/cancel-invite" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="invitationId" value="@inv.InvitationId" />
                                        <button type="submit" class="text-red-600 hover:text-red-900" onclick="return confirm('Bạn có chắc chắn muốn hủy lời mời này không?');">Hủy</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
