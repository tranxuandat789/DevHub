<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevHub</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#4640DE',
                        dark: '#25324B',
                        muted: '#515B6F',
                        bordercolor: '#D6DDEB',
                        lightbg: '#F7F5FC'
                    },
                    fontFamily: {
                        epilogue: ['Epilogue', 'sans-serif'],
                        inter: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
@using System.Security.Claims
@using DevHub.Services.Interfaces
@inject IAuthService AuthService
@{
    var path = Context.Request.Path.Value?.ToLower() ?? "";

    bool isEmployer = path.Contains("employer") || path.Contains("recruiter");
    bool isLoggedIn = User.Identity?.IsAuthenticated == true;
    string userRole = User.FindFirstValue(ClaimTypes.Role) ?? "";

    if (isLoggedIn)
    {
        if (isEmployer && userRole != "RECRUITER")
        {
            isLoggedIn = false;
        }
        else if (!isEmployer && userRole == "RECRUITER")
        {
            isLoggedIn = false;
        }
    }

    string fullName = User.FindFirstValue("FullName") ?? User.FindFirstValue(ClaimTypes.Email) ?? "";
    string claimAvatar = User.FindFirstValue("AvatarUrl") ?? "";

    string avatarUrl = claimAvatar;
    if (isLoggedIn)
    {
        var email = User.FindFirstValue(ClaimTypes.Email) ?? "";
        if (!string.IsNullOrEmpty(email))
        {
            var dbUser = await AuthService.FindUserByEmailAsync(email);
            if (dbUser != null)
            {
                var dbAvatar = dbUser.Candidate?.ImageUrl ?? dbUser.Recruiter?.CompanyLogoUrl ?? "";
                if (!string.IsNullOrEmpty(dbAvatar))
                    avatarUrl = dbAvatar;
            }
        }
    }

    bool isEmployerHome = path == "/home/employer";
}
<body class="bg-white text-muted m-0 p-0">
    <!-- Global Spotlight Effect -->
    
    <!-- Header -->
    @if (ViewData["HideHeaderFooter"] as bool? != true)
    {
    <header class="bg-white relative z-[100] shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-[90px]">
                
                <!-- Left Section: Logo & Nav -->
                <div class="flex items-center space-x-12">
                    <!-- Logo -->
                    <a href="@(isEmployer ? "/Home/Employer" : "/")" class="flex-shrink-0 flex items-center gap-2 cursor-pointer text-decoration-none">
                        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white relative overflow-hidden">
                            <!-- DevHub Logo Icon Approximation -->
                            <div class="absolute w-5 h-5 border-2 border-white rounded-full"></div>
                            <div class="absolute top-2 right-2 w-1.5 h-1.5 bg-white rounded-full"></div>
                        </div>
                        <span class="text-[28px] font-bold text-dark tracking-tight">DevHub</span>
                    </a>

                    <!-- Desktop Nav -->
                    <nav class="hidden md:flex space-x-8">
                        @if (isEmployer)
                        {
                            <a href="/Home/Employer" class="@(isEmployerHome ? "text-primary font-bold" : "text-muted font-medium") hover:text-primary transition-colors text-[16px]">Giới thiệu</a>
                            @if (isLoggedIn)
                            {
                                <a href="/recruiter/dashboard" class="text-muted font-medium hover:text-primary transition-colors text-[16px]">Dashboard</a>
                                <a href="/Recruiter/RecruiterService" class="text-muted font-medium hover:text-primary transition-colors text-[16px]">Bảng giá</a>
                            }
                        }
                        else
                        {
                            <!-- Mega menu: Tìm việc -->
                            <div class="relative" id="jobs-mega-menu">
                                <button type="button" id="jobs-menu-btn"
                                        class="flex items-center gap-1 text-muted font-medium hover:text-primary transition-colors text-[16px] py-2">
                                    Tìm việc
                                    <svg class="w-4 h-4 transition-transform duration-200" id="jobs-menu-caret" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>

                                <!-- Dropdown container (2 cột: menu trái + panel phải) -->
                                <div id="jobs-dropdown"
                                     class="hidden absolute left-0 top-full pt-1 z-[200]"
                                     style="min-width:200px">
                                    <div class="flex shadow-[0_8px_40px_rgba(0,0,0,0.15)] rounded-xl overflow-hidden border border-gray-100">

                                        <!-- Cột trái: 3 mục -->
                                        <div class="bg-white w-52 py-2 flex-shrink-0">
                                            <div class="jobs-menu-item group/item flex items-center justify-between px-5 py-3 cursor-pointer hover:bg-primary/5 transition-colors"
                                                 data-panel="skill-panel">
                                                <span class="text-[15px] font-medium text-dark group-hover/item:text-primary">Việc làm theo Kỹ năng</span>
                                                <svg class="w-4 h-4 text-muted group-hover/item:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                            </div>
                                            <div class="jobs-menu-item group/item flex items-center justify-between px-5 py-3 cursor-pointer hover:bg-primary/5 transition-colors"
                                                 data-panel="city-panel">
                                                <span class="text-[15px] font-medium text-dark group-hover/item:text-primary">Việc làm theo Thành phố</span>
                                                <svg class="w-4 h-4 text-muted group-hover/item:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                            </div>
                                            <div class="jobs-menu-item group/item flex items-center justify-between px-5 py-3 cursor-pointer hover:bg-primary/5 transition-colors"
                                                 data-panel="company-panel">
                                                <span class="text-[15px] font-medium text-dark group-hover/item:text-primary">Việc làm theo Công ty</span>
                                                <svg class="w-4 h-4 text-muted group-hover/item:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                            </div>
                                            <div class="border-t border-gray-100 mt-1 pt-1">
                                                <a href="/Jobs" class="flex items-center px-5 py-3 text-[14px] text-muted hover:text-primary hover:bg-primary/5 transition-colors">
                                                    Xem tất cả việc làm →
                                                </a>
                                            </div>
                                        </div>

                                        <!-- Cột phải: các panel con -->
                                        <div class="bg-white border-l border-gray-100" id="jobs-right-panel" style="display:none; min-width:480px; max-width:700px">

                                            <!-- Panel kỹ năng -->
                                            <div id="skill-panel" class="hidden p-5">
                                                <p class="text-[12px] font-bold text-muted uppercase tracking-wider mb-3">Kỹ năng phổ biến</p>
                                                <div id="skill-list" class="flex flex-wrap gap-2">
                                                    <span class="text-muted text-sm">Đang tải...</span>
                                                </div>
                                                <a href="/Jobs" class="mt-4 inline-block text-primary text-[13px] font-semibold hover:underline">
                                                    Xem tất cả việc làm theo kỹ năng →
                                                </a>
                                            </div>

                                            <!-- Panel thành phố -->
                                            <div id="city-panel" class="hidden p-5">
                                                <p class="text-[12px] font-bold text-muted uppercase tracking-wider mb-3">Thành phố phổ biến</p>
                                                <div id="city-list" class="grid grid-cols-2 gap-1">
                                                    <span class="text-muted text-sm">Đang tải...</span>
                                                </div>
                                            </div>

                                            <!-- Panel công ty -->
                                            <div id="company-panel" class="hidden p-5">
                                                <p class="text-[12px] font-bold text-muted uppercase tracking-wider mb-3">Công ty đang tuyển nhiều nhất</p>
                                                <div id="company-list" class="space-y-1">
                                                    <span class="text-muted text-sm">Đang tải...</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <a href="/CareerHandbook" class="text-muted font-medium hover:text-primary transition-colors text-[16px]">Cẩm nang nghề nghiệp</a>
                        }

                    </nav>
                </div>

                <!-- Right Section: Auth Buttons / User Profile -->
                @if (isLoggedIn)
                {
                    <div class="hidden md:flex items-center space-x-6">
                        <!-- Notification Bell Dropdown -->
                        <div class="relative group">
                            <button class="text-muted hover:text-primary transition-colors relative">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                                <span class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-red-500 text-white text-[10px] font-bold flex items-center justify-center rounded-full border border-white">3</span>
                            </button>
                            <!-- Notification Dropdown -->
                            <div class="absolute top-full right-0 pt-2 w-80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <div class="bg-white border border-[#D6DDEB] rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.12)] overflow-hidden">
                                    <div class="px-4 py-3 border-b border-gray-100 flex justify-between items-center">
                                        <span class="font-bold text-dark text-[15px]">Thông báo</span>
                                        <span class="text-xs text-primary font-medium">3 thông báo mới</span>
                                    </div>
                                    @{ var notifBase = isEmployer ? "/recruiter/notifications" : "/candidate/notifications"; }
                                    <a href="@notifBase/details/1" class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors border-b border-gray-50">
                                        <div class="w-9 h-9 bg-[#EEF2FF] rounded-full flex items-center justify-center flex-shrink-0">
                                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-[13px] font-semibold text-dark">Đơn ứng tuyển được xem xét</p>
                                            <p class="text-[12px] text-muted mt-0.5 line-clamp-1">FPT Software đã xem hồ sơ của bạn</p>
                                            <p class="text-[11px] text-gray-400 mt-1">2 giờ trước</p>
                                        </div>
                                        <div class="w-2 h-2 bg-primary rounded-full flex-shrink-0 mt-1.5"></div>
                                    </a>
                                    <a href="@notifBase/details/2" class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors border-b border-gray-50">
                                        <div class="w-9 h-9 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                                            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-[13px] font-semibold text-dark">Lịch phỏng vấn đã xác nhận</p>
                                            <p class="text-[12px] text-muted mt-0.5 line-clamp-1">Phỏng vấn với VNG Corporation</p>
                                            <p class="text-[11px] text-gray-400 mt-1">5 giờ trước</p>
                                        </div>
                                        <div class="w-2 h-2 bg-green-500 rounded-full flex-shrink-0 mt-1.5"></div>
                                    </a>
                                    <a href="@notifBase/details/3" class="flex gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
                                        <div class="w-9 h-9 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0">
                                            <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-[13px] font-semibold text-dark">Việc làm phù hợp mới</p>
                                            <p class="text-[12px] text-muted mt-0.5 line-clamp-1">3 công việc mới phù hợp với bạn</p>
                                            <p class="text-[11px] text-gray-400 mt-1">1 ngày trước</p>
                                        </div>
                                        <div class="w-2 h-2 bg-orange-400 rounded-full flex-shrink-0 mt-1.5"></div>
                                    </a>
                                    <div class="border-t border-gray-100 px-4 py-2.5 text-center">
                                        <a href="@notifBase" class="text-primary text-[13px] font-bold hover:underline">Xem tất cả thông báo</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 cursor-pointer relative group py-2">
                            @{
                            var displayAvatar = !string.IsNullOrEmpty(avatarUrl)
                                ? avatarUrl
                                : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(fullName)}&background=4640DE&color=fff&size=128";
                        }
                        <img src="@displayAvatar" alt="Avatar" class="w-10 h-10 rounded-full object-cover"
                             onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(fullName)&background=4640DE&color=fff&size=128'" />
                            <span class="font-bold text-dark text-[15px]">@fullName</span>
                            <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>                            
                            <!-- Dropdown Menu -->
                            <div class="absolute top-full right-0 pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <div class="bg-white border border-[#D6DDEB] rounded-lg shadow-[0_4px_20px_rgba(0,0,0,0.08)] py-2 overflow-hidden">
                                    @if (userRole == "RECRUITER")
                                    {
                                        <a href="/recruiter/dashboard" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Dashboard</a>
                                        <a href="/Recruiter/JobPost" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Quản lý tin tuyển dụng</a>
                                        <a href="/Recruiter/Settings" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Cài đặt tài khoản</a>
                                    }
                                    else
                                    {
                                        <a href="/Candidate/Profile" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Hồ sơ cá nhân</a>
                                        <a href="/Candidate/Dashboard" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Bảng điều khiển</a>
                                        <a href="/Candidate/SavedJobs" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Việc làm đã lưu</a>
                                        <a href="/Candidate/ChangePassword" class="block px-4 py-2.5 text-[15px] font-medium text-dark hover:bg-gray-50 transition-colors">Cài đặt tài khoản</a>
                                    }
                                    <div class="w-full h-[1px] bg-gray-100 my-1"></div>
                                    @if (userRole == "RECRUITER")
                                    {
                                        <a href="/Auth/EmployerLogout" class="block px-4 py-2.5 text-[15px] font-medium text-red-600 hover:bg-red-50 transition-colors">Đăng xuất</a>
                                    }
                                    else
                                    {
                                        <a href="/Auth/Logout" class="block px-4 py-2.5 text-[15px] font-medium text-red-600 hover:bg-red-50 transition-colors">Đăng xuất</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="hidden md:flex items-center space-x-4">
                        @if (isEmployer)
                        {
                            <a href="/Auth/EmployerLogin" class="text-primary font-bold hover:text-primary/80 transition-colors px-2 text-[16px]">Đăng nhập</a>
                            <div class="w-[1px] h-10 bg-bordercolor mx-2"></div>
                            <a href="/Auth/EmployerRegister" class="bg-primary text-white font-bold px-6 py-3 rounded-[20px] hover:bg-opacity-90 transition-all shadow-sm text-[16px]">Đăng ký</a>
                            <a href="/" class="bg-primary text-white font-bold px-6 py-3 rounded-[20px] hover:bg-opacity-90 transition-all shadow-sm text-[16px] flex items-center gap-2">
                                Trang ứng viên <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </a>
                        }
                        else
                        {
                            <a href="/Auth/Login" class="text-primary font-bold hover:text-primary/80 transition-colors px-2 text-[16px]">Đăng nhập</a>
                            <div class="w-[1px] h-10 bg-bordercolor mx-2"></div>
                            <a href="/Auth/Register" class="bg-primary text-white font-bold px-6 py-3 rounded-[20px] hover:bg-opacity-90 transition-all shadow-sm text-[16px]">Đăng ký</a>
                            <a href="/Home/Employer" class="bg-primary text-white font-bold px-6 py-3 rounded-[20px] hover:bg-opacity-90 transition-all shadow-sm text-[16px] flex items-center gap-2">
                                Nhà tuyển dụng <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </a>
                        }
                    </div>
                }

                <!-- Mobile menu button -->
                <div class="md:hidden flex items-center">
                    <button class="text-dark hover:text-primary focus:outline-none">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </header>
    }

    <div class="h-full">
        <main role="main" class="h-full">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    @if (ViewData["HideHeaderFooter"] as bool? != true)
    {
    <footer class="bg-[#202430] text-[#D6DDEB] pt-16 pb-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12 mb-16">
                <!-- Brand & Description -->
                <div class="md:col-span-12 lg:col-span-5">
                    <a href="@(isEmployer ? "/Home/Employer" : "/")" class="flex-shrink-0 flex items-center gap-2 cursor-pointer text-decoration-none mb-6">
                        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white relative overflow-hidden">
                            <div class="absolute w-5 h-5 border-2 border-white rounded-full"></div>
                            <div class="absolute top-2 right-2 w-1.5 h-1.5 bg-white rounded-full"></div>
                        </div>
                        <span class="text-[28px] font-bold text-white tracking-tight">DevHub</span>
                    </a>
                    <p class="text-[#D6DDEB] text-[16px] leading-[26px] opacity-80 max-w-[320px]">
                        Nền tảng tuyệt vời dành cho những người tìm việc đam mê các startup. Giúp bạn tìm được công việc mơ ước dễ dàng hơn.
                    </p>
                </div>

                <!-- Links: Về chúng tôi -->
                <div class="md:col-span-4 lg:col-span-2">
                    <h4 class="text-white text-[18px] font-bold mb-6">Về chúng tôi</h4>
                    <ul class="space-y-4">
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Công ty</a></li>
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Giá cả</a></li>
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Điều khoản</a></li>
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Tư vấn</a></li>
                    </ul>
                </div>

                <!-- Links: Tài nguyên -->
                <div class="md:col-span-4 lg:col-span-2">
                    <h4 class="text-white text-[18px] font-bold mb-6">Tài nguyên</h4>
                    <ul class="space-y-4">
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Tài liệu</a></li>
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Hướng dẫn</a></li>
                        <li><a href="#" class="text-[#D6DDEB] hover:text-white transition-colors opacity-80 hover:opacity-100">Cập nhật</a></li>
