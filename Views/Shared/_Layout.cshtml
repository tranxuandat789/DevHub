    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Number counter animation for badges
        document.addEventListener("DOMContentLoaded", () => {
            const counters = document.querySelectorAll('.counter-number');
            const speed = 200; // The lower the slower

            counters.forEach(counter => {
                const updateCount = () => {
                    const target = +counter.getAttribute('data-target');
                    const count = +counter.innerText;
                    const inc = target / speed;

                    if (count < target) {
                        counter.innerText = Math.ceil(count + inc);
                        setTimeout(updateCount, 10);
                    } else {
                        counter.innerText = target;
                    }
                };
                updateCount();
            });
        });
    </script>

    <!-- Mega Menu: Tìm việc -->
    <script>
    (function () {
        const btn = document.getElementById('jobs-menu-btn');
        if (!btn) return;

        const dropdown   = document.getElementById('jobs-dropdown');
        const caret      = document.getElementById('jobs-menu-caret');
        const rightPanel = document.getElementById('jobs-right-panel');
        const menuItems  = document.querySelectorAll('.jobs-menu-item');

        let loaded = false;

        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            const isOpen = !dropdown.classList.contains('hidden');
            if (isOpen) { closeMenu(); } else { openMenu(); }
        });

        function openMenu() {
            dropdown.classList.remove('hidden');
            caret.style.transform = 'rotate(180deg)';
            if (!loaded) loadData();
        }

        function closeMenu() {
            dropdown.classList.add('hidden');
            caret.style.transform = '';
            rightPanel.style.display = 'none';
            document.querySelectorAll('#jobs-right-panel > div').forEach(p => p.classList.add('hidden'));
            menuItems.forEach(i => i.classList.remove('bg-primary/5'));
        }

        document.addEventListener('click', function (e) {
            if (!document.getElementById('jobs-mega-menu').contains(e.target)) closeMenu();
        });

        // Hover vào mục trái → hiện panel phải tương ứng
        menuItems.forEach(item => {
            item.addEventListener('mouseenter', function () {
                menuItems.forEach(i => i.classList.remove('bg-primary/5'));
                this.classList.add('bg-primary/5');
                rightPanel.style.display = 'block';
                document.querySelectorAll('#jobs-right-panel > div').forEach(p => p.classList.add('hidden'));
                const panel = document.getElementById(this.dataset.panel);
                if (panel) panel.classList.remove('hidden');
            });
        });

        // Lazy-load: chỉ fetch 1 lần khi lần đầu mở menu
        function loadData() {
            fetch('/Jobs/NavData')
                .then(r => r.json())
                .then(data => {
                    loaded = true;
                    renderSkills(data.techs);
                    renderCities(data.locations);
                    renderCompanies(data.companies);
                })
                .catch(() => {});
        }

        function renderSkills(techs) {
            const el = document.getElementById('skill-list');
            if (!el || !techs) return;
            el.innerHTML = techs.map(t =>
                `<a href="/Jobs?techId=${t.techId}"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 text-[13px] font-medium text-dark hover:border-primary hover:text-primary transition-all">
                    ${t.techName}
                    <span class="text-[11px] text-muted">${t.jobCount}</span>
                 </a>`
            ).join('');
        }

        function renderCities(locations) {
            const el = document.getElementById('city-list');
            if (!el || !locations) return;
            el.innerHTML = locations.map(l =>
                `<a href="/Jobs?filterLocation=${encodeURIComponent(l.location)}"
                    class="flex justify-between items-center px-3 py-2 rounded-lg text-[14px] text-dark hover:bg-primary/5 hover:text-primary transition-colors">
                    <span>${l.location}</span>
                    <span class="text-[12px] text-muted ml-2">${l.jobCount} việc</span>
                 </a>`
            ).join('');
        }

        function renderCompanies(companies) {
            const el = document.getElementById('company-list');
            if (!el || !companies) return;
            el.innerHTML = companies.map(c => {
                const logo = c.logoUrl
                    ? `<img src="${c.logoUrl}" class="w-6 h-6 rounded object-contain flex-shrink-0" />`
                    : `<span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary font-bold text-[11px] flex-shrink-0">${c.companyName[0]}</span>`;
                return `<a href="/Jobs?recruiterId=${c.recruiterId}"
                           class="flex justify-between items-center px-3 py-1.5 rounded-lg text-[14px] text-dark hover:bg-primary/5 hover:text-primary transition-colors">
                            <div class="flex items-center gap-2 min-w-0">
                                ${logo}
                                <span class="truncate">${c.companyName}</span>
                            </div>
                            <span class="text-[12px] text-muted ml-2 flex-shrink-0">${c.jobCount} việc</span>
                         </a>`;
            }).join('');
        }
    })();
    </script>

