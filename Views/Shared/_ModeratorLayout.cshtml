@using System.Security.Claims
@{
    Layout = "_Layout";
    ViewData["HideHeaderFooter"] = true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Moderator Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#4640DE',
                        dark: '#25324B',
                        muted: '#515B6F',
                        bordercolor: '#D6DDEB',
                        lightbg: '#F7F5FC'
                    },
                    fontFamily: {
                        epilogue: ['Epilogue', 'sans-serif'],
                        inter: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; margin: 0; padding: 0; }
    </style>
</head>
<body class="bg-[#F7F5FC] text-muted">
    <div class="flex h-screen bg-[#F7F5FC]">
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-[#D6DDEB] hidden md:flex flex-col flex-shrink-0">
            <!-- Logo -->
            <a href="/" class="p-6 border-b border-[#D6DDEB] flex items-center gap-2 text-decoration-none hover:opacity-80 transition-opacity">
                <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white relative overflow-hidden flex-shrink-0">
                    <div class="absolute w-5 h-5 border-2 border-white rounded-full"></div>
                    <div class="absolute top-2 right-2 w-1.5 h-1.5 bg-white rounded-full"></div>
                </div>
                <span class="text-[24px] font-bold text-dark tracking-tight">DevHub</span>
            </a>
            <div class="p-6 flex-1 overflow-y-auto">
                <h5 class="text-xs uppercase tracking-wider text-muted font-bold mb-4">Moderator Panel</h5>
                @{
                    var taskType = User.FindFirstValue("TaskType");
                }
                <nav class="space-y-2">
                    <a href="#" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                        Dashboard
                    </a>
                    
                    @if (string.IsNullOrEmpty(taskType) || taskType == "JOB_POST")
                    {
                        <a href="/moderator/job-approvals" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("job-approvals") == true ? "text-primary bg-blue-50 font-bold" : "")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Duyệt bài đăng
                        </a>
                    }
                    
                    @if (string.IsNullOrEmpty(taskType) || taskType == "COMPANY_APPROVAL")
                    {
                        <a href="/moderator/company-approvals" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("company-approvals") == true ? "text-primary bg-blue-50 font-bold" : "")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                            Duyệt công ty
                        </a>
                    }
                    
                    @if (string.IsNullOrEmpty(taskType) || taskType == "REVIEW")
                    {
                        <a href="/moderator/reviews" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("reviews") == true ? "text-primary bg-blue-50 font-bold" : "")">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                            Duyệt đánh giá
                        </a>
                    }
                    
                    <a href="/ModeratorBlog" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorBlog") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Quản lý Blog
                    </a>
                    
                    <a href="/ModeratorUser" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorUser") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        Quản lý Người dùng 
                    </a>
                    
                    <a href="/ModeratorPosition" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorPosition") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        Vị trí tuyển dụng
                    </a>
                    
                    <a href="/ModeratorTechStack" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorTechStack") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                        Quản lý công nghệ
                    </a>
                    
                    <a href="/ModeratorPackage" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorPackage") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                        Gói dịch vụ
                    </a>
                    
                    <a href="/ModeratorVoucher" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("ModeratorVoucher") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path></svg>
                        Khuyến mãi & Voucher
                    </a>
                    
                    <a href="/moderator/logs" class="flex items-center gap-3 px-4 py-3 text-muted hover:text-primary hover:bg-blue-50 rounded-lg transition-colors font-medium @(Context.Request.Path.Value?.Contains("logs") == true ? "text-primary bg-blue-50 font-bold" : "")">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Nhật ký hệ thống
                    </a>
                </nav>
            </div>
        <!-- Logout Button -->
        <div class="p-6 border-t border-[#D6DDEB]">
            <a href="/Auth/AdminLogout" class="flex items-center gap-3 px-4 py-3 text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors font-medium text-decoration-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Đăng xuất
            </a>
        </div>
    </aside>

        <!-- Main Content -->
        <main class="flex-1 p-6 md:p-8 overflow-y-auto">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
