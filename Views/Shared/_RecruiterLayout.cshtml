    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('toggle-sidebar');
            const secondarySidebar = document.getElementById('sidebar-secondary');
            const popovers = document.querySelectorAll('.sidebar-popover');
            const secondaryContent = document.getElementById('secondary-content');
            const sidebarItems = document.querySelectorAll('.sidebar-item');

            let isExpanded = localStorage.getItem('sidebarExpanded') === 'true';

            function highlightActiveLinks() {
                const currentPath = window.location.pathname.toLowerCase();
                let currentSearch = window.location.search.toLowerCase();
                if (currentPath === '/recruiter/settings' && !currentSearch) {
                    currentSearch = '?tab=account';
                }
                const links = Array.from(secondaryContent.querySelectorAll('a'));
                
                let matchedLink = null;
                let maxScore = -1;

                links.forEach(link => {
                    const href = link.getAttribute('href')?.toLowerCase() || "";
                    if (href !== '#') {
                        let score = 0;
                        const urlParts = href.split('?');
                        const pathPart = urlParts[0];
                        const queryPart = urlParts[1] || "";

                        if (currentPath === pathPart) {
                            score += 1;
                            if (queryPart && currentSearch.includes(queryPart)) {
                                score += 10;
                            } else if (!queryPart && !currentSearch) {
                                score += 5;
                            }
                        } else if (currentPath.startsWith(pathPart + '/')) {
                            score += 0.5;
                        }

                        if (score > 0 && score > maxScore) {
                            maxScore = score;
                            matchedLink = link;
                        }
                    }
                });

                links.forEach(link => {
                    if (link === matchedLink) {
                        link.classList.remove('text-gray-700', 'hover:bg-gray-50');
                        link.classList.add('text-blue-600', 'bg-blue-50', 'font-semibold');
                        const icon = link.querySelector('svg');
                        if(icon) {
                            icon.classList.remove('text-gray-400');
                            icon.classList.add('text-blue-500');
                        }
                    } else {
                        link.classList.add('text-gray-700', 'hover:bg-gray-50');
                        link.classList.remove('text-blue-600', 'bg-blue-50', 'font-semibold');
                        const icon = link.querySelector('svg');
                        if(icon) {
                            icon.classList.add('text-gray-400');
                            icon.classList.remove('text-blue-500');
                        }
                    }
                });
            }
            
            // Set initial content based on active menu if possible
            const activeItem = document.querySelector('.sidebar-item a.bg-blue-500');
            if(activeItem) {
                const parent = activeItem.closest('.sidebar-item');
                if(parent && parent.querySelector('.sidebar-popover')) {
                    secondaryContent.innerHTML = parent.querySelector('.sidebar-popover').innerHTML;
                    highlightActiveLinks();
                }
            }

            // Apply initial state
            if(isExpanded) {
                secondarySidebar.classList.add('open');
                popovers.forEach(p => p.classList.remove('enabled'));
            }

            toggleBtn.addEventListener('click', () => {
                isExpanded = !isExpanded;
                localStorage.setItem('sidebarExpanded', isExpanded);
                if(isExpanded) {
                    secondarySidebar.classList.add('open');
                    popovers.forEach(p => p.classList.remove('enabled'));
                } else {
                    secondarySidebar.classList.remove('open');
                    popovers.forEach(p => p.classList.add('enabled'));
                }
            });

        });
    </script>
