                    <p class="text-[14px] font-semibold text-green-800">Thành công</p>
                    <p class="text-[13px] text-green-700 mt-0.5">@toastSuccess</p>
                </div>
                <button onclick="this.closest('.toast').remove()" class="text-gray-400 hover:text-gray-600 ml-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <script>
            setTimeout(() => {
                document.querySelectorAll('.toast').forEach(t => {
                    t.style.transition = 'opacity 0.4s, transform 0.4s';
                    t.style.opacity = '0';
                    t.style.transform = 'translateY(-10px)';
                    setTimeout(() => t.remove(), 400);
                });
            }, 2500);
        </script>
    }
